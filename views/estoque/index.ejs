<% layout('layout') %>

<div class="page-head">
  <div>
    <h1>Estoque</h1>
    <p class="muted">Controle de itens, saldos, mínimos e estrutura de armazenamento.</p>
  </div>
</div>

<%- include('_tabs', { tab: 'itens' }) %>

<div class="grid-3" style="margin-bottom:14px;">
  <div class="card"><div class="label">Itens ativos</div><div style="font-size:28px;font-weight:900;"><%= cards.itens %></div></div>
  <div class="card"><div class="label">Abaixo do mínimo</div><div style="font-size:28px;font-weight:900;"><%= cards.baixo %></div></div>
  <div class="card"><div class="label">Saldo total</div><div style="font-size:28px;font-weight:900;"><%= cards.saldo %></div></div>
</div>

<div class="card">
  <div class="page-head" style="margin-top:0;">
    <div>
      <h2 style="margin:0;font-size:22px;">Itens cadastrados</h2>
      <p class="muted">Visão consolidada do estoque atual.</p>
    </div>
  </div>
  <div class="table-wrap">
    <table class="table">
      <thead><tr><th>Código</th><th>Nome</th><th>Categoria</th><th>Local</th><th>Saldo</th><th>Mínimo</th></tr></thead>
      <tbody>
        <% if (!itens.length) { %>
          <tr><td colspan="6" class="muted">Nenhum item ativo encontrado.</td></tr>
        <% } %>
        <% itens.forEach((item) => { %>
          <tr>
            <td><%= item.codigo || '-' %></td>
            <td><strong><%= item.nome %></strong></td>
            <td><%= item.categoria_nome || '-' %></td>
            <td><%= item.local_nome || '-' %></td>
            <td><%= item.saldo_atual %> <%= item.unidade %></td>
            <td><%= item.saldo_minimo %> <%= item.unidade %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
