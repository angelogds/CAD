<%# views/layout.ejs %>
<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title || "Manutenção Campo do Gado" %></title>
  <link rel="stylesheet" href="/css/app.css" />
  <script>window.__VAPID_PUBLIC_KEY__ = "<%= VAPID_PUBLIC_KEY || "" %>";</script>
</head>
<body>
  <% const isAuthFullscreen = Boolean((typeof authFullscreen !== 'undefined' && authFullscreen) || (typeof locals !== 'undefined' && locals.authFullscreen)); %>
  <% if (isAuthFullscreen) { %>
    <%- body %>
  <% } else { %>
    <div class="app" id="appRoot">
      <%- include("partials/sidebar") %>

      <main class="main">
        <header class="topbar">
          <div class="topbar-left">
            <button type="button" class="sidebar-toggle" id="sidebarToggle" aria-label="Mostrar/ocultar menu">☰</button>
            <div>
              <div class="topbar-title">Manutenção Campo do Gado</div>
              <div class="topbar-sub">Sistema Industrial V2</div>
            </div>
            <div class="topbar-logos" aria-label="Logos institucionais">
              <img src="/IMG/menu_campo_do_gado.png.png.png.png.png" alt="Logo Campo do Gado" />
              <img src="/IMG/login_campo_do_gado.png.png.png" alt="Logo Manutenção" />
              <img src="/IMG/logopdf_campo_do_gado.png.png" alt="Logo Reciclagem" />
            </div>
          </div>

          <div class="topbar-right">
            <% if ((onlineUsers || []).length) { %>
              <div class="online-users" title="Usuários online no sistema">
                <span class="online-users-label">Online</span>
                <div class="online-users-list">
                  <% (onlineUsers || []).forEach(online => { %>
                    <div class="online-user-pill">
                      <% if (online.photo_path) { %>
                        <img class="online-user-avatar" src="<%= online.photo_path %>" alt="Foto de <%= online.name %>" />
                      <% } else { %>
                        <span class="online-user-avatar online-user-avatar-fallback" aria-hidden="true"><%= String(online.name || 'U').trim().charAt(0).toUpperCase() %></span>
                      <% } %>
                      <span class="online-user-name"><%= online.name %></span>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% } %>

            <% if (user) { %>
              <div class="pill">
                <% if (user.photo_path) { %>
                  <img class="pill-avatar" src="<%= user.photo_path %>" alt="Foto de <%= user.name %>" />
                <% } else { %>
                  <span class="pill-avatar pill-avatar-fallback" aria-hidden="true"><%= String(user.name || 'U').trim().charAt(0).toUpperCase() %></span>
                <% } %>
                <span class="pill-name"><%= user.name %></span>
                <span class="pill-role"><%= String(user.role || '').toUpperCase() %></span>
              </div>
              <form action="/auth/logout" method="POST">
                <button class="btn btn-ghost" type="submit">Sair</button>
              </form>
            <% } %>
          </div>
        </header>

        <section class="flash"><%- include("partials/alerts") %></section>
        <section class="content"><%- body %></section>
        <footer class="footer">
          <div>Manutenção Industrial • Campo do Gado</div>
          <div>© <%= new Date().getFullYear() %> • Sistema V2</div>
        </footer>
      </main>
    </div>

    <script src="/js/app-layout.js" defer></script>
    <script src="/js/push.js" defer></script>
  <% } %>
</body>
</html>
