<%# views/layout.ejs %>
<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#15803d" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="icon" type="image/png" sizes="1024x1024" href="/images/pwa/icon.png" />
  <link rel="apple-touch-icon" sizes="1024x1024" href="/images/pwa/icon.png" />
  <title><%= title || "Manutenção Campo do Gado" %></title>
  <link rel="stylesheet" href="/css/app.css" />
  <script>window.__VAPID_PUBLIC_KEY__ = "<%= VAPID_PUBLIC_KEY || "" %>";</script>
</head>
<body>
  <% const isAuthFullscreen = Boolean((typeof authFullscreen !== 'undefined' && authFullscreen) || (typeof locals !== 'undefined' && locals.authFullscreen)); %>
  <% if (isAuthFullscreen) { %>
    <%- body %>
  <% } else { %>
    <div class="app" id="appRoot">
      <%- include("partials/sidebar") %>

      <main class="main">
        <% if (typeof storageAlert !== "undefined" && storageAlert) { %>
          <div class="alert" style="margin:12px;padding:12px;border-radius:10px;border:1px solid #f59e0b;background:#fffbeb;">
            ⚠️ <strong><%= storageAlert.critical ? 'Armazenamento crítico' : 'Pouco armazenamento' %></strong> — O volume <%= storageAlert.dataDir %> possui apenas <%= storageAlert.freeLabel %> livres. Execute a limpeza de sessões, logs e temporários.
          </div>
        <% } %>
        <header class="topbar">
          <div class="topbar-left">
            <button type="button" class="sidebar-toggle" id="sidebarToggle" aria-label="Mostrar/ocultar menu">☰</button>
            <div>
              <div class="topbar-title">Manutenção Campo do Gado</div>
              <div class="topbar-sub">Sistema Industrial V2</div>
            </div>
            <div class="topbar-logos" aria-label="Logos institucionais">
              <img src="/IMG/menu_campo_do_gado.png.png.png.png.png" alt="Logo Campo do Gado" />
              <img src="/IMG/login_campo_do_gado.png.png.png" alt="Logo Manutenção" />
              <img src="/IMG/logopdf_campo_do_gado.png.png" alt="Logo Reciclagem" />
            </div>
          </div>

          <div class="topbar-right">
            <% if (user) { %>
              <% const extraRoles = ['MECANICO','ENCARREGADO_MANUTENCAO','MANUTENCAO_SUPERVISOR','SUPERVISOR_MANUTENCAO','ADMIN']; %>
              <% if (extraRoles.includes(String(user.role || '').toUpperCase())) { %>
                <a class="btn btn-green topbar-extra-btn" href="/escala/hora-extra/nova" title="Hora extra vinculada à OS">⏱ Extra</a>
              <% } %>
              <% const chatNotifs = Array.isArray(typeof osChatNotificacoes !== 'undefined' ? osChatNotificacoes : []) ? osChatNotificacoes : []; %>
              <% const topbarCounters = (typeof operationalCounters !== 'undefined' && operationalCounters) ? operationalCounters : {}; %>
              <% const chatUnread = Number(topbarCounters.osChatNaoLidas || 0); %>
              <details class="chat-bell topbar-notification-wrap" style="position:relative;">
                <summary class="btn btn-ghost topbar-notification" style="list-style:none;cursor:pointer;" aria-label="Notificações do Chat de OS">🔔 <strong><%= chatUnread %></strong></summary>
                <div style="position:absolute;right:0;top:42px;width:320px;max-width:80vw;background:#fff;border:1px solid #d1d5db;border-radius:14px;box-shadow:0 12px 30px rgba(0,0,0,.14);padding:8px;z-index:30;">
                  <% if (!chatNotifs.length) { %><div class="muted" style="padding:10px;">Sem novas notificações do Chat de OS.</div><% } %>
                  <% chatNotifs.forEach((n) => { %>
                    <a href="/chat-os/<%= n.origem_id %>" style="display:block;padding:9px;border-radius:10px;text-decoration:none;color:inherit;border-bottom:1px solid #f1f5f9;">
                      <strong><%= n.titulo %></strong><br><span class="muted"><%= n.mensagem %></span>
                    </a>
                  <% }) %>
                </div>
              </details>
              <details class="user-menu">
                <summary class="pill user-menu-summary" aria-label="Abrir menu do usuário">
                  <% if (user.photo_path) { %>
                    <img class="pill-avatar" src="<%= user.photo_path %>" alt="Foto de <%= user.name %>" />
                  <% } else { %>
                    <span class="pill-avatar pill-avatar-fallback" aria-hidden="true"><%= String(user.name || 'U').trim().charAt(0).toUpperCase() %></span>
                  <% } %>
                  <span class="pill-name"><%= user.name %></span>
                  <span class="pill-role"><%= String(user.role || '').toUpperCase() %></span>
                </summary>
                <div class="user-menu-dropdown">
                  <strong><%= user.name %></strong>
                  <span class="pill-role"><%= String(user.role || '').toUpperCase() %></span>
                  <form action="/auth/logout" method="POST">
                    <button class="btn btn-ghost" type="submit">Sair</button>
                  </form>
                </div>
              </details>
              <form class="desktop-logout" action="/auth/logout" method="POST">
                <button class="btn btn-ghost" type="submit">Sair</button>
              </form>
            <% } %>
          </div>
        </header>

        <section class="flash"><%- include("partials/alerts") %></section>
        <section class="content"><%- body %></section>
        <footer class="footer">
          <div>Manutenção Industrial • Campo do Gado</div>
          <div>© <%= new Date().getFullYear() %> • Sistema V2</div>
        </footer>
      </main>
    </div>

    <script src="/js/app-layout.js" defer></script>
    <script src="/js/push.js" defer></script>
    <script src="/js/mobile-bridge.js" defer></script>
  <% } %>
</body>
</html>
