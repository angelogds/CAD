<% layout('layout') %>

<div class="page-head">
  <div>
    <h1><%= sol.numero || ('Solicitação #' + sol.id) %></h1>
    <p class="muted">Solicitante: <%= sol.solicitante_nome || '-' %> • Setor: <%= sol.setor_origem || '-' %> • Prioridade: <%= sol.prioridade || '-' %></p>
  </div>
  <div style="display:flex;gap:8px;">
    <a class="btn btn-ghost" href="/compras/solicitacoes?status=<%= sol.status || 'ABERTA' %>">Voltar</a>
    <a class="btn btn-green" href="/compras/solicitacoes/<%= sol.id %>/pdf">Baixar PDF</a>
  </div>
</div>

<div class="card" style="margin-bottom:12px;">
  <div class="label" style="margin-bottom:8px;">Itens solicitados</div>
  <div class="table-wrap">
    <table class="table">
      <thead><tr><th>Item</th><th>Descrição</th><th>UN</th><th>Qtd</th></tr></thead>
      <tbody>
        <% if (!sol.itens?.length) { %><tr><td colspan="4" class="muted">Sem itens.</td></tr><% } %>
        <% (sol.itens || []).forEach((it) => { %>
          <tr>
            <td><strong><%= it.item_nome || '-' %></strong></td>
            <td><%= it.item_descricao || '-' %></td>
            <td><%= it.unidade || 'UN' %></td>
            <td><%= it.qtd_solicitada || 0 %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="card" style="margin-bottom:12px;">
  <div class="label" style="margin-bottom:8px;">Dados de cotação/compra</div>
  <form method="POST" action="/compras/solicitacoes/<%= sol.id %>/atualizar-dados" class="grid-3">
    <div>
      <div class="label">Fornecedor (cadastro)</div>
      <select class="input" name="fornecedor_id" onchange="const opt=this.options[this.selectedIndex]; document.getElementById('fornecedor_nome').value = opt.dataset.nome || '';">
        <option value="">Selecionar fornecedor</option>
        <% (fornecedores || []).forEach((f) => { %>
          <option value="<%= f.id %>" data-nome="<%= f.nome %>" <%= Number(sol.fornecedor_id || 0) === Number(f.id) ? 'selected' : '' %>>
            <%= f.nome %><%= f.cnpj ? (' • ' + f.cnpj) : '' %><%= f.cidade ? (' • ' + f.cidade) : '' %>
          </option>
        <% }) %>
      </select>
    </div>
    <div>
      <div class="label">Fornecedor (texto livre)</div>
      <input id="fornecedor_nome" class="input" name="fornecedor" value="<%= sol.fornecedor || sol.fornecedor_nome || '' %>" />
    </div>
    <div><div class="label">Previsão de entrega</div><input class="input" type="date" name="previsao_entrega" value="<%= sol.previsao_entrega ? String(sol.previsao_entrega).slice(0,10) : '' %>" /></div>
    <div><div class="label">Valor total</div><input class="input" name="valor_total" type="number" step="0.01" min="0" value="<%= sol.valor_total || '' %>" /></div>
    <div style="grid-column:1/-1;"><div class="label">Observações compras</div><textarea class="input" name="observacoes_compras"><%= sol.observacoes_compras || '' %></textarea></div>
    <div style="grid-column:1/-1;display:flex;gap:8px;flex-wrap:wrap;">
      <button class="btn btn-ghost" type="submit">Salvar dados</button>
    </div>
  </form>
  <% if (sol.status === 'EM_COTACAO') { %>
    <form method="POST" action="/compras/solicitacoes/<%= sol.id %>/marcar-comprada" style="margin-top:8px;">
      <button class="btn btn-green" type="submit">Marcar como COMPRADA</button>
    </form>
  <% } %>
</div>

<div class="card" style="margin-bottom:12px;">
  <div class="label" style="margin-bottom:8px;">Anexar cotação</div>
  <form method="POST" action="/compras/solicitacoes/<%= sol.id %>/anexos" enctype="multipart/form-data" class="grid-3">
    <div>
      <div class="label">Tipo</div>
      <select class="input" name="tipo">
        <option value="COTACAO">COTAÇÃO</option>
        <option value="NF">NF</option>
      </select>
    </div>
    <div style="grid-column: span 2;">
      <div class="label">Arquivo (PDF/JPG/PNG/WEBP)</div>
      <input class="input" type="file" name="arquivo" accept="application/pdf,image/jpeg,image/png,image/webp" required />
    </div>
    <div style="grid-column:1/-1;"><button class="btn" type="submit">Enviar anexo</button></div>
  </form>

  <div class="table-wrap" style="margin-top:10px;">
    <table class="table">
      <thead><tr><th>Tipo</th><th>Nome original</th><th>Data</th><th>Ações</th></tr></thead>
      <tbody>
        <% if (!sol.anexos?.length) { %><tr><td colspan="4" class="muted">Sem anexos.</td></tr><% } %>
        <% (sol.anexos || []).forEach((a) => { %>
          <tr>
            <td><%= a.tipo || '-' %></td>
            <td><%= a.original_name || a.filename %></td>
            <td><%= fmtBR(a.created_at || a.uploaded_at) %></td>
            <td style="display:flex;gap:6px;">
              <a class="btn btn-sm btn-ghost" href="/compras/anexos/<%= a.id %>/download">Download</a>
              <form method="POST" action="/compras/anexos/<%= a.id %>/delete"><button class="btn btn-sm" type="submit">Excluir</button></form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
