<!doctype html>
<html>
<head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title><%= title %></title>
<style>body{font-family:Arial;padding:20px}.print-box{border:1px solid #ddd;padding:18px;max-width:340px;text-align:center}img{width:210px}</style>
</head>
<body onload="window.print()">
  <div class="print-box">
    <h3><%= equip.nome %></h3>
    <p><%= equip.codigo || '-' %></p>
    <img src="<%= qrImage %>" alt="QR"/>
    <small><%= qrUrl %></small>
  </div>
</body>
</html>
