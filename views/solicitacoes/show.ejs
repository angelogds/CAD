<% layout('layout') %>

<div class="page-head">
  <div>
    <h1>Solicitação <%= solicitacao.numero || ('#' + solicitacao.id) %></h1>
    <p class="muted">Acompanhe os dados e itens da solicitação criada.</p>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;">
    <% if (canEdit) { %><a class="btn btn-green" href="/solicitacoes/<%= solicitacao.id %>/editar">Editar</a><% } %>
    <a class="btn btn-ghost" href="/solicitacoes/<%= solicitacao.id %>/pdf" target="_blank" rel="noopener">Baixar cópia do PDF</a>
    <a class="btn btn-ghost" href="<%= backUrl %>">Voltar</a>
  </div>
</div>

<div class="card" style="margin-bottom:14px;">
  <div class="grid-3">
    <div><div class="label">Solicitante</div><div><strong><%= solicitacao.solicitante_nome || '-' %></strong></div></div>
    <div><div class="label">Setor solicitante</div><div><strong><%= solicitacao.setor_origem || 'Não informado' %></strong></div></div>
    <div><div class="label">Setor destinatário</div><div><strong><%= solicitacao.setor_destino || 'Não informado' %></strong></div></div>
    <div><div class="label">Responsável</div><div><strong><%= solicitacao.responsavel_nome || 'Informação pendente de confirmação' %></strong></div></div>
    <div><div class="label">Prioridade</div><div><strong><%= solicitacao.prioridade || 'Não informado' %></strong></div></div>
    <div><div class="label">Status</div><span class="pill-tag pill-gray"><%= solicitacao.status || 'Não informado' %></span></div>
    <div><div class="label">Criado em</div><div><strong><%= solicitacao.created_at ? fmtBR(solicitacao.created_at) : 'Não informado' %></strong></div></div>
    <div><div class="label">Aplicação</div><div><strong><%= solicitacao.aplicacao || 'Informação pendente de confirmação' %></strong></div></div>
    <div><div class="label">Título</div><div><strong><%= solicitacao.titulo || 'Não informado' %></strong></div></div>
  </div>
  <div style="margin-top:12px;">
    <div class="label">Descrição</div>
    <div class="note"><%= solicitacao.descricao || 'Informação pendente de confirmação' %></div>
  </div>
</div>

<% if (solicitacao.os_id) { %>
  <div class="card" style="margin-bottom:14px;border-left:4px solid #16a34a;">
    <strong>🔗 Vinculada à OS <%= solicitacao.os_id %></strong>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;">
      <a class="btn btn-green" href="/chat-os/<%= solicitacao.os_id %>">Abrir conversa da OS</a>
      <a class="btn btn-ghost" href="/os/<%= solicitacao.os_id %>">Abrir OS</a>
    </div>
  </div>
<% } %>

<div class="card" style="margin-bottom:14px;">
  <div class="label">Timeline</div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;">
    <span class="pill-tag pill-gray">Abertura: <%= solicitacao.created_at ? fmtBR(solicitacao.created_at) : '-' %></span>
    <span class="pill-tag pill-gray">Início cotação: <%= solicitacao.cotacao_inicio_em ? fmtBR(solicitacao.cotacao_inicio_em) : '-' %></span>
    <span class="pill-tag pill-gray">Comprada: <%= solicitacao.comprada_em ? fmtBR(solicitacao.comprada_em) : '-' %></span>
    <span class="pill-tag pill-gray">Recebida: <%= solicitacao.recebida_em ? fmtBR(solicitacao.recebida_em) : '-' %></span>
    <span class="pill-tag pill-gray">Fechada: <%= solicitacao.fechada_em ? fmtBR(solicitacao.fechada_em) : '-' %></span>
  </div>
</div>

<div class="card">
  <div class="label">Itens da solicitação</div>
  <div class="table-wrap" style="margin-top:10px;">
    <table class="table">
      <thead><tr><th>Item</th><th>Unidade</th><th>Qtde</th><th>Observação</th></tr></thead>
      <tbody>
        <% if (!itens.length) { %>
          <tr><td colspan="4" class="muted" style="text-align:center;">Sem itens cadastrados.</td></tr>
        <% } %>
        <% itens.forEach((item) => { %>
          <tr>
            <td><strong><%= item.item_nome || 'Não informado' %></strong></td>
            <td><%= item.unidade || 'UN' %></td>
            <td><%= item.qtd_solicitada ?? item.quantidade ?? 0 %></td>
            <td><%= item.item_descricao || item.observacao_item || 'Não informado' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>


<div class="card" style="margin-top:14px;">
  <div class="label">Fotos / anexos</div>
  <% const anexosSeguros = Array.isArray(anexos) ? anexos : []; %>
  <% if (!anexosSeguros.length) { %>
    <p class="muted" style="margin-top:8px;">Sem fotos ou anexos cadastrados.</p>
  <% } else { %>
    <ul style="margin-top:8px;">
      <% anexosSeguros.forEach((anexo) => { %>
        <li><%= anexo.original_name || anexo.filename || 'Anexo sem nome informado' %></li>
      <% }) %>
    </ul>
  <% } %>
</div>
