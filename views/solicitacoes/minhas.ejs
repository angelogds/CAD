<% layout('layout') %>
<%
const statusMeta = {
  ABERTA: { label: 'Aberta', icon: '📝', cls: 'open' },
  EM_COTACAO: { label: 'Em cotação', icon: '💬', cls: 'quote' },
  COMPRADA: { label: 'Comprada', icon: '🛒', cls: 'bought' },
  EM_RECEBIMENTO: { label: 'Em recebimento', icon: '📦', cls: 'receive' },
  RECEBIDA_PARCIAL: { label: 'Recebida parcial', icon: '◐', cls: 'partial' },
  RECEBIDA_TOTAL: { label: 'Recebida total', icon: '✅', cls: 'done' },
  FECHADA: { label: 'Fechada', icon: '🔒', cls: 'closed' },
  REABERTA: { label: 'Reaberta', icon: '↺', cls: 'open' },
  CANCELADA: { label: 'Cancelada', icon: '✕', cls: 'cancel' },
};
const prioridadeClass = (p) => ['ALTA','URGENTE','CRITICA','CRÍTICA','EMERGENCIAL'].includes(String(p || '').toUpperCase()) ? 'danger' : 'soft';
%>

<style>
  .sol-page { display:grid; gap:14px; }
  .sol-summary { display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:10px; }
  .sol-indicator { background:#fff; border:1px solid #dcfce7; border-radius:16px; padding:12px; box-shadow:0 8px 24px rgba(22,101,52,.06); }
  .sol-indicator span { color:#64748b; font-size:.84rem; font-weight:700; }
  .sol-indicator strong { display:block; color:#14532d; font-size:1.35rem; margin-top:4px; }
  .sol-filters { display:grid; grid-template-columns:1.2fr 1fr 1fr auto; gap:10px; align-items:end; }
  .sol-tabs { display:flex; gap:8px; flex-wrap:wrap; }
  .sol-card-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:12px; }
  .sol-card { border:1px solid #e5e7eb; border-radius:18px; background:#fff; padding:14px; display:grid; gap:12px; box-shadow:0 10px 28px rgba(15,23,42,.05); }
  .sol-card-head { display:flex; justify-content:space-between; gap:10px; align-items:flex-start; }
  .sol-title { color:#0f172a; font-weight:900; font-size:1rem; }
  .sol-meta { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:8px; }
  .sol-meta div { background:#f8fafc; border:1px solid #eef2f7; border-radius:12px; padding:8px; }
  .sol-meta small { display:block; color:#64748b; font-weight:800; margin-bottom:2px; }
  .sol-actions { display:flex; gap:7px; flex-wrap:wrap; justify-content:flex-end; align-items:center; border-top:1px solid #f1f5f9; padding-top:10px; }
  .sol-actions form { margin:0; }
  .sol-actions .btn-danger { background:#dc2626; border-color:#dc2626; color:#fff; }
  .sol-actions .btn-danger:hover { background:#b91c1c; border-color:#b91c1c; color:#fff; }
  .sol-badge { display:inline-flex; align-items:center; gap:5px; border-radius:999px; padding:5px 9px; font-size:.78rem; font-weight:900; border:1px solid transparent; white-space:nowrap; }
  .sol-badge.open { background:#ecfdf5; color:#166534; border-color:#bbf7d0; }
  .sol-badge.quote { background:#eff6ff; color:#1d4ed8; border-color:#bfdbfe; }
  .sol-badge.bought { background:#fef3c7; color:#92400e; border-color:#fde68a; }
  .sol-badge.receive,.sol-badge.partial { background:#f5f3ff; color:#6d28d9; border-color:#ddd6fe; }
  .sol-badge.done,.sol-badge.closed { background:#f0fdf4; color:#15803d; border-color:#bbf7d0; }
  .sol-badge.cancel { background:#fef2f2; color:#b91c1c; border-color:#fecaca; }
  .sol-badge.danger { background:#fef2f2; color:#b91c1c; border-color:#fecaca; }
  .sol-badge.soft { background:#f8fafc; color:#475569; border-color:#e2e8f0; }
  @media (max-width: 780px) { .sol-filters { grid-template-columns:1fr; } .sol-card-grid { grid-template-columns:1fr; } .sol-meta { grid-template-columns:1fr; } }
</style>

<div class="sol-page">
  <div class="page-head">
    <div>
      <h1>Solicitações de Material</h1>
      <p class="muted">Controle rastreável do fluxo solicitação → compras → almoxarifado → OS.</p>
    </div>
    <div><a class="btn btn-green" href="/solicitacoes/nova">+ Nova Solicitação</a></div>
  </div>

  <div class="sol-summary">
    <% statuses.forEach((st) => { const meta = statusMeta[st] || { label: st, icon: '•', cls: 'soft' }; %>
      <a class="sol-indicator" href="/solicitacoes/minhas?status=<%= st %>" style="text-decoration:none;">
        <span><%= meta.icon %> <%= meta.label %></span>
        <strong><%= counters?.[st] || 0 %></strong>
      </a>
    <% }) %>
  </div>

  <div class="card">
    <div class="sol-tabs" style="margin-bottom:12px;">
      <a class="btn <%= !filters?.status && !filters?.vinculadasOs && !filters?.urgentes ? 'btn-green' : 'btn-ghost' %>" href="/solicitacoes/minhas">Todas</a>
      <% statuses.forEach((st) => { const meta = statusMeta[st] || { label: st }; %>
        <a class="btn <%= filters?.status === st ? 'btn-green' : 'btn-ghost' %>" href="/solicitacoes/minhas?status=<%= st %>"><%= meta.label %></a>
      <% }) %>
      <a class="btn <%= filters?.vinculadasOs ? 'btn-green' : 'btn-ghost' %>" href="/solicitacoes/minhas?vinculadas_os=1">Vinculadas à OS</a>
      <a class="btn <%= filters?.urgentes ? 'btn-green' : 'btn-ghost' %>" href="/solicitacoes/minhas?urgentes=1">Urgentes</a>
    </div>
    <form class="sol-filters" method="GET" action="/solicitacoes/minhas">
      <div>
        <label class="label">Buscar</label>
        <input class="input" type="text" name="q" placeholder="Número, título, setor ou solicitante" value="<%= filters?.query || '' %>" />
      </div>
      <div>
        <label class="label">Status</label>
        <select class="input" name="status">
          <option value="">Todos</option>
          <% statuses.forEach((st) => { const meta = statusMeta[st] || { label: st }; %>
            <option value="<%= st %>" <%= filters?.status === st ? 'selected' : '' %>><%= meta.label %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="label">Data</label>
        <input class="input" type="date" name="date" value="<%= filters?.date || '' %>" />
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button class="btn" type="submit">Filtrar</button>
        <a class="btn btn-ghost" href="/solicitacoes/minhas">Limpar</a>
      </div>
    </form>
  </div>

  <div class="sol-card-grid">
    <% if (!lista.length) { %>
      <div class="card muted">Nenhuma solicitação encontrada com os filtros informados.</div>
    <% } %>
    <% lista.forEach((s) => { const meta = statusMeta[s.status] || { label: s.status || '-', icon: '•', cls: 'soft' }; %>
      <article class="sol-card">
        <div class="sol-card-head">
          <div>
            <div class="sol-title">Solicitação nº <%= s.numero || ('#' + s.id) %></div>
            <div class="muted"><%= s.titulo || 'Solicitação de material' %></div>
          </div>
          <span class="sol-badge <%= meta.cls %>"><%= meta.icon %> <%= meta.label %></span>
        </div>
        <div class="sol-meta">
          <div><small>Setor</small><strong><%= s.setor_origem || 'Manutenção Industrial' %></strong></div>
          <div><small>OS vinculada</small><strong><%= s.os_id ? ('OS ' + s.os_id) : 'Sem OS vinculada' %></strong></div>
          <div><small>Prioridade</small><span class="sol-badge <%= prioridadeClass(s.prioridade) %>"><%= s.prioridade || 'Média' %></span></div>
          <div><small>Solicitante</small><strong><%= s.solicitante_nome || '-' %></strong></div>
          <div><small>Data</small><strong><%= s.created_at ? fmtBR(s.created_at) : '-' %></strong></div>
          <div><small>Itens</small><strong><%= s.itens_count || 0 %> material(is)</strong></div>
        </div>
        <div class="sol-actions">
          <a class="btn btn-sm btn-ghost" href="/solicitacoes/<%= s.id %>">Abrir</a>
          <a class="btn btn-sm" href="/solicitacoes/<%= s.id %>/editar">Editar</a>
          <% if (s.status === 'ABERTA' && canAccessModule(user?.role, 'compras_manage')) { %><a class="btn btn-sm btn-green" href="/compras/solicitacoes/<%= s.id %>">Enviar para compras</a><% } %>
          <% if (['COMPRADA','EM_RECEBIMENTO','RECEBIDA_PARCIAL'].includes(s.status) && canAccessModule(user?.role, 'almoxarifado_manage')) { %><a class="btn btn-sm btn-green" href="/almoxarifado/solicitacoes/<%= s.id %>/conferir">Conferir recebimento</a><% } %>
          <a class="btn btn-sm btn-ghost" href="/solicitacoes/<%= s.id %>/pdf" target="_blank" rel="noopener">Gerar PDF</a>
          <% if (canAccessModule(user?.role, 'solicitacoes_delete')) { %>
            <form method="POST" action="/solicitacoes/<%= s.id %>/excluir" onsubmit="return confirm('Tem certeza que deseja excluir esta solicitação de material?');">
              <button type="submit" class="btn btn-sm btn-danger">Excluir</button>
            </form>
          <% } %>
        </div>
      </article>
    <% }) %>
  </div>
</div>
