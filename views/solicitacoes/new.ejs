<% layout('layout') %>
<% const fd = (typeof formData !== "undefined" && formData) ? formData : {}; const rows = (typeof formItens !== "undefined" && formItens && formItens.length) ? formItens : [{}]; const editing = typeof editMode !== "undefined" ? !!editMode : false; const submitUrl = typeof actionUrl !== "undefined" && actionUrl ? actionUrl : "/solicitacoes"; %>

<div class="page-head">
  <div>
    <h1><%= editing ? "Editar Solicitação" : "Nova Solicitação" %></h1>
    <p class="muted"><%= editing ? "Atualize os dados e itens enquanto a solicitação ainda permite revisão." : "Registre a necessidade de material para manutenção ou produção." %></p>
  </div>
</div>

<div class="card">
  <form method="POST" action="<%= submitUrl %>" id="form-solicitacao">
    <% if (fd.os_id) { %>
      <input type="hidden" name="os_id" value="<%= fd.os_id %>" />
      <% if (fd.equipamento_id) { %><input type="hidden" name="equipamento_id" value="<%= fd.equipamento_id %>" /><% } %>
      <div class="note" style="margin-bottom:12px;">🔗 Solicitação vinculada à OS #<%= fd.os_id %>. Ao salvar, o vínculo e a mensagem automática serão registrados no Chat de OS.</div>
      <div class="grid-3" style="margin-bottom:12px;">
        <div><div class="label">Número da OS</div><input class="input" value="OS #<%= fd.os_id %>" readonly /></div>
        <div><div class="label">Equipamento</div><input class="input" value="<%= fd.equipamento_nome || '-' %>" readonly /></div>
        <div><div class="label">Setor</div><input class="input" value="<%= fd.setor_os || fd.setor_origem || '-' %>" readonly /></div>
        <div><div class="label">Motivo da paralisação</div><input class="input" value="<%= fd.motivo_paralisacao || '-' %>" readonly /></div>
        <div><div class="label">Justificativa técnica</div><input class="input" value="<%= fd.justificativa_tecnica || '-' %>" readonly /></div>
        <div><div class="label">Ação necessária</div><input class="input" value="<%= fd.acao_necessaria || '-' %>" readonly /></div>
        <div><div class="label">Usuário solicitante</div><input class="input" value="<%= fd.solicitante_nome || '-' %>" readonly /></div>
      </div>
    <% } %>
    <div class="grid-3">
      <div>
        <div class="label">Título</div>
        <input class="input" name="titulo" placeholder="Ex.: Troca de rolamento transportador" value="<%= fd.titulo || "" %>" required />
      </div>
      <div>
        <div class="label">Setor origem</div>
        <select class="input" name="setor_origem">
          <% const setorOrigemAtual = fd.setor_origem || "Manutenção"; %>
          <% if (!["Manutenção", "Produção"].includes(setorOrigemAtual)) { %><option value="<%= setorOrigemAtual %>" selected><%= setorOrigemAtual %></option><% } %>
          <option value="Manutenção" <%= setorOrigemAtual === "Manutenção" ? "selected" : "" %>>Manutenção</option>
          <option value="Produção" <%= setorOrigemAtual === "Produção" ? "selected" : "" %>>Produção</option>
        </select>
      </div>
      <div>
        <div class="label">Prioridade</div>
        <select class="input" name="prioridade">
          <option value="BAIXA" <%= (fd.prioridade || "MEDIA") === "BAIXA" ? "selected" : "" %>>Baixa</option>
          <option value="MEDIA" <%= (fd.prioridade || "MEDIA") === "MEDIA" ? "selected" : "" %>>Média</option>
          <option value="ALTA" <%= (fd.prioridade || "MEDIA") === "ALTA" ? "selected" : "" %>>Alta</option>
          <option value="URGENTE" <%= (fd.prioridade || "MEDIA") === "URGENTE" ? "selected" : "" %>>Urgente</option>
        </select>
      </div>
    </div>

    <div style="margin-top:12px;">
      <div class="label">Descrição</div>
      <textarea class="input" name="descricao" placeholder="Descreva o motivo e o serviço relacionado"><%= fd.descricao || "" %></textarea>
    </div>

    <div class="divider"></div>

    <h3 style="margin:0 0 10px;">Itens da solicitação</h3>
    <div class="table-wrap" style="border:1px solid var(--border);border-radius:14px;">
      <table class="table" style="margin:0;min-width:780px;">
        <thead>
          <tr>
            <th>Item</th>
            <th>Descrição</th>
            <th>Unidade</th>
            <th>Quantidade</th>
            <th>Vínculo estoque (opcional)</th>
            <th>Ação</th>
          </tr>
        </thead>
        <tbody id="itens-body"></tbody>
      </table>
    </div>

    <div style="display:flex;gap:8px;margin-top:12px;">
      <button type="button" class="btn btn-ghost" id="btn-add-item">+ Adicionar item</button>
      <button class="btn btn-green" type="submit"><%= editing ? "Salvar alterações" : "Criar solicitação" %></button>
      <% if (editing && fd.id) { %><a class="btn btn-ghost" href="/solicitacoes/<%= fd.id %>">Cancelar</a><% } %>
    </div>
  </form>
</div>

<template id="item-row-template">
  <tr>
    <td><input class="input" name="itens_nome[]" placeholder="Nome do item" required /></td>
    <td><input class="input" name="itens_especificacao[]" placeholder="Descrição técnica" /></td>
    <td>
      <select class="input" name="itens_un[]">
        <option value="UN">UN</option>
        <option value="KG">KG</option>
        <option value="MT">MT</option>
        <option value="LT">LT</option>
        <option value="CX">CX</option>
      </select>
    </td>
    <td><input class="input" name="itens_qtd[]" type="number" min="0.01" step="0.01" value="1" required /></td>
    <td>
      <select class="input" name="itens_item_id[]">
        <option value="">Sem vínculo</option>
        <% estoqueItens.forEach((item) => { %>
          <option value="<%= item.id %>"><%= item.nome %> (<%= item.unidade %>)</option>
        <% }) %>
      </select>
    </td>
    <td><button type="button" class="btn btn-sm btn-ghost btn-remove-item">Remover</button></td>
  </tr>
</template>

<script>
  (function () {
    const tbody = document.getElementById("itens-body");
    const tpl = document.getElementById("item-row-template");
    const btnAdd = document.getElementById("btn-add-item");
    const initialRows = <%- JSON.stringify(rows) %>;

    function bindRemoveButtons() {
      const rowsEls = tbody.querySelectorAll("tr");
      rowsEls.forEach((row) => {
        const btn = row.querySelector(".btn-remove-item");
        if (!btn) return;
        btn.disabled = rowsEls.length <= 1;
        btn.onclick = () => {
          row.remove();
          bindRemoveButtons();
        };
      });
    }

    function addRow(data = {}) {
      const frag = tpl.content.cloneNode(true);
      const row = frag.querySelector("tr");
      row.querySelector('[name="itens_nome[]"]').value = data.item_nome || "";
      row.querySelector('[name="itens_especificacao[]"]').value = data.item_descricao || "";
      row.querySelector('[name="itens_un[]"]').value = data.unidade || "UN";
      row.querySelector('[name="itens_qtd[]"]').value = data.qtd_solicitada || 1;
      row.querySelector('[name="itens_item_id[]"]').value = data.estoque_item_id || "";
      tbody.appendChild(frag);
      bindRemoveButtons();
    }

    btnAdd.addEventListener("click", () => addRow());
    (initialRows.length ? initialRows : [{}]).forEach((row) => addRow(row));
  })();
</script>
