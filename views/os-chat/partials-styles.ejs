<style>
.os-chat-filters{display:flex;gap:8px;flex-wrap:wrap;margin:0 0 12px}.os-chat-shell{display:grid;grid-template-columns:360px 1fr;gap:14px;min-height:68vh}.os-chat-list{background:#fff;border:1px solid var(--border,#ddd);border-radius:16px;overflow:auto;max-height:72vh}.os-chat-contact{display:block;padding:12px 14px;border-bottom:1px solid #eef2ee;color:inherit;text-decoration:none}.os-chat-contact:hover,.os-chat-contact.active{background:#ecfdf3}.os-chat-contact-top{display:flex;justify-content:space-between;gap:8px}.os-chat-contact-top span,.os-chat-contact small{font-size:12px;color:#64748b}.os-chat-preview{color:#475569;font-size:13px;margin-top:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.os-chat-badges{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}.badge-unread{background:#16a34a;color:white;border-radius:999px;padding:3px 8px;font-size:12px;font-weight:700}.os-chat-placeholder,.os-chat-conversation{background:#fff;border:1px solid var(--border,#ddd);border-radius:16px;padding:16px}.os-chat-header{position:sticky;top:0;background:#fff;z-index:2;border-bottom:1px solid #e5e7eb;padding-bottom:12px}.os-chat-header h2{margin:0;color:#166534}.os-chat-meta{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin:10px 0}.os-chat-meta span{background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:8px;font-size:13px}.os-chat-actions{display:flex;gap:8px;flex-wrap:wrap}.os-chat-messages{background:#f0fdf4;border-radius:14px;padding:16px;margin:12px 0;min-height:360px}.msg{max-width:76%;background:white;border:1px solid #dcfce7;border-radius:14px 14px 14px 4px;padding:10px 12px;margin:0 0 10px;box-shadow:0 1px 2px rgba(0,0,0,.04)}.msg.mine{margin-left:auto;background:#dcfce7;border-radius:14px 14px 4px 14px}.msg.system{margin-left:auto;margin-right:auto;background:#f8fafc;border-color:#cbd5e1;border-radius:14px;text-align:center}.msg-head{display:flex;justify-content:space-between;gap:8px;font-size:12px;color:#475569}.msg p{margin:6px 0 0;white-space:pre-wrap}.os-chat-input{display:grid;grid-template-columns:1fr auto;gap:10px}.os-chat-input textarea{min-height:58px;border:1px solid #d1d5db;border-radius:14px;padding:10px}.os-chat-empty{padding:18px;color:#64748b;text-align:center}.pill-green{background:#dcfce7;color:#166534}.pill-blue{background:#dbeafe;color:#1d4ed8}.pill-amber{background:#fef3c7;color:#92400e}@media(max-width:900px){.os-chat-shell{grid-template-columns:1fr}.os-chat-list.compact{display:none}.os-chat-meta{grid-template-columns:1fr}.msg{max-width:94%}.os-chat-list-only .os-chat-placeholder{display:none}}
