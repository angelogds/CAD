<% layout("layout") %>
<section class="card" style="display:flex;justify-content:space-between;align-items:center;gap:12px;">
  <h1>Desenho Técnico</h1>
  <a class="btn btn-dark" href="/desenho-tecnico/cad/novo">Novo Desenho CAD</a>
</section>

<form class="card" method="GET" action="/desenho-tecnico" style="display:grid;grid-template-columns:minmax(220px,1fr) auto;gap:10px;align-items:end;">
  <div>
    <label class="label" for="q">Buscar</label>
    <input class="input" type="text" id="q" name="q" placeholder="Buscar por título" value="<%= filtros.q %>">
  </div>
  <button class="btn" type="submit">Filtrar</button>
</form>

<section class="card">
  <h2 style="margin-top:0;">Lista de Desenhos</h2>
  <div class="table-wrap">
    <table class="table">
      <thead><tr><th>ID</th><th>Título</th><th>Equipamento vinculado</th><th>Data</th><th>Abrir editor</th><th>PDF</th></tr></thead>
      <tbody>
      <% if(!lista.length){ %><tr><td colspan="6">Nenhum desenho CAD encontrado.</td></tr><% } %>
      <% lista.forEach((d)=>{ %>
        <tr>
          <td><%= d.id %></td>
          <td><%= d.titulo %></td>
          <td><%= d.equipamento_nome || '-' %></td>
          <td><%= (d.atualizado_em || '').slice(0,10) %></td>
          <td><a class="btn" href="/desenho-tecnico/cad/<%= d.id %>/editor">Abrir editor</a></td>
          <td><a class="btn" href="/desenho-tecnico/cad/<%= d.id %>/pdf" target="_blank" rel="noopener">PDF</a></td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>
