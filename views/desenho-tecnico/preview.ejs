<% layout("layout") %>
<section class="card" style="display:flex;justify-content:space-between;align-items:center;">
  <h1>Revisões - <%= desenho.codigo %></h1>
  <a class="btn" href="/desenho-tecnico/<%= desenho.id %>">Voltar ao desenho</a>
</section>
<section class="card">
  <table class="table"><thead><tr><th>ID</th><th>Tipo</th><th>Revisão</th><th>Arquivo</th><th>Data</th></tr></thead><tbody>
    <% if(!revisoes.length){ %><tr><td colspan="5">Sem revisões registradas.</td></tr><% } %>
    <% revisoes.forEach((r)=>{ %>
      <tr><td>#<%= r.id %></td><td><%= r.tipo_arquivo %></td><td>R<%= r.revisao %></td><td><%= r.arquivo_pdf ? 'PDF' : 'SVG' %></td><td><%= fmtBR(r.criado_em) %></td></tr>
    <% }) %>
  </tbody></table>
</section>
