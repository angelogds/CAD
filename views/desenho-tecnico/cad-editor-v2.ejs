<% layout("layout") %>
<%# CAD Editor V2 - Estilo AutoCAD %>

<link rel="stylesheet" href="/css/cad-autocad.css">

<div class="cad-fullscreen cad-left-compact">
  <!-- TOOLBAR SUPERIOR -->
  <div class="cad-toolbar">
    <div class="cad-toolbar-row">
      <div class="cad-toolbar-group">
        <a class="cad-btn" href="/desenho-tecnico/cad/<%= desenho.id %>">
          ← Voltar
        </a>
      </div>
      
      <div class="cad-toolbar-group">
        <span class="cad-toolbar-group-label">Arquivo</span>
        <button class="cad-btn cad-btn-success" id="cadSaveBtn" data-action="save" type="button" title="Salvar (Ctrl+S)">
          Salvar
        </button>
        <a class="cad-btn" href="/desenho-tecnico/cad/<%= desenho.id %>/pdf" title="Gerar PDF">
          PDF
        </a>
      </div>
      
      <div class="cad-toolbar-divider"></div>
      
      <div class="cad-toolbar-group">
        <span class="cad-toolbar-group-label">Editar</span>
        <button class="cad-btn" id="cadUndoBtn" data-action="undo" type="button" title="Desfazer (Ctrl+Z)">↶</button>
        <button class="cad-btn" id="cadRedoBtn" data-action="redo" type="button" title="Refazer (Ctrl+Y)">↷</button>
        <button class="cad-btn cad-btn-danger" id="cadDeleteBtn" data-action="delete-selection" type="button" title="Apagar seleção (Del)">Del</button>
      </div>
      
      <div class="cad-toolbar-divider"></div>
      
      <div class="cad-toolbar-group">
        <span class="cad-toolbar-group-label">Ferramentas</span>
        <button class="cad-btn" data-action="tool-select" data-tool="select" type="button" title="Selecionar (V)">Seleção</button>
        <button class="cad-btn" data-action="tool-pan" data-tool="pan" type="button" title="Pan (M)">Pan</button>
        <button class="cad-btn" data-action="tool-line" data-tool="line" type="button" title="Linha (L)">Linha</button>
        <button class="cad-btn" data-action="tool-polyline" data-tool="polyline" type="button" title="Polilinha (P)">Polilinha</button>
        <button class="cad-btn" data-action="tool-rect" data-tool="rect" type="button" title="Retângulo (R)">Retângulo</button>
        <button class="cad-btn" data-action="tool-circle" data-tool="circle" type="button" title="Círculo (C)">Círculo</button>
        <button class="cad-btn" data-action="tool-arc" data-tool="arc" type="button" title="Arco">Arco</button>
        <button class="cad-btn" data-action="tool-text" data-tool="text" type="button" title="Texto (T)">T Texto</button>
      </div>
      
      <div class="cad-toolbar-divider"></div>
      
      <div class="cad-toolbar-group">
        <span class="cad-toolbar-group-label">Eixo</span>
        <button class="cad-btn cad-btn-primary" data-action="tool-shaft" data-tool="shaft" type="button" title="Eixo Paramétrico (X)">
          Eixo
        </button>
        <button class="cad-btn" data-action="tool-centerline" data-tool="centerline" type="button" title="Linha de Centro">
          Centro
        </button>
      </div>
      
      <div class="cad-toolbar-divider"></div>
      
      <div class="cad-toolbar-group">
        <span class="cad-toolbar-group-label">Cotas</span>
        <button class="cad-btn" data-action="tool-dim-linear" data-tool="dim_linear" type="button" title="Cota Linear (D)">Linear</button>
        <button class="cad-btn" data-action="tool-dim-diameter" data-tool="dim_diameter" type="button" title="Cota Diâmetro">Diâmetro</button>
        <button class="cad-btn" data-action="tool-dim-angular" data-tool="dim_angular" type="button" title="Cota Angular">Angular</button>
      </div>
    </div>
    
    <div class="cad-toolbar-row">
      <div class="cad-toolbar-group">
        <span class="cad-toolbar-group-label">Precisão</span>
        <button class="cad-btn" id="cadGridToggle" data-action="toggle-grid" type="button">Grid</button>
        <button class="cad-btn" id="cadSnapToggle" data-action="toggle-snap" type="button">Snap</button>
        <button class="cad-btn" id="cadOrthoToggle" data-action="toggle-ortho" type="button">Ortho</button>
      </div>
      
      <div class="cad-toolbar-group">
        <span class="cad-toolbar-group-label">Zoom</span>
        <button class="cad-btn" data-action="tool-zoom-window" data-tool="zoom-window" type="button" title="Zoom janela">Janela</button>
        <button class="cad-btn" id="cadZoomExtentsBtn" data-action="zoom-extents" type="button" title="Zoom Extents">Extents</button>
        <button class="cad-btn" id="cadResetViewBtn" data-action="reset-view" type="button" title="Resetar vista">Resetar</button>
      </div>
      
      <div class="cad-toolbar-group" style="margin-left:auto;">
        <span style="color:#94a3b8;font-size:12px;">
          <strong><%= desenho.codigo %></strong> - <%= desenho.titulo %>
        </span>
      </div>
    </div>
  </div>
  
  <!-- WORKSPACE -->
  <div class="cad-workspace" id="cadWorkspace">
    <!-- PAINEL ESQUERDO - FERRAMENTAS -->
    <div class="cad-panel-left">
      <div class="cad-panel-section">
        <div class="cad-panel-header">Desenho</div>
        <div class="cad-panel-content">
          <button class="cad-tool-btn" data-action="tool-select" data-tool="select" type="button">
            <span class="cad-tool-icon">◻</span>
            <span>Selecionar</span>
          </button>
          <button class="cad-tool-btn" data-action="tool-line" data-tool="line" type="button">
            <span class="cad-tool-icon">／</span>
            <span>Linha</span>
          </button>
          <button class="cad-tool-btn" data-action="tool-pan" data-tool="pan" type="button">
            <span class="cad-tool-icon">⟂</span>
            <span>Pan</span>
          </button>
          <button class="cad-tool-btn" data-action="tool-polyline" data-tool="polyline" type="button">
            <span class="cad-tool-icon">⎺</span>
            <span>Polilinha</span>
          </button>
          <button class="cad-tool-btn" data-action="tool-rect" data-tool="rect" type="button">
            <span class="cad-tool-icon">▭</span>
            <span>Retângulo</span>
          </button>
          <button class="cad-tool-btn" data-action="tool-circle" data-tool="circle" type="button">
            <span class="cad-tool-icon">◯</span>
            <span>Círculo</span>
          </button>
          <button class="cad-tool-btn" data-action="tool-arc" data-tool="arc" type="button">
            <span class="cad-tool-icon">◜</span>
            <span>Arco</span>
          </button>
          <button class="cad-tool-btn" data-action="tool-text" data-tool="text" type="button">
            <span class="cad-tool-icon">T</span>
            <span>Texto</span>
          </button>
        </div>
      </div>
      
      <div class="cad-panel-section">
        <div class="cad-panel-header">Eixo Mecânico</div>
        <div class="cad-panel-content">
          <button class="cad-tool-btn" data-action="tool-shaft" data-tool="shaft" type="button">
            <span class="cad-tool-icon">◎</span>
            <span>Eixo Paramétrico</span>
          </button>
          <button class="cad-tool-btn" data-action="tool-centerline" data-tool="centerline" type="button">
            <span class="cad-tool-icon">╍</span>
            <span>Linha de Centro</span>
          </button>
        </div>
      </div>
      
      <div class="cad-panel-section">
        <div class="cad-panel-header">Cotas</div>
        <div class="cad-panel-content">
          <button class="cad-tool-btn" data-action="tool-dim-linear" data-tool="dim_linear" type="button">
            <span class="cad-tool-icon">↔</span>
            <span>Cota Linear</span>
          </button>
          <button class="cad-tool-btn" data-action="tool-dim-diameter" data-tool="dim_diameter" type="button">
            <span class="cad-tool-icon">⌀</span>
            <span>Cota Diâmetro</span>
          </button>
          <button class="cad-tool-btn" data-action="tool-dim-angular" data-tool="dim_angular" type="button">
            <span class="cad-tool-icon">∠</span>
            <span>Cota Angular</span>
          </button>
        </div>
      </div>
      
      <div class="cad-panel-section">
        <div class="cad-panel-header">Modificar</div>
        <div class="cad-panel-content">
          <button class="cad-tool-btn" data-action="tool-copy" data-tool="copy" type="button"><span class="cad-tool-icon">⎘</span><span>Copy</span></button>
          <button class="cad-tool-btn" data-action="tool-move" data-tool="move" type="button"><span class="cad-tool-icon">↕</span><span>Move</span></button>
          <button class="cad-tool-btn" data-action="tool-mirror" data-tool="mirror" type="button"><span class="cad-tool-icon">⇋</span><span>Mirror</span></button>
          <button class="cad-tool-btn" data-action="tool-offset" data-tool="offset" type="button"><span class="cad-tool-icon">⧉</span><span>Offset</span></button>
          <button class="cad-tool-btn" data-action="tool-trim" data-tool="trim" type="button"><span class="cad-tool-icon">✂</span><span>Trim</span></button>
          <button class="cad-tool-btn" data-action="tool-extend" data-tool="extend" type="button"><span class="cad-tool-icon">⇢</span><span>Extend</span></button>
          <button class="cad-tool-btn" data-action="tool-measure" data-tool="measure" type="button"><span class="cad-tool-icon">∣</span><span>Medição</span></button>
          <button class="cad-tool-btn" data-action="tool-erase" data-tool="erase" type="button">
            <span class="cad-tool-icon">Del</span>
            <span>Apagar</span>
          </button>
        </div>
      </div>
    </div>
    
    <!-- CANVAS CENTRAL -->
    <div class="cad-canvas-container">
      <svg id="cadCanvas" aria-label="Área de desenho técnico">
      </svg>
      <div id="cadDynamicInput" class="cad-dynamic-input" aria-live="polite"></div>
    </div>
    
    <!-- PAINEL DIREITO - PROPRIEDADES -->
    <div class="cad-panel-right" id="cadRightPanel">
      <div class="cad-panel-section">
        <div class="cad-panel-header">Propriedades</div>
        <div class="cad-panel-content" id="cadProperties">
          <p style="color:#94a3b8;font-size:12px;">Selecione um objeto para editar suas propriedades.</p>
        </div>
      </div>
      
      <div class="cad-panel-section">
        <div class="cad-panel-header">Camadas</div>
        <div class="cad-panel-content">
          <div style="margin-bottom:8px;">
            <label class="cad-prop-label">Camada Ativa</label>
            <select class="cad-select" id="cadLayerSelect"></select>
          </div>
          <div class="cad-layer-create">
            <input class="cad-input" id="cadLayerNewName" placeholder="Nova camada (ex.: furacao)">
            <button class="cad-btn" id="cadLayerAddBtn" data-action="add-layer" type="button">Adicionar</button>
          </div>
          <div id="cadLayersList"></div>
        </div>
      </div>
      
      <div class="cad-panel-section">
        <div class="cad-panel-header">Metadados</div>
        <div class="cad-panel-content">
          <div class="cad-props-grid">
            <div class="cad-prop-row">
              <span class="cad-prop-label">Código</span>
              <input class="cad-input" type="text" id="cadMetaCodigo" value="<%= desenho.codigo %>">
            </div>
            <div class="cad-prop-row">
              <span class="cad-prop-label">Título</span>
              <input class="cad-input" type="text" id="cadMetaTitulo" value="<%= desenho.titulo %>">
            </div>
            <div class="cad-prop-row">
              <span class="cad-prop-label">Material</span>
              <input class="cad-input" type="text" id="cadMetaMaterial" value="<%= desenho.material || '' %>">
            </div>
            <div class="cad-prop-row">
              <span class="cad-prop-label">Equipamento</span>
              <select class="cad-select" id="cadMetaEquipamento">
                <option value="">-- Sem vínculo --</option>
                <% (equipamentos || []).forEach(eq => { %>
                  <option value="<%= eq.id %>" <%= Number(desenho.equipamento_id) === Number(eq.id) ? 'selected' : '' %>>
                    <%= eq.codigo || '#' + eq.id %> - <%= eq.nome %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div style="grid-column:1/-1;margin-top:4px;">
              <label class="cad-prop-label">Observações</label>
              <textarea class="cad-input" id="cadMetaObservacoes" rows="3" style="min-height:60px;"><%= desenho.observacoes || '' %></textarea>
            </div>
            <button class="cad-btn cad-btn-lg" id="cadMetaSaveBtn" data-action="save-metadata" type="button" style="width:100%;margin-top:8px;">
              Salvar Metadados
            </button>
          </div>
        </div>
      </div>
    </div>

    <button
      class="cad-right-toggle"
      id="cadRightToggle"
      data-action="toggle-right-panel"
      type="button"
      aria-label="Recolher painel direito"
      aria-expanded="true"
      title="Recolher painel direito"
    >
      <span class="cad-right-toggle-icon">⟩</span>
      <span class="cad-right-toggle-label">Painel</span>
    </button>
  </div>
  
  <!-- STATUS BAR -->
  <div class="cad-statusbar" id="cadStatusBar">
    <div class="cad-status-left">
      <div class="cad-status-item">
        <span class="cad-status-value" id="cadStatusMessage">Inicializando...</span>
      </div>
      <div class="cad-status-item">
        <span class="cad-status-value" id="cadStatusTool">Tool: select</span>
      </div>
      <div class="cad-status-item">
        <span class="cad-status-value" id="cadStatusX">X: 0.00</span>
      </div>
      <div class="cad-status-item">
        <span class="cad-status-value" id="cadStatusY">Y: 0.00</span>
      </div>
      <div class="cad-status-item">
        <span class="cad-status-value" id="cadStatusZoom">Zoom: 100%</span>
      </div>
      <div class="cad-status-item">
        <span class="cad-status-value" id="cadStatusSelected">Selecionado: -</span>
      </div>
    </div>
    <div class="cad-status-right">
      <button class="cad-status-toggle active" data-toggle="grid" data-action="toggle-grid" type="button">GRID</button>
      <button class="cad-status-toggle active" data-toggle="snap" data-action="toggle-snap" type="button">SNAP</button>
      <button class="cad-status-toggle" data-toggle="ortho" data-action="toggle-ortho" type="button">ORTHO</button>
    </div>
  </div>
</div>

<script>
window.CAD_INITIAL = {
  desenhoId: <%= desenho.id %>,
  canManage: <%= !!canManage %>,
  data: <%- JSON.stringify(cadData || { objects: [], dimensions: [], layers: {}, activeLayer: 'geometria_principal' }) %>
};
document.body.classList.add('cad-editor-mode');

window.addEventListener('error', function () {
  var status = document.getElementById('cadStatusMessage');
  if (status) status.textContent = 'CAD carregado com limitações (ver console).';
});
</script>
<script type="module" src="/js/cad-engine-v2.js" onerror="(function(){var s=document.getElementById('cadStatusMessage'); if(s) s.textContent='Falha ao carregar o motor CAD.';})()"></script>

<style>
body.cad-editor-mode { overflow: hidden; }
</style>
