<!DOCTYPE html>
<html lang="pt-BR" class="tv-theme-dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <meta name="theme-color" content="#0a0f1a">
  <title><%= title || 'Modo TV — Campo do Gado' %></title>
  <link rel="stylesheet" href="/css/tv-mode.css">
</head>

<body class="cg-tv">
  <div id="tvApp" class="tv-shell">

    <header class="tv-topbar">
      <div class="tv-left">
        <div class="tv-logo-box">
          <img
            src="/IMG/login_campo_do_gado.png.png.png"
            alt="Campo do Gado"
            onerror="this.onerror=null; this.src='/img/tv/avatar-default.jpg'; this.onerror=function(){ this.onerror=null; this.src='/img/logo.png'; this.onerror=function(){ this.onerror=null; this.src='/IMG/logo.png'; }; };"
            class="tv-header-logo"
          >
        </div>

        <div class="tv-title-box">
          <div class="tv-kicker">GERENCIAMENTO DA MANUTENÇÃO</div>
          <div class="tv-brand">RECICLAGEM CAMPO DO GADO</div>
          <div class="tv-responsavel">Responsável: Ângelo Gomes da Silva — Encarregado de Manutenção</div>
          <div id="tvScreenLabel" class="tv-screen-label">ORDENS DE SERVIÇO</div>
        </div>
      </div>

      <div class="tv-clock-center">
        <div id="tvClock" class="tv-clock">--:--:--</div>
        <div id="tvDate" class="tv-date">Carregando...</div>
      </div>

      <div class="tv-right">
        <div id="tvWeatherMini" class="tv-weather-mini">
          <span>⛅</span>
          <strong>--°</strong>
          <small>Feira</small>
        </div>

        <button id="tvThemeToggle" class="tv-icon-btn" type="button" title="Alternar tema">
          <span id="tvThemeIcon">☀️</span>
        </button>

        <button id="tvFullscreenBtn" class="tv-icon-btn" type="button" title="Tela cheia">
          ⛶
        </button>

        <div class="tv-online">
          <span class="tv-dot"></span>
          <span>SISTEMA ONLINE</span>
        </div>

        <div class="tv-mechanics-label">EQUIPE</div>
        <div id="tvAvatars" class="tv-avatars"></div>
      </div>

      <div class="tv-progress-line">
        <div id="tvProgress" class="tv-progress"></div>
      </div>
    </header>

    <section id="tvLed" class="tv-led" hidden>
      <strong id="tvLedText">Nova OS crítica</strong>
      <button id="tvLedClose" type="button">×</button>
    </section>

    <main id="tvContent" class="tv-content"></main>

    <div id="tvToast" class="tv-toast" hidden></div>

    <footer class="tv-ticker">
      <div id="tvTickerTrack" class="tv-ticker-track"></div>
    </footer>

  </div>

  <script>
    window.CG_TV_CONFIG = {
      snapshotUrl: '/api/tv/snapshot',
      weatherUrl: '/api/tv/weather',
      refreshMs: 15000,
      rotationMs: 30000,
      defaultAvatar: '/IMG/login_campo_do_gado.png.png.png',
      galleryPlaceholder: '/img/tv/galeria-placeholder.jpg'
    };
  </script>

  <script src="/js/tv-mode.js"></script>
</body>
</html>
