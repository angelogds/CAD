<% layout('layout') %>
<link rel="stylesheet" href="/css/tv.css" />

<div class="tv-shell" id="tv-app">
  <header class="tv-header">
    <div class="tv-header-left">
      <div class="tv-brand">
        <img src="/IMG/menu_campo_do_gado.png.png.png.png.png" alt="Logo Campo do Gado" class="tv-logo" />
        <div>
          <h1>Manutenção Campo do Gado</h1>
          <p id="tv-screen-title">Modo TV • Ordens de serviço</p>
        </div>
      </div>
    </div>

    <div class="tv-header-right">
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Alternar tema" title="Alternar tema">🌙</button>
      <div class="tv-clock-wrap">
        <div id="tv-date" class="tv-date"></div>
        <div id="tv-clock" class="tv-clock"></div>
        <div class="tv-status"><span class="dot"></span>Sistema Online</div>
      </div>
      <div class="tv-online-block">
        <span class="block-title">Equipe em tempo real</span>
        <div id="online-mecanicos" class="avatar-list"></div>
      </div>
    </div>
  </header>

  <div id="screen-progress-wrap" class="screen-progress-wrap" aria-label="Tempo até próxima tela">
    <div id="screen-progress" class="screen-progress"></div>
  </div>

  <div id="tv-top-alert" class="tv-top-alert" aria-live="assertive"></div>

  <main class="tv-content">
    <section class="tv-page tv-screen active" data-screen="0" data-title="Ordens de serviço" aria-label="Tela de ordens de serviço">
      <div class="tv-grid grid-2-1">
        <article class="tv-card tv-card-stack">
          <h2 class="tv-section-title">Ordens de Serviço em Tempo Real</h2>
          <div class="tv-kpi-row three">
            <div class="tv-stat-card accent-green"><span>Abertas</span><strong class="number" id="os-abertas">0</strong></div>
            <div class="tv-stat-card accent-yellow"><span>Em andamento</span><strong class="number" id="os-andamento">0</strong></div>
            <div class="tv-stat-card accent-red"><span>Paradas / Críticas</span><strong class="number" id="os-criticas">0</strong></div>
          </div>
          <div class="table-wrap">
            <table class="tv-table">
              <thead>
                <tr><th>#OS</th><th>Equipamento</th><th>Responsável</th><th>Criticidade</th><th>Status</th><th>Abertura</th></tr>
              </thead>
              <tbody id="os-lista"></tbody>
            </table>
          </div>
        </article>

        <div class="tv-side-column">
          <article class="tv-card">
            <h2 class="tv-section-title">OS por Status</h2>
            <div class="chart-box"><canvas id="chart-os"></canvas></div>
          </article>
          <article class="tv-card">
            <h2 class="tv-section-title">Últimas OS abertas</h2>
            <ul id="latest-os-list" class="compact-list"></ul>
          </article>
          <article class="tv-card">
            <h2 class="tv-section-title">Alertas rápidos de OS</h2>
            <ul id="os-quick-alerts" class="alert-list"></ul>
          </article>
        </div>
      </div>
    </section>

    <section class="tv-page tv-screen" data-screen="1" data-title="Escala e ranking" aria-label="Tela de escala e ranking">
      <div class="tv-grid grid-escala">
        <article class="tv-card">
          <h2 class="tv-section-title">Escala do dia</h2>
          <div class="escala-block"><h3>Mecânicos</h3><div id="escala-dia" class="chip-list"></div></div>
          <div class="escala-block"><h3>Apoio</h3><div id="escala-apoio" class="chip-list"></div></div>
          <div class="escala-block"><h3>Responsável noite</h3><div id="escala-noite" class="chip-list"></div></div>
        </article>
        <article class="tv-card">
          <h2 class="tv-section-title">Ranking mecânicos</h2>
          <ol id="ranking-mecanicos" class="ranking-list"></ol>
          <h2 class="tv-section-title">Ranking apoio</h2>
          <ol id="ranking-apoio" class="ranking-list"></ol>
        </article>
        <article class="tv-card span-2">
          <h2 class="tv-section-title">Galeria da manutenção</h2>
          <div id="maintenance-gallery" class="gallery-grid"></div>
        </article>
      </div>
    </section>

    <section class="tv-page tv-screen" data-screen="2" data-title="Preventivas" aria-label="Tela de preventivas">
      <div class="tv-grid grid-2-1">
        <article class="tv-card tv-card-stack">
          <h2 class="tv-section-title">Preventivas</h2>
          <div class="tv-kpi-row four">
            <div class="tv-stat-card accent-yellow"><span>Abertas</span><strong class="number" id="prev-abertas">0</strong></div>
            <div class="tv-stat-card accent-blue"><span>Em andamento</span><strong class="number" id="prev-andamento">0</strong></div>
            <div class="tv-stat-card accent-green"><span>Fechadas</span><strong class="number" id="prev-fechadas">0</strong></div>
            <div class="tv-stat-card accent-red"><span>Atrasadas</span><strong class="number" id="prev-atrasadas">0</strong></div>
          </div>
          <div class="table-wrap">
            <table class="tv-table">
              <thead>
                <tr><th>#</th><th>Equipamento</th><th>Responsável</th><th>Data Prevista</th><th>Criticidade</th><th>Status</th></tr>
              </thead>
              <tbody id="prev-lista"></tbody>
            </table>
          </div>
        </article>

        <div class="tv-side-column">
          <article class="tv-card"><h2 class="tv-section-title">Por Criticidade</h2><div class="chart-box"><canvas id="chart-prev-criticidade"></canvas></div></article>
          <article class="tv-card"><h2 class="tv-section-title">Por Status</h2><div class="chart-box"><canvas id="chart-prev-status"></canvas></div></article>
          <article class="tv-card"><h2 class="tv-section-title">Preventivas críticas / atrasadas</h2><ul id="preventivas-alert-list" class="alert-list"></ul></article>
        </div>
      </div>
    </section>

    <section class="tv-page tv-screen" data-screen="3" data-title="Alertas e críticos" aria-label="Tela de alertas e performance">
      <div class="tv-grid grid-2">
        <article class="tv-card"><h2 class="tv-section-title">Alertas Ativos</h2><ul id="alertas-list" class="alert-list"></ul></article>
        <article class="tv-card">
          <h2 class="tv-section-title">Equipamentos críticos</h2>
          <ul id="incidencia-list" class="incidencia-list"></ul>
          <div class="attention-kpis">
            <div><span>OS Críticas</span><strong id="attention-os-criticas">0</strong></div>
            <div><span>Preventivas Atrasadas</span><strong id="attention-prev-atrasadas">0</strong></div>
          </div>
        </article>
        <article class="tv-card"><h2 class="tv-section-title">Performance da equipe</h2><div class="chart-box"><canvas id="chart-team"></canvas></div></article>
        <article class="tv-card weather-card"><h2 class="tv-section-title">Previsão do tempo</h2><div id="weather-card-content" class="weather-fallback">Previsão indisponível</div></article>
      </div>
    </section>
  </main>

  <footer id="tv-ticker" class="tv-ticker priority-baixa">
    <div id="tv-ticker-track" class="tv-ticker-track"></div>
  </footer>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/tv-dashboard.js" defer></script>
