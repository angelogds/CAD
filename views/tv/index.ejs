<% layout('layout') %>
<link rel="stylesheet" href="/css/tv.css" />

<div class="tv-shell" id="tv-app">
  <header class="tv-header">
    <div class="tv-header-left">
      <a class="tv-back-btn" href="/dashboard">Modo Normal</a>
      <div class="tv-brand">
        <img src="/IMG/menu_campo_do_gado.png.png.png.png.png" alt="Logo Campo do Gado" class="tv-logo" />
        <div>
          <h1>Manutenção Campo do Gado • Modo TV</h1>
          <p>Monitoramento industrial em tempo real</p>
        </div>
      </div>
    </div>

    <div class="tv-header-right">
      <div class="tv-online-block">
        <span class="block-title">Mecânicos Online</span>
        <div id="online-mecanicos" class="avatar-list"></div>
      </div>
      <div class="tv-clock-wrap">
        <div id="tv-date" class="tv-date"></div>
        <div id="tv-clock" class="tv-clock"></div>
        <div class="tv-status"><span class="dot"></span>Sistema Online</div>
      </div>
    </div>
  </header>

  <div class="screen-indicators" id="screen-indicators">
    <button type="button" data-screen="0" class="active">OS</button>
    <button type="button" data-screen="1">Escala</button>
    <button type="button" data-screen="2">Preventivas</button>
    <button type="button" data-screen="3">Alertas</button>
  </div>

  <main class="tv-screens">
    <section class="tv-screen active" data-screen="0" aria-label="Tela de ordens de serviço">
      <div class="grid-2-1">
        <article class="card span-2">
          <h2>Ordens de Serviço em Tempo Real</h2>
          <div class="kpi-row three">
            <div class="kpi accent-green"><span>Abertas</span><strong id="os-abertas">0</strong></div>
            <div class="kpi accent-yellow"><span>Em andamento</span><strong id="os-andamento">0</strong></div>
            <div class="kpi accent-red"><span>Paradas / Críticas</span><strong id="os-criticas">0</strong></div>
          </div>
          <div class="table-wrap">
            <table class="tv-table">
              <thead>
                <tr><th>#OS</th><th>Equipamento</th><th>Mecânico</th><th>Criticidade</th><th>Status</th><th>Abertura</th></tr>
              </thead>
              <tbody id="os-lista"></tbody>
            </table>
          </div>
        </article>
        <article class="card">
          <h2>OS por Status</h2>
          <canvas id="chart-os"></canvas>
        </article>
      </div>
    </section>

    <section class="tv-screen" data-screen="1" aria-label="Tela de escala e ranking">
      <div class="grid-2">
        <article class="card">
          <h2>Escala do Dia</h2>
          <div class="escala-block"><h3>Mecânicos do dia</h3><div id="escala-dia" class="chip-list"></div></div>
          <div class="escala-block"><h3>Apoio operacional</h3><div id="escala-apoio" class="chip-list"></div></div>
          <div class="escala-block"><h3>Responsável da noite</h3><div id="escala-noite" class="chip-list"></div></div>
        </article>
        <article class="card">
          <h2>Top 5 Mecânicos</h2>
          <ol id="ranking-mecanicos" class="ranking-list"></ol>
        </article>
        <article class="card span-2">
          <h2>Ranking Apoio Operacional</h2>
          <ol id="ranking-apoio" class="ranking-list two-col"></ol>
        </article>
      </div>
    </section>

    <section class="tv-screen" data-screen="2" aria-label="Tela de preventivas">
      <div class="grid-2-1">
        <article class="card span-2">
          <h2>Preventivas</h2>
          <div class="kpi-row four">
            <div class="kpi accent-yellow"><span>Abertas</span><strong id="prev-abertas">0</strong></div>
            <div class="kpi accent-blue"><span>Em andamento</span><strong id="prev-andamento">0</strong></div>
            <div class="kpi accent-green"><span>Fechadas</span><strong id="prev-fechadas">0</strong></div>
            <div class="kpi accent-red"><span>Atrasadas</span><strong id="prev-atrasadas">0</strong></div>
          </div>
          <div class="table-wrap">
            <table class="tv-table">
              <thead>
                <tr><th>#</th><th>Equipamento</th><th>Mecânico</th><th>Criticidade</th><th>Data Prevista</th><th>Status</th></tr>
              </thead>
              <tbody id="prev-lista"></tbody>
            </table>
          </div>
        </article>
        <article class="card"><h2>Por Criticidade</h2><canvas id="chart-prev-criticidade"></canvas></article>
        <article class="card"><h2>Por Status</h2><canvas id="chart-prev-status"></canvas></article>
      </div>
    </section>

    <section class="tv-screen" data-screen="3" aria-label="Tela de alertas e performance">
      <div class="grid-2">
        <article class="card">
          <h2>Alertas Ativos</h2>
          <ul id="alertas-list" class="alert-list"></ul>
        </article>
        <article class="card">
          <h2>Equipamentos com Maior Incidência</h2>
          <ul id="incidencia-list" class="incidencia-list"></ul>
          <div class="attention-kpis">
            <div><span>OS Críticas</span><strong id="attention-os-criticas">0</strong></div>
            <div><span>Preventivas Atrasadas</span><strong id="attention-prev-atrasadas">0</strong></div>
          </div>
        </article>
        <article class="card span-2">
          <h2>Performance da Equipe</h2>
          <canvas id="chart-team"></canvas>
        </article>
      </div>
    </section>
  </main>

  <footer id="tv-ticker" class="tv-ticker priority-baixa">
    <div id="tv-ticker-track" class="tv-ticker-track"></div>
  </footer>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/tv-dashboard.js" defer></script>
