<% layout('layout') %>
<style>
  .tr-page{display:grid;gap:14px}.tr-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px}
  .tr-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
  .img-tecnica{width:100%;max-width:980px;display:block;margin:0 auto;border:1px solid #e2e8f0;border-radius:12px;background:#fff;object-fit:contain}
  .img-planificacao{max-width:760px}.resultado{display:grid;gap:6px;font-size:1rem}
  @media(max-width:920px){.tr-grid{grid-template-columns:1fr}}
</style>
<div class="tr-page">
  <div style="display:flex;justify-content:space-between;align-items:center;"><h1>Semicílindro</h1><a class="btn" href="/tracagem">Voltar</a></div>
  <div class="tr-card"><form method="POST" action="/tracagem/semi-cilindro/calcular" style="display:grid;gap:10px;">
    <div class="tr-grid">
      <div><label>D (diâmetro)</label><input class="input" name="D" type="number" step="0.01" required value="<%= calculo?.parametros?.D || '' %>"></div>
      <div><label>H (comprimento)</label><input class="input" name="H" type="number" step="0.01" required value="<%= calculo?.parametros?.H || '' %>"></div>
      <div><label>E (espessura)</label><input class="input" name="E" type="number" step="0.01" required value="<%= calculo?.parametros?.E || '' %>"></div>
    </div>
    <div class="tr-grid">
      <div><label>Unidade</label><select class="input" name="unidade"><option value="mm" <%= (calculo?.parametros?.unidade || "mm") === "mm" ? "selected" : "" %>>mm</option><option value="cm" <%= calculo?.parametros?.unidade === "cm" ? "selected" : "" %>>cm</option></select></div>
    </div>
    <img src="/img/tracagem/planificacoes/semicilindro-peca.png.JPG" class="img-tecnica" alt="Semicílindro - peça">
    <div><button class="btn btn-green" type="submit">CALCULAR</button></div>
  </form></div>
  <% if (calculo?.resultado) { const resultado = calculo.resultado.resultado; %>
    <div class="tr-card"><h3>Planificação</h3><img src="/img/tracagem/planificacoes/semicilindro-planificacao.png.JPG" class="img-tecnica img-planificacao" alt="Semicílindro - planificação"></div>
    <div class="tr-card"><h3>Resultados</h3><div class="resultado">
      <div>Meia circunferência = <%= resultado.meiaCircunferencia.toFixed(2) %> mm</div>
      <div>Área = <%= resultado.area.toFixed(2) %> mm²</div>
    </div></div>

    <div class="tr-card">
      <%- include('partials/relacionar-equipamento', { tipo: 'semi-cilindro', calculo, equipamentos, tituloPadrao: 'Semi-cilindro' }) %>
    </div>
  <% } %>
</div>
