<% layout('layout') %>
<style>
  .tr-page{display:grid;gap:14px}.tr-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px}
  .tr-grid{display:grid;grid-template-columns:repeat(4,minmax(160px,1fr));gap:10px}
  .tr-main{display:grid;grid-template-columns:minmax(280px,1fr) minmax(300px,420px);gap:14px;align-items:start}
  .img-frame{height:min(400px,55vh);min-height:260px;display:flex;align-items:center;justify-content:center;overflow:hidden;border:1px solid #e2e8f0;border-radius:12px;background:#fff;padding:12px}
  .img-tecnica{max-width:100%;max-height:100%;width:auto;height:auto;display:block;object-fit:contain}
  .img-planificacao{max-height:340px}.resultado{display:grid;gap:6px;font-size:1rem}
  .optional-title{margin:0 0 8px;color:#15803d}.hint{font-size:.86rem;color:#64748b}.manual-equipment{display:none}.manual-equipment.open{display:block}
  @media(max-width:1100px){.tr-main{grid-template-columns:1fr}.tr-grid{grid-template-columns:repeat(2,minmax(160px,1fr))}.img-frame{height:min(360px,48vh)}}
  @media(max-width:640px){.tr-grid{grid-template-columns:1fr}.img-frame{height:min(320px,48vh);min-height:220px;padding:8px}}
</style>
<% const unidadeAtual = calculo?.parametros?.unidade || 'mm'; const fatorUnidade = unidadeAtual === 'cm' ? 10 : 1; const fmt = (v) => (Number(v || 0) / fatorUnidade).toFixed(2); %>
<div class="tr-page">
  <div style="display:flex;justify-content:space-between;align-items:center;"><h1>Cilindro</h1><a class="btn" href="/tracagem">Voltar</a></div>
  <div class="tr-card"><form method="POST" action="/tracagem/cilindro/calcular" style="display:grid;gap:12px;">
    <div class="tr-main">
      <div style="display:grid;gap:12px;">
        <div class="tr-grid">
          <div><label>D — Diâmetro externo</label><input class="input" name="D" type="number" step="0.01" required value="<%= calculo?.parametros?.D || '' %>"></div>
          <div><label>h — Altura útil</label><input class="input" name="h" type="number" step="0.01" required value="<%= calculo?.parametros?.h || '' %>"></div>
          <div><label>E — Espessura da chapa</label><input class="input" name="E" type="number" step="0.01" required value="<%= calculo?.parametros?.E || '' %>"></div>
          <div><label>Folga para solda</label><input class="input" name="folgaSolda" type="number" step="0.01" min="0" value="<%= calculo?.parametros?.folgaSolda ?? '0.00' %>"></div>
        </div>
        <div class="tr-grid">
          <div><label>Unidade de medida</label><select class="input" name="unidade"><option value="mm" <%= unidadeAtual === "mm" ? "selected" : "" %>>mm</option><option value="cm" <%= unidadeAtual === "cm" ? "selected" : "" %>>cm</option></select></div>
        </div>
        <div><button class="btn btn-green" type="submit">CALCULAR</button></div>
      </div>
      <div class="img-frame"><img src="/img/tracagem/planificacoes/cilindro-peca.png" class="img-tecnica" alt="Cilindro - peça"></div>
    </div>
  </form></div>
  <% if (calculo?.resultado) { const resultado = calculo.resultado.resultado; %>
    <div class="tr-card"><h3>Planificação</h3><div class="img-frame"><img src="/img/tracagem/planificacoes/cilindro-planificacao.png" class="img-tecnica img-planificacao" alt="Cilindro - planificação"></div></div>
    <div class="tr-card"><h3>Resultados</h3><div class="resultado">
      <div>A — Comprimento desenvolvido da chapa: <%= fmt(resultado.A) %> <%= unidadeAtual %></div>
      <div>B — Altura útil da chapa: <%= fmt(resultado.B) %> <%= unidadeAtual %></div>
      <div>FS — Folga para solda: <%= fmt(resultado.FS) %> <%= unidadeAtual %></div>
      <div>Comprimento final para corte (A + FS): <%= fmt(resultado.comprimentoComFolga) %> <%= unidadeAtual %></div>
      <div>Área: <%= fmt(resultado.area) %> <%= unidadeAtual %>²</div>
    </div></div>

    <div class="tr-card">
      <%- include('partials/relacionar-equipamento', { tipo: 'cilindro', calculo, equipamentos, ordensServico, tituloPadrao: 'Cilindro' }) %>
    </div>
  <% } %>
</div>
