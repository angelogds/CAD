<%
  const labels = planificacao?.labels || {};
  const divisoes = planificacao?.divisoes || [];
  const A = Number(entrada?.A || labels.A || 0);
  const P = Number(labels.P || resultado?.anguloPorGomo || 0);
%>
<svg viewBox="0 0 800 600" role="img" aria-label="Curva de gomos com planificação" style="width:100%;max-width:960px;border:1px solid #e2e8f0;border-radius:14px;background:#fff;">
  <text x="30" y="35" fill="#222" font-size="20">Peça montada - Curva de gomos</text>
  <path d="M120 250 Q250 120 380 250" stroke="#222" fill="none"/>
  <path d="M160 250 Q250 170 340 250" stroke="#222" fill="none"/>
  <text x="420" y="200" fill="#222">A = <%= A.toFixed(2) %>°</text>
  <text x="420" y="230" fill="#222">P = <%= P.toFixed(2) %>°/gomo</text>

  <text x="30" y="330" fill="#222" font-size="20">Planificação com divisões numeradas</text>
  <line x1="90" y1="400" x2="710" y2="400" stroke="#222"/>
  <% divisoes.forEach((d, idx) => { const x = 90 + (idx * (620 / Math.max(divisoes.length - 1, 1))); %>
    <line x1="<%= x %>" y1="392" x2="<%= x %>" y2="408" stroke="#222"/>
    <text x="<%= x - 3 %>" y="430" fill="#222" font-size="12"><%= d.indice %></text>
  <% }); %>
  <text x="90" y="465" fill="#222">Divisões: 1,2,3,4...</text>
</svg>
