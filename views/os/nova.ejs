<% layout('layout') %>

<div class="card">
  <div class="page-head" style="margin-top:0;">
    <div>
      <h1 style="font-size:28px;">Nova Ordem de Serviço</h1>
      <p class="muted">Informe o problema do solicitante e os dados técnicos para alimentar automaticamente a Inspeção PAC 01.</p>
    </div>
  </div>

  <form method="POST" action="/os" enctype="multipart/form-data" id="os-form">
    <div class="grid-2">
      <div>
        <label class="label">Equipamento (cadastro)</label>
        <select name="equipamento_id" id="equipamento_id">
          <option value="">Selecione...</option>
          <% (equipamentos || []).forEach(e => { %>
            <option value="<%= e.id %>" <%= String(prefillEquipamentoId||'')===String(e.id)?'selected':'' %>><%= e.codigo ? e.codigo + ' - ' : '' %><%= e.nome %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="label">Equipamento (manual)</label>
        <input class="input" type="text" name="equipamento_manual" id="equipamento_manual" placeholder="Ex.: Digestor sem cadastro" />
      </div>

      <div>
        <label class="label">Tipo da OS</label>
        <select name="tipo" class="input" required>
          <% (tipos || ['CORRETIVA','PREVENTIVA','ELETRICA','NRS','OUTROS']).forEach(t => { %>
            <option value="<%= t %>"><%= t %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="label">Grau</label>
        <select name="grau" class="input" required>
          <% (graus || ['BAIXA','MEDIA','ALTA','CRITICA']).forEach(g => { %>
            <option value="<%= g %>"><%= g %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="label">Data de início</label>
        <input class="input" type="date" name="data_inicio" />
      </div>

      <div>
        <label class="label">Data de fim (se já concluída)</label>
        <input class="input" type="date" name="data_fim" />
      </div>

      <div style="grid-column:1 / -1;">
        <label class="label">Descrição do problema (solicitante)</label>
        <textarea name="descricao" class="input" required placeholder="Descreva o que está acontecendo no equipamento"></textarea>
        <div style="margin:12px 0 0;">
          <button type="button" id="btn-tecnico-mic" class="btn btn-ghost" style="padding:11px 20px; font-weight:600; margin-right:8px;">
            🎤 Analisar com o Técnico (Gravar Áudio)
          </button>
          <button type="button" id="btn-analisar-tecnico" class="btn btn-blue" style="padding:11px 20px; font-weight:600;">
            👷 Analisar com o Técnico
          </button>
        </div>
        <div id="status-tecnico" style="display:none; align-items:center; gap:10px; margin:12px 0; color:#444;">
          <div class="spinner-tecnico" style="width:20px;height:20px;border:4px solid #ddd;border-top:4px solid #16a34a;border-radius:50%;animation:spin-tecnico 1s linear infinite;"></div>
          <span id="status-text">Pronto para gravar</span>
        </div>
        <div id="loading-tecnico" style="display:none; align-items:center; gap:10px; margin:12px 0; color:#444;">
          <div class="spinner-tecnico" style="width:20px;height:20px;border:4px solid #ddd;border-top:4px solid #16a34a;border-radius:50%;animation:spin-tecnico 1s linear infinite;"></div>
          <span id="loading-text-tecnico">O Técnico está analisando a OS...</span>
        </div>
      </div>

      <div>
        <label class="label">Ação preventiva</label>
        <textarea name="resumo_tecnico" class="input" placeholder="Recomendação para evitar reincidência"></textarea>
      </div>

      <div>
        <label class="label">Ação corretiva</label>
        <textarea name="causa_diagnostico" class="input" placeholder="Intervenção para corrigir o problema atual"></textarea>
      </div>

      <div style="grid-column:1 / -1;">
        <label class="label">Solicitante</label>
        <input class="input" type="text" readonly value="<%= user?.name || '-' %>" />
      </div>

      <div style="grid-column:1 / -1;">
        <label class="label">Fotos de abertura (opcional)</label>
        <input id="abertura_fotos" type="file" name="abertura_fotos" accept="image/*" multiple style="display:none" />
        <button type="button" class="btn btn-outline" onclick="document.getElementById('abertura_fotos').click()">📷 Adicionar fotos</button>
        <div class="muted" style="margin-top:8px;">Registro visual do estado inicial.</div>
        <div id="preview-abertura" style="margin-top:6px;"></div>
      </div>
    </div>

    <div class="row" style="justify-content:space-between; margin-top:16px;">
      <a href="/os" class="btn btn-ghost">Cancelar</a>
      <button type="submit" class="btn btn-primary">Salvar OS</button>
    </div>
  </form>
</div>

<style>
  @keyframes spin-tecnico {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  const fileInput = document.getElementById('abertura_fotos');
  const preview = document.getElementById('preview-abertura');
  fileInput.addEventListener('change', function(){
    preview.innerHTML = '';
    Array.from(fileInput.files || []).forEach(f => {
      const el = document.createElement('span');
      el.className = 'pill-tag pill-gray';
      el.style.marginRight = '6px';
      el.textContent = f.name;
      preview.appendChild(el);
    });
  });

  document.getElementById('os-form').addEventListener('submit', function(e){
    const id = document.getElementById('equipamento_id').value.trim();
    const manual = document.getElementById('equipamento_manual').value.trim();
    if (!id && !manual) {
      e.preventDefault();
      alert('Informe um equipamento cadastrado ou manual.');
    }
  });

  document.getElementById('btn-analisar-tecnico').addEventListener('click', async () => {
    const equipamento = document.querySelector('[name="equipamento_id"]')?.value || '';
    const descricaoField = document.querySelector('[name="descricao"]');
    const descricao = String(descricaoField?.value || '').trim();
    const btn = document.getElementById('btn-analisar-tecnico');
    const loading = document.getElementById('loading-tecnico');
    const loadingText = document.getElementById('loading-text-tecnico');

    if (!descricao) {
      alert('❌ Descreva o problema antes de chamar o Técnico.');
      return;
    }

    btn.disabled = true;
    btn.style.opacity = '0.6';
    loading.style.display = 'flex';
    loadingText.textContent = 'O Técnico está analisando a OS...';
    loadingText.style.color = '#444';

    try {
      const res = await fetch('/ia/os/analisar-abertura', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          equipamento_id: equipamento,
          descricao,
        }),
      });

      const data = await res.json();

      if (data.ok) {
        const criticidadeField = document.querySelector('[name="grau"]');
        const diagnosticoField = document.querySelector('[name="causa_diagnostico"]');
        const acaoInicialField = document.querySelector('[name="resumo_tecnico"]');

        if (criticidadeField) criticidadeField.value = data.resultado?.criticidade_sugerida || data.resultado?.criticidade || criticidadeField.value;
        if (diagnosticoField) diagnosticoField.value = data.resultado?.diagnostico_inicial || data.resultado?.causa_mais_provavel || '';
        if (acaoInicialField) acaoInicialField.value = data.resultado?.acoes_iniciais || '';
        loadingText.textContent = '✅ Análise do Técnico concluída!';
        setTimeout(() => { loading.style.display = 'none'; }, 1800);
      } else {
        throw new Error(data.error || 'Não foi possível completar a análise');
      }
    } catch (e) {
      loadingText.textContent = `❌ ${e.message || 'Erro de conexão com o Técnico'}`;
      loadingText.style.color = '#dc2626';
      setTimeout(() => { loading.style.display = 'none'; }, 3500);
    } finally {
      btn.disabled = false;
      btn.style.opacity = '1';
    }
  });

  let mediaRecorder;
  let audioChunks = [];
  let isRecording = false;

  document.getElementById('btn-tecnico-mic').addEventListener('click', async () => {
    const btn = document.getElementById('btn-tecnico-mic');
    const statusDiv = document.getElementById('status-tecnico');
    const statusText = document.getElementById('status-text');

    if (!isRecording) {
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        mediaRecorder = new MediaRecorder(stream);
        audioChunks = [];

        mediaRecorder.ondataavailable = (event) => audioChunks.push(event.data);
        mediaRecorder.onstop = () => processarAudio();

        mediaRecorder.start();
        isRecording = true;

        btn.textContent = '⏹️ Parar Gravação';
        btn.style.background = '#ef4444';
        statusDiv.style.display = 'flex';
        statusText.textContent = 'Gravando... Fale o problema claramente.';
        statusText.style.color = '#444';
      } catch (err) {
        alert('❌ Não foi possível acessar o microfone. Verifique as permissões.');
      }
    } else {
      mediaRecorder.stop();
      mediaRecorder.stream.getTracks().forEach((track) => track.stop());
      isRecording = false;
    }
  });

  async function processarAudio() {
    const btn = document.getElementById('btn-tecnico-mic');
    const statusText = document.getElementById('status-text');

    btn.disabled = true;
    statusText.textContent = 'Transcrevendo e analisando com o Técnico...';

    const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
    const formData = new FormData();
    formData.append('audio', audioBlob, 'os_audio.webm');

    try {
      const transRes = await fetch('/ia/transcrever/abertura', {
        method: 'POST',
        body: formData,
      });
      const transData = await transRes.json();

      if (!transRes.ok || transData.status !== 'concluido') {
        throw new Error(transData.erro || 'Falha na transcrição');
      }

      const transcricao = transData.transcricao_bruta || '';
      document.querySelector('textarea[name="descricao"]').value = transcricao;

      const analiseRes = await fetch('/ia/os/analisar-abertura', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          descricao: transcricao,
          equipamento_id: document.querySelector('select[name="equipamento_id"]').value || null,
        }),
      });
      const analiseData = await analiseRes.json();

      if (analiseRes.ok && analiseData.ok && analiseData.resultado) {
        document.querySelector('select[name="grau"]').value = analiseData.resultado.criticidade_sugerida || analiseData.resultado.criticidade || 'MEDIA';
        document.querySelector('textarea[name="causa_diagnostico"]').value = analiseData.resultado.diagnostico_inicial || analiseData.resultado.causa_mais_provavel || '';
        document.querySelector('textarea[name="resumo_tecnico"]').value = analiseData.resultado.acoes_iniciais || '';

        statusText.textContent = '✅ Pronto! Áudio transcrito e analisado pelo Técnico.';
        statusText.style.color = '#166534';
      } else {
        statusText.textContent = '✅ Áudio transcrito, mas análise falhou.';
      }
    } catch (err) {
      console.error(err);
      statusText.textContent = `❌ Erro: ${err.message}`;
      statusText.style.color = '#dc2626';
    } finally {
      btn.disabled = false;
      btn.textContent = '🎤 Analisar com o Técnico (Gravar Áudio)';
      btn.style.background = '';
      setTimeout(() => {
        document.getElementById('status-tecnico').style.display = 'none';
      }, 4000);
    }
  }
</script>
