<% layout('layout') %>

<div class="card">
  <div class="page-head" style="margin-top:0;">
    <div>
      <h1 style="font-size:28px;">Nova Ordem de Serviço</h1>
      <p class="muted">Informe o problema do solicitante e os dados técnicos para alimentar automaticamente a Inspeção PAC 01.</p>
    </div>
  </div>

  <form method="POST" action="/os" enctype="multipart/form-data" id="os-form">
    <div class="grid-2">
      <div>
        <label class="label">Equipamento (cadastro)</label>
        <select name="equipamento_id" id="equipamento_id">
          <option value="">Selecione...</option>
          <% (equipamentos || []).forEach(e => { %>
            <option value="<%= e.id %>" <%= String(prefillEquipamentoId||'')===String(e.id)?'selected':'' %>><%= e.codigo ? e.codigo + ' - ' : '' %><%= e.nome %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="label">Equipamento (manual)</label>
        <input class="input" type="text" name="equipamento_manual" id="equipamento_manual" placeholder="Ex.: Digestor sem cadastro" />
      </div>

      <div>
        <label class="label">Tipo da OS</label>
        <select name="tipo" class="input" required>
          <% (tipos || ['CORRETIVA','PREVENTIVA','ELETRICA','NRS','OUTROS']).forEach(t => { %>
            <option value="<%= t %>"><%= t %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="label">Grau</label>
        <select name="grau" class="input" required>
          <% (graus || ['BAIXA','MEDIA','ALTA','CRITICA']).forEach(g => { %>
            <option value="<%= g %>"><%= g %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="label">Data de início</label>
        <input class="input" type="date" name="data_inicio" />
      </div>

      <div>
        <label class="label">Data de fim (se já concluída)</label>
        <input class="input" type="date" name="data_fim" />
      </div>

      <div style="grid-column:1 / -1;">
        <label class="label">Descrição do problema (solicitante)</label>
        <textarea name="descricao" class="input" required placeholder="Descreva o que está acontecendo no equipamento"></textarea>
        <div style="margin:12px 0 0;">
          <button type="button" id="btn-analisar-ia" class="btn btn-blue" style="padding:10px 18px;font-weight:600;">
            🤖 Analisar com IA
          </button>
        </div>
        <div id="loading-ia" style="display:none;align-items:center;gap:8px;margin:12px 0;color:#666;">
          <div class="spinner-ia" style="width:18px;height:18px;border:3px solid #ddd;border-top:3px solid #3b82f6;border-radius:50%;animation:spin-ia 1s linear infinite;"></div>
          <span id="loading-text">A IA está analisando a ordem de serviço...</span>
        </div>
      </div>

      <div>
        <label class="label">Ação preventiva</label>
        <textarea name="resumo_tecnico" class="input" placeholder="Recomendação para evitar reincidência"></textarea>
      </div>

      <div>
        <label class="label">Ação corretiva</label>
        <textarea name="causa_diagnostico" class="input" placeholder="Intervenção para corrigir o problema atual"></textarea>
      </div>

      <div style="grid-column:1 / -1;">
        <label class="label">Solicitante</label>
        <input class="input" type="text" readonly value="<%= user?.name || '-' %>" />
      </div>

      <div style="grid-column:1 / -1;">
        <label class="label">Fotos de abertura (opcional)</label>
        <input id="abertura_fotos" type="file" name="abertura_fotos" accept="image/*" multiple style="display:none" />
        <button type="button" class="btn btn-outline" onclick="document.getElementById('abertura_fotos').click()">📷 Adicionar fotos</button>
        <div class="muted" style="margin-top:8px;">Registro visual do estado inicial.</div>
        <div id="preview-abertura" style="margin-top:6px;"></div>
      </div>
    </div>

    <div class="row" style="justify-content:space-between; margin-top:16px;">
      <a href="/os" class="btn btn-ghost">Cancelar</a>
      <button type="submit" class="btn btn-primary">Salvar OS</button>
    </div>
  </form>
</div>

<style>
  @keyframes spin-ia {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  const fileInput = document.getElementById('abertura_fotos');
  const preview = document.getElementById('preview-abertura');
  fileInput.addEventListener('change', function(){
    preview.innerHTML = '';
    Array.from(fileInput.files || []).forEach(f => {
      const el = document.createElement('span');
      el.className = 'pill-tag pill-gray';
      el.style.marginRight = '6px';
      el.textContent = f.name;
      preview.appendChild(el);
    });
  });

  document.getElementById('os-form').addEventListener('submit', function(e){
    const id = document.getElementById('equipamento_id').value.trim();
    const manual = document.getElementById('equipamento_manual').value.trim();
    if (!id && !manual) {
      e.preventDefault();
      alert('Informe um equipamento cadastrado ou manual.');
    }
  });

  document.getElementById('btn-analisar-ia').addEventListener('click', async () => {
    const equipamento = document.querySelector('[name="equipamento_id"]')?.value || '';
    const descricaoField = document.querySelector('[name="descricao"]');
    const descricao = String(descricaoField?.value || '').trim();
    const btn = document.getElementById('btn-analisar-ia');
    const loading = document.getElementById('loading-ia');
    const loadingText = document.getElementById('loading-text');

    if (!descricao) {
      alert('Preencha a descrição do problema antes de analisar.');
      return;
    }

    btn.disabled = true;
    btn.style.opacity = '0.6';
    loading.style.display = 'flex';
    loadingText.textContent = 'A IA está analisando a ordem de serviço...';
    loadingText.style.color = '#666';

    try {
      const res = await fetch('/ia/os/analisar-abertura', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          equipamento_id: equipamento,
          descricao,
        }),
      });

      const data = await res.json();

      if (data.ok) {
        const criticidadeField = document.querySelector('[name="grau"]');
        const diagnosticoField = document.querySelector('[name="causa_diagnostico"]');
        const acaoInicialField = document.querySelector('[name="resumo_tecnico"]');

        if (criticidadeField) criticidadeField.value = data.resultado?.criticidade_sugerida || criticidadeField.value;
        if (diagnosticoField) diagnosticoField.value = data.resultado?.diagnostico_inicial || '';
        if (acaoInicialField) acaoInicialField.value = data.resultado?.acoes_iniciais || '';
        loadingText.textContent = '✅ Análise concluída!';
        setTimeout(() => { loading.style.display = 'none'; }, 1500);
      } else {
        throw new Error(data.error || 'Não foi possível analisar.');
      }
    } catch (e) {
      loadingText.textContent = `❌ ${e.message || 'Erro de conexão com a IA'}`;
      loadingText.style.color = '#ef4444';
      setTimeout(() => { loading.style.display = 'none'; }, 3000);
    } finally {
      btn.disabled = false;
      btn.style.opacity = '1';
    }
  });
</script>
