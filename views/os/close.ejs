<% layout('layout') %>

<div class="card">
  <div class="page-head" style="margin-top:0;">
    <div>
      <h1 style="font-size:28px;">Concluir OS #<%= os.id %></h1>
      <p class="muted">Fechamento rápido com IA: selecione ações e valide os textos técnicos sugeridos.</p>
    </div>
  </div>

  <div class="note" style="margin-bottom:12px;">
    <b>Não conformidade:</b><br />
    <%= os.descricao || '-' %>
  </div>

  <form method="POST" action="/os/<%= os.id %>/fechar" enctype="multipart/form-data" id="form-fechar-os">
    <div class="grid-2">
      <div style="grid-column:1 / -1;">
        <label class="label">Ações executadas</label>
        <div class="row" style="gap:14px; flex-wrap:wrap;">
          <% ['inspecao','limpeza','reaperto','alinhamento','lubrificacao','substituicao_peca','regulagem','solda','fechamento','teste_operacional'].forEach(acao => { %>
            <label><input type="checkbox" name="acoes_executadas" value="<%= acao %>"> <%= acao.replaceAll('_',' ') %></label>
          <% }) %>
        </div>
      </div>

      <div>
        <label class="label">Peça substituída</label>
        <input class="input" type="text" name="peca_descricao" placeholder="Ex.: Rolamento 6204" />
      </div>
      <div>
        <label class="label">Quantidade</label>
        <input class="input" type="number" step="0.01" min="0" name="peca_quantidade" value="1" />
      </div>

      <div>
        <label class="label">Falha eliminada?</label>
        <select class="input" name="falha_eliminada">
          <option value="1">Sim</option>
          <option value="0">Não</option>
        </select>
      </div>

      <div>
        <label class="label">Tipo de ação</label>
        <select class="input" name="tipo_acao">
          <option value="CORRETIVA">Corretiva</option>
          <option value="PREVENTIVA">Preventiva</option>
          <option value="AJUSTE">Ajuste</option>
        </select>
      </div>

      <div>
        <label class="label">Teste operacional realizado?</label>
        <select class="input" name="teste_operacional_realizado">
          <option value="1">Sim</option>
          <option value="0">Não</option>
        </select>
      </div>

      <div>
        <label class="label">Requer acompanhamento?</label>
        <select class="input" name="requer_monitoramento">
          <option value="0">Não</option>
          <option value="1">Sim</option>
        </select>
      </div>

      <div style="grid-column:1 / -1;">
        <label class="label">Observação curta (opcional)</label>
        <input class="input" type="text" name="observacao_curta" maxlength="180" placeholder="Detalhe final curto" />
      </div>

      <div>
        <label class="label">Resumo técnico (editável)</label>
        <textarea class="input" name="resumo_tecnico" placeholder="Pode deixar em branco para IA gerar automaticamente"></textarea>
      </div>
      <div>
        <label class="label">Causa/Diagnóstico (editável)</label>
        <textarea class="input" name="causa_diagnostico" placeholder="Pode deixar em branco para IA gerar automaticamente"></textarea>
      </div>
    </div>

    <div style="margin-top:10px;">
      <label class="label">Fotos de fechamento (opcional)</label>
      <input id="fechamento_fotos" type="file" name="fechamento_fotos" accept="image/*" multiple />
    </div>

    <div class="row" style="justify-content:space-between; margin-top:16px;">
      <a class="btn btn-ghost" href="/os/<%= os.id %>">Voltar</a>
      <button type="submit" class="btn btn-primary">Concluir OS</button>
    </div>
  </form>
</div>
