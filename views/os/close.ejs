<% layout('layout') %>

<div class="card">
  <div class="page-head" style="margin-top:0;">
    <div>
      <h1 style="font-size:28px;">Concluir OS #<%= os.id %></h1>
      <p class="muted">Fluxo simplificado: anexe pelo menos uma foto final para concluir a ordem.</p>
    </div>
  </div>

  <div class="note" style="margin-bottom:12px;">
    <b>Descrição do problema (solicitante):</b><br />
    <%= os.descricao || '-' %>
  </div>

  <form method="POST" action="/os/<%= os.id %>/fechar" enctype="multipart/form-data" id="form-fechar-os">
    <div style="margin-bottom:12px;">
      <label class="label" for="descricao_assistida">Descrição assistida (editável)</label>
      <div class="row" style="justify-content:flex-start; gap:8px; margin-bottom:8px;">
        <button
          type="button"
          class="btn btn-ghost"
          data-audio-transcriber
          data-endpoint="/ia/transcrever/fechamento"
          data-target="#descricao_assistida"
          data-status="#status-transcricao-fechamento"
          title="Gravar áudio para transcrever"
          aria-label="Gravar áudio para transcrever"
        >🎤</button>
        <span id="status-transcricao-fechamento" class="muted">Pronto para gravar</span>
      </div>
      <textarea
        id="descricao_assistida"
        name="descricao_assistida"
        class="input"
        style="min-height:120px;"
        placeholder="Descreva o serviço executado (você pode editar antes de concluir)."
      ></textarea>
    </div>

    <div>
      <label class="label">Fotos de fechamento *</label>
      <input id="fechamento_fotos" class="input" type="file" name="fechamento_fotos" accept="image/*" multiple required />
      <div class="muted" style="margin-top:6px;">Adicione evidências visuais do serviço executado.</div>
    </div>

    <div class="row" style="justify-content:space-between; margin-top:16px;">
      <a class="btn btn-ghost" href="/os/<%= os.id %>">Voltar</a>
      <button type="submit" class="btn btn-primary">Concluir OS</button>
    </div>
  </form>
</div>
<script src="/js/os-audio-transcription.js"></script>
