<% layout('layout') %>

<div class="card">
  <div class="page-head" style="margin-top:0;">
    <div>
      <h1 style="font-size:28px;">Concluir OS #<%= os.id %></h1>
      <p class="muted">Fluxo simplificado: anexe pelo menos uma foto final para concluir a ordem.</p>
    </div>
  </div>

  <div class="note" style="margin-bottom:12px;">
    <b>Descrição do problema (solicitante):</b><br />
    <%= os.descricao || '-' %>
  </div>

  <form method="POST" action="/os/<%= os.id %>/fechar" enctype="multipart/form-data" id="form-fechar-os">
    <div style="margin-bottom:12px;">
      <label class="label" for="descricao_assistida">Descrição assistida (editável)</label>
      <div class="row" style="justify-content:flex-start; gap:8px; margin-bottom:8px;">
        <button
          type="button"
          class="btn btn-ghost"
          data-audio-transcriber
          data-endpoint="/ia/transcrever/fechamento"
          data-target="#descricao_assistida"
          data-status="#status-transcricao-fechamento"
          title="Gravar áudio para transcrever"
          aria-label="Gravar áudio para transcrever"
        >🎤</button>
        <span id="status-transcricao-fechamento" class="muted">Pronto para gravar</span>
      </div>
      <textarea
        id="descricao_assistida"
        name="descricao_assistida"
        class="input"
        style="min-height:120px;"
        placeholder="Descreva o serviço executado (você pode editar antes de concluir)."
      ></textarea>
    </div>

    <div>
      <label class="label">Fotos de fechamento *</label>
      <input id="fechamento_fotos" class="input" type="file" name="fechamento_fotos" accept="image/*" multiple required />
      <div class="muted" style="margin-top:6px;">Adicione evidências visuais do serviço executado.</div>
    </div>

    <input type="hidden" name="fotos_metadados_json" id="fotos_metadados_json" value="[]" />
    <input type="hidden" name="versao_tecnica_sugerida" id="versao_tecnica_sugerida" value="" />
    <input type="hidden" name="fonte_descricao" id="fonte_descricao" value="texto" />

    <div style="margin-top:14px;">
      <button type="button" class="btn btn-outline" id="btn-gerar-descricao">Gerar descrição técnica</button>
      <span class="muted" id="status-geracao" style="margin-left:8px;"></span>
    </div>

    <div style="margin-top:10px;">
      <div class="muted">
        Fonte detectada: <strong id="fonte-indicador">texto</strong>
      </div>
      <label class="label" for="preview_tecnica" style="margin-top:6px;">Pré-visualização editável (versão final aprovada)</label>
      <textarea id="preview_tecnica" name="versao_final_aprovada" class="input" rows="5" placeholder="A versão final aprovada aparecerá aqui..."></textarea>
    </div>

    <div class="row" style="justify-content:space-between; margin-top:16px;">
      <a class="btn btn-ghost" href="/os/<%= os.id %>">Voltar</a>
      <button type="submit" class="btn btn-primary">Concluir OS</button>
    </div>
  </form>
</div>
<script src="/js/os-audio-transcription.js"></script>
<script>
  (function(){
    const form = document.getElementById('form-fechar-os');
    const fotosInput = document.getElementById('fechamento_fotos');
    const fotosMetaInput = document.getElementById('fotos_metadados_json');
    const descricaoInput = document.getElementById('descricao_assistida');
    const previewInput = document.getElementById('preview_tecnica');
    const fonteInput = document.getElementById('fonte_descricao');
    const versaoSugeridaInput = document.getElementById('versao_tecnica_sugerida');
    const fonteIndicador = document.getElementById('fonte-indicador');
    const statusGeracao = document.getElementById('status-geracao');
    const btnGerar = document.getElementById('btn-gerar-descricao');

    function syncFotosMetadados() {
      const payload = Array.from(fotosInput?.files || []).map((f) => ({
        nome_arquivo: f.name,
        tipo_mime: f.type || null,
        tamanho_bytes: f.size || null,
      }));
      fotosMetaInput.value = JSON.stringify(payload);
      return payload;
    }

    fotosInput?.addEventListener('change', syncFotosMetadados);
    syncFotosMetadados();

    btnGerar?.addEventListener('click', async function(){
      const textoDigitado = (descricaoInput?.value || '').trim();
      const fotosMetadados = syncFotosMetadados();
      const fonte = textoDigitado ? 'texto' : (fotosMetadados.length ? 'foto' : 'texto');

      statusGeracao.textContent = 'Gerando descrição técnica...';
      btnGerar.disabled = true;

      try {
        const resp = await fetch('/os/<%= os.id %>/gerar-descricao-tecnica', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            texto_digitado: textoDigitado,
            transcricao_audio: textoDigitado,
            fotos_metadados: fotosMetadados,
            fonte,
          }),
        });
        const data = await resp.json();
        if (!resp.ok || !data?.ok) throw new Error(data?.error || 'Falha ao gerar descrição técnica.');

        const textoFinal = (data?.descricaoTecnica || '').trim();
        if (textoFinal) {
          previewInput.value = textoFinal;
          versaoSugeridaInput.value = textoFinal;
        }
        const fonteDetectada = data?.fonte || fonte;
        fonteInput.value = fonteDetectada;
        fonteIndicador.textContent = fonteDetectada;
        statusGeracao.textContent = textoFinal ? 'Descrição técnica pronta para edição.' : 'Sem conteúdo da IA. Continue manualmente.';
      } catch (err) {
        statusGeracao.textContent = err?.message || 'Falha da IA. Continue manualmente.';
      } finally {
        btnGerar.disabled = false;
      }
    });

    form?.addEventListener('submit', function(){
      syncFotosMetadados();
      const preview = (previewInput?.value || '').trim();
      if (!preview) previewInput.value = (descricaoInput?.value || '').trim();
    });
  })();
</script>
