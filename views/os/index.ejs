<% layout('layout') %>

<style>
  /* ─── OS INDEX — responsivo completo ─── */
  .os-page-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .os-page-head h1 {
    margin: 0;
    font-size: 30px;
    letter-spacing: -.02em;
  }

  .muted {
    font-size: 13px;
    color: #6b7280;
    margin-top: 4px;
  }

  .card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 18px;
  }

  .btn-primary {
    background: #16a34a;
    color: #fff;
    border: none;
    padding: 10px 16px;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: #15803d;
  }

  .bulk-whatsapp {
    margin-bottom: 14px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    align-items: end;
  }

  .bulk-whatsapp-title {
    font-weight: 900;
    color: #0f172a;
    margin-bottom: 4px;
  }

  .bulk-whatsapp-form {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .bulk-whatsapp-form select {
    min-width: 260px;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    padding: 9px 11px;
    font-weight: 700;
    color: #0f172a;
    background: #fff;
  }

  .btn-whatsapp {
    background: #22c55e;
    color: #052e16;
    border-color: #16a34a;
  }

  .btn-whatsapp:hover {
    background: #dcfce7;
  }

  /* ─── TABELA DESKTOP ─── */
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    min-width: 1080px;
  }

  thead th {
    text-align: left;
    font-size: 12px;
    color: #64748b;
    font-weight: 700;
    letter-spacing: .02em;
    padding: 10px 12px;
    border-bottom: 1px solid #e5e7eb;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 1;
  }

  tbody td {
    padding: 11px 12px;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
    font-size: 13px;
    color: #0f172a;
  }

  tbody tr:hover td {
    background: #f8fafc;
  }

  .td-clip {
    max-width: 240px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border-radius: 999px;
    font-weight: 800;
    font-size: 11px;
    border: 1px solid #e5e7eb;
    background: #f8fafc;
    color: #0f172a;
    white-space: nowrap;
  }

  .pill-blue {
    background: #eff6ff;
    border-color: #bfdbfe;
    color: #1d4ed8;
  }

  .pill-amber {
    background: #fff7ed;
    border-color: #fed7aa;
    color: #9a3412;
  }

  .pill-sky {
    background: #ecfeff;
    border-color: #a5f3fc;
    color: #155e75;
  }

  .pill-gray {
    background: #f1f5f9;
    border-color: #e2e8f0;
    color: #334155;
  }

  .pill-green {
    background: #ecfdf5;
    border-color: #bbf7d0;
    color: #14532d;
  }

  .pill-red {
    background: #fef2f2;
    border-color: #fecaca;
    color: #991b1b;
  }

  .btn-sm {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 11px;
    border-radius: 9px;
    border: 1px solid #d1d5db;
    background: #fff;
    cursor: pointer;
    text-decoration: none;
    font-weight: 800;
    font-size: 12px;
    color: #0f172a;
    white-space: nowrap;
  }

  .btn-sm:hover {
    border-color: rgba(22, 163, 74, .45);
    background: #ecfdf5;
  }

  .os-actions {
    display: inline-flex;
    flex-direction: column;
    gap: 6px;
    align-items: stretch;
  }

  .os-action-btn {
    justify-content: center;
    min-width: 74px;
    padding: 5px 10px;
    line-height: 1.1;
    transition: background .18s ease, border-color .18s ease, color .18s ease, box-shadow .18s ease;
  }

  .os-action-open:hover {
    border-color: rgba(22, 163, 74, .5);
    background: linear-gradient(180deg, #f0fdf4 0%, #dcfce7 100%);
  }

  .os-action-delete:hover {
    border-color: rgba(185, 28, 28, .5);
    color: #7f1d1d;
    background: linear-gradient(180deg, #fee2e2 0%, #fecaca 100%);
  }

  /* ─── CARDS MOBILE (escondidos no desktop) ─── */
  .os-cards {
    display: none;
    gap: 10px;
    flex-direction: column;
  }

  .os-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 14px;
    display: grid;
    gap: 8px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow .15s ease;
  }

  .os-card:hover {
    box-shadow: 0 4px 12px rgba(0, 0, 0, .08);
  }

  .os-card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
  }

  .os-card-id {
    font-weight: 900;
    font-size: 13px;
    color: #64748b;
  }

  .os-card-equip {
    font-weight: 700;
    font-size: 15px;
    color: #0f172a;
    line-height: 1.3;
  }

  .os-card-desc {
    font-size: 13px;
    color: #475569;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .os-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    flex-wrap: wrap;
    padding-top: 6px;
    border-top: 1px solid #f1f5f9;
  }

  .os-card-meta {
    font-size: 12px;
    color: #94a3b8;
  }

  .os-card-pills {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .os-card-executores {
    font-size: 12px;
    color: #334155;
  }

  .empty-state {
    text-align: center;
    padding: 40px 20px;
    color: #94a3b8;
    font-size: 14px;
  }

  /* ─── BREAKPOINTS ─── */
  @media (max-width: 760px) {
    .os-page-head h1 {
      font-size: 24px;
    }

    .os-page-head {
      align-items: flex-start;
    }

    .card {
      padding: 0;
      border: none;
      background: transparent;
    }

    .table-wrap {
      display: none;
    }

    .os-cards {
      display: flex;
    }

    .bulk-whatsapp {
      grid-template-columns: 1fr;
      padding: 14px;
      border: 1px solid #e5e7eb;
      background: #fff;
    }

    .bulk-whatsapp-form {
      justify-content: stretch;
    }

    .bulk-whatsapp-form select,
    .bulk-whatsapp-form button {
      width: 100%;
    }
  }

  @media (max-width: 400px) {
    .btn-primary {
      width: 100%;
      justify-content: center;
    }

    .os-page-head {
      gap: 8px;
    }
  }
</style>

<div class="os-page-head">
  <div>
    <h1>Ordens de Serviço</h1>
    <div class="muted">Abertas, em andamento e finalizadas.</div>
  </div>
  <a class="btn-primary" href="/os/novo">+ Nova OS</a>
</div>

<% if (canSendWhatsapp) { %>
  <div class="card bulk-whatsapp">
    <div>
      <div class="bulk-whatsapp-title">Enviar OS abertas do colaborador</div>
      <div class="muted">Selecione um colaborador para reenviar, por WhatsApp, todas as OS abertas atribuídas ao nome dele.</div>
    </div>
    <form class="bulk-whatsapp-form" id="bulkWhatsappForm">
      <select id="colaboradorWhatsAppSelect" name="colaborador_id" required>
        <option value="">Selecione o colaborador</option>
        <% (colaboradores || []).forEach((colaborador) => { %>
          <option value="<%= colaborador.id %>" data-nome="<%= colaborador.name %>" data-telefone="<%= colaborador.telefone_whatsapp || '' %>"><%= colaborador.name %></option>
        <% }) %>
      </select>
      <button class="btn-sm btn-whatsapp" type="submit" data-action="enviar-os-whatsapp" disabled>Enviar selecionadas pelo WhatsApp</button>
    </form>
  </div>
<% } else { %>
  <div class="card bulk-whatsapp">
    <div>
      <div class="bulk-whatsapp-title">Notificações WhatsApp</div>
      <div class="muted">Notificações disponíveis apenas para Admin e Encarregado de Manutenção.</div>
    </div>
  </div>
<% } %>

<div class="card">
  <%# ── TABELA (desktop) ── %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="width:44px;"><input type="checkbox" id="osSelectAll" aria-label="Selecionar todas as OS visíveis"></th>
          <th style="width:60px;">#</th>
          <th>Equipamento</th>
          <th style="width:120px;">Tipo</th>
          <th style="width:100px;">Grau</th>
          <th style="width:130px;">Status</th>
          <th style="width:160px;">Solicitante</th>
          <th style="width:150px;">Abertura</th>
          <th style="width:90px;">Dias aberta</th>
          <th style="width:230px;">Andamento / rastreabilidade</th>
          <th style="width:150px;">Fechamento</th>
          <th style="width:220px;">Executores</th>
          <th style="width:120px; text-align:right;">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (!lista || !lista.length) { %>
          <tr>
            <td colspan="13" class="empty-state">Nenhuma OS cadastrada.</td>
          </tr>
        <% } %>
        <% (lista || []).forEach(o => {
          const st = (o.status || '').toUpperCase();
          const stClass = st === 'ABERTA' ? 'pill-amber'
            : (st === 'ANDAMENTO' || st === 'EM_ANDAMENTO') ? 'pill-sky'
            : (st === 'PAUSADA') ? 'pill-gray'
            : (st === 'CONCLUIDA' || st === 'FINALIZADA' || st === 'FECHADA') ? 'pill-green'
            : (st === 'CANCELADA') ? 'pill-red'
            : 'pill-gray';
          const andamentoClass = o.status_em_andamento && o.dias_aberta > 1 && !o.ultimo_registro_andamento_em ? 'pill-red'
            : o.status_em_andamento && Number(o.justificativa_andamento_hoje || 0) === 1 ? 'pill-green'
            : o.status_em_andamento && o.dias_aberta > 1 ? 'pill-amber' : 'pill-gray';
          const executores = [o.mecanico_nome, o.auxiliar_nome, o.mecanico_secundario_nome, o.auxiliar_secundario_nome]
            .map(v => String(v || '').trim())
            .filter(Boolean)
            .join(' + ') || '-';
        %>
          <tr>
            <td>
              <input
                type="checkbox"
                class="os-checkbox"
                data-os-id="<%= o.id %>"
                data-numero="<%= o.id %>"
                data-equipamento="<%= o.equipamento || "-" %>"
                data-setor="<%= o.setor || "-" %>"
                data-criticidade="<%= o.grau || "-" %>"
                data-descricao="<%= o.descricao || o.nao_conformidade || "-" %>"
                data-status="<%= st || "-" %>"
              >
            </td>
            <td><%= o.id %></td>
            <td class="td-clip"><%= o.equipamento || '-' %></td>
            <td><span class="pill pill-blue"><%= (o.tipo || '-').toUpperCase() %></span></td>
            <td><span class="pill pill-gray"><%= o.grau || '-' %></span></td>
            <td><span class="pill <%= stClass %>"><%= st || '-' %></span></td>
            <td class="td-clip"><%= o.solicitante || '-' %></td>
            <td><%= o.opened_at ? fmtBR(o.opened_at) : '-' %></td>
            <td><%= o.dias_aberta %></td>
            <td><span class="pill <%= andamentoClass %>"><%= o.ultimo_motivo_andamento || (o.status_em_andamento && o.dias_aberta > 1 ? 'Justificativa pendente' : '-') %></span><br><small class="muted"><%= o.ultimo_registro_andamento_em ? `Atualizada em ${fmtBR(o.ultimo_registro_andamento_em)}` : '' %></small></td>
            <td><%= o.closed_at ? fmtBR(o.closed_at) : '-' %></td>
            <td class="td-clip"><%= executores %></td>
            <td style="text-align:right;">
              <div class="os-actions">
                <a class="btn-sm os-action-btn os-action-open" href="/os/<%= o.id %>">Abrir</a>
                <% if (canDeleteOS) { %>
                  <form method="POST" action="/os/<%= o.id %>/excluir" style="display:inline;" onsubmit="return confirm('Confirma excluir a OS #<%= o.id %>?');">
                    <button class="btn-sm os-action-btn os-action-delete" type="submit">Excluir</button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <%# ── CARDS (mobile) ── %>
  <div class="os-cards">
    <% if (!lista || !lista.length) { %>
      <div class="empty-state">Nenhuma OS cadastrada.</div>
    <% } %>
    <% (lista || []).forEach(o => {
      const st = (o.status || '').toUpperCase();
      const stClass = st === 'ABERTA' ? 'pill-amber'
        : (st === 'ANDAMENTO' || st === 'EM_ANDAMENTO') ? 'pill-sky'
        : (st === 'PAUSADA') ? 'pill-gray'
        : (st === 'CONCLUIDA' || st === 'FINALIZADA' || st === 'FECHADA') ? 'pill-green'
        : (st === 'CANCELADA') ? 'pill-red'
        : 'pill-gray';
      const executores = [o.mecanico_nome, o.auxiliar_nome, o.mecanico_secundario_nome, o.auxiliar_secundario_nome]
        .map(v => String(v || '').trim())
        .filter(Boolean)
        .join(' + ') || '-';
    %>
      <a class="os-card" href="/os/<%= o.id %>">
        <div class="os-card-head">
          <div>
            <div class="os-card-id">OS #<%= o.id %></div>
            <div class="os-card-equip"><%= o.equipamento || '-' %></div>
          </div>
          <span class="pill <%= stClass %>"><%= st || '-' %></span>
        </div>
        <% if (o.descricao) { %>
          <div class="os-card-desc"><%= o.descricao %></div>
        <% } %>
        <div class="os-card-executores"><b>Executores:</b> <%= executores %></div>
        <div class="os-card-executores"><b>Dias aberta:</b> <%= o.dias_aberta %> • <b>Andamento:</b> <%= o.ultimo_motivo_andamento || (o.status_em_andamento && o.dias_aberta > 1 ? 'Justificativa pendente' : '-') %></div>
        <div class="os-card-footer">
          <span class="os-card-meta">Abertura: <%= o.opened_at ? fmtBR(o.opened_at) : '-' %> • Fechamento: <%= o.closed_at ? fmtBR(o.closed_at) : '-' %></span>
          <div class="os-card-pills">
            <span class="pill pill-blue"><%= (o.tipo || '-').toUpperCase() %></span>
            <span class="pill pill-gray"><%= o.grau || '-' %></span>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
</div>


<script>
(function(){
  const form = document.getElementById('bulkWhatsappForm');
  if (!form) return;
  const sendButton = form.querySelector("[data-action='enviar-os-whatsapp']");
  const colaboradorSelect = document.getElementById('colaboradorWhatsAppSelect');
  const selectAll = document.getElementById('osSelectAll');

  function normalizeWhatsAppPhone(phone) {
    if (!phone) return '';
    let digits = String(phone).replace(/\D/g, '');
    if ((digits.length === 10 || digits.length === 11) && digits.startsWith('75')) digits = '55' + digits;
    return digits;
  }

  function buildBulkOsWhatsAppMessage(colaborador, ordens) {
    let message = `Olá, ${colaborador.nome}.\n\n`;
    message += 'Segue relação de OS abertas direcionadas para acompanhamento/execução:\n\n';
    ordens.forEach((os, index) => {
      message += `${index + 1}. OS #${os.numero || os.id}\n`;
      message += `Equipamento: ${os.equipamento || '-'}\n`;
      message += `Setor: ${os.setor || '-'}\n`;
      message += `Criticidade: ${os.criticidade || '-'}\n`;
      message += `Descrição: ${os.descricao || '-'}\n`;
      message += `Status: ${os.status || '-'}\n\n`;
    });
    message += 'Favor verificar as demandas e atualizar o andamento no sistema.\n\n';
    message += 'Manutenção Industrial Campo do Gado';
    return message;
  }

  function selectedCheckboxes() {
    return Array.from(document.querySelectorAll('.os-checkbox:checked'));
  }

  function syncButtonState() {
    if (!sendButton) return;
    const hasOs = selectedCheckboxes().length > 0;
    const hasColaborador = !!(colaboradorSelect && colaboradorSelect.value);
    sendButton.disabled = !(hasOs && hasColaborador);
  }

  document.addEventListener('change', function(event){
    if (event.target.matches('.os-checkbox') || event.target === colaboradorSelect) syncButtonState();
  });

  if (selectAll) {
    selectAll.addEventListener('change', function(){
      document.querySelectorAll('.os-checkbox').forEach((cb) => { cb.checked = selectAll.checked; });
      syncButtonState();
    });
  }

  form.addEventListener('submit', function(event){
    event.preventDefault();
    const checked = selectedCheckboxes();
    console.log('[WhatsApp OS] quantidade selecionada:', checked.length);
    if (!checked.length) { alert('Selecione pelo menos uma OS para enviar.'); return; }
    if (!colaboradorSelect || !colaboradorSelect.value) { alert('Selecione o colaborador que receberá as OS.'); return; }

    const selectedOption = colaboradorSelect.options[colaboradorSelect.selectedIndex];
    const colaboradorNome = selectedOption.dataset.nome || selectedOption.textContent.trim();
    const colaboradorTelefone = normalizeWhatsAppPhone(selectedOption.dataset.telefone || '');
    console.log('[WhatsApp OS] colaborador:', colaboradorNome);
    console.log('[WhatsApp OS] telefone normalizado:', colaboradorTelefone);

    if (!colaboradorTelefone || colaboradorTelefone.length < 12) {
      alert('O colaborador selecionado não possui WhatsApp válido cadastrado.');
      return;
    }

    const confirmar = confirm(`Enviar ${checked.length} OS selecionada(s) para ${colaboradorNome} pelo WhatsApp?`);
    if (!confirmar) return;

    const ordens = checked.slice(0, 20).map((checkbox) => ({
      id: checkbox.dataset.osId,
      numero: checkbox.dataset.numero,
      equipamento: checkbox.dataset.equipamento,
      setor: checkbox.dataset.setor,
      criticidade: checkbox.dataset.criticidade,
      descricao: checkbox.dataset.descricao,
      status: checkbox.dataset.status
    }));

    let message = buildBulkOsWhatsAppMessage({ nome: colaboradorNome }, ordens);
    if (checked.length > ordens.length) {
      message += `\n\nObs.: envio limitado às primeiras ${ordens.length} OS selecionadas para evitar excesso de tamanho da mensagem.`;
    }

    const whatsappUrl = `https://wa.me/${colaboradorTelefone}?text=${encodeURIComponent(message)}`;
    console.log('[WhatsApp OS] URL gerada:', whatsappUrl.slice(0, 140) + '...');
    window.location.assign(whatsappUrl);
  });

  syncButtonState();
})();
</script>
