<% layout('layout') %>

<style>
  /* ─── OS INDEX — responsivo completo ─── */
  .os-page-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .os-page-head h1 {
    margin: 0;
    font-size: 30px;
    letter-spacing: -.02em;
  }

  .muted {
    font-size: 13px;
    color: #6b7280;
    margin-top: 4px;
  }

  .card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 18px;
  }

  .btn-primary {
    background: #16a34a;
    color: #fff;
    border: none;
    padding: 10px 16px;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: #15803d;
  }

  /* ─── TABELA DESKTOP ─── */
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    min-width: 1080px;
  }

  thead th {
    text-align: left;
    font-size: 12px;
    color: #64748b;
    font-weight: 700;
    letter-spacing: .02em;
    padding: 10px 12px;
    border-bottom: 1px solid #e5e7eb;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 1;
  }

  tbody td {
    padding: 11px 12px;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
    font-size: 13px;
    color: #0f172a;
  }

  tbody tr:hover td {
    background: #f8fafc;
  }

  .td-clip {
    max-width: 240px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border-radius: 999px;
    font-weight: 800;
    font-size: 11px;
    border: 1px solid #e5e7eb;
    background: #f8fafc;
    color: #0f172a;
    white-space: nowrap;
  }

  .pill-blue {
    background: #eff6ff;
    border-color: #bfdbfe;
    color: #1d4ed8;
  }

  .pill-amber {
    background: #fff7ed;
    border-color: #fed7aa;
    color: #9a3412;
  }

  .pill-sky {
    background: #ecfeff;
    border-color: #a5f3fc;
    color: #155e75;
  }

  .pill-gray {
    background: #f1f5f9;
    border-color: #e2e8f0;
    color: #334155;
  }

  .pill-green {
    background: #ecfdf5;
    border-color: #bbf7d0;
    color: #14532d;
  }

  .pill-red {
    background: #fef2f2;
    border-color: #fecaca;
    color: #991b1b;
  }

  .btn-sm {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 11px;
    border-radius: 9px;
    border: 1px solid #d1d5db;
    background: #fff;
    cursor: pointer;
    text-decoration: none;
    font-weight: 800;
    font-size: 12px;
    color: #0f172a;
    white-space: nowrap;
  }

  .btn-sm:hover {
    border-color: rgba(22, 163, 74, .45);
    background: #ecfdf5;
  }

  .os-actions {
    display: inline-flex;
    flex-direction: column;
    gap: 6px;
    align-items: stretch;
  }

  .os-action-btn {
    justify-content: center;
    min-width: 74px;
    padding: 5px 10px;
    line-height: 1.1;
    transition: background .18s ease, border-color .18s ease, color .18s ease, box-shadow .18s ease;
  }

  .os-action-open:hover {
    border-color: rgba(22, 163, 74, .5);
    background: linear-gradient(180deg, #f0fdf4 0%, #dcfce7 100%);
  }

  .os-action-delete:hover {
    border-color: rgba(185, 28, 28, .5);
    color: #7f1d1d;
    background: linear-gradient(180deg, #fee2e2 0%, #fecaca 100%);
  }

  /* ─── CARDS MOBILE (escondidos no desktop) ─── */
  .os-cards {
    display: none;
    gap: 10px;
    flex-direction: column;
  }

  .os-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 14px;
    display: grid;
    gap: 8px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow .15s ease;
  }

  .os-card:hover {
    box-shadow: 0 4px 12px rgba(0, 0, 0, .08);
  }

  .os-card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
  }

  .os-card-id {
    font-weight: 900;
    font-size: 13px;
    color: #64748b;
  }

  .os-card-equip {
    font-weight: 700;
    font-size: 15px;
    color: #0f172a;
    line-height: 1.3;
  }

  .os-card-desc {
    font-size: 13px;
    color: #475569;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .os-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    flex-wrap: wrap;
    padding-top: 6px;
    border-top: 1px solid #f1f5f9;
  }

  .os-card-meta {
    font-size: 12px;
    color: #94a3b8;
  }

  .os-card-pills {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .os-card-executores {
    font-size: 12px;
    color: #334155;
  }

  .empty-state {
    text-align: center;
    padding: 40px 20px;
    color: #94a3b8;
    font-size: 14px;
  }

  /* ─── BREAKPOINTS ─── */
  @media (max-width: 760px) {
    .os-page-head h1 {
      font-size: 24px;
    }

    .os-page-head {
      align-items: flex-start;
    }

    .card {
      padding: 0;
      border: none;
      background: transparent;
    }

    .table-wrap {
      display: none;
    }

    .os-cards {
      display: flex;
    }
  }

  @media (max-width: 400px) {
    .btn-primary {
      width: 100%;
      justify-content: center;
    }

    .os-page-head {
      gap: 8px;
    }
  }
</style>

<div class="os-page-head">
  <div>
    <h1>Ordens de Serviço</h1>
    <div class="muted">Abertas, em andamento e finalizadas.</div>
  </div>
  <a class="btn-primary" href="/os/novo">+ Nova OS</a>
</div>

<div class="card">
  <%# ── TABELA (desktop) ── %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="width:60px;">#</th>
          <th>Equipamento</th>
          <th style="width:120px;">Tipo</th>
          <th style="width:100px;">Grau</th>
          <th style="width:130px;">Status</th>
          <th style="width:160px;">Solicitante</th>
          <th style="width:150px;">Abertura</th>
          <th style="width:150px;">Fechamento</th>
          <th style="width:220px;">Executores</th>
          <th style="width:120px; text-align:right;">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (!lista || !lista.length) { %>
          <tr>
            <td colspan="10" class="empty-state">Nenhuma OS cadastrada.</td>
          </tr>
        <% } %>
        <% (lista || []).forEach(o => {
          const st = (o.status || '').toUpperCase();
          const stClass = st === 'ABERTA' ? 'pill-amber'
            : (st === 'ANDAMENTO' || st === 'EM_ANDAMENTO') ? 'pill-sky'
            : (st === 'PAUSADA') ? 'pill-gray'
            : (st === 'CONCLUIDA' || st === 'FINALIZADA' || st === 'FECHADA') ? 'pill-green'
            : (st === 'CANCELADA') ? 'pill-red'
            : 'pill-gray';
          const principal = o.mecanico_nome || '-';
          const apoio = o.auxiliar_nome || '';
          const executores = apoio ? `${principal} + ${apoio}` : principal;
        %>
          <tr>
            <td><%= o.id %></td>
            <td class="td-clip"><%= o.equipamento || '-' %></td>
            <td><span class="pill pill-blue"><%= (o.tipo || '-').toUpperCase() %></span></td>
            <td><span class="pill pill-gray"><%= o.grau || '-' %></span></td>
            <td><span class="pill <%= stClass %>"><%= st || '-' %></span></td>
            <td class="td-clip"><%= o.solicitante || '-' %></td>
            <td><%= o.opened_at ? fmtBR(o.opened_at) : '-' %></td>
            <td><%= o.closed_at ? fmtBR(o.closed_at) : '-' %></td>
            <td class="td-clip"><%= executores %></td>
            <td style="text-align:right;">
              <div class="os-actions">
                <a class="btn-sm os-action-btn os-action-open" href="/os/<%= o.id %>">Abrir</a>
                <% if (canDeleteOS) { %>
                  <form method="POST" action="/os/<%= o.id %>/excluir" style="display:inline;" onsubmit="return confirm('Confirma excluir a OS #<%= o.id %>?');">
                    <button class="btn-sm os-action-btn os-action-delete" type="submit">Excluir</button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <%# ── CARDS (mobile) ── %>
  <div class="os-cards">
    <% if (!lista || !lista.length) { %>
      <div class="empty-state">Nenhuma OS cadastrada.</div>
    <% } %>
    <% (lista || []).forEach(o => {
      const st = (o.status || '').toUpperCase();
      const stClass = st === 'ABERTA' ? 'pill-amber'
        : (st === 'ANDAMENTO' || st === 'EM_ANDAMENTO') ? 'pill-sky'
        : (st === 'PAUSADA') ? 'pill-gray'
        : (st === 'CONCLUIDA' || st === 'FINALIZADA' || st === 'FECHADA') ? 'pill-green'
        : (st === 'CANCELADA') ? 'pill-red'
        : 'pill-gray';
      const principal = o.mecanico_nome || '-';
      const apoio = o.auxiliar_nome || '';
      const executores = apoio ? `${principal} + ${apoio}` : principal;
    %>
      <a class="os-card" href="/os/<%= o.id %>">
        <div class="os-card-head">
          <div>
            <div class="os-card-id">OS #<%= o.id %></div>
            <div class="os-card-equip"><%= o.equipamento || '-' %></div>
          </div>
          <span class="pill <%= stClass %>"><%= st || '-' %></span>
        </div>
        <% if (o.descricao) { %>
          <div class="os-card-desc"><%= o.descricao %></div>
        <% } %>
        <div class="os-card-executores"><b>Executores:</b> <%= executores %></div>
        <div class="os-card-footer">
          <span class="os-card-meta">Abertura: <%= o.opened_at ? fmtBR(o.opened_at) : '-' %> • Fechamento: <%= o.closed_at ? fmtBR(o.closed_at) : '-' %></span>
          <div class="os-card-pills">
            <span class="pill pill-blue"><%= (o.tipo || '-').toUpperCase() %></span>
            <span class="pill pill-gray"><%= o.grau || '-' %></span>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
</div>
