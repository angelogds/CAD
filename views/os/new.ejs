<% layout('layout') %>

<div class="card">
  <div class="page-head" style="margin-top:0;">
    <div>
      <h1 style="font-size:28px;">Nova Não Conformidade / OS</h1>
      <p class="muted">Fluxo rápido para operação em campo: poucos cliques e geração técnica automática.</p>
    </div>
  </div>

  <form method="POST" action="/os" enctype="multipart/form-data" id="os-form">
    <div class="grid-2">
      <div>
        <label class="label">Equipamento</label>
        <select name="equipamento_id" id="equipamento_id" required>
          <option value="">Selecione...</option>
          <% (equipamentos || []).forEach(e => { %>
            <option value="<%= e.id %>" <%= String(prefillEquipamentoId||'')===String(e.id)?'selected':'' %>><%= e.codigo ? e.codigo + ' - ' : '' %><%= e.nome %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="label">Setor (opcional)</label>
        <input class="input" type="number" name="setor_id" placeholder="ID do setor" />
      </div>

      <div>
        <label class="label">Sintoma principal</label>
        <select name="sintoma_principal" class="input" required>
          <option value="">Selecione...</option>
          <option value="vazamento">Vazamento</option>
          <option value="aquecimento">Aquecimento</option>
          <option value="vibracao">Vibração</option>
          <option value="ruido_anormal">Ruído anormal</option>
          <option value="travamento">Travamento</option>
          <option value="queda_de_desempenho">Queda de desempenho</option>
          <option value="folga_mecanica">Folga mecânica</option>
          <option value="desalinhamento">Desalinhamento</option>
          <option value="material_acumulado">Material acumulado</option>
          <option value="falha_eletrica">Falha elétrica</option>
        </select>
      </div>

      <div>
        <label class="label">Severidade</label>
        <select name="severidade" class="input" required>
          <% (graus || ['BAIXA','MEDIA','ALTA','CRITICA']).forEach(g => { %>
            <option value="<%= g %>"><%= g %></option>
          <% }) %>
        </select>
      </div>

      <div style="grid-column:1 / -1;">
        <label class="label">Observação curta (opcional)</label>
        <input class="input" type="text" name="observacao_curta" maxlength="180" placeholder="Detalhe curto" />
      </div>

      <div style="grid-column:1 / -1;">
        <label class="label">Flags rápidas</label>
        <div class="row" style="gap:14px; flex-wrap:wrap;">
          <label><input type="checkbox" name="equipamento_parado" value="1"> Equipamento parado</label>
          <label><input type="checkbox" name="vazamento" value="1"> Vazamento</label>
          <label><input type="checkbox" name="aquecimento" value="1"> Aquecimento</label>
          <label><input type="checkbox" name="ruido_anormal" value="1"> Ruído anormal</label>
          <label><input type="checkbox" name="vibracao" value="1"> Vibração</label>
          <label><input type="checkbox" name="odor_anormal" value="1"> Odor anormal</label>
          <label><input type="checkbox" name="baixa_performance" value="1"> Baixa performance</label>
          <label><input type="checkbox" name="travamento" value="1"> Travamento</label>
        </div>
      </div>

      <input type="hidden" name="tipo" value="CORRETIVA" />
      <input type="hidden" name="grau" value="MEDIA" />
      <div style="display:none;">
        <textarea name="descricao">Não conformidade aberta via fluxo rápido operacional.</textarea>
      </div>

      <div style="grid-column:1 / -1;">
        <label class="label">Fotos de abertura (opcional)</label>
        <input id="abertura_fotos" type="file" name="abertura_fotos" accept="image/*" multiple style="display:none" />
        <button type="button" class="btn btn-outline" onclick="document.getElementById('abertura_fotos').click()">📷 Adicionar fotos</button>
      </div>
    </div>

    <div class="row" style="justify-content:space-between; margin-top:16px;">
      <a href="/os" class="btn btn-ghost">Cancelar</a>
      <button type="submit" class="btn btn-primary">Salvar e gerar OS automática</button>
    </div>
  </form>
</div>
