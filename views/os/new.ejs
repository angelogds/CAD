<% layout('layout') %>

<div class="card" style="max-width:980px; margin:0 auto;">
  <div class="page-head" style="margin-top:0;">
    <div>
      <h1 style="font-size:28px;">Nova Não Conformidade / OS</h1>
      <p class="muted">Abertura rápida da ocorrência para geração automática da ordem de serviço.</p>
    </div>
  </div>

  <form method="POST" action="/os" enctype="multipart/form-data" id="os-form">
    <div class="grid-2" style="gap:16px;">
      <div style="grid-column:1 / -1;">
        <label class="label" for="equipamento_id">EQUIPAMENTO</label>
        <div class="muted" style="margin-bottom:8px;">Selecione o equipamento cadastrado ou informe manualmente.</div>
        <select name="equipamento_id" id="equipamento_id" class="input">
          <option value="">Selecionar equipamento cadastrado</option>
          <% (equipamentos || []).forEach(e => { %>
            <option value="<%= e.id %>" <%= String(prefillEquipamentoId||'')===String(e.id)?'selected':'' %>><%= e.codigo ? e.codigo + ' - ' : '' %><%= e.nome %></option>
          <% }) %>
        </select>
        <div class="muted" style="margin:10px 0 6px;">Ou digitar equipamento manualmente</div>
        <input class="input" type="text" name="equipamento_manual" id="equipamento_manual" placeholder="Ex.: Bomba de recirculação do setor de lavagem" />
      </div>

      <div style="grid-column:1 / -1;">
        <label class="label" for="sintoma_principal">SINTOMA PRINCIPAL *</label>
        <select name="sintoma_principal" id="sintoma_principal" class="input" required>
          <option value="">Selecione...</option>
          <option value="equipamento_parado">Equipamento parado</option>
          <option value="vazamento">Vazamento</option>
          <option value="aquecimento">Aquecimento</option>
          <option value="vibracao">Vibração</option>
          <option value="ruido_anormal">Ruído anormal</option>
          <option value="travamento">Travamento</option>
          <option value="baixa_performance">Baixa performance</option>
          <option value="falha_eletrica">Falha elétrica</option>
          <option value="desalinhamento">Desalinhamento</option>
          <option value="folga_mecanica">Folga mecânica</option>
          <option value="material_acumulado">Material acumulado</option>
          <option value="outro">Outro</option>
        </select>
      </div>

      <div style="grid-column:1 / -1;">
        <label class="label" for="nao_conformidade">NÃO CONFORMIDADE DO EQUIPAMENTO *</label>
        <div class="muted" style="margin-bottom:10px;">Fale o problema e deixe a IA preencher a descrição e os campos técnicos automaticamente.</div>

        <button type="button" id="btn-converse-mecanico" class="btn-converse-mecanico" aria-label="Converse com o Mecânico">
          <span class="emoji">🎤</span>
          <span id="btn-converse-label">Converse com o Mecânico</span>
        </button>

        <div id="status-converse" class="status-converse" role="status" aria-live="polite">Pronto para gravar.</div>

        <textarea
          id="nao_conformidade"
          name="nao_conformidade"
          class="input"
          style="min-height:150px; margin-top:10px;"
          minlength="10"
          required
          placeholder="Ex.: Equipamento apresentando vibração forte, ruído e aquecimento durante operação."
        ></textarea>
      </div>

      <input type="hidden" name="criticidade" id="criticidade" value="MEDIA" />
      <input type="hidden" name="ai_tempo_estimado" id="ai_tempo_estimado" value="" />
      <input type="hidden" name="ai_diagnostico_inicial" id="ai_diagnostico_inicial" value="" />
      <input type="hidden" name="ai_causa" id="ai_causa" value="" />
      <input type="hidden" name="ai_acoes_iniciais" id="ai_acoes_iniciais" value="" />

      <input type="hidden" name="descricao" id="descricao_hidden" value="" />
      <input type="hidden" name="diagnostico_inicial" id="diagnostico_inicial_hidden" value="" />
      <input type="hidden" name="causa_mais_provavel" id="causa_mais_provavel_hidden" value="" />
      <input type="hidden" name="acoes_iniciais" id="acoes_iniciais_hidden" value="" />

      <div style="grid-column:1 / -1;">
        <label class="label">FOTOS DE ABERTURA (OPCIONAL)</label>
        <input id="abertura_fotos" type="file" name="abertura_fotos" accept="image/*" multiple style="display:none" />
        <button type="button" class="btn btn-outline" onclick="document.getElementById('abertura_fotos').click()">📷 Adicionar fotos</button>
        <div id="preview-abertura" style="margin-top:6px;"></div>
      </div>
    </div>

    <div class="row" style="justify-content:space-between; margin-top:16px;">
      <a href="/os" class="btn btn-ghost">Cancelar</a>
      <button type="submit" class="btn btn-primary" id="btn-salvar-os">Salvar e gerar OS automática</button>
    </div>
  </form>
</div>

<style>
  .btn-converse-mecanico {
    width: 100%;
    border: none;
    border-radius: 14px;
    padding: 12px 14px;
    background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    cursor: pointer;
    transition: transform .12s ease, box-shadow .2s ease, filter .2s ease;
    box-shadow: 0 6px 16px rgba(37, 99, 235, .25);
  }
  .btn-converse-mecanico:hover { filter: brightness(1.03); transform: translateY(-1px); }
  .btn-converse-mecanico.is-recording {
    background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
    box-shadow: 0 6px 16px rgba(185, 28, 28, .25);
  }
  .btn-converse-mecanico[disabled] { opacity: .7; cursor: wait; transform: none; }
  .status-converse {
    margin-top: 10px;
    border: 1px solid #bfdbfe;
    background: #eff6ff;
    color: #1d4ed8;
    border-radius: 10px;
    padding: 10px 12px;
    font-size: .92rem;
  }
  .status-converse.error {
    border-color: #fecaca;
    background: #fef2f2;
    color: #991b1b;
  }
  .status-converse.success {
    border-color: #bbf7d0;
    background: #f0fdf4;
    color: #166534;
  }
  .status-converse.warning {
    border-color: #fde68a;
    background: #fffbeb;
    color: #92400e;
  }
  @media (max-width: 768px) {
    .btn-converse-mecanico { font-size: .96rem; padding: 12px; }
  }
</style>

<script>
  (function () {
    const fileInput = document.getElementById('abertura_fotos');
    const preview = document.getElementById('preview-abertura');

    fileInput.addEventListener('change', function(){
      preview.innerHTML = '';
      Array.from(fileInput.files || []).forEach(function (f) {
        const el = document.createElement('span');
        el.className = 'pill-tag pill-gray';
        el.style.marginRight = '6px';
        el.textContent = f.name;
        preview.appendChild(el);
      });
    });

    const form = document.getElementById('os-form');
    const submitBtn = document.getElementById('btn-salvar-os');
    const btn = document.getElementById('btn-converse-mecanico');
    const btnLabel = document.getElementById('btn-converse-label');
    const statusEl = document.getElementById('status-converse');

    const naoConformidadeEl = document.getElementById('nao_conformidade');
    const descricaoHiddenEl = document.getElementById('descricao_hidden');
    const criticidadeEl = document.getElementById('criticidade');
    const diagnosticoEl = document.getElementById('ai_diagnostico_inicial');
    const causaEl = document.getElementById('ai_causa');
    const acoesEl = document.getElementById('ai_acoes_iniciais');
    const tempoEl = document.getElementById('ai_tempo_estimado');

    const diagnosticoHiddenEl = document.getElementById('diagnostico_inicial_hidden');
    const causaHiddenEl = document.getElementById('causa_mais_provavel_hidden');
    const acoesHiddenEl = document.getElementById('acoes_iniciais_hidden');

    let mediaRecorder = null;
    let mediaStream = null;
    let chunks = [];
    let isRecording = false;
    let isProcessing = false;
    let recordingMimeType = 'audio/webm';
    let autoStopTimer = null;

    const MAX_RECORDING_MS = 120000;
    const TRANSCRIBE_TIMEOUT_MS = 25000;
    const ANALISE_TIMEOUT_MS = 20000;
    const TRANSCRIBE_RETRIES = 1;

    function setStatus(message, tone) {
      statusEl.textContent = message;
      statusEl.classList.remove('error', 'success', 'warning');
      if (tone) statusEl.classList.add(tone);
    }

    function setButtonState(state) {
      if (state === 'recording') {
        btn.classList.add('is-recording');
        btnLabel.textContent = 'Parar gravação';
        btn.disabled = false;
        return;
      }
      if (state === 'processing') {
        btn.classList.remove('is-recording');
        btnLabel.textContent = 'Processando...';
        btn.disabled = true;
        return;
      }
      if (state === 'done') {
        btn.classList.remove('is-recording');
        btnLabel.textContent = 'Pronto!';
        btn.disabled = false;
        return;
      }
      if (state === 'error') {
        btn.classList.remove('is-recording');
        btnLabel.textContent = 'Falha temporária';
        btn.disabled = false;
        return;
      }
      btn.classList.remove('is-recording');
      btnLabel.textContent = 'Converse com o Mecânico';
      btn.disabled = false;
    }

    function clearRecordGuards() {
      if (autoStopTimer) {
        clearTimeout(autoStopTimer);
        autoStopTimer = null;
      }
    }

    function stopTracks() {
      clearRecordGuards();
      if (mediaStream) {
        mediaStream.getTracks().forEach(function (track) { track.stop(); });
        mediaStream = null;
      }
    }

    function stopRecordingSafely() {
      if (!mediaRecorder || mediaRecorder.state === 'inactive') return Promise.resolve();
      return new Promise(function (resolve) {
        mediaRecorder.addEventListener('stop', resolve, { once: true });
        mediaRecorder.stop();
      });
    }

    function pickSupportedMimeType() {
      if (typeof MediaRecorder === 'undefined' || typeof MediaRecorder.isTypeSupported !== 'function') {
        return '';
      }
      const candidates = [
        'audio/mp4',
        'audio/webm;codecs=opus',
        'audio/webm',
        'audio/ogg;codecs=opus',
        'audio/ogg',
      ];
      return candidates.find(function (type) { return MediaRecorder.isTypeSupported(type); }) || '';
    }

    async function parseJsonSafe(response) {
      const contentType = response.headers.get('content-type') || '';
      const raw = await response.text();
      if (!contentType.includes('application/json')) {
        throw new Error('Resposta inválida do servidor (não retornou JSON).');
      }
      try {
        return JSON.parse(raw);
      } catch (_error) {
        throw new Error('JSON inválido retornado pelo servidor.');
      }
    }

    async function fetchWithTimeout(url, options, timeoutMs) {
      const controller = new AbortController();
      const timeout = setTimeout(function () { controller.abort(); }, timeoutMs);
      try {
        return await fetch(url, Object.assign({}, options, { signal: controller.signal }));
      } finally {
        clearTimeout(timeout);
      }
    }

    function getAudioExtension(blobType) {
      if (blobType.includes('ogg')) return 'ogg';
      if (blobType.includes('mp4') || blobType.includes('m4a')) return 'm4a';
      if (blobType.includes('mpeg') || blobType.includes('mp3')) return 'mp3';
      if (blobType.includes('wav')) return 'wav';
      return 'webm';
    }

    async function enviarParaTranscricao(audioBlob) {
      const extension = getAudioExtension(audioBlob.type || recordingMimeType || 'audio/webm');
      const formData = new FormData();
      formData.append('audio', audioBlob, 'abertura-os-' + Date.now() + '.' + extension);

      let lastError = null;
      for (let tentativa = 0; tentativa <= TRANSCRIBE_RETRIES; tentativa += 1) {
        try {
          const response = await fetchWithTimeout('/ai/os/transcrever-abertura', {
            method: 'POST',
            body: formData,
          }, TRANSCRIBE_TIMEOUT_MS);

          const payload = await parseJsonSafe(response);
          if (!response.ok || payload.status === 'erro_validacao') {
            throw new Error(payload.erro || 'Falha na validação do áudio.');
          }
          if (!payload.ok || payload.status === 'erro') {
            throw new Error(payload.erro || 'Não foi possível transcrever agora (falha temporária).');
          }

          const transcricao = String(payload.transcricao || payload.transcricao_bruta || '').trim();
          if (!transcricao) {
            throw new Error('Não foi possível entender o áudio. Pode continuar manualmente.');
          }
          return transcricao;
        } catch (error) {
          lastError = error;
          if (tentativa < TRANSCRIBE_RETRIES) {
            setStatus('Transcrição instável. Tentando novamente...', 'warning');
            await new Promise(function (resolve) { setTimeout(resolve, 700); });
          }
        }
      }

      if (lastError && lastError.name === 'AbortError') {
        throw new Error('Tempo de transcrição excedido. Continue manualmente sem bloquear o salvamento.');
      }
      throw new Error((lastError && lastError.message) || 'Não foi possível transcrever agora (falha temporária).');
    }

    async function enviarParaAnalise(transcricao) {
      const body = {
        descricao: transcricao,
        equipamento_id: document.getElementById('equipamento_id').value || null,
      };

      const response = await fetchWithTimeout('/ai/os/analisar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      }, ANALISE_TIMEOUT_MS);

      const payload = await parseJsonSafe(response);
      if (!response.ok || !payload.ok) {
        throw new Error(payload.error || 'Falha ao analisar descrição com IA.');
      }
      return payload.resultado || {};
    }

    function preencherCampos(transcricao, analise) {
      naoConformidadeEl.value = transcricao;
      descricaoHiddenEl.value = transcricao;

      const criticidade = String(analise.criticidade_sugerida || analise.criticidade || '').toUpperCase();
      if (criticidade) criticidadeEl.value = criticidade;

      const diagnostico = String(analise.ai_diagnostico_inicial || analise.diagnostico_inicial || '').trim();
      const causa = String(analise.ai_causa || analise.causa_mais_provavel || '').trim();
      const acoes = String(analise.ai_acoes_iniciais || analise.acoes_iniciais || '').trim();
      const tempo = Number(analise.ai_tempo_estimado || analise.tempo_estimado_minutos || 0);

      diagnosticoEl.value = diagnostico;
      causaEl.value = causa;
      acoesEl.value = acoes;
      if (tempo > 0) tempoEl.value = String(tempo);

      diagnosticoHiddenEl.value = diagnostico;
      causaHiddenEl.value = causa;
      acoesHiddenEl.value = acoes;
    }

    async function processarAudioGravado() {
      const blobType = chunks[0] && chunks[0].type ? chunks[0].type : (recordingMimeType || 'audio/webm');
      const audioBlob = new Blob(chunks, { type: blobType });
      chunks = [];

      if (!audioBlob.size) {
        throw new Error('Áudio vazio. Tente gravar novamente ou continue manualmente.');
      }

      setStatus('Transcrevendo...', null);
      const transcricao = await enviarParaTranscricao(audioBlob);
      naoConformidadeEl.value = transcricao;
      descricaoHiddenEl.value = transcricao;

      setStatus('Analisando com o Técnico...', null);
      const analise = await enviarParaAnalise(transcricao);
      preencherCampos(transcricao, analise);
    }

    btn.addEventListener('click', async function () {
      if (isProcessing) return;

      if (isRecording && mediaRecorder) {
        isProcessing = true;
        setButtonState('processing');
        setStatus('Transcrevendo...', null);
        await stopRecordingSafely();
        return;
      }

      if (!navigator.mediaDevices || typeof navigator.mediaDevices.getUserMedia !== 'function') {
        setButtonState('error');
        setStatus('Microfone indisponível neste navegador. Use preenchimento manual.', 'warning');
        return;
      }
      if (typeof MediaRecorder === 'undefined') {
        setButtonState('error');
        setStatus('Este navegador não suporta gravação direta. Continue manualmente.', 'warning');
        return;
      }

      try {
        mediaStream = await navigator.mediaDevices.getUserMedia({
          audio: {
            echoCancellation: true,
            noiseSuppression: true,
            autoGainControl: true,
          },
        });
        recordingMimeType = pickSupportedMimeType() || '';
        mediaRecorder = recordingMimeType
          ? new MediaRecorder(mediaStream, { mimeType: recordingMimeType })
          : new MediaRecorder(mediaStream);

        chunks = [];
        mediaRecorder.addEventListener('dataavailable', function (evt) {
          if (evt.data && evt.data.size > 0) chunks.push(evt.data);
        });

        mediaRecorder.addEventListener('stop', async function () {
          try {
            isRecording = false;
            await processarAudioGravado();
            setButtonState('done');
            setStatus('Pronto! Texto preenchido e análise aplicada.', 'success');
          } catch (err) {
            const fallbackMessage = (err && err.message) || 'Falha temporária – continue manualmente.';
            setButtonState('error');
            setStatus(fallbackMessage + ' O salvamento manual segue liberado.', 'warning');
          } finally {
            stopTracks();
            isProcessing = false;
            setTimeout(function () {
              if (!isRecording && !isProcessing) setButtonState('idle');
            }, 1800);
          }
        }, { once: true });

        mediaRecorder.start(250);
        isRecording = true;
        setButtonState('recording');
        setStatus('Gravando... toque no botão novamente para parar.', null);
        autoStopTimer = setTimeout(function () {
          if (isRecording) {
            isProcessing = true;
            setButtonState('processing');
            setStatus('Tempo máximo atingido. Encerrando e processando...', 'warning');
            stopRecordingSafely();
          }
        }, MAX_RECORDING_MS);
      } catch (_error) {
        stopTracks();
        isRecording = false;
        isProcessing = false;
        setButtonState('error');
        setStatus('Permissão de microfone negada ou indisponível. Continue manualmente.', 'warning');
      }
    });

    form.addEventListener('submit', function(e){
      const id = document.getElementById('equipamento_id').value.trim();
      const manual = document.getElementById('equipamento_manual').value.trim();
      const sintoma = document.getElementById('sintoma_principal').value.trim();
      const naoConformidade = naoConformidadeEl.value.trim();

      descricaoHiddenEl.value = naoConformidade;
      diagnosticoHiddenEl.value = diagnosticoEl.value.trim();
      causaHiddenEl.value = causaEl.value.trim();
      acoesHiddenEl.value = acoesEl.value.trim();

      if (!id && !manual) {
        e.preventDefault();
        alert('Selecione um equipamento cadastrado ou digite o equipamento manualmente.');
        return;
      }
      if (!sintoma) {
        e.preventDefault();
        alert('Selecione o sintoma principal.');
        return;
      }
      if (!naoConformidade || naoConformidade.length < 10) {
        e.preventDefault();
        alert('Descreva a não conformidade com pelo menos 10 caracteres.');
        return;
      }

      if (submitBtn?.disabled) {
        e.preventDefault();
        return;
      }
      submitBtn.disabled = true;
      submitBtn.textContent = 'Salvando...';
    });

    window.addEventListener('beforeunload', stopTracks);
    document.addEventListener('visibilitychange', function () {
      if (document.hidden && isRecording) {
        setStatus('App em segundo plano: a gravação pode pausar no iOS. Retorne e finalize.', 'warning');
      }
    });
  })();
</script>
