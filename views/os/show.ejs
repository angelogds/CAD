<% layout('layout') %>

<style>
  .top{display:grid;grid-template-columns:2fr 1fr;gap:12px}
  .card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:14px}
  .muted{color:#64748b;font-size:13px}
  .grid2{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
  .status{font-weight:700}.g-baixa{color:#15803d}.g-media{color:#b45309}.g-alta{color:#b91c1c}.g-critica{color:#7f1d1d}
  .card-head{display:flex;justify-content:space-between;align-items:center;gap:8px;margin-bottom:10px}
  .actions{display:flex;gap:8px;flex-wrap:wrap}
  .camera-btn{border:1px solid #d1d5db;background:#fff;border-radius:10px;padding:10px 12px;cursor:pointer}
  .galeria{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:10px;margin-top:8px}
  .foto-card{display:block;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;background:#f8fafc;text-decoration:none}
  .foto-card img,.foto-card video{display:block;width:100%;height:140px;object-fit:cover;background:#e5e7eb}
  .foto-card span{display:block;padding:6px 8px;font-size:12px;color:#64748b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .resumo-exec{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .tabela-compacta{width:100%;border-collapse:collapse;margin-top:10px}
  .tabela-compacta th,.tabela-compacta td{border:1px solid #e2e8f0;padding:8px 10px;font-size:13px;text-align:left}
  .tabela-compacta th{background:#f8fafc;font-weight:700}

  .badge-funcao{display:inline-block;padding:2px 8px;border-radius:999px;font-size:11px;font-weight:700}
  .func-mec{background:#fee2e2;color:#991b1b}.func-mon{background:#dbeafe;color:#1e3a8a}.func-aux{background:#dcfce7;color:#166534}
  .whatsapp-status{display:inline-block;padding:3px 10px;border-radius:999px;font-size:12px;font-weight:800;background:#dcfce7;color:#166534}
  .whatsapp-status.erro{background:#fee2e2;color:#991b1b}.whatsapp-status.warn{background:#fef3c7;color:#92400e}
  .whatsapp-btn{display:inline-flex;align-items:center;gap:7px;}
  .wa-icon{display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:999px;background:#25d366;color:#fff;font-size:13px;font-weight:900;line-height:1;box-shadow:0 1px 2px rgba(0,0,0,.12)}
  .wa-icon::before{content:"☎";}
  .os-menu-wrap{position:relative;display:inline-block}
  .os-menu-btn{display:inline-flex;align-items:center;gap:6px}
  .os-menu-panel{position:absolute;right:0;top:calc(100% + 6px);z-index:20;background:#fff;border:1px solid #dbe3ee;border-radius:10px;box-shadow:0 8px 20px rgba(15,23,42,.12);padding:10px;min-width:260px;display:none}
  .os-menu-wrap.open .os-menu-panel{display:block}
  .os-menu-list{display:flex;flex-direction:column;gap:6px}
  .os-menu-list a,.os-menu-list button{width:100%;text-align:left}
  .os-module{display:none}
  .os-module.active{display:block}
  .os-menu-sep{height:1px;background:#e5e7eb;margin:6px 0}
  @media(max-width:900px){.top{grid-template-columns:1fr}.grid2{grid-template-columns:1fr}.resumo-exec{grid-template-columns:1fr}}
</style>

<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;">
  <div>
    <h1>OS #<%= os.id %></h1>
    <div class="muted">Solicitante: <strong><%= os.solicitante_nome || '-' %></strong></div>
  </div>
  <div style="display:flex;gap:8px;align-items:center;">
    <% const canOpenOSMenu = true; // A justificativa de andamento permanece disponível no menu para todos que podem consultar a OS. %>
    <% if (canOpenOSMenu) { %>
      <div class="os-menu-wrap" id="os-menu-wrap">
        <button class="btn btn-outline os-menu-btn" type="button" id="os-menu-btn" aria-expanded="false" aria-controls="os-menu-panel">☰ Menu OS</button>
        <div class="os-menu-panel" id="os-menu-panel">
          <div class="os-menu-list">
            <button class="btn btn-outline" type="button" data-os-module="tracagens-vinculadas">Traçagens vinculadas</button>
            <button class="btn btn-outline" type="button" data-os-module="equipe-os">Equipe da OS</button>
            <button class="btn btn-outline" type="button" data-os-module="whatsapp-os">Notificações WhatsApp</button>
            <button class="btn btn-outline" type="button" data-os-module="justificativa-andamento">Justificativa de OS em andamento</button>
            <div class="os-menu-sep"></div>
            <% if (canAutoAssign) { %>
              <form method="POST" action="/os/<%= os.id %>/auto-alocar">
                <button class="btn btn-primary" type="submit">Reatribuir automaticamente</button>
              </form>
            <% } %>
            <% if (canSendWhatsapp && (os.executor_nome || os.execucao_ativa?.executor_nome || whatsappResponsavel?.nome)) { %>
              <a class="btn btn-green whatsapp-btn" href="/os/<%= os.id %>/whatsapp" target="_blank" rel="noopener"><span class="wa-icon" aria-hidden="true"></span> Enviar WhatsApp local</a>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>
    <% if (canExecuteOS) { %>
      <form method="POST" action="/os/<%= os.id %>/pdf-institucional" style="display:inline;">
        <button class="btn btn-primary" type="submit">Gerar PDF institucional</button>
      </form>
    <% } %>
    <% if (documentoInstitucional && documentoInstitucional.pdf_url) { %>
      <a class="btn btn-outline" href="<%= documentoInstitucional.pdf_url %>" target="_blank" rel="noopener">Baixar PDF institucional</a>
    <% } %>
    <a class="btn btn-ghost" href="/os">Voltar</a>
  </div>
</div>

<% const isOSFechada = String(os.status || '').toUpperCase() === 'FECHADA'; %>

<div class="top" style="margin-top:10px;">
  <div class="card">
    <div class="card-head">
      <div class="muted">Dados principais da OS</div>
      <% if (!isOSFechada && canExecuteOS) { %>
        <div class="actions">
          <form method="POST" action="/os/<%= os.id %>/pausar"><button class="btn" type="submit">Pausar OS</button></form>
          <% if (canSendWhatsapp && (os.executor_nome || os.execucao_ativa?.executor_nome || whatsappResponsavel?.nome)) { %>
            <a class="btn btn-green whatsapp-btn" href="/os/<%= os.id %>/whatsapp" target="_blank" rel="noopener"><span class="wa-icon" aria-hidden="true"></span> Enviar WhatsApp à equipe</a>
          <% } %>
        </div>
      <% } %>
    </div>
    <div class="grid2">
      <div><b>Equipamento:</b> <%= os.equipamento_resolvido || '-' %></div>
      <div><b>Tipo:</b> <%= os.tipo || '-' %></div>
      <div><b>Grau:</b>
        <% const gg = String(os.grau||'').toUpperCase(); %>
        <span class="status <%= gg==='BAIXA'?'g-baixa':(gg==='MEDIA'?'g-media':(gg==='ALTA'?'g-alta':'g-critica')) %>"><%= gg || '-' %></span>
      </div>
      <div><b>Status:</b> <%= os.status %></div>
      <% if (String(os.status || "").toUpperCase() === "AGUARDANDO_EQUIPE") { %>
        <div style="grid-column:1/-1;color:#b91c1c;font-weight:700;">Sem executor disponível no turno: OS aguardando alocação.</div>
      <% } %>
      <div><b>Abertura:</b> <%= os.opened_at ? fmtBR(os.opened_at) : '-' %></div>
      <div><b>Início:</b> <%= os.data_inicio ? fmtBR(os.data_inicio) : (os.execucao_iniciada_em ? fmtBR(os.execucao_iniciada_em) : '-') %></div>
      <div><b>Conclusão:</b> <%= os.data_conclusao ? fmtBR(os.data_conclusao) : '-' %></div>
      <div><b>Turno da alocação:</b> <%= os.turno_alocado || os.execucao_ativa?.turno_alocacao || '-' %>
        <% if ((os.turno_alocado || os.execucao_ativa?.turno_alocacao) === 'NOITE' && (os.executor_nome || '').trim()) { %>
          <span class="badge-funcao func-mon" style="margin-left:6px;">PLANTONISTA</span>
        <% } %>
      </div>
      <div><b>Setor solicitante:</b> <%= os.setor_solicitante || '-' %></div>
      <div><b>Setor destinatário:</b> <%= os.setor_destinatario || 'Manutenção' %></div>
      <div><b>Responsável manutenção:</b> <%= os.responsavel_manutencao || '-' %></div>
      <div><b>Executor em andamento:</b> <%= os.executor_nome || os.execucao_ativa?.executor_nome || '-' %></div>
      <div><b>Auxiliar em andamento:</b> <%= os.auxiliar_nome || os.execucao_ativa?.auxiliar_nome || '-' %></div>
      <div><b>2º mecânico em andamento:</b> <%= os.executor_secundario_nome || '-' %></div>
      <div><b>2º apoio em andamento:</b> <%= os.auxiliar_secundario_nome || '-' %></div>
      <div><b>Modo da alocação:</b> <%= os.alocacao_modo || '-' %></div>
    </div>

    <% if (documentoInstitucional && documentoInstitucional.pdf_url) { %>
      <hr style="border:none;border-top:1px solid #e5e7eb;margin:12px 0"/>
      <div class="muted" style="font-weight:700;">Documento institucional</div>
      <div style="margin-top:6px;display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
        <span>Último PDF gerado: <strong><%= documentoInstitucional.numero_os %></strong></span>
        <a class="btn btn-outline" href="<%= documentoInstitucional.pdf_url %>" target="_blank" rel="noopener">Visualizar / imprimir</a>
      </div>
    <% } %>

    <hr style="border:none;border-top:1px solid #e5e7eb;margin:12px 0"/>
    <div class="muted">Descrição do problema (solicitante)</div>
    <div><%= os.descricao || '-' %></div>

    <% const diagnosticoInicialOS = os.ai_diagnostico_inicial || os.diagnostico || os.causa_diagnostico || '-'; %>
    <hr style="border:none;border-top:1px solid #e5e7eb;margin:12px 0"/>
    <div class="muted" style="font-weight:700;">Diagnóstico inicial para execução</div>
    <table class="tabela-compacta">
      <tbody>
        <tr>
          <th style="width:220px;">Diagnóstico inicial para execução</th>
          <td><%= diagnosticoInicialOS %></td>
        </tr>
      </tbody>
    </table>

    <% if (os.acao_corretiva || os.acao_preventiva) { %>
      <hr style="border:none;border-top:1px solid #e5e7eb;margin:12px 0"/>
      <div><b>Ação corretiva:</b><br/><%= os.acao_corretiva || '-' %></div>
      <div style="margin-top:8px;"><b>Ação preventiva:</b><br/><%= os.acao_preventiva || '-' %></div>
    <% } %>
  </div>

  <div class="card os-module" id="tracagens-vinculadas">
    <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
      <h3 style="margin:0;">Traçagens vinculadas</h3>
      <a class="btn btn-green" href="/tracagem?os_id=<%= os.id %>">Abrir Traçagem</a>
    </div>
    <div class="muted">Cálculos de caldeiraria relacionados a esta OS.</div>
    <table class="tabela-compacta">
      <thead>
        <tr>
          <th>Equipe</th>
          <th>Executor</th>
          <th>Auxiliar</th>
          <th>Turno</th>
          <th>Modo</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><%= (os.executor_nome || os.execucao_ativa?.executor_nome || os.executor_secundario_nome || os.auxiliar_nome || os.execucao_ativa?.auxiliar_nome || os.auxiliar_secundario_nome) ? 'Equipe alocada' : '-' %></td>
          <td><%= os.executor_nome || os.execucao_ativa?.executor_nome || '-' %></td>
          <td><%= os.auxiliar_nome || os.execucao_ativa?.auxiliar_nome || '-' %></td>
          <td><%= os.turno_alocado || os.execucao_ativa?.turno_alocacao || '-' %></td>
          <td><%= os.alocacao_modo || '-' %></td>
        </tr>
        <% if (os.executor_secundario_nome || os.auxiliar_secundario_nome) { %>
          <tr>
            <td>Complemento manual</td>
            <td><%= os.executor_secundario_nome || '-' %></td>
            <td><%= os.auxiliar_secundario_nome || '-' %></td>
            <td colspan="2">Apoio extra definido manualmente</td>
          </tr>
        <% } %>
      </tbody>
    </table>
    <% if (canAutoAssign) { %>
      <div style="margin-top:8px;display:flex;justify-content:flex-end;">
        <form method="POST" action="/os/<%= os.id %>/auto-alocar">
          <button class="btn btn-primary" type="submit">Reatribuir automaticamente</button>
        </form>
      </div>
    <% } %>
    <% if (canManualEditEquipe) { %>
      <% const mecanicosTurno = (equipeUsuarios || []).filter(u => String(u.funcao || '').toLowerCase() === 'mecanico'); %>
      <% const auxiliaresTurno = (equipeUsuarios || []).filter(u => ['auxiliar','apoio'].includes(String(u.funcao || '').toLowerCase())); %>
      <div id="equipe-os">
      <form method="POST" action="/os/<%= os.id %>/equipe" style="margin-top:10px;">
        <div class="grid2">
          <div>
            <label>Executor</label>
            <select class="input" name="executor_colaborador_id" required>
              <option value="">Selecione</option>
              <% if (mecanicosTurno.length) { %>
                <optgroup label="Mecânicos">
                  <% mecanicosTurno.forEach(function(u){ %>
                    <option value="<%= u.id %>" <%= Number(os.executor_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                  <% }) %>
                </optgroup>
              <% } %>
              <% if (auxiliaresTurno.length) { %>
                <optgroup label="Apoio/Auxiliares">
                  <% auxiliaresTurno.forEach(function(u){ %>
                    <option value="<%= u.id %>" <%= Number(os.executor_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                  <% }) %>
                </optgroup>
              <% } %>
            </select>
          </div>
          <div>
            <label>Auxiliar</label>
            <select class="input" name="auxiliar_colaborador_id">
              <option value="">Sem auxiliar</option>
              <% if (mecanicosTurno.length) { %>
                <optgroup label="Mecânicos">
                  <% mecanicosTurno.forEach(function(u){ %>
                    <option value="<%= u.id %>" <%= Number(os.auxiliar_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                  <% }) %>
                </optgroup>
              <% } %>
              <% if (auxiliaresTurno.length) { %>
                <optgroup label="Auxiliares">
                  <% auxiliaresTurno.forEach(function(u){ %>
                    <option value="<%= u.id %>" <%= Number(os.auxiliar_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                  <% }) %>
                </optgroup>
              <% } %>
            </select>
          </div>
          <div>
            <label>2º mecânico (opcional)</label>
            <select class="input" name="executor_secundario_colaborador_id">
              <option value="">Sem 2º mecânico</option>
              <% if (mecanicosTurno.length) { %>
                <optgroup label="Mecânicos">
                  <% mecanicosTurno.forEach(function(u){ %>
                    <option value="<%= u.id %>" <%= Number(os.executor_secundario_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                  <% }) %>
                </optgroup>
              <% } %>
            </select>
          </div>
          <div>
            <label>2º apoio operacional (opcional)</label>
            <select class="input" name="auxiliar_secundario_colaborador_id">
              <option value="">Sem 2º apoio</option>
              <% if (auxiliaresTurno.length) { %>
                <optgroup label="Auxiliares">
                  <% auxiliaresTurno.forEach(function(u){ %>
                    <option value="<%= u.id %>" <%= Number(os.auxiliar_secundario_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                  <% }) %>
                </optgroup>
              <% } %>
            </select>
          </div>
        </div>
        <div style="margin-top:8px;"><button class="btn" type="submit">Salvar equipe</button></div>
      </form>
    </div>
    <% } %>
    <ul style="margin-top:8px;">
      <% if (!(tracagens||[]).length) { %>
        <li class="muted">Nenhuma traçagem vinculada.</li>
      <% } %>
      <% (tracagens||[]).forEach((t) => { %>
        <li><a href="/tracagem/<%= t.id %>">#<%= t.id %> - <%= t.titulo || t.tipo %></a> (<%= fmtBR(t.created_at) %>)</li>
      <% }) %>
    </ul>
  </div>
</div>



<% const statusPermiteAndamento = ['ABERTA','ANDAMENTO','EM_ANDAMENTO','PAUSADA','AGUARDANDO_EQUIPE'].includes(String(os.status || '').toUpperCase()); %>
<div class="card os-module" id="justificativa-andamento" style="margin-top:12px;">
  <div class="card-head">
    <div>
      <h3 style="margin:0;">Justificativa de OS em andamento</h3>
      <div class="muted">Rastreabilidade diária da permanência da OS em aberto, preservada também após a finalização.</div>
    </div>
    <span class="badge-funcao <%= alertaJustificativaAndamento ? 'func-mec' : 'func-aux' %>"><%= metricasAndamento.dias_aberta %> dia(s) aberta</span>
  </div>

  <% if (alertaJustificativaAndamento) { %>
    <div class="alert alert-error" style="margin-bottom:12px;">Esta OS está aberta há mais de 1 dia. Registre o motivo da permanência em andamento para manter a rastreabilidade do equipamento.</div>
  <% } %>

  <div class="grid2">
    <div><b>Data de abertura:</b> <%= os.opened_at ? fmtBR(os.opened_at) : '-' %></div>
    <div><b>Data de início:</b> <%= os.data_inicio ? fmtBR(os.data_inicio) : (os.execucao_iniciada_em ? fmtBR(os.execucao_iniciada_em) : '-') %></div>
    <div><b>Responsável/mecânico:</b> <%= os.executor_nome || os.execucao_ativa?.executor_nome || '-' %></div>
    <div><b>Último motivo:</b> <%= os.ultimo_motivo_andamento || '-' %></div>
    <div style="grid-column:1/-1;"><b>Última justificativa técnica:</b><br><%= os.ultima_justificativa_andamento || '-' %></div>
  </div>

  <% if (statusPermiteAndamento && canRegisterAndamento) { %>
    <form method="POST" action="/os/<%= os.id %>/andamento/registrar" style="margin-top:14px;">
      <div class="muted" style="font-weight:700;margin-bottom:7px;">Selecione um motivo rápido:</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:7px;">
        <% (motivosAndamento || []).forEach((motivo) => { %>
          <label style="display:flex;gap:8px;align-items:flex-start;border:1px solid #e2e8f0;border-radius:10px;padding:9px;cursor:pointer;">
            <input type="radio" name="motivo_codigo" value="<%= motivo.codigo %>" required>
            <span><b><%= motivo.nome %></b><% if (motivo.exige_observacao) { %><br><small class="muted">Exige observação curta</small><% } %></span>
          </label>
        <% }) %>
      </div>
      <label style="display:block;margin-top:10px;"><b>Observação complementar do mecânico</b>
        <textarea name="observacao_mecanico" maxlength="500" rows="3" placeholder="Opcional, exceto para Outro motivo" style="width:100%;margin-top:5px;border:1px solid #d1d5db;border-radius:10px;padding:9px;"></textarea>
      </label>
      <div class="actions" style="margin-top:10px;">
        <button class="btn btn-green" type="submit">Registrar justificativa</button>
        <button class="btn btn-outline" type="submit" formaction="/os/<%= os.id %>/material-chegou" formnovalidate>Material chegou</button>
      </div>
    </form>
  <% } %>

  <h4 style="margin:16px 0 6px;">Linha do tempo da OS</h4>
  <ol style="margin:0;padding-left:20px;">
    <li>OS aberta em <%= os.opened_at ? fmtBR(os.opened_at) : '-' %>.</li>
    <% if (os.data_inicio || os.execucao_iniciada_em) { %><li>OS iniciada em <%= fmtBR(os.data_inicio || os.execucao_iniciada_em) %>.</li><% } %>
    <% (historicoAndamento || []).slice().reverse().forEach((item) => { %>
      <li style="margin-top:6px;"><b><%= item.motivo_nome %></b> — <%= item.registrado_em ? fmtBR(item.registrado_em) : '-' %><br><span class="muted"><%= item.texto_ia || item.texto_padrao %><% if (item.observacao_mecanico) { %> Observação: <%= item.observacao_mecanico %><% } %></span></li>
    <% }) %>
    <% if (isOSFechada) { %><li style="margin-top:6px;">OS finalizada em <%= os.data_conclusao || os.closed_at || os.data_fim ? fmtBR(os.data_conclusao || os.closed_at || os.data_fim) : '-' %>.</li><% } %>
  </ol>
</div>

<% if (canSendWhatsappNotification) { %>
<div class="card os-module" style="margin-top:12px;" id="whatsapp-os">
  <% const whatsappEquipe = whatsappDestinatarios || []; %>
  <% const whatsPhone = whatsappResponsavel ? (whatsappResponsavel.telefone_normalizado || whatsappResponsavel.colaborador_telefone_whatsapp || whatsappResponsavel.telefone_whatsapp || whatsappResponsavel.user_telefone_whatsapp || whatsappResponsavel.colaborador_telefone || whatsappResponsavel.telefone || '') : ''; %>
  <% const whatsappSemTelefone = whatsappEquipe.filter((p) => !(p.telefone_normalizado || p.colaborador_telefone_whatsapp || p.telefone_whatsapp || p.user_telefone_whatsapp || p.colaborador_telefone || p.telefone)); %>
  <% const whatsappMotivo = whatsappProvider === 'disabled' ? 'WhatsApp desativado. Configure WHATSAPP_PROVIDER=manual ou cloud_api.' : (!whatsPhone ? 'Telefone não encontrado nas tabelas de usuários/colaboradores/funcionários/equipe/mecânicos ou vínculo textual ambíguo.' : ''); %>
  <div class="card-head">
    <div>
      <h3 style="margin:0;">Notificação WhatsApp</h3>
      <div class="muted">Envio da OS ao executor e ao apoio operacional da equipe direcionada.</div>
    </div>
    <% if (canSendWhatsapp && (os.executor_nome || os.execucao_ativa?.executor_nome || whatsappResponsavel?.nome)) { %>
      <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;">
        <a class="btn btn-green whatsapp-btn" href="/os/<%= os.id %>/whatsapp" target="_blank" rel="noopener"><span class="wa-icon" aria-hidden="true"></span> Reenviar template</a>
        <a class="btn btn-outline whatsapp-btn" href="/os/<%= os.id %>?whatsapp_historico=completo#whatsapp-eventos"><span class="wa-icon" aria-hidden="true"></span> Ver eventos do WhatsApp</a>
      </div>
    <% } %>
  </div>

  <div class="grid2">
    <div><b>Responsável:</b> <%= os.executor_nome || os.execucao_ativa?.executor_nome || whatsappResponsavel?.nome || '-' %></div>
    <div><b>ID responsável vinculado:</b> <%= whatsappResponsavel?.id || os.executor_colaborador_id || os.responsavel_user_id || os.mecanico_user_id || '-' %></div>
    <div><b>Origem:</b> <%= whatsappResponsavel?.origem || '-' %></div>
    <div><b>Telefone WhatsApp responsável:</b> <%= whatsPhone || '-' %></div>
    <div><b>Apoio operacional:</b> <%= os.auxiliar_nome || os.execucao_ativa?.auxiliar_nome || '-' %></div>
    <div><b>Destinatários da equipe:</b> <%= whatsappEquipe.length || 0 %></div>
    <div><b>Provider atual:</b> <%= whatsappProvider || 'disabled' %></div>
    <div><b>Template usado:</b> <%= whatsappLast?.template_name || '-' %></div>
    <div><b>ID da mensagem Meta:</b> <%= whatsappLast?.whatsapp_message_id || '-' %></div>
    <div><b>Enviado em:</b> <%= whatsappLast?.enviado_em ? fmtBR(whatsappLast.enviado_em) : '-' %></div>
    <div><b>Entregue em:</b> <%= whatsappLast?.entregue_em ? fmtBR(whatsappLast.entregue_em) : '-' %></div>
    <div><b>Lido em:</b> <%= whatsappLast?.lido_em ? fmtBR(whatsappLast.lido_em) : '-' %></div>
    <div><b>Falha em:</b> <%= whatsappLast?.falhou_em ? fmtBR(whatsappLast.falhou_em) : '-' %></div>
    <div><b>Último erro:</b> <%= whatsappLast?.erro || '-' %></div>
    <div><b>Motivo/diagnóstico:</b> <%= whatsappMotivo || '-' %></div>
    <div>
      <b>Último acompanhamento:</b> <%= whatsappLast?.enviado_em ? fmtBR(whatsappLast.enviado_em) : '-' %>
      <% if (whatsappLast?.status) { %>
        <% const stW = String(whatsappLast.status || ''); %>
        <span class="whatsapp-status <%= stW === 'ERRO' || stW === 'SEM_TELEFONE' ? 'erro' : (stW === 'IGNORADO' || stW === 'SEM_PROVIDER' || stW === 'WHATSAPP_DESATIVADO' ? 'warn' : '') %>"><%= stW %></span>
      <% } %>
    </div>
  </div>

  <% if (whatsappResponsavel?.aviso_ambiguidade) { %>
    <div style="margin-top:10px;color:#92400e;font-weight:800;"><span class="wa-icon" aria-hidden="true"></span> <%= whatsappResponsavel.aviso_ambiguidade %></div>
  <% } %>
  <% if (whatsappProvider === 'disabled') { %>
    <div style="margin-top:10px;color:#92400e;font-weight:800;"><span class="wa-icon" aria-hidden="true"></span> WhatsApp desativado. Configure WHATSAPP_PROVIDER=manual ou cloud_api.</div>
  <% } else if (whatsappSemTelefone.length) { %>
    <div style="margin-top:10px;color:#b91c1c;font-weight:800;"><span class="wa-icon" aria-hidden="true"></span> <%= whatsappSemTelefone.length %> integrante(s) da equipe sem número de WhatsApp cadastrado no perfil.</div>
  <% } else if (whatsappProvider === 'cloud_api') { %>
    <div style="margin-top:10px;color:#166534;font-weight:800;"><span class="wa-icon" aria-hidden="true"></span> Envio automático ativo para os WhatsApps cadastrados no perfil do funcionário e do apoio operacional.</div>
  <% } else if (whatsappProvider === 'manual') { %>
    <div style="margin-top:10px;color:#166534;font-weight:800;"><span class="wa-icon" aria-hidden="true"></span> WhatsApp pronto para envio manual pela OS aberta. Para envio direto automático, configure WHATSAPP_PROVIDER=cloud_api.</div>
  <% } else { %>
    <div style="margin-top:10px;color:#92400e;font-weight:800;"><span class="wa-icon" aria-hidden="true"></span> Provider inválido ou não configurado.</div>
  <% } %>

  <% if (whatsappEquipe.length) { %>
    <h4 style="margin:14px 0 0;">Destinatários da equipe direcionada</h4>
    <table class="tabela-compacta">
      <thead><tr><th>Papel</th><th>ID</th><th>Nome</th><th>Origem</th><th>WhatsApp</th></tr></thead>
      <tbody>
        <% whatsappEquipe.forEach(function(p){ const tel = p.telefone_normalizado || p.colaborador_telefone_whatsapp || p.telefone_whatsapp || p.user_telefone_whatsapp || p.colaborador_telefone || p.telefone || ''; %>
          <tr>
            <td><%= p.papel || '-' %></td>
            <td><%= p.id || p.user_id || p.colaborador_id || '-' %></td>
            <td><%= p.nome || p.name || p.user_name || '-' %></td>
            <td><%= p.origem || '-' %></td>
            <td><%= tel || '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
  <% if (whatsappLast?.erro) { %>
    <div style="margin-top:10px;color:#991b1b;"><b>Erro do último envio:</b> <%= whatsappLast.erro %></div>
  <% } %>

  <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;margin-top:14px;">
    <h4 style="margin:0;">Histórico de envio na OS</h4>
    <% if (!whatsappHistoricoCompleto) { %>
      <a class="btn btn-sm btn-outline" href="/os/<%= os.id %>?whatsapp_historico=completo#whatsapp-historico">Ver histórico completo</a>
    <% } else { %>
      <a class="btn btn-sm btn-outline" href="/os/<%= os.id %>#whatsapp-historico">Mostrar últimos 10</a>
    <% } %>
  </div>
  <% if (!whatsappHistoricoCompleto) { %>
    <div class="muted" style="margin-top:6px;">Mostrando apenas os últimos 10 registros.</div>
  <% } %>
  <table class="tabela-compacta" id="whatsapp-historico">
    <thead>
      <tr>
        <th>Data/Hora</th>
        <th>Evento</th>
        <th>Responsável</th>
        <th>Telefone</th>
        <th>Status</th>
        <th>Template</th>
        <th>ID Meta</th>
        <th>Entregue</th>
        <th>Lido</th>
        <th>Falha</th>
        <th>Erro</th>
      </tr>
    </thead>
    <tbody>
      <% if (!(whatsappLogs || []).length) { %>
        <tr><td colspan="11" class="muted" style="text-align:center;">Nenhum envio registrado.</td></tr>
      <% } %>
      <% (whatsappLogs || []).forEach(function(log){ %>
        <tr>
          <td><%= log.enviado_em ? fmtBR(log.enviado_em) : '-' %></td>
          <td><%= log.tipo_evento || '-' %></td>
          <td><%= log.usuario_nome || os.executor_nome || '-' %></td>
          <td><%= log.telefone || '-' %></td>
          <td><span class="whatsapp-status <%= log.status === 'ERRO' || log.status === 'SEM_TELEFONE' ? 'erro' : (log.status === 'IGNORADO' || log.status === 'SEM_PROVIDER' ? 'warn' : '') %>"><%= log.status || '-' %></span></td>
          <td><%= log.template_name || '-' %></td>
          <td><%= log.whatsapp_message_id || '-' %></td>
          <td><%= log.entregue_em ? fmtBR(log.entregue_em) : '-' %></td>
          <td><%= log.lido_em ? fmtBR(log.lido_em) : '-' %></td>
          <td><%= log.falhou_em ? fmtBR(log.falhou_em) : '-' %></td>
          <td><%= log.erro || '-' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;margin-top:14px;" id="whatsapp-eventos">
    <h4 style="margin:0;">Eventos recebidos pelo webhook</h4>
  </div>
  <table class="tabela-compacta">
    <thead><tr><th>Recebido em</th><th>Status/evento</th><th>Telefone</th><th>ID Meta</th><th>Erro</th></tr></thead>
    <tbody>
      <% if (!(whatsappEventos || []).length) { %>
        <tr><td colspan="5" class="muted" style="text-align:center;">Nenhum evento recebido pelo webhook.</td></tr>
      <% } %>
      <% (whatsappEventos || []).forEach(function(ev){ %>
        <tr>
          <td><%= ev.recebido_em ? fmtBR(ev.recebido_em) : '-' %></td>
          <td><%= ev.status || '-' %></td>
          <td><%= ev.recipient_phone || '-' %></td>
          <td><%= ev.whatsapp_message_id || '-' %></td>
          <td><%= ev.erro || '-' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

</div>
<% } else { %>
  <div class="card os-module" style="margin-top:12px;" id="whatsapp-os">
    <div class="card-head">
      <div>
        <h3 style="margin:0;">Notificação WhatsApp</h3>
        <div class="muted">Notificações disponíveis apenas para Admin e Encarregado de Manutenção.</div>
      </div>
    </div>
    <p class="muted" style="margin-bottom:0;">Acesso restrito. Apenas Admin e Encarregado de Manutenção podem enviar notificações via WhatsApp ou visualizar dados de contato dos colaboradores.</p>
  </div>
<% } %>


<div class="card" style="margin-top:12px;">
  <h3 style="margin:0;">Mídias de abertura da OS</h3>
  <div class="muted">Registro visual inicial do equipamento (foto ou vídeo).</div>
  <div class="galeria">
    <% if (!(os.fotos_abertura||[]).length) { %><span class="muted">Sem mídias de abertura.</span><% } %>
    <% (os.fotos_abertura||[]).forEach((f, idx) => { const src = f.pathPublic || f.path || f.filepath; %>
      <% if (src) { %>
        <% const isVideo = /\.(mp4|mov|webm|ogg|m4v|avi)$/i.test(src); %>
        <a class="foto-card" href="<%= src %>" target="_blank">
          <% if (Number(f.arquivo_removido||0) === 1) { %><div class="muted" style="padding:12px;">Arquivo removido pela limpeza automática de armazenamento em <%= (f.removido_em ? new Date(f.removido_em).toLocaleDateString('pt-BR') : '-') %>. As informações escritas da OS foram preservadas.</div><% } else if (isVideo) { %><video src="<%= src %>" muted playsinline preload="metadata"></video><% } else { %><img src="<%= src %>" alt="mídia abertura <%= idx + 1 %>"/><% } %>
          <span><%= isVideo ? 'Vídeo' : 'Foto' %> abertura <%= idx + 1 %></span>
        </a>
      <% } %>
    <% }) %>
  </div>
</div>

<% if (!isOSFechada && canExecuteOS) { %>
  <div class="card" style="margin-top:12px;">
    <h3>Concluir OS</h3>
    <div class="muted">Adicione pelo menos uma mídia de fechamento (foto ou vídeo) para concluir a OS.</div>
    <form method="POST" action="/os/<%= os.id %>/concluir" enctype="multipart/form-data" id="form-concluir">
      <div style="margin-top:10px;">
        <label>Mídias de fechamento *</label>
        <input id="fechamento_fotos" type="file" name="fechamento_fotos" accept="image/*,video/*" capture="environment" multiple required style="display:none" />
        <button type="button" class="camera-btn" onclick="document.getElementById('fechamento_fotos').click()">📎 Adicionar arquivo (foto ou vídeo)</button>
        <div class="thumbs" id="preview-fechamento" style="margin-top:8px;"></div>
        <div class="muted" style="margin-top:6px;">Vídeos curtos: até 1 minuto.</div>
      </div>

      <div style="margin-top:12px; display:flex; justify-content:flex-end;">
        <button class="btn btn-green" type="submit">Concluir OS</button>
      </div>
    </form>
  </div>
<% } %>

<div class="card" style="margin-top:12px;">
  <h3 style="margin:0;">Mídias de fechamento</h3>
  <div class="muted">Registro visual após execução (foto ou vídeo).</div>
  <div class="galeria">
    <% if (!(os.fotos_fechamento||[]).length) { %><span class="muted">Sem mídias de fechamento.</span><% } %>
    <% (os.fotos_fechamento||[]).forEach((f, idx) => { const src = f.pathPublic || f.path || f.filepath; %>
      <% if (src) { %>
        <% const isVideo = /\.(mp4|mov|webm|ogg|m4v|avi)$/i.test(src); %>
        <a class="foto-card" href="<%= src %>" target="_blank">
          <% if (Number(f.arquivo_removido||0) === 1) { %><div class="muted" style="padding:12px;">Arquivo removido pela limpeza automática de armazenamento em <%= (f.removido_em ? new Date(f.removido_em).toLocaleDateString('pt-BR') : '-') %>. As informações escritas da OS foram preservadas.</div><% } else if (isVideo) { %><video src="<%= src %>" muted playsinline preload="metadata"></video><% } else { %><img src="<%= src %>" alt="mídia fechamento <%= idx + 1 %>"/><% } %>
          <span><%= isVideo ? 'Vídeo' : 'Foto' %> fechamento <%= idx + 1 %></span>
        </a>
      <% } %>
    <% }) %>
  </div>
</div>

<script>
  (function(){
    const menuWrap = document.getElementById('os-menu-wrap');
    const menuBtn = document.getElementById('os-menu-btn');
    function activateModule(moduleId) {
      const modules = document.querySelectorAll('.os-module');
      modules.forEach((el) => el.classList.remove('active'));
      const target = document.getElementById(moduleId);
      if (target) target.classList.add('active');
      return target;
    }

    function activateHashModule() {
      const moduleId = window.location.hash.replace(/^#/, '');
      if (!moduleId) return;
      const target = document.getElementById(moduleId);
      if (target && target.classList.contains('os-module')) activateModule(moduleId);
    }

    if (menuWrap && menuBtn) {
      menuBtn.addEventListener('click', function(){
        const isOpen = menuWrap.classList.toggle('open');
        menuBtn.setAttribute('aria-expanded', String(isOpen));
      });
      menuWrap.querySelectorAll('[data-os-module]').forEach(function(btn){
        btn.addEventListener('click', function(){
          const moduleId = btn.getAttribute('data-os-module');
          if (moduleId === 'equipe-os') {
            activateModule('tracagens-vinculadas');
            const equipe = document.getElementById('equipe-os');
            if (equipe) equipe.scrollIntoView({ behavior: 'smooth', block: 'start' });
          } else {
            const target = activateModule(moduleId);
            if (target && moduleId === 'justificativa-andamento') {
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          }
          menuWrap.classList.remove('open');
          menuBtn.setAttribute('aria-expanded', 'false');
        });
      });
      activateHashModule();
      window.addEventListener('hashchange', activateHashModule);
      document.addEventListener('click', function(ev){
        if (!menuWrap.contains(ev.target)) {
          menuWrap.classList.remove('open');
          menuBtn.setAttribute('aria-expanded', 'false');
        }
      });
    }
  })();

  (function () {
    const input = document.getElementById('fechamento_fotos');
    const preview = document.getElementById('preview-fechamento');
    if (!input) return;

    async function getVideoDuration(file) {
      return new Promise(function(resolve, reject){
        const url = URL.createObjectURL(file);
        const video = document.createElement('video');
        video.preload = 'metadata';
        video.onloadedmetadata = function(){
          const duration = Number(video.duration || 0);
          URL.revokeObjectURL(url);
          resolve(duration);
        };
        video.onerror = function(){
          URL.revokeObjectURL(url);
          reject(new Error('Falha ao ler duração do vídeo.'));
        };
        video.src = url;
      });
    }

    async function sanitizeFiles() {
      const MAX_VIDEO_SECONDS = 60;
      const dt = new DataTransfer();
      for (const f of Array.from(input.files || [])) {
        const isVideo = (f.type || '').startsWith('video/');
        if (isVideo) {
          try {
            const duration = await getVideoDuration(f);
            if (duration > MAX_VIDEO_SECONDS) {
              alert('O vídeo "' + f.name + '" excede 1 minuto. Envie um vídeo curto (até 60s).');
              continue;
            }
          } catch (_e) {}
        }
        dt.items.add(f);
      }
      input.files = dt.files;
    }

    function renderPreview() {
      if (!preview) return;
      preview.innerHTML = '';
      Array.from(input.files || []).forEach(function (f) {
        const chip = document.createElement('span');
        chip.className = 'pill-tag pill-gray';
        chip.style.marginRight = '6px';
        const isVideo = (f.type || '').startsWith('video/');
        chip.textContent = (isVideo ? '🎬 ' : '🖼️ ') + f.name;
        preview.appendChild(chip);
      });
    }

    input.addEventListener('change', async function(){
      await sanitizeFiles();
      renderPreview();
    });
  })();
</script>
