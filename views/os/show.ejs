<% layout('layout') %>

<style>
  .top{display:grid;grid-template-columns:2fr 1fr;gap:12px}
  .card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:14px}
  .muted{color:#64748b;font-size:13px}
  .grid2{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
  .status{font-weight:700}.g-baixa{color:#15803d}.g-media{color:#b45309}.g-alta{color:#b91c1c}.g-critica{color:#7f1d1d}
  .card-head{display:flex;justify-content:space-between;align-items:center;gap:8px;margin-bottom:10px}
  .actions{display:flex;gap:8px;flex-wrap:wrap}
  .camera-btn{border:1px solid #d1d5db;background:#fff;border-radius:10px;padding:10px 12px;cursor:pointer}
  .galeria{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:10px;margin-top:8px}
  .foto-card{display:block;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;background:#f8fafc;text-decoration:none}
  .foto-card img,.foto-card video{display:block;width:100%;height:140px;object-fit:cover;background:#e5e7eb}
  .foto-card span{display:block;padding:6px 8px;font-size:12px;color:#64748b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .resumo-exec{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .tabela-compacta{width:100%;border-collapse:collapse;margin-top:10px}
  .tabela-compacta th,.tabela-compacta td{border:1px solid #e2e8f0;padding:8px 10px;font-size:13px;text-align:left}
  .tabela-compacta th{background:#f8fafc;font-weight:700}

  .badge-funcao{display:inline-block;padding:2px 8px;border-radius:999px;font-size:11px;font-weight:700}
  .func-mec{background:#fee2e2;color:#991b1b}.func-mon{background:#dbeafe;color:#1e3a8a}.func-aux{background:#dcfce7;color:#166534}
  .whatsapp-status{display:inline-block;padding:3px 10px;border-radius:999px;font-size:12px;font-weight:800;background:#dcfce7;color:#166534}
  .whatsapp-status.erro{background:#fee2e2;color:#991b1b}.whatsapp-status.warn{background:#fef3c7;color:#92400e}
  .whatsapp-btn{display:inline-flex;align-items:center;gap:7px;}
  .wa-icon{display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:999px;background:#25d366;color:#fff;font-size:13px;font-weight:900;line-height:1;box-shadow:0 1px 2px rgba(0,0,0,.12)}
  .wa-icon::before{content:"☎";}
  @media(max-width:900px){.top{grid-template-columns:1fr}.grid2{grid-template-columns:1fr}.resumo-exec{grid-template-columns:1fr}}
</style>

<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;">
  <div>
    <h1>OS #<%= os.id %></h1>
    <div class="muted">Solicitante: <strong><%= os.solicitante_nome || '-' %></strong></div>
  </div>
  <a class="btn btn-ghost" href="/os">Voltar</a>
</div>

<% const isOSFechada = String(os.status || '').toUpperCase() === 'FECHADA'; %>

<div class="top" style="margin-top:10px;">
  <div class="card">
    <div class="card-head">
      <div class="muted">Dados principais da OS</div>
      <% if (!isOSFechada) { %>
        <div class="actions">
          <form method="POST" action="/os/<%= os.id %>/pausar"><button class="btn" type="submit">Pausar OS</button></form>
          <% if (canSendWhatsapp && (os.executor_nome || os.execucao_ativa?.executor_nome)) { %>
            <a class="btn btn-green whatsapp-btn" href="/os/<%= os.id %>/whatsapp" target="_blank" rel="noopener"><span class="wa-icon" aria-hidden="true"></span> Enviar WhatsApp à equipe</a>
          <% } %>
        </div>
      <% } %>
    </div>
    <div class="grid2">
      <div><b>Equipamento:</b> <%= os.equipamento_resolvido || '-' %></div>
      <div><b>Tipo:</b> <%= os.tipo || '-' %></div>
      <div><b>Grau:</b>
        <% const gg = String(os.grau||'').toUpperCase(); %>
        <span class="status <%= gg==='BAIXA'?'g-baixa':(gg==='MEDIA'?'g-media':(gg==='ALTA'?'g-alta':'g-critica')) %>"><%= gg || '-' %></span>
      </div>
      <div><b>Status:</b> <%= os.status %></div>
      <% if (String(os.status || "").toUpperCase() === "AGUARDANDO_EQUIPE") { %>
        <div style="grid-column:1/-1;color:#b91c1c;font-weight:700;">Sem executor disponível no turno: OS aguardando alocação.</div>
      <% } %>
      <div><b>Abertura:</b> <%= os.opened_at ? fmtBR(os.opened_at) : '-' %></div>
      <div><b>Início:</b> <%= os.data_inicio ? fmtBR(os.data_inicio) : (os.execucao_iniciada_em ? fmtBR(os.execucao_iniciada_em) : '-') %></div>
      <div><b>Conclusão:</b> <%= os.data_conclusao ? fmtBR(os.data_conclusao) : '-' %></div>
      <div><b>Turno da alocação:</b> <%= os.turno_alocado || os.execucao_ativa?.turno_alocacao || '-' %>
        <% if ((os.turno_alocado || os.execucao_ativa?.turno_alocacao) === 'NOITE' && (os.executor_nome || '').trim()) { %>
          <span class="badge-funcao func-mon" style="margin-left:6px;">PLANTONISTA</span>
        <% } %>
      </div>
      <div><b>Executor em andamento:</b> <%= os.executor_nome || os.execucao_ativa?.executor_nome || '-' %></div>
      <div><b>Auxiliar em andamento:</b> <%= os.auxiliar_nome || os.execucao_ativa?.auxiliar_nome || '-' %></div>
      <div><b>Modo da alocação:</b> <%= os.alocacao_modo || '-' %></div>
    </div>

    <hr style="border:none;border-top:1px solid #e5e7eb;margin:12px 0"/>
    <div class="muted">Descrição do problema (solicitante)</div>
    <div><%= os.descricao || '-' %></div>

    <% const diagnosticoInicialOS = os.ai_diagnostico_inicial || os.diagnostico || os.causa_diagnostico || '-'; %>
    <hr style="border:none;border-top:1px solid #e5e7eb;margin:12px 0"/>
    <div class="muted" style="font-weight:700;">Diagnóstico inicial para execução</div>
    <table class="tabela-compacta">
      <tbody>
        <tr>
          <th style="width:220px;">Diagnóstico inicial para execução</th>
          <td><%= diagnosticoInicialOS %></td>
        </tr>
      </tbody>
    </table>

    <% if (os.acao_corretiva || os.acao_preventiva) { %>
      <hr style="border:none;border-top:1px solid #e5e7eb;margin:12px 0"/>
      <div><b>Ação corretiva:</b><br/><%= os.acao_corretiva || '-' %></div>
      <div style="margin-top:8px;"><b>Ação preventiva:</b><br/><%= os.acao_preventiva || '-' %></div>
    <% } %>
  </div>

  <div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
      <h3 style="margin:0;">Traçagens vinculadas</h3>
      <a class="btn btn-green" href="/tracagem?os_id=<%= os.id %>">Abrir Traçagem</a>
    </div>
    <div class="muted">Cálculos de caldeiraria relacionados a esta OS.</div>
    <table class="tabela-compacta">
      <thead>
        <tr>
          <th>Equipe</th>
          <th>Executor</th>
          <th>Auxiliar</th>
          <th>Turno</th>
          <th>Modo</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><%= (os.executor_nome || os.execucao_ativa?.executor_nome || os.executor_secundario_nome || os.auxiliar_nome || os.execucao_ativa?.auxiliar_nome || os.auxiliar_secundario_nome) ? 'Equipe alocada' : '-' %></td>
          <td><%= os.executor_nome || os.execucao_ativa?.executor_nome || '-' %></td>
          <td><%= os.auxiliar_nome || os.execucao_ativa?.auxiliar_nome || '-' %></td>
          <td><%= os.turno_alocado || os.execucao_ativa?.turno_alocacao || '-' %></td>
          <td><%= os.alocacao_modo || '-' %></td>
        </tr>
        <% if (os.executor_secundario_nome || os.auxiliar_secundario_nome) { %>
          <tr>
            <td>Complemento manual</td>
            <td><%= os.executor_secundario_nome || '-' %></td>
            <td><%= os.auxiliar_secundario_nome || '-' %></td>
            <td colspan="2">Apoio extra definido manualmente</td>
          </tr>
        <% } %>
      </tbody>
    </table>
    <% if (canAutoAssign) { %>
      <div style="margin-top:8px;display:flex;justify-content:flex-end;">
        <form method="POST" action="/os/<%= os.id %>/auto-alocar">
          <button class="btn btn-primary" type="submit">Reatribuir automaticamente</button>
        </form>
      </div>
    <% } %>
    <% if (canManualEditEquipe) { %>
      <% const mecanicosTurno = (equipeUsuarios || []).filter(u => String(u.funcao || '').toLowerCase() === 'mecanico'); %>
      <% const auxiliaresTurno = (equipeUsuarios || []).filter(u => ['auxiliar','apoio'].includes(String(u.funcao || '').toLowerCase())); %>
      <form method="POST" action="/os/<%= os.id %>/equipe" style="margin-top:10px;">
        <div class="grid2">
          <div>
            <label>Executor</label>
            <select class="input" name="executor_colaborador_id" required>
              <option value="">Selecione</option>
              <% if (mecanicosTurno.length) { %>
                <optgroup label="Mecânicos">
                  <% mecanicosTurno.forEach(function(u){ %>
                    <option value="<%= u.id %>" <%= Number(os.executor_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                  <% }) %>
                </optgroup>
              <% } %>
              <% if (auxiliaresTurno.length) { %>
                <optgroup label="Apoio/Auxiliares">
                  <% auxiliaresTurno.forEach(function(u){ %>
                    <option value="<%= u.id %>" <%= Number(os.executor_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                  <% }) %>
                </optgroup>
              <% } %>
            </select>
          </div>
          <div>
            <label>Auxiliar</label>
            <select class="input" name="auxiliar_colaborador_id">
              <option value="">Sem auxiliar</option>
              <% if (mecanicosTurno.length) { %>
                <optgroup label="Mecânicos">
                  <% mecanicosTurno.forEach(function(u){ %>
                    <option value="<%= u.id %>" <%= Number(os.auxiliar_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                  <% }) %>
                </optgroup>
              <% } %>
              <% if (auxiliaresTurno.length) { %>
                <optgroup label="Auxiliares">
                  <% auxiliaresTurno.forEach(function(u){ %>
                    <option value="<%= u.id %>" <%= Number(os.auxiliar_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                  <% }) %>
                </optgroup>
              <% } %>
            </select>
          </div>
          <div>
            <label>2º mecânico (opcional)</label>
            <select class="input" name="executor_secundario_colaborador_id">
              <option value="">Sem 2º mecânico</option>
              <% if (mecanicosTurno.length) { %>
                <optgroup label="Mecânicos">
                  <% mecanicosTurno.forEach(function(u){ %>
                    <option value="<%= u.id %>" <%= Number(os.executor_secundario_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                  <% }) %>
                </optgroup>
              <% } %>
            </select>
          </div>
          <div>
            <label>2º apoio operacional (opcional)</label>
            <select class="input" name="auxiliar_secundario_colaborador_id">
              <option value="">Sem 2º apoio</option>
              <% if (auxiliaresTurno.length) { %>
                <optgroup label="Auxiliares">
                  <% auxiliaresTurno.forEach(function(u){ %>
                    <option value="<%= u.id %>" <%= Number(os.auxiliar_secundario_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                  <% }) %>
                </optgroup>
              <% } %>
            </select>
          </div>
        </div>
        <div style="margin-top:8px;"><button class="btn" type="submit">Salvar equipe</button></div>
      </form>
    <% } %>
    <ul style="margin-top:8px;">
      <% if (!(tracagens||[]).length) { %>
        <li class="muted">Nenhuma traçagem vinculada.</li>
      <% } %>
      <% (tracagens||[]).forEach((t) => { %>
        <li><a href="/tracagem/<%= t.id %>">#<%= t.id %> - <%= t.titulo || t.tipo %></a> (<%= fmtBR(t.created_at) %>)</li>
      <% }) %>
    </ul>
  </div>
</div>


<div class="card" style="margin-top:12px;">
  <% const whatsappEquipe = whatsappDestinatarios || []; %>
  <% const whatsPhone = whatsappResponsavel ? (whatsappResponsavel.telefone_normalizado || whatsappResponsavel.colaborador_telefone_whatsapp || whatsappResponsavel.telefone_whatsapp || whatsappResponsavel.user_telefone_whatsapp || whatsappResponsavel.colaborador_telefone || '') : ''; %>
  <% const whatsappSemTelefone = whatsappEquipe.filter((p) => !(p.telefone_normalizado || p.colaborador_telefone_whatsapp || p.telefone_whatsapp || p.user_telefone_whatsapp || p.colaborador_telefone)); %>
  <div class="card-head">
    <div>
      <h3 style="margin:0;">Notificação WhatsApp</h3>
      <div class="muted">Envio da OS ao executor e ao apoio operacional da equipe direcionada.</div>
    </div>
    <% if (canSendWhatsapp && (os.executor_nome || os.execucao_ativa?.executor_nome)) { %>
      <a class="btn btn-green whatsapp-btn" href="/os/<%= os.id %>/whatsapp" target="_blank" rel="noopener"><span class="wa-icon" aria-hidden="true"></span> Enviar WhatsApp à equipe</a>
    <% } %>
  </div>

  <div class="grid2">
    <div><b>Responsável:</b> <%= os.executor_nome || os.execucao_ativa?.executor_nome || '-' %></div>
    <div><b>Telefone WhatsApp responsável:</b> <%= whatsPhone || '-' %></div>
    <div><b>Apoio operacional:</b> <%= os.auxiliar_nome || os.execucao_ativa?.auxiliar_nome || '-' %></div>
    <div><b>Destinatários da equipe:</b> <%= whatsappEquipe.length || 0 %></div>
    <div><b>Provider:</b> <%= whatsappProvider || 'disabled' %></div>
    <div>
      <b>Último envio:</b> <%= whatsappLast?.enviado_em ? fmtBR(whatsappLast.enviado_em) : '-' %>
      <% if (whatsappLast?.status) { %>
        <% const stW = String(whatsappLast.status || ''); %>
        <span class="whatsapp-status <%= stW === 'ERRO' || stW === 'SEM_TELEFONE' ? 'erro' : (stW === 'IGNORADO' || stW === 'SEM_PROVIDER' ? 'warn' : '') %>"><%= stW %></span>
      <% } %>
    </div>
  </div>

  <% if (whatsappSemTelefone.length) { %>
    <div style="margin-top:10px;color:#b91c1c;font-weight:800;"><span class="wa-icon" aria-hidden="true"></span> <%= whatsappSemTelefone.length %> integrante(s) da equipe sem número de WhatsApp cadastrado no perfil.</div>
  <% } else if (whatsappProvider === 'cloud_api') { %>
    <div style="margin-top:10px;color:#166534;font-weight:800;"><span class="wa-icon" aria-hidden="true"></span> Envio automático ativo para os WhatsApps cadastrados no perfil do funcionário e do apoio operacional.</div>
  <% } else if (whatsappProvider === 'manual') { %>
    <div style="margin-top:10px;color:#166534;font-weight:800;"><span class="wa-icon" aria-hidden="true"></span> WhatsApp pronto para envio manual pela OS aberta. Para envio direto automático, configure WHATSAPP_PROVIDER=cloud_api.</div>
  <% } else { %>
    <div style="margin-top:10px;color:#92400e;font-weight:800;"><span class="wa-icon" aria-hidden="true"></span> Integração desabilitada. Configure WHATSAPP_PROVIDER=cloud_api para envio direto.</div>
  <% } %>

  <% if (whatsappEquipe.length) { %>
    <h4 style="margin:14px 0 0;">Destinatários da equipe direcionada</h4>
    <table class="tabela-compacta">
      <thead><tr><th>Papel</th><th>Nome</th><th>WhatsApp</th></tr></thead>
      <tbody>
        <% whatsappEquipe.forEach(function(p){ const tel = p.telefone_normalizado || p.colaborador_telefone_whatsapp || p.telefone_whatsapp || p.user_telefone_whatsapp || p.colaborador_telefone || ''; %>
          <tr>
            <td><%= p.papel || '-' %></td>
            <td><%= p.name || p.user_name || '-' %></td>
            <td><%= tel || '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
  <% if (whatsappLast?.erro) { %>
    <div style="margin-top:10px;color:#991b1b;"><b>Erro do último envio:</b> <%= whatsappLast.erro %></div>
  <% } %>

  <h4 style="margin:14px 0 0;">Histórico de envio na OS</h4>
  <table class="tabela-compacta">
    <thead>
      <tr>
        <th>Data/Hora</th>
        <th>Evento</th>
        <th>Responsável</th>
        <th>Telefone</th>
        <th>Status</th>
        <th>Erro</th>
      </tr>
    </thead>
    <tbody>
      <% if (!(whatsappLogs || []).length) { %>
        <tr><td colspan="6" class="muted" style="text-align:center;">Nenhum envio registrado.</td></tr>
      <% } %>
      <% (whatsappLogs || []).forEach(function(log){ %>
        <tr>
          <td><%= log.enviado_em ? fmtBR(log.enviado_em) : '-' %></td>
          <td><%= log.tipo_evento || '-' %></td>
          <td><%= log.usuario_nome || os.executor_nome || '-' %></td>
          <td><%= log.telefone || '-' %></td>
          <td><span class="whatsapp-status <%= log.status === 'ERRO' || log.status === 'SEM_TELEFONE' ? 'erro' : (log.status === 'IGNORADO' || log.status === 'SEM_PROVIDER' ? 'warn' : '') %>"><%= log.status || '-' %></span></td>
          <td><%= log.erro || '-' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>


<div class="card" style="margin-top:12px;">
  <h3 style="margin:0;">Mídias de abertura da OS</h3>
  <div class="muted">Registro visual inicial do equipamento (foto ou vídeo).</div>
  <div class="galeria">
    <% if (!(os.fotos_abertura||[]).length) { %><span class="muted">Sem mídias de abertura.</span><% } %>
    <% (os.fotos_abertura||[]).forEach((f, idx) => { const src = f.pathPublic || f.path || f.filepath; %>
      <% if (src) { %>
        <% const isVideo = /\.(mp4|mov|webm|ogg|m4v|avi)$/i.test(src); %>
        <a class="foto-card" href="<%= src %>" target="_blank">
          <% if (isVideo) { %><video src="<%= src %>" muted playsinline preload="metadata"></video><% } else { %><img src="<%= src %>" alt="mídia abertura <%= idx + 1 %>"/><% } %>
          <span><%= isVideo ? 'Vídeo' : 'Foto' %> abertura <%= idx + 1 %></span>
        </a>
      <% } %>
    <% }) %>
  </div>
</div>

<% if (!isOSFechada) { %>
  <div class="card" style="margin-top:12px;">
    <h3>Concluir OS</h3>
    <div class="muted">Adicione pelo menos uma mídia de fechamento (foto ou vídeo) para concluir a OS.</div>
    <form method="POST" action="/os/<%= os.id %>/concluir" enctype="multipart/form-data" id="form-concluir">
      <div style="margin-top:10px;">
        <label>Mídias de fechamento *</label>
        <input id="fechamento_fotos" type="file" name="fechamento_fotos" accept="image/*,video/*" capture="environment" multiple required style="display:none" />
        <button type="button" class="camera-btn" onclick="document.getElementById('fechamento_fotos').click()">📎 Adicionar arquivo (foto ou vídeo)</button>
        <div class="thumbs" id="preview-fechamento" style="margin-top:8px;"></div>
        <div class="muted" style="margin-top:6px;">Vídeos curtos: até 1 minuto.</div>
      </div>

      <div style="margin-top:12px; display:flex; justify-content:flex-end;">
        <button class="btn btn-green" type="submit">Concluir OS</button>
      </div>
    </form>
  </div>
<% } %>

<div class="card" style="margin-top:12px;">
  <h3 style="margin:0;">Mídias de fechamento</h3>
  <div class="muted">Registro visual após execução (foto ou vídeo).</div>
  <div class="galeria">
    <% if (!(os.fotos_fechamento||[]).length) { %><span class="muted">Sem mídias de fechamento.</span><% } %>
    <% (os.fotos_fechamento||[]).forEach((f, idx) => { const src = f.pathPublic || f.path || f.filepath; %>
      <% if (src) { %>
        <% const isVideo = /\.(mp4|mov|webm|ogg|m4v|avi)$/i.test(src); %>
        <a class="foto-card" href="<%= src %>" target="_blank">
          <% if (isVideo) { %><video src="<%= src %>" muted playsinline preload="metadata"></video><% } else { %><img src="<%= src %>" alt="mídia fechamento <%= idx + 1 %>"/><% } %>
          <span><%= isVideo ? 'Vídeo' : 'Foto' %> fechamento <%= idx + 1 %></span>
        </a>
      <% } %>
    <% }) %>
  </div>
</div>

<script>
  (function () {
    const input = document.getElementById('fechamento_fotos');
    const preview = document.getElementById('preview-fechamento');
    if (!input) return;

    async function getVideoDuration(file) {
      return new Promise(function(resolve, reject){
        const url = URL.createObjectURL(file);
        const video = document.createElement('video');
        video.preload = 'metadata';
        video.onloadedmetadata = function(){
          const duration = Number(video.duration || 0);
          URL.revokeObjectURL(url);
          resolve(duration);
        };
        video.onerror = function(){
          URL.revokeObjectURL(url);
          reject(new Error('Falha ao ler duração do vídeo.'));
        };
        video.src = url;
      });
    }

    async function sanitizeFiles() {
      const MAX_VIDEO_SECONDS = 60;
      const dt = new DataTransfer();
      for (const f of Array.from(input.files || [])) {
        const isVideo = (f.type || '').startsWith('video/');
        if (isVideo) {
          try {
            const duration = await getVideoDuration(f);
            if (duration > MAX_VIDEO_SECONDS) {
              alert('O vídeo "' + f.name + '" excede 1 minuto. Envie um vídeo curto (até 60s).');
              continue;
            }
          } catch (_e) {}
        }
        dt.items.add(f);
      }
      input.files = dt.files;
    }

    function renderPreview() {
      if (!preview) return;
      preview.innerHTML = '';
      Array.from(input.files || []).forEach(function (f) {
        const chip = document.createElement('span');
        chip.className = 'pill-tag pill-gray';
        chip.style.marginRight = '6px';
        const isVideo = (f.type || '').startsWith('video/');
        chip.textContent = (isVideo ? '🎬 ' : '🖼️ ') + f.name;
        preview.appendChild(chip);
      });
    }

    input.addEventListener('change', async function(){
      await sanitizeFiles();
      renderPreview();
    });
  })();
</script>
