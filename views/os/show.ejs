<% layout('layout') %>

<style>
  .top{display:grid;grid-template-columns:2fr 1fr;gap:12px}
  .card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:14px}
  .muted{color:#64748b;font-size:13px}
  .grid2{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
  .status{font-weight:700}.g-baixa{color:#15803d}.g-media{color:#b45309}.g-alta{color:#b91c1c}.g-critica{color:#7f1d1d}
  .actions{display:flex;gap:8px;flex-wrap:wrap}
  .camera-btn{border:1px solid #d1d5db;background:#fff;border-radius:10px;padding:10px 12px;cursor:pointer}
  .pecas-grid{display:grid;grid-template-columns:1fr 140px;gap:8px;margin-top:8px}.peca-row{display:contents}
  .galeria{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:10px;margin-top:8px}
  .foto-card{display:block;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;background:#f8fafc;text-decoration:none}
  .foto-card img{display:block;width:100%;height:140px;object-fit:cover;background:#e5e7eb}
  .foto-card span{display:block;padding:6px 8px;font-size:12px;color:#64748b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .resumo-exec{display:grid;grid-template-columns:1fr 1fr;gap:12px}

  .badge-funcao{display:inline-block;padding:2px 8px;border-radius:999px;font-size:11px;font-weight:700}
  .func-mec{background:#fee2e2;color:#991b1b}.func-mon{background:#dbeafe;color:#1e3a8a}.func-aux{background:#dcfce7;color:#166534}
  @media(max-width:900px){.top{grid-template-columns:1fr}.grid2{grid-template-columns:1fr}.resumo-exec{grid-template-columns:1fr}}
</style>

<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;">
  <div>
    <h1>OS #<%= os.id %></h1>
    <div class="muted">Solicitante: <strong><%= os.solicitante_nome || '-' %></strong></div>
  </div>
  <a class="btn btn-ghost" href="/os">Voltar</a>
</div>

<% const isOSFechada = String(os.status || '').toUpperCase() === 'FECHADA'; %>

<div class="top" style="margin-top:10px;">
  <div class="card">
    <div class="grid2">
      <div><b>Equipamento:</b> <%= os.equipamento_resolvido || '-' %></div>
      <div><b>Tipo:</b> <%= os.tipo || '-' %></div>
      <div><b>Grau:</b>
        <% const gg = String(os.grau||'').toUpperCase(); %>
        <span class="status <%= gg==='BAIXA'?'g-baixa':(gg==='MEDIA'?'g-media':(gg==='ALTA'?'g-alta':'g-critica')) %>"><%= gg || '-' %></span>
      </div>
      <div><b>Status:</b> <%= os.status %></div>
      <% if (String(os.status || "").toUpperCase() === "AGUARDANDO_EQUIPE") { %>
        <div style="grid-column:1/-1;color:#b91c1c;font-weight:700;">Sem executor disponível no turno: OS aguardando alocação.</div>
      <% } %>
      <div><b>Abertura:</b> <%= os.opened_at ? fmtBR(os.opened_at) : '-' %></div>
      <div><b>Início:</b> <%= os.data_inicio ? fmtBR(os.data_inicio) : (os.execucao_iniciada_em ? fmtBR(os.execucao_iniciada_em) : '-') %></div>
      <div><b>Conclusão:</b> <%= os.data_conclusao ? fmtBR(os.data_conclusao) : '-' %></div>
      <div><b>Turno da alocação:</b> <%= os.turno_alocado || os.execucao_ativa?.turno_alocacao || '-' %>
        <% if ((os.turno_alocado || os.execucao_ativa?.turno_alocacao) === 'NOITE' && (os.executor_nome || '').trim()) { %>
          <span class="badge-funcao func-mon" style="margin-left:6px;">PLANTONISTA</span>
        <% } %>
      </div>
      <div><b>Executor em andamento:</b> <%= os.executor_nome || os.execucao_ativa?.executor_nome || '-' %></div>
      <div><b>Auxiliar em andamento:</b> <%= os.auxiliar_nome || os.execucao_ativa?.auxiliar_nome || '-' %></div>
      <div><b>Modo da alocação:</b> <%= os.alocacao_modo || '-' %></div>
    </div>

    <hr style="border:none;border-top:1px solid #e5e7eb;margin:12px 0"/>
    <div class="muted">Descrição do problema (solicitante)</div>
    <div><%= os.descricao || '-' %></div>

    <% if (os.diagnostico || os.causa_diagnostico || os.acao_executada || os.resumo_tecnico) { %>
      <hr style="border:none;border-top:1px solid #e5e7eb;margin:12px 0"/>
      <div><b>Causa / Diagnóstico / Ação preventiva:</b><br/><%= os.causa_diagnostico || os.diagnostico || '-' %></div>
      <div style="margin-top:8px;"><b>Resumo técnico / Ação corretiva:</b><br/><%= os.resumo_tecnico || os.acao_executada || '-' %></div>
    <% } %>
  </div>

  <% if (!isOSFechada) { %>
    <div class="card">
      <div class="actions">
        <form method="POST" action="/os/<%= os.id %>/iniciar"><button class="btn btn-green" type="submit">Iniciar OS</button></form>
        <form method="POST" action="/os/<%= os.id %>/pausar"><button class="btn" type="submit">Pausar OS</button></form>
        <a class="btn btn-primary" href="/os/<%= os.id %>/fechar">Ir para fechamento</a>
      </div>
    </div>
  <% } %>
</div>



<div class="card" style="margin-top:12px;">
  <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
    <h3 style="margin:0;">Traçagens vinculadas</h3>
    <a class="btn btn-green" href="/tracagem?os_id=<%= os.id %>">Abrir Traçagem</a>
  </div>
  <div class="muted">Cálculos de caldeiraria relacionados a esta OS.</div>
  <ul style="margin-top:8px;">
    <% if (!(tracagens||[]).length) { %>
      <li class="muted">Nenhuma traçagem vinculada.</li>
    <% } %>
    <% (tracagens||[]).forEach((t) => { %>
      <li><a href="/tracagem/<%= t.id %>">#<%= t.id %> - <%= t.titulo || t.tipo %></a> (<%= fmtBR(t.created_at) %>)</li>
    <% }) %>
  </ul>
</div>


<div class="card" style="margin-top:12px;">
  <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
    <h3 style="margin:0;">Equipe</h3>
    <% if (canAutoAssign) { %>
      <form method="POST" action="/os/<%= os.id %>/auto-alocar">
        <button class="btn btn-primary" type="submit">Reatribuir automaticamente</button>
      </form>
    <% } %>
  </div>

  <div class="muted" style="margin-top:6px;">Executor: <strong><%= os.executor_nome || os.execucao_ativa?.executor_nome || '-' %></strong></div>
  <div class="muted">Auxiliar: <strong><%= os.auxiliar_nome || os.execucao_ativa?.auxiliar_nome || '-' %></strong></div>
  <div class="muted">Turno: <strong><%= os.turno_alocado || os.execucao_ativa?.turno_alocacao || '-' %></strong></div>
  <div class="muted">Modo: <strong><%= os.alocacao_modo || '-' %></strong></div>

  <% if (canManualEditEquipe) { %>
    <% const mecanicosTurno = (equipeUsuarios || []).filter(u => String(u.funcao || '').toLowerCase() === 'mecanico'); %>
    <% const auxiliaresTurno = (equipeUsuarios || []).filter(u => ['auxiliar','apoio'].includes(String(u.funcao || '').toLowerCase())); %>
    <% const grauManual = String(os.grau || '').toUpperCase(); %>
    <% const exigirMecanico = ['MEDIA','ALTA','CRITICA'].includes(grauManual); %>
    <form method="POST" action="/os/<%= os.id %>/equipe" style="margin-top:10px;">
      <div class="grid2">
        <div>
          <label>Executor</label>
          <select class="input" name="executor_colaborador_id" required>
            <option value="">Selecione</option>
            <% if (mecanicosTurno.length) { %>
              <optgroup label="Mecânicos">
                <% mecanicosTurno.forEach(function(u){ %>
                  <option value="<%= u.id %>" <%= Number(os.executor_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                <% }) %>
              </optgroup>
            <% } %>
            <% if (!exigirMecanico && auxiliaresTurno.length) { %>
              <optgroup label="Apoio/Auxiliares">
                <% auxiliaresTurno.forEach(function(u){ %>
                  <option value="<%= u.id %>" <%= Number(os.executor_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                <% }) %>
              </optgroup>
            <% } %>
          </select>
        </div>
        <div>
          <label>Auxiliar</label>
          <select class="input" name="auxiliar_colaborador_id">
            <option value="">Sem auxiliar</option>
            <% if (auxiliaresTurno.length) { %>
              <optgroup label="Auxiliares">
                <% auxiliaresTurno.forEach(function(u){ %>
                  <option value="<%= u.id %>" <%= Number(os.auxiliar_colaborador_id)===Number(u.id) ? 'selected' : '' %>><%= u.name %></option>
                <% }) %>
              </optgroup>
            <% } %>
          </select>
        </div>
      </div>
      <div style="margin-top:8px;"><button class="btn" type="submit">Salvar equipe</button></div>
    </form>
  <% } %>
</div>


<div class="card" style="margin-top:12px;">
  <h3 style="margin:0;">Fotos de abertura da OS</h3>
  <div class="muted">Registro visual inicial do equipamento.</div>
  <div class="galeria">
    <% if (!(os.fotos_abertura||[]).length) { %><span class="muted">Sem fotos de abertura.</span><% } %>
    <% (os.fotos_abertura||[]).forEach((f, idx) => { const src = f.pathPublic || f.path || f.filepath; %>
      <% if (src) { %><a class="foto-card" href="<%= src %>" target="_blank"><img src="<%= src %>" alt="foto abertura <%= idx + 1 %>"/><span>Abertura <%= idx + 1 %></span></a><% } %>
    <% }) %>
  </div>
</div>


<% if (!isOSFechada) { %>
  <div class="card" style="margin-top:12px;">
    <h3>Concluir OS</h3>
    <form method="POST" action="/os/<%= os.id %>/concluir" enctype="multipart/form-data" id="form-concluir">
      <div class="grid2">
        <div>
          <label>Causa / Diagnóstico / Ação preventiva *</label>
          <textarea class="input" name="causa_diagnostico" required placeholder="Causa encontrada"></textarea>
        </div>
        <div>
          <label>Resumo técnico / Ação corretiva *</label>
          <textarea class="input" name="resumo_tecnico" required placeholder="Descreva a ação executada"></textarea>
        </div>
      </div>

      <div style="margin-top:8px; max-width:280px;">
        <label>Data de fim</label>
        <input class="input" type="date" name="data_fim" />
      </div>

      <div style="margin-top:8px;">
        <label>Peças utilizadas</label>
        <div id="pecas-wrap">
          <div class="pecas-grid">
            <input class="input" name="peca_descricao" placeholder="Peça" />
            <input class="input" name="peca_quantidade" type="number" min="0" step="0.01" placeholder="Qtd" />
            <input class="input" name="peca_descricao" placeholder="Peça" />
            <input class="input" name="peca_quantidade" type="number" min="0" step="0.01" placeholder="Qtd" />
          </div>
        </div>
      </div>

      <div style="margin-top:10px;">
        <label>Foto de fechamento *</label>
        <input id="fechamento_fotos" type="file" name="fechamento_fotos" accept="image/*" multiple style="display:none" />
        <button type="button" class="camera-btn" onclick="document.getElementById('fechamento_fotos').click()">📷 Adicionar fotos de fechamento</button>
        <div class="thumbs" id="preview-fechamento" style="margin-top:8px;"></div>
      </div>

      <div style="margin-top:12px; display:flex; justify-content:flex-end;">
        <button class="btn btn-green" type="submit">Concluir OS</button>
      </div>
    </form>
  </div>
<% } %>

<div class="card" style="margin-top:12px;">
  <h3 style="margin:0;">Fotos de fechamento</h3>
  <div class="muted">Registro visual após execução.</div>
  <div class="galeria">
    <% if (!(os.fotos_fechamento||[]).length) { %><span class="muted">Sem fotos de fechamento.</span><% } %>
    <% (os.fotos_fechamento||[]).forEach((f, idx) => { const src = f.pathPublic || f.path || f.filepath; %>
      <% if (src) { %><a class="foto-card" href="<%= src %>" target="_blank"><img src="<%= src %>" alt="foto fechamento <%= idx + 1 %>"/><span>Fechamento <%= idx + 1 %></span></a><% } %>
    <% }) %>
  </div>
</div>
