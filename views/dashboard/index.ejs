<% layout('layout') %>

<style>
  .tv-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
    grid-template-areas:
      "os andamento"
      "preventivas escala"
      "mural quick"
      "demandas quick";
    gap: 10px;
    align-items: start;
  }

  .dash-col {
    display:flex;
    flex-direction:column;
    gap:16px;
    min-width:0;
  }

  .dash-col .dashboard-card {
    height:auto;
    min-height:unset;
  }

  .dashboard-card { background:#fff; border:1px solid #e5e7eb; border-radius:14px; padding:12px; box-shadow:0 1px 2px rgba(15,23,42,.04); }
  .dashboard-title { font-size:13px; font-weight:900; letter-spacing:.04em; color:#475569; text-transform:uppercase; margin-bottom:10px; }

  .kpi-grid { display:grid; grid-template-columns:repeat(3,minmax(120px,1fr)); gap:8px; margin-bottom:10px; }
  .kpi-grid.two { grid-template-columns:repeat(2,minmax(120px,1fr)); margin-bottom:0; }
  .kpi-box { border:1px solid #e5e7eb; border-radius:10px; padding:8px 10px; background:#fafafa; }
  .kpi-label { font-size:clamp(12px, .9vw, 14px); color:#64748b; }
  .kpi-value { margin-top:2px; font-size:clamp(24px, 2.2vw, 36px); font-weight:900; line-height:1.1; color:#0f172a; }

  .table-wrap { overflow:auto; }
  .table.compact th, .table.compact td { padding:8px; vertical-align:middle; font-size:13px; }
  .table.compact thead th { background:#f8fafc; }
  .muted-xs { font-size:12px; color:#64748b; }
  .list-tight { margin:8px 0 0 16px; padding:0; }

  .pagination { display:flex; justify-content:space-between; align-items:center; margin-top:10px; gap:8px; flex-wrap:wrap; }
  .btn-outline { border:1px solid #d1d5db; border-radius:9px; padding:6px 10px; background:#fff; color:#0f172a; text-decoration:none; font-weight:700; font-size:12px; }
  .btn-inline { border:none; border-radius:8px; padding:5px 9px; background:#16a34a; color:#fff; font-weight:800; cursor:pointer; font-size:12px; }
  .aviso-item { border:1px solid #e5e7eb; border-radius:10px; padding:9px 10px; background:#fff; margin-top:8px; }
  .quick-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  .dashboard-actions { display:flex; gap:8px; flex-wrap:wrap; }
  .ranking-header { display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:10px; }
  .ranking-subtitle { font-size:11px; color:#64748b; font-weight:700; }
  .ranking-list { display:flex; flex-direction:column; gap:10px; }
  .ranking-item { display:grid; grid-template-columns:auto 1fr auto; gap:10px; align-items:center; border:1px solid #e2e8f0; border-radius:12px; padding:10px; background:linear-gradient(180deg,#ffffff 0%,#f8fafc 100%); }
  .ranking-pos { width:34px; height:34px; border-radius:999px; background:#0f172a; color:#fff; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:900; }
  .ranking-avatar-wrap { position:relative; display:inline-flex; }
  .ranking-avatar { width:38px; height:38px; border-radius:999px; object-fit:cover; border:2px solid #dbeafe; background:#e2e8f0; display:inline-flex; align-items:center; justify-content:center; font-size:11px; font-weight:800; color:#1e293b; transition:border-color .2s ease, box-shadow .2s ease; }
  .ranking-avatar.online { border-color:#22c55e; box-shadow:0 0 0 2px rgba(34,197,94,.2); }
  .ranking-online-dot { position:absolute; right:-1px; bottom:-1px; width:11px; height:11px; border-radius:999px; background:#22c55e; border:2px solid #fff; box-shadow:0 0 0 1px rgba(34,197,94,.35); }
  .ranking-main { display:flex; align-items:center; gap:9px; min-width:0; }
  .ranking-name { font-size:14px; font-weight:900; color:#0f172a; }
  .ranking-meta { font-size:11px; color:#64748b; margin-top:1px; }
  .ranking-score { text-align:right; }
  .ranking-score .pts { font-size:20px; font-weight:900; color:#0f766e; line-height:1; }
  .ranking-score .lbl { font-size:10px; color:#64748b; text-transform:uppercase; letter-spacing:.04em; }
  .ranking-highlight { border:1px solid #a7f3d0; background:#ecfdf5; color:#065f46; border-radius:10px; padding:8px 10px; font-size:12px; margin-top:10px; }
  .ranking-empty { border:1px dashed #cbd5e1; border-radius:10px; padding:10px; color:#64748b; font-size:12px; }

  .op-toast{position:fixed;right:16px;bottom:16px;z-index:9999;background:#0f172a;color:#fff;padding:10px 12px;border-radius:10px;font-weight:700;box-shadow:0 10px 20px rgba(0,0,0,.2);display:none;max-width:340px;}
  .op-toast.show{display:block;}
  .op-toast-grande{
    position:fixed;
    top:20px;
    left:50%;
    transform:translateX(-50%);
    z-index:10000;
    min-width:min(860px, calc(100vw - 24px));
    max-width:min(920px, calc(100vw - 24px));
    border:3px solid #dc2626;
    border-radius:16px;
    background:#7f1d1d;
    color:#fff;
    padding:18px 20px;
    box-shadow:0 20px 40px rgba(0,0,0,.35);
    display:none;
    animation: alertaPulse 1s infinite;
  }
  .op-toast-grande.show{display:block;}
  .op-toast-grande__titulo{font-size:30px;font-weight:900;letter-spacing:.02em;}
  .op-toast-grande__meta{font-size:20px;font-weight:800;margin-top:6px;}
  .boasvindas{border:1px solid #e2e8f0; background:#f8fafc; border-radius:12px; padding:10px 12px; margin-bottom:10px;}
  .alerta-tv { border:2px solid #dc2626; border-radius:14px; background:#fff1f2; color:#7f1d1d; padding:14px; margin-bottom:10px; display:flex; gap:14px; align-items:center; justify-content:space-between; }
  .alerta-tv.hidden { display:none; }
  .alerta-tv__title { font-size:28px; font-weight:900; letter-spacing:.02em; }
  .alerta-tv__meta { font-size:16px; font-weight:700; }
  .alerta-tv.piscar { animation: alertaPulse 1s infinite; }
  @keyframes alertaPulse { 0%{box-shadow:0 0 0 0 rgba(220,38,38,.45);} 70%{box-shadow:0 0 0 14px rgba(220,38,38,0);} 100%{box-shadow:0 0 0 0 rgba(220,38,38,0);} }
  .pill-prioridade { padding:3px 8px; border-radius:999px; font-size:11px; font-weight:800; border:1px solid #d1d5db; }
  .pill-status {
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-width:114px;
    min-height:30px;
    text-align:center;
    font-weight:800;
    white-space:nowrap;
  }
  .pill-prioridade.emergencial { background:#fee2e2; color:#991b1b; border-color:#fca5a5; }
  .pill-prioridade.alta { background:#ffedd5; color:#9a3412; border-color:#fdba74; }
  .os-row-critico { background:#f3f4f6; border-left:4px solid #9ca3af; }
  .os-row-medio { background:#fffbeb; border-left:4px solid #f59e0b; }
  .os-row-leve { background:#f8fafc; }

  @media (max-width: 1200px) {
    .tv-grid { grid-template-columns: 1fr; grid-template-areas: "os" "andamento" "preventivas" "escala" "mural" "quick" "demandas"; }
    .alerta-tv__title { font-size:22px; }
  }

  @media (max-width: 760px) {
    .dash-grid { grid-template-columns: 1fr !important; }
    .dash-col { gap: 16px; }
    .kpi-grid, .kpi-grid.two, .quick-grid { grid-template-columns:1fr; }
    .alerta-tv { flex-direction:column; align-items:flex-start; }
    .alerta-tv__title { font-size:20px; }
    .op-toast-grande{top:12px;padding:12px;min-width:calc(100vw - 16px);}
    .op-toast-grande__titulo{font-size:20px;}
    .op-toast-grande__meta{font-size:15px;}
    .dashboard-actions { gap:6px; }
    .dashboard-actions > * {
      width:auto;
      min-height:34px;
      padding:5px 9px;
      font-size:11px;
      text-align:center;
      justify-content:center;
    }
    .boasvindas { font-size:14px; }
    .kpi-value { font-size:clamp(22px, 7vw, 28px); }
    .table.compact th, .table.compact td { font-size:12px; padding:6px; }
    .area-escala .table td, .area-escala .table th { white-space:normal; }
  }
</style>

<%
  var safeDemandasResumo = demandasResumo || {};
  var demandasEmTrabalho = safeDemandasResumo.em_trabalho || [];
  var safeOSResumo = osResumo || {};
  var safeOSPainel = osPainel || {};
  var osItems = safeOSPainel.items || [];
  var osAndamento = osEmAndamento || [];
  var safeAvisos = avisos || [];
  var safeEscala = escala || {};
  var escalaDiurno = (safeEscala.diurno_mecanicos || []).map(function(p) { return p.nome; }).join(', ');
  var escalaApoio = (safeEscala.apoio_operacional || []).map(function(p) { return p.nome; }).join(', ');
  var escalaNoturno = (safeEscala.noturno || []).map(function(p) { return p.nome; }).join(', ');
  var escalaFolgasAfastamentos = safeEscala.folgas_afastamentos || [];
  var safeMotoresResumo = motoresResumo || {};
  var rankingMecanicosData = rankingMecanicos || {};
  var rankingMecanicosItems = rankingMecanicosData.itemsMecanicos || rankingMecanicosData.items || [];
  var rankingApoioItems = rankingMecanicosData.itemsApoio || [];
  var rankingMetaMensal = Number(rankingMecanicosData.metaMensal || 100);
  var rankingPesos = rankingMecanicosData.pesosCriticidade || { BAIXA: 0.5, MEDIA: 1, ALTA: 2, CRITICA: 3 };
  var onlineUserIds = new Set((onlineUsers || []).map(function(u) { return Number(u && u.id || 0); }).filter(Boolean));
    var safePreventivas = preventivas || {};
  var preventivasItems = safePreventivas.items || [];
  var preventivasResumo = safePreventivas.resumo || {};
  var preventivasCrit = safePreventivas.criticidade || {};
  var alertaInicial = alertaAtivo || null;
  var counters = operationalCounters || { osAbertas: 0, osCriticas: 0, preventivasHoje: 0 };
  var timezonePainel = TZ || 'America/Sao_Paulo';
  var horaPainel = Number(new Intl.DateTimeFormat('pt-BR', { hour: '2-digit', hour12: false, timeZone: timezonePainel }).format(new Date()));
  var horaAtualFmt = new Intl.DateTimeFormat('pt-BR', { hour: '2-digit', minute: '2-digit', timeZone: timezonePainel }).format(new Date());
  var saudacao = (horaPainel < 12) ? "Bom dia" : (horaPainel < 18 ? "Boa tarde" : "Boa noite");
  var roleNorm = (typeof normalizeRole === 'function') ? normalizeRole(user?.role || '') : String(user?.role || '').toUpperCase();
  var isMecanico = roleNorm === 'MECANICO';
  var isProducao = roleNorm === 'PRODUCAO' || roleNorm === 'ENCARREGADO_PRODUCAO';
  var isAdminPainel = roleNorm === 'ADMIN' || roleNorm === 'DIRETORIA' || roleNorm === 'RH' || roleNorm === 'MANUTENCAO_SUPERVISOR' || roleNorm === 'SUPERVISOR_MANUTENCAO' || roleNorm === 'ENCARREGADO_MANUTENCAO';
  var showPreventivasCard = isMecanico || isProducao || isAdminPainel;
%>

<div class="page-head">
  <div>
    <h1>Painel Operacional Reciclagem</h1>
    <p class="muted">TV da manutenção • OS, mural, preventivas, escala e demandas em tempo real</p>
    
  </div>
  <div class="dashboard-actions">
    <a class="btn-outline" href="/tv">Modo TV</a>
  </div>
</div>

<section id="alerta-tv" class="alerta-tv <%= alertaInicial ? 'piscar' : 'hidden' %>">
  <div>
    <div class="alerta-tv__title">⚠ NOVA OS EMERGENCIAL</div>
    <div class="alerta-tv__meta" id="alerta-tv-meta">
      <% if (alertaInicial) { %>
        Equipamento: <%= alertaInicial.equipamento || '-' %> • Setor: <%= alertaInicial.setor || '-' %> • Grau: <%= alertaInicial.grau || alertaInicial.prioridade || '-' %>
      <% } else { %>
        Nenhum alerta crítico no momento.
      <% } %>
    </div>
  </div>
  <div>
    <button id="btn-reconhecer-alerta" class="btn-inline" style="background:#dc2626;">Reconhecer alerta</button>
  </div>
</section>

<section class="boasvindas">
  <strong><%= saudacao %>, senhor <%= user?.name || "Equipe" %>.</strong>
  Bem-vindo ao sistema de manutenção Campo do Gado.
  <% if (isMecanico) { %>
    Você tem <strong><%= counters.osAbertas %></strong> ordens de serviço abertas
    <% if (counters.osCriticas > 0) { %>• <strong><%= counters.osCriticas %></strong> crítica(s) aguardando atendimento<% } %>
    <% if (counters.preventivasHoje > 0) { %>• <strong><%= counters.preventivasHoje %></strong> preventiva(s) pendente(s) hoje<% } %>.
  <% } %>
  <span class="muted-xs" style="display:block; margin-top:6px;">Horário de Brasília: <strong><%= horaAtualFmt %></strong></span>
</section>

<div id="op-toast" class="op-toast"></div>
<div id="op-toast-grande" class="op-toast-grande" role="alert" aria-live="assertive">
  <div class="op-toast-grande__titulo">🚨 NOVA ORDEM DE SERVIÇO</div>
  <div id="op-toast-grande-meta" class="op-toast-grande__meta">Aguardando evento...</div>
</div>

<div class="dash-grid">
  <div class="dash-col">
<section class="dashboard-card area-os">
    <div class="dashboard-title">Ordem de Serviço</div>
    <div class="kpi-grid">
      <div class="kpi-box"><div class="kpi-label">Abertas</div><div class="kpi-value"><%= safeOSResumo.abertas || 0 %></div></div>
      <div class="kpi-box"><div class="kpi-label">Em andamento</div><div class="kpi-value"><%= safeOSResumo.andamento || 0 %></div></div>
      <div class="kpi-box"><div class="kpi-label">Fechadas</div><div class="kpi-value"><%= safeOSResumo.fechadas || 0 %></div></div>
    </div>
    <div class="table-wrap">
      <table class="table compact">
        <thead><tr><th>#</th><th>Equipamento</th><th>Responsável(is)</th><th>Criticidade</th><th>Status</th><th>Abertura</th><th style="text-align:right;">Ações</th></tr></thead>
        <tbody>
          <% if (osItems.length === 0) { %><tr><td colspan="7" style="text-align:center; color:#6b7280;">Nenhuma OS aberta ou em andamento.</td></tr><% } %>
          <% osItems.forEach(function(o) { var prio = String(o.grau || o.prioridade || 'MEDIA').toUpperCase(); var rowClass = (prio === 'CRITICO' || prio === 'CRÍTICO' || prio === 'ALTO' || prio === 'EMERGENCIAL') ? 'os-row-critico' : ((prio === 'MEDIO' || prio === 'MÉDIO' || prio === 'MEDIA') ? 'os-row-medio' : 'os-row-leve'); %>
            <tr class="<%= rowClass %>">
              <td><%= o.id %></td>
              <td><strong><%= o.equipamento || '-' %></strong></td>
              <td><%= o.responsavel_exibicao || '-' %></td>
              <td><span class="pill-prioridade <%= (prio === 'CRITICO' || prio === 'CRÍTICO' || prio === 'EMERGENCIAL') ? 'emergencial' : ((prio === 'ALTO' || prio === 'ALTA' || prio === 'MEDIO' || prio === 'MÉDIO' || prio === 'MEDIA') ? 'alta' : '') %>"><%= prio %></span></td>
              <td>
                <% var statusOs = String(o.status || '').toUpperCase(); %>
                <% if (statusOs === 'ABERTA') { %><span class="pill-tag pill-amber pill-status">Aberta</span>
                <% } else if (statusOs === 'AGUARDANDO_EQUIPE') { %><span class="pill-tag pill-amber pill-status">Aguardando equipe</span>
                <% } else if (statusOs === 'ANDAMENTO' || statusOs === 'EM_ANDAMENTO') { %><span class="pill-tag pill-blue pill-status">Em andamento</span>
                <% } else if (statusOs === 'PAUSADA') { %><span class="pill-tag pill-gray pill-status">Pausada</span>
                <% } else if (statusOs === 'CONCLUIDA' || statusOs === 'FINALIZADA' || statusOs === 'FECHADA') { %><span class="pill-tag pill-green pill-status">Fechada</span>
                <% } else if (statusOs === 'CANCELADA') { %><span class="pill-tag pill-gray pill-status">Cancelada</span>
                <% } else { %><span class="pill-tag pill-gray pill-status"><%= statusOs || '-' %></span><% } %>
              </td>
              <td><%= o.abertura ? fmtBR(o.abertura) : (o.opened_at ? fmtBR(o.opened_at) : '-') %></td>
              <td style="text-align:right;">
                <% if (statusOs === 'ABERTA') { %>
                  <form method="POST" action="/os/<%= o.id %>/status" style="display:inline;"><input type="hidden" name="status" value="ANDAMENTO"><button class="btn-inline" type="submit">Iniciar</button></form>
                <% } else { %><a class="btn-outline" href="/os/<%= o.id %>">Ver</a><% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="pagination">
      <div class="muted-xs">Mostrando <strong><%= osItems.length || 0 %></strong> OS ativas (limite de <strong><%= safeOSPainel.pageSize || 15 %></strong> no painel). Fechadas ficam apenas no histórico do equipamento.</div>
    </div>
  </section>

<% if (showPreventivasCard) { %>
<section class="dashboard-card area-preventivas">
    <div class="dashboard-title">Preventivas Programadas</div>
    <div class="kpi-grid">
      <div class="kpi-box"><div class="kpi-label">Preventivas abertas</div><div class="kpi-value"><%= preventivasResumo.abertas || 0 %></div></div>
      <div class="kpi-box"><div class="kpi-label">Em andamento</div><div class="kpi-value"><%= preventivasResumo.andamento || 0 %></div></div>
      <div class="kpi-box"><div class="kpi-label">Fechadas</div><div class="kpi-value"><%= preventivasResumo.fechadas || 0 %></div></div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:8px;margin-bottom:10px;">
      <span class="pill-tag pill-green">Baixa: <%= preventivasCrit.BAIXA || 0 %></span>
      <span class="pill-tag pill-blue">Média: <%= preventivasCrit.MEDIA || 0 %></span>
      <span class="pill-tag pill-amber">Alta: <%= preventivasCrit.ALTA || 0 %></span>
      <span class="pill-tag pill-gray">Crítica: <%= preventivasCrit.CRITICA || 0 %></span>
    </div>
    <% if (preventivasItems.length === 0) { %><p class="muted" style="margin:0;">Nenhuma preventiva ativa.</p><% } else { %>
      <div class="table-wrap"><table class="table compact"><thead><tr><th>#</th><th>Equipamento</th><th>Responsável(is)</th><th>Data prevista</th><th>Criticidade</th><th>Status</th><th style="text-align:right;">Ações</th></tr></thead><tbody>
      <% preventivasItems.forEach(function(p) { var critic = String(p.criticidade || 'MEDIA').toUpperCase(); var stat = String(p.status || '').toUpperCase(); %>
        <tr class="<%= critic === 'CRITICA' ? 'os-row-critico' : (critic === 'ALTA' ? 'os-row-medio' : 'os-row-leve') %>">
          <td>#<%= p.id %></td>
          <td><strong><%= p.equipamento_nome || '-' %></strong></td>
          <td><%= p.responsavel_exibicao || '-' %></td>
          <td><%= p.data_prevista || '-' %></td>
          <td><span class="pill-tag <%= critic === 'CRITICA' ? 'pill-gray' : (critic === 'ALTA' ? 'pill-amber' : (critic === 'MEDIA' ? 'pill-blue' : 'pill-green')) %>"><%= critic %></span></td>
          <td><span class="pill-tag <%= stat === 'EM_ANDAMENTO' ? 'pill-blue' : (stat === 'PENDENTE' ? 'pill-amber' : 'pill-gray') %>"><%= stat %></span></td>
          <td style="text-align:right;">
            <% var podeIniciar = roleNorm === 'ADMIN' || roleNorm === 'MANUTENCAO_SUPERVISOR' || roleNorm === 'SUPERVISOR_MANUTENCAO' || roleNorm === 'ENCARREGADO_MANUTENCAO' || Number(p.responsavel_1_id || 0) === Number(user?.id || 0) || Number(p.responsavel_2_id || 0) === Number(user?.id || 0); %>
            <% if (stat === 'PENDENTE' && podeIniciar) { %>
              <form method="POST" action="/dashboard/preventivas/<%= p.id %>/iniciar" style="display:inline;">
                <button class="btn-inline" type="submit">Iniciar</button>
              </form>
            <% } else if ((stat === 'EM_ANDAMENTO' || stat === 'ANDAMENTO') && podeIniciar) { %>
              <form method="POST" action="/dashboard/preventivas/<%= p.id %>/finalizar" style="display:inline;">
                <button class="btn-inline" type="submit" style="background:#2563eb;">Finalizar</button>
              </form>
            <% } else { %>
              <span class="muted-xs">—</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
      </tbody></table></div>
    <% } %>
    <div class="pagination"><div class="muted-xs">Mostrando 10 preventivas ativas no painel. Finalizadas ficam apenas no histórico do equipamento.</div></div>
  </section>
<% } %>

<section class="dashboard-card area-demandas">
    <div class="dashboard-title">Demandas</div>
    <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:8px;">
      <span class="pill-tag pill-blue">Novas: <%= safeDemandasResumo.novas || 0 %></span>
      <span class="pill-tag pill-amber">Em andamento: <%= safeDemandasResumo.em_andamento || 0 %></span>
      <span class="pill-tag pill-gray">Paradas: <%= safeDemandasResumo.paradas || 0 %></span>
    </div>
    <ul class="list-tight">
      <% if (demandasEmTrabalho.length === 0) { %><li class="muted-xs">Nenhuma demanda em andamento.</li><% } %>
      <% demandasEmTrabalho.slice(0, 4).forEach(function(d) { %><li><a href="/demandas/<%= d.id %>">#<%= d.id %> - <%= d.titulo %></a></li><% }) %>
    </ul>
  </section>
  </div>

  <div class="dash-col">
<section class="dashboard-card area-escala">
    <div class="dashboard-title">Escala da Semana</div>
    <% if (escalaDiurno || escalaApoio || escalaNoturno || escalaFolgasAfastamentos.length) { %>
      <div class="muted-xs" style="margin-bottom:8px;">Semana #<%= safeEscala.semana_numero || '-' %> • <%= safeEscala.data_inicio || '-' %> até <%= safeEscala.data_fim || '-' %></div>
      <table class="table compact"><tbody>
        <tr><td><strong>Dia (mecânicos)</strong></td><td><%= escalaDiurno || '-' %></td></tr>
        <tr><td><strong>Apoio operacional</strong></td><td><%= escalaApoio || '-' %></td></tr>
        <tr><td><strong>Noite (responsável)</strong></td><td><%= escalaNoturno || '-' %></td></tr>
      </tbody></table>

      <div class="dashboard-title" style="margin-top:10px; margin-bottom:6px; font-size:11px;">Folga / atestado</div>
      <% if (escalaFolgasAfastamentos.length === 0) { %>
        <p class="muted-xs" style="margin:0;">Sem mecânicos em folga/atestado nesta semana.</p>
      <% } else { %>
        <ul class="list-tight" style="margin-top:0;">
          <% escalaFolgasAfastamentos.forEach(function(item) { %>
            <li>
              <strong><%= item.nome || '-' %></strong>
              — <%= item.tipo || '-' %>
              <% if (item.data_inicio || item.data_fim) { %>
                (<%= item.data_inicio || '-' %> até <%= item.data_fim || '-' %>)
              <% } %>
            </li>
          <% }) %>
        </ul>
      <% } %>
    <% } else { %><p class="muted" style="margin:0;">Escala não disponível.</p><% } %>
</section>

<section class="dashboard-card area-ranking-mecanicos">
    <div class="ranking-header">
      <div class="dashboard-title" style="margin:0;">Ranking dos mecânicos</div>
      <span class="ranking-subtitle">Ranking por participação na OS</span>
    </div>
    <p class="muted-xs" style="margin-top:-4px; margin-bottom:10px;">
      Meta mensal: <strong><%= rankingMetaMensal %> pontos</strong>. Pesos: <strong>Baixa <%= rankingPesos.BAIXA %></strong> • <strong>Média <%= rankingPesos.MEDIA %></strong> • <strong>Alta <%= rankingPesos.ALTA %></strong> • <strong>Crítica <%= rankingPesos.CRITICA %></strong>.
      A pontuação é dividida igualmente entre os participantes de cada OS.
    </p>
    <% if (!rankingMecanicosItems.length) { %>
      <div class="ranking-empty">Sem fechamentos suficientes nesta semana para montar o ranking.</div>
    <% } else { %>
      <div class="ranking-list">
        <% rankingMecanicosItems.forEach(function(item) { %>
          <article class="ranking-item">
            <div class="ranking-pos"><%= item.posicao %>º</div>
            <div class="ranking-main">
              <% var itemOnline = onlineUserIds.has(Number(item.user_id || 0)); %>
              <span class="ranking-avatar-wrap">
                <% if (item.photo_path) { %>
                  <img class="ranking-avatar <%= itemOnline ? 'online' : '' %>" src="<%= item.photo_path %>" alt="Foto de <%= item.nome %>">
                <% } else { %>
                  <span class="ranking-avatar <%= itemOnline ? 'online' : '' %>"><%= String(item.nome || '?').split(' ').map(function(n){return n[0];}).join('').slice(0,2).toUpperCase() %></span>
                <% } %>
                <% if (itemOnline) { %><span class="ranking-online-dot" title="Online" aria-label="Online"></span><% } %>
              </span>
              <div style="min-width:0;">
                <div class="ranking-name"><%= item.nome %></div>
                <div class="ranking-meta">
                  <%= item.os_total || 0 %> OS finalizadas
                  • Críticas: <%= item.os_criticas || 0 %>
                  • Altas: <%= item.os_altas || 0 %>
                </div>
              </div>
            </div>
            <div class="ranking-score">
              <div class="pts"><%= Number(item.score || 0).toFixed(1) %></div>
              <div class="lbl">pontos</div>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>

<section class="dashboard-card area-ranking-apoio">
    <div class="ranking-header">
      <div class="dashboard-title" style="margin:0;">Ranking do apoio operacional</div>
      <span class="ranking-subtitle">Auxiliares elegíveis para escala de folga</span>
    </div>
    <p class="muted-xs" style="margin-top:-4px; margin-bottom:10px;">
      Controle de pontuação dos auxiliares/apoio para reconhecimento e escalonamento de folgas aos sábados após atingir a meta de <strong><%= rankingMetaMensal %> pontos</strong>.
    </p>
    <% if (!rankingApoioItems.length) { %>
      <div class="ranking-empty">Sem fechamentos suficientes nesta semana para montar o ranking de apoio.</div>
    <% } else { %>
      <div class="ranking-list">
        <% rankingApoioItems.forEach(function(item) { %>
          <article class="ranking-item">
            <div class="ranking-pos"><%= item.posicao %>º</div>
            <div class="ranking-main">
              <% var itemOnline = onlineUserIds.has(Number(item.user_id || 0)); %>
              <span class="ranking-avatar-wrap">
                <% if (item.photo_path) { %>
                  <img class="ranking-avatar <%= itemOnline ? 'online' : '' %>" src="<%= item.photo_path %>" alt="Foto de <%= item.nome %>">
                <% } else { %>
                  <span class="ranking-avatar <%= itemOnline ? 'online' : '' %>"><%= String(item.nome || '?').split(' ').map(function(n){return n[0];}).join('').slice(0,2).toUpperCase() %></span>
                <% } %>
                <% if (itemOnline) { %><span class="ranking-online-dot" title="Online" aria-label="Online"></span><% } %>
              </span>
              <div style="min-width:0;">
                <div class="ranking-name"><%= item.nome %></div>
                <div class="ranking-meta">
                  <%= item.os_total || 0 %> OS finalizadas
                  • Críticas: <%= item.os_criticas || 0 %>
                  • Altas: <%= item.os_altas || 0 %>
                </div>
              </div>
            </div>
            <div class="ranking-score">
              <div class="pts"><%= Number(item.score || 0).toFixed(1) %></div>
              <div class="lbl">pontos</div>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>

<section class="dashboard-card area-avisos">
    <div class="dashboard-title">Avisos</div>
    <% if (safeAvisos.length === 0) { %>
      <p class="muted" style="margin:0;">Nenhum aviso ativo no momento.</p>
    <% } else { %>
      <% safeAvisos.slice(0, 5).forEach(function(aviso) { %>
        <article class="aviso-item">
          <strong><%= aviso.titulo || 'Aviso' %></strong>
          <div class="muted-xs" style="margin-top:4px;"><%= aviso.mensagem || '-' %></div>
          <div class="muted-xs" style="margin-top:6px;">
            <% if (aviso.publicado_em) { %>Publicado em <%= fmtBR(aviso.publicado_em) %><% } %>
            <% if (aviso.autor_nome) { %> • por <%= aviso.autor_nome %><% } %>
          </div>
        </article>
      <% }) %>
    <% } %>
  </section>

<section class="area-quick">
    <div class="dashboard-card"><div class="dashboard-title">Motores</div><div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:8px;"><span class="pill-tag pill-green">Funcionando: <%= safeMotoresResumo.em_funcionamento || 0 %></span><span class="pill-tag pill-blue">Estoque: <%= safeMotoresResumo.em_estoque || 0 %></span><span class="pill-tag pill-amber">Conserto: <%= safeMotoresResumo.em_conserto || 0 %></span></div></div>
  </section>
  </div>
</div>

<script>
(function(){
  var eventSource = new EventSource('/dashboard/alertas/stream');
  var box = document.getElementById('alerta-tv');
  var meta = document.getElementById('alerta-tv-meta');
  var btnReconhecer = document.getElementById('btn-reconhecer-alerta');
  var alertaAtual = <%- JSON.stringify(alertaInicial || null) %>;

  function tocarAlerta(tipo){
    try {
      var src = tipo === 'critica' ? '/audio/os-critica.mp3' : '/audio/os-nova.mp3';
      var audio = new Audio(src);
      audio.volume = 1;
      audio.play().catch(function(){});
    } catch(_e){}
  }

  function toast(msg){
    var el = document.getElementById('op-toast');
    if (!el) return;
    el.textContent = msg;
    el.classList.add('show');
    setTimeout(function(){ el.classList.remove('show'); }, 4000);
  }

  function toastGrande(titulo, msg){
    var boxGrande = document.getElementById('op-toast-grande');
    var metaGrande = document.getElementById('op-toast-grande-meta');
    if (!boxGrande || !metaGrande) return;
    var tituloEl = boxGrande.querySelector('.op-toast-grande__titulo');
    if (tituloEl && titulo) tituloEl.textContent = titulo;
    metaGrande.textContent = msg || '';
    boxGrande.classList.add('show');
    setTimeout(function(){ boxGrande.classList.remove('show'); }, 9000);
  }

  function renderAlerta(payload){
    if (!payload || !payload.id_os) {
      box.classList.add('hidden');
      box.classList.remove('piscar');
      meta.textContent = 'Nenhum alerta crítico no momento.';
      return;
    }
    alertaAtual = payload;
    box.classList.remove('hidden');
    box.classList.add('piscar');
    meta.textContent = 'Equipamento: ' + (payload.equipamento || '-') + ' • Setor: ' + (payload.setor || '-') + ' • Grau: ' + (payload.grau || payload.prioridade || '-') + ' • OS #' + payload.id_os;
  }

  eventSource.addEventListener('estado_inicial', function(e){
    try {
      var data = JSON.parse(e.data || '{}');
      if (data.alertaAtivo) renderAlerta({
        id_os: data.alertaAtivo.os_id,
        equipamento: data.alertaAtivo.equipamento,
        setor: data.alertaAtivo.setor,
        prioridade: data.alertaAtivo.prioridade,
        grau: data.alertaAtivo.grau,
      });
    } catch(_e){}
  });

  eventSource.addEventListener('os_criada', function(e){
    var data = {};
    try { data = JSON.parse(e.data || '{}'); } catch(_e) {}
    var mensagem = 'OS #' + (data.id_os || '-') + ' • Equipamento: ' + (data.equipamento || '-') + ' • Setor: ' + (data.setor || '-') + ' • Prioridade: ' + (data.prioridade || '-');
    toast('Nova OS #' + (data.id_os || '-') + ' aberta para ' + (data.equipamento || 'equipamento') + '.');
    toastGrande('🚨 NOVA ORDEM DE SERVIÇO', mensagem);
    tocarAlerta('normal');
    setTimeout(function(){ window.location.reload(); }, 1200);
  });

  eventSource.addEventListener('nova_os_emergencial', function(e){
    var data = JSON.parse(e.data || '{}');
    renderAlerta(data);
    tocarAlerta('critica');
    setTimeout(function(){ window.location.reload(); }, 1800);
  });

  eventSource.addEventListener('os_status_alterado', function(e){
    var data = {};
    try { data = JSON.parse(e.data || '{}'); } catch(_e) {}
    var statusAtual = String(data.status || '').toUpperCase();
    var finalizada = ['FECHADA', 'FINALIZADA', 'CONCLUIDA', 'CONCLUÍDA'].indexOf(statusAtual) >= 0;
    toast(finalizada
      ? 'OS #' + (data.id_os || '-') + ' finalizada.'
      : 'OS #' + (data.id_os || '-') + ' mudou de status para ' + (data.status || '-') + '.');
    tocarAlerta(finalizada ? 'critica' : 'normal');
    setTimeout(function(){ window.location.reload(); }, 1200);
  });



  var isTVMode = <%- JSON.stringify(Boolean(tvMode)) %>;
  if (isTVMode) {
    setInterval(function(){ window.location.reload(); }, 30000);
    if (document.documentElement && document.documentElement.requestFullscreen) {
      setTimeout(function(){ document.documentElement.requestFullscreen().catch(function(){}); }, 800);
    }
  }

  btnReconhecer?.addEventListener('click', function(){
    if (!alertaAtual || !alertaAtual.id_os) return;
    fetch('/dashboard/alertas/reconhecer', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ os_id: alertaAtual.id_os })
    }).then(function(){
      box.classList.remove('piscar');
      box.classList.add('hidden');
      setTimeout(function(){ window.location.reload(); }, 500);
    }).catch(function(){});
  });
})();
</script>
