<% layout('layout') %>
<div class="tv-wrapper" id="tv-app">
  <header class="tv-header card">
    <div class="brand-wrap">
      <div class="brand-icon" aria-hidden="true">🛠️</div>
      <div>
      <h1>Manutenção Campo do Gado • Modo TV</h1>
      <p class="subtitle">Monitoramento contínuo industrial em tempo real</p>
      </div>
    </div>
    <div class="topbar-wrap">
      <div class="online-box">
        <label>Mecânicos online</label>
        <div id="mecanicos-online" class="online-list"></div>
      </div>
      <div class="status-wrap">
        <div id="tv-date" class="date"></div>
        <div id="tv-clock" class="clock"></div>
        <div class="system-online"><span class="dot"></span> Sistema Online</div>
      </div>
    </div>
  </header>

  <main class="tv-grid" id="tv-grid">
    <section class="card card-os">
      <h2>OS Tempo Real</h2>
      <div class="kpi-row">
        <div class="kpi"><span>Abertas</span><strong id="os-abertas">0</strong></div>
        <div class="kpi"><span>Em andamento</span><strong id="os-andamento">0</strong></div>
        <div class="kpi critica"><span>Paradas críticas</span><strong id="os-criticas">0</strong></div>
      </div>
      <div class="table-wrap tv-table-wrap">
        <table class="tv-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Equipamento</th>
              <th>Mecânico(s)</th>
              <th>Criticidade</th>
              <th>Status</th>
              <th>Abertura</th>
            </tr>
          </thead>
          <tbody id="os-lista"></tbody>
        </table>
      </div>
    </section>

    <section class="card card-ranking">
      <h2>Ranking Mecânicos (Top 5)</h2>
      <ol id="ranking-list" class="ranking"></ol>
    </section>

    <section class="card">
      <h2>Escala</h2>
      <div class="escala-grid">
        <div><label>Dia</label><p id="escala-dia">-</p></div>
        <div><label>Noite</label><p id="escala-noite">-</p></div>
        <div><label>Apoio</label><p id="escala-apoio">-</p></div>
      </div>
    </section>

    <section class="card">
      <h2>Gráfico OS por Status</h2>
      <canvas id="chart-os"></canvas>
    </section>

    <section class="card card-preventivas">
      <h2>Preventivas</h2>
      <div class="kpi-row">
        <div class="kpi"><span>Total</span><strong id="prev-total">0</strong></div>
        <div class="kpi ok"><span>Verde (ok)</span><strong id="prev-verde">0</strong></div>
        <div class="kpi atencao"><span>Amarelo</span><strong id="prev-amarelo">0</strong></div>
        <div class="kpi atraso"><span>Vermelho</span><strong id="prev-vermelho">0</strong></div>
      </div>
      <div class="table-wrap tv-table-wrap">
        <table class="tv-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Equipamento</th>
              <th>Mecânico(s)</th>
              <th>Criticidade</th>
              <th>Data preventiva</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="prev-lista"></tbody>
        </table>
      </div>
      <h3>Preventivas por criticidade</h3>
      <canvas id="chart-prev"></canvas>
    </section>

    <section class="card">
      <h2>Alertas</h2>
      <ul id="alertas-list" class="alerts"></ul>
      <h3>Performance da equipe</h3>
      <canvas id="chart-team"></canvas>
    </section>
  </main>

  <audio id="audio-critico" src="/audio/os-critica.mp3" preload="auto"></audio>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const REFRESH_MS = 10000;
  let osChart, prevChart, teamChart;
  let lastCriticalCount = 0;

  function setDateTime() {
    const now = new Date();
    document.getElementById('tv-clock').textContent = now.toLocaleTimeString('pt-BR');
    document.getElementById('tv-date').textContent = now.toLocaleDateString('pt-BR', { weekday:'long', day:'2-digit', month:'2-digit', year:'numeric' });
  }

  function textList(arr) {
    return (arr && arr.length) ? arr.join(', ') : '-';
  }

  function buildCharts(data) {
    const osCtx = document.getElementById('chart-os');
    const prevCtx = document.getElementById('chart-prev');
    const teamCtx = document.getElementById('chart-team');

    if (!osChart) {
      osChart = new Chart(osCtx, {
        type: 'doughnut',
        data: { labels: ['Abertas', 'Em andamento', 'Fechadas'], datasets: [{ data: [0,0,0], backgroundColor: ['#2563EB','#FACC15','#16A34A'] }] },
        options: { plugins: { legend: { labels: { color: '#0f172a' } } } }
      });
    }

    if (!prevChart) {
      prevChart = new Chart(prevCtx, {
        type: 'bar',
        data: { labels: ['Baixa', 'Média', 'Alta', 'Crítica'], datasets: [{ data: [0,0,0,0], backgroundColor: ['#16A34A','#84CC16','#FACC15','#DC2626'] }] },
        options: { scales: { y: { beginAtZero: true } }, plugins: { legend: { display: false } } }
      });
    }

    if (!teamChart) {
      teamChart = new Chart(teamCtx, {
        type: 'bar',
        data: { labels: [], datasets: [{ label: 'OS concluídas', data: [], backgroundColor: '#2563EB' }] },
        options: { scales: { y: { beginAtZero: true } }, plugins: { legend: { display: false } } }
      });
    }

    osChart.data.datasets[0].data = [data.charts.osStatus.abertas, data.charts.osStatus.andamento, data.charts.osStatus.fechadas];
    osChart.update();

    prevChart.data.datasets[0].data = [
      data.charts.preventivasCriticidade.baixa,
      data.charts.preventivasCriticidade.media,
      data.charts.preventivasCriticidade.alta,
      data.charts.preventivasCriticidade.critica,
    ];
    prevChart.update();

    teamChart.data.labels = (data.charts.equipePerformance || []).map((i) => i.nome);
    teamChart.data.datasets[0].data = (data.charts.equipePerformance || []).map((i) => i.concluidas);
    teamChart.update();
  }

  function formatDate(value) {
    if (!value) return '-';
    const parsed = new Date(value);
    if (Number.isNaN(parsed.getTime())) return value;
    return parsed.toLocaleDateString('pt-BR');
  }

  function renderOnlineMecanicos(list = []) {
    const el = document.getElementById('mecanicos-online');
    el.innerHTML = (list || []).length
      ? list.map((m) => `<span class="online-pill"><span class="online-dot"></span>${m.nome || '-'}</span>`).join('')
      : '<span class="online-pill muted-online">Nenhum mecânico online</span>';
  }

  function render(data) {
    document.getElementById('os-abertas').textContent = data.os.abertas;
    document.getElementById('os-andamento').textContent = data.os.andamento;
    document.getElementById('os-criticas').textContent = data.os.criticas;

    const criticaEl = document.querySelector('.kpi.critica');
    criticaEl.classList.toggle('blink', data.os.criticas > 0);

    document.getElementById('prev-total').textContent = data.preventivas.total;
    document.getElementById('prev-verde').textContent = data.preventivas.status.verde;
    document.getElementById('prev-amarelo').textContent = data.preventivas.status.amarelo;
    document.getElementById('prev-vermelho').textContent = data.preventivas.status.vermelho;

    document.getElementById('escala-dia').textContent = textList(data.escala.dia);
    document.getElementById('escala-noite').textContent = textList(data.escala.noite);
    document.getElementById('escala-apoio').textContent = textList(data.escala.apoio);
    renderOnlineMecanicos(data.mecanicosOnline || []);

    const osLista = document.getElementById('os-lista');
    osLista.innerHTML = (data.os.itens || []).slice(0, 8).map((o) => {
      const critic = ['CRITICO','CRÍTICO','ALTO','ALTA','EMERGENCIAL'].includes(String(o.grau || o.prioridade || '').toUpperCase());
      const prio = String(o.grau || o.prioridade || 'MÉDIA').toUpperCase();
      return `<tr class="${critic ? 'critical-row' : ''}">
        <td>#${o.id || '-'}</td>
        <td>${o.equipamento || '-'}</td>
        <td>${o.responsavel_exibicao || '-'}</td>
        <td><span class="tv-pill ${critic ? 'pill-red' : 'pill-blue'}">${prio}</span></td>
        <td>${o.status || '-'}</td>
        <td>${formatDate(o.abertura || o.opened_at)}</td>
      </tr>`;
    }).join('') || '<tr><td colspan="6" class="empty-row">Nenhuma OS ativa.</td></tr>';

    const prevLista = document.getElementById('prev-lista');
    prevLista.innerHTML = (data.preventivas.itens || []).slice(0, 8).map((p) => {
      const critic = String(p.criticidade || 'MEDIA').toUpperCase();
      const critClass = critic === 'CRITICA' ? 'pill-red' : (critic === 'ALTA' ? 'pill-amber' : 'pill-blue');
      const stat = String(p.status || '-').toUpperCase();
      const statClass = stat === 'PENDENTE' ? 'pill-amber' : (stat.includes('ANDAMENTO') ? 'pill-blue' : 'pill-green');
      return `<tr>
        <td>#${p.id || '-'}</td>
        <td>${p.equipamento_nome || '-'}</td>
        <td>${p.responsavel_exibicao || '-'}</td>
        <td><span class="tv-pill ${critClass}">${critic}</span></td>
        <td>${formatDate(p.data_prevista)}</td>
        <td><span class="tv-pill ${statClass}">${stat}</span></td>
      </tr>`;
    }).join('') || '<tr><td colspan="6" class="empty-row">Nenhuma preventiva ativa.</td></tr>';

    const ranking = document.getElementById('ranking-list');
    ranking.innerHTML = (data.ranking || []).map((r, idx) => `
      <li class="${idx === 0 ? 'first' : ''}"><span>${r.nome}</span><strong>${r.pontuacao}</strong></li>
    `).join('') || '<li><span>Sem dados</span><strong>0</strong></li>';

    const alertas = document.getElementById('alertas-list');
    alertas.innerHTML = (data.alertas || []).map((a) => `<li>${a.mensagem}</li>`).join('') || '<li>Nenhum alerta no momento.</li>';

    if (data.os.criticas > lastCriticalCount) {
      document.getElementById('audio-critico').play().catch(() => {});
    }
    lastCriticalCount = data.os.criticas;

    buildCharts(data);
  }

  async function refresh() {
    try {
      const res = await fetch('/api/tv-data', { cache: 'no-store' });
      if (!res.ok) return;
      const data = await res.json();
      render(data);
    } catch (_e) {
      // keep current state and retry on next cycle
    }
  }

  setDateTime();
  setInterval(setDateTime, 1000);
  setInterval(refresh, REFRESH_MS);
  refresh();
</script>

<style>
  body { margin: 0; background: radial-gradient(circle at top left, #152238 0%, #0c1424 55%, #060b14 100%); }
  .tv-wrapper { width: 100vw; min-height: 100vh; padding: 16px; box-sizing: border-box; color: #e2e8f0; font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; }
  .tv-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; gap: 16px; }
  .brand-wrap { display: flex; align-items: center; gap: 14px; }
  .brand-icon { width: 56px; height: 56px; border-radius: 14px; display: grid; place-items: center; font-size: 30px; background: linear-gradient(145deg, #1d4ed8, #0b1020); border: 1px solid rgba(148, 163, 184, .35); }
  .tv-header h1 { font-size: 30px; margin: 0; }
  .subtitle { margin: 4px 0 0; color: #94a3b8; font-size: 18px; }
  .topbar-wrap { margin-left: auto; display: flex; align-items: flex-start; gap: 18px; }
  .online-box { text-align: right; max-width: 460px; }
  .online-box label { display: block; margin-bottom: 4px; font-size: 13px; color: #94a3b8; text-transform: uppercase; letter-spacing: .05em; }
  .online-list { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 6px; }
  .online-pill { display: inline-flex; align-items: center; gap: 6px; padding: 3px 8px; border-radius: 999px; font-size: 13px; background: rgba(15, 23, 42, .6); border: 1px solid rgba(71, 85, 105, .6); }
  .online-dot { width: 8px; height: 8px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 8px rgba(34, 197, 94, .8); }
  .muted-online { color: #94a3b8; }
  .status-wrap { text-align: right; }
  .date { text-transform: capitalize; font-size: 18px; color: #cbd5e1; }
  .clock { font-size: 38px; font-weight: 800; color: #60a5fa; }
  .system-online { margin-top: 4px; font-size: 16px; font-weight: 600; color: #16A34A; }
  .dot { width: 10px; height: 10px; border-radius: 50%; background: #16A34A; display: inline-block; margin-right: 6px; }

  .tv-grid { display: grid; gap: 12px; grid-template-columns: 1.8fr 1fr 1fr; }
  .card { background: linear-gradient(160deg, rgba(15, 23, 42, .88), rgba(2, 6, 23, .9)); border-radius: 16px; box-shadow: 0 8px 22px rgba(2, 6, 23, .45); padding: 14px; border: 1px solid rgba(71, 85, 105, .4); }
  .card-os, .card-preventivas { grid-column: span 2; }
  h2 { margin: 0 0 10px; font-size: 24px; }
  h3 { margin: 12px 0 8px; font-size: 20px; }

  .kpi-row { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; margin-bottom: 10px; }
  .card-os .kpi-row { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .kpi { background: rgba(15, 23, 42, .6); border-radius: 14px; padding: 12px; border: 1px solid rgba(51, 65, 85, .7); }
  .kpi span { display: block; color: #94a3b8; font-size: 16px; }
  .kpi strong { font-size: 36px; line-height: 1.1; }
  .kpi.ok strong { color: #4ade80; }
  .kpi.atencao strong { color: #facc15; }
  .kpi.atraso strong, .kpi.critica strong { color: #f87171; }

  .tv-table-wrap { max-height: 280px; overflow: auto; border-radius: 12px; border: 1px solid rgba(51, 65, 85, .8); }
  .tv-table { width: 100%; border-collapse: collapse; font-size: 15px; }
  .tv-table thead th { position: sticky; top: 0; z-index: 1; text-align: left; padding: 8px; background: #0f172a; color: #cbd5e1; border-bottom: 1px solid #334155; }
  .tv-table tbody td { padding: 8px; border-bottom: 1px solid rgba(51, 65, 85, .5); color: #e2e8f0; }
  .critical-row td { background: rgba(127, 29, 29, .45); }
  .empty-row { text-align: center; color: #94a3b8 !important; padding: 16px !important; }
  .tv-pill { display: inline-block; padding: 3px 8px; border-radius: 999px; font-size: 12px; font-weight: 700; }
  .pill-red { background: #7f1d1d; color: #fecaca; }
  .pill-blue { background: #1e3a8a; color: #dbeafe; }
  .pill-amber { background: #854d0e; color: #fde68a; }
  .pill-green { background: #14532d; color: #bbf7d0; }

  .ranking { list-style: none; margin: 0; padding: 0; display: grid; gap: 8px; }
  .ranking li { display: flex; justify-content: space-between; align-items: center; padding: 10px 12px; border-radius: 12px; border: 1px solid rgba(71, 85, 105, .7); font-size: 20px; background: rgba(15, 23, 42, .55); }
  .ranking li.first { background: #1e3a8a; border-color: #60a5fa; font-size: 24px; }

  .escala-grid { display: grid; gap: 10px; }
  .escala-grid label { font-size: 16px; color: #94a3b8; }
  .escala-grid p { margin: 4px 0 0; font-size: 24px; font-weight: 700; }

  .alerts { margin: 0; padding: 0 0 0 20px; display: grid; gap: 8px; font-size: 18px; }

  .blink { animation: blink 1s infinite; }
  @keyframes blink { 50% { opacity: 0.3; } }

  @media (max-width: 1400px) {
    .tv-header { flex-direction: column; align-items: flex-start; }
    .topbar-wrap { width: 100%; justify-content: space-between; }
    .tv-grid { grid-template-columns: 1fr; }
    .card-os, .card-preventivas { grid-column: span 1; }
    .kpi-row { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
</style>
