<% layout('layout') %>
<link rel="stylesheet" href="/css/inspecao.css" />
<%
  const prevMes = mes === 1 ? 12 : mes - 1;
  const prevAno = mes === 1 ? ano - 1 : ano;
  const nextMes = mes === 12 ? 1 : mes + 1;
  const nextAno = mes === 12 ? ano + 1 : ano;
  const canEdit = canAccessModule(normalizeRole(user?.role), 'inspecao_edit');
%>

<div class="page-head">
  <div>
    <h1>PAC 01 – Inspeção</h1>
    <p class="muted">Mês <strong><%= String(mes).padStart(2,'0') %>/<%= ano %></strong> • Grade e NC carregadas automaticamente pelas OS.</p>
  </div>
</div>

<div class="card" style="margin-bottom:14px;">
  <div class="top-actions">
    <div class="inspecao-top-actions">
    <a class="btn btn-outline action-btn" href="<%= backUrl %>">← Voltar</a>
    <a class="btn btn-outline action-btn" href="/inspecao/<%= prevAno %>/<%= prevMes %>">◀ Mês anterior</a>
    <a class="btn btn-outline action-btn" href="/inspecao/<%= nextAno %>/<%= nextMes %>">Próximo mês ▶</a>
    <a class="btn btn-outline action-btn" href="/inspecao/<%= ano %>/<%= mes %>/os-em-andamento">OS em andamento</a>
    <a class="btn btn-outline action-btn" href="/inspecao/<%= ano %>/<%= mes %>/pdf?<%= preventivasQuery %>">Exportar PDF</a>
    <a class="btn btn-outline action-btn" href="/inspecao/<%= ano %>/<%= mes %>/export/csv?<%= preventivasQuery %>">Exportar CSV</a>
    <% if (canEdit) { %>
      <form method="POST" action="/inspecao/<%= ano %>/<%= mes %>/recalcular" style="display:contents;">
        <input type="hidden" name="monitor_nome" value="<%= inspecao.monitor_nome || '' %>" />
        <input type="hidden" name="verificador_nome" value="<%= inspecao.verificador_nome || '' %>" />
        <input type="hidden" name="frequencia" value="<%= inspecao.frequencia || 'Diária' %>" />
        <button class="btn btn-primary action-btn" type="submit">Atualizar Sistema</button>
      </form>
    <% } %>
    </div>
  </div>

  <form method="POST" action="/inspecao/<%= ano %>/<%= mes %>/recalcular" class="inspecao-header-form" style="margin-top:12px;">
    <input type="text" name="monitor_nome" placeholder="Monitor" value="<%= inspecao.monitor_nome || '' %>" <%= canEdit ? '' : 'readonly' %> />
    <input type="text" name="verificador_nome" placeholder="Verificador" value="<%= inspecao.verificador_nome || '' %>" <%= canEdit ? '' : 'readonly' %> />
    <input type="text" name="frequencia" placeholder="Frequência" value="<%= inspecao.frequencia || 'Diária' %>" <%= canEdit ? '' : 'readonly' %> />
    <% if (canEdit) { %><button type="submit" class="btn btn-outline">Salvar cabeçalho</button><% } %>
  </form>
</div>

<div class="card" style="margin-bottom:14px;">
  <h3>Indicadores de preventivas</h3>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;">
    <% [['Programadas', indicadoresPreventivas.programadas],['Executadas', indicadoresPreventivas.executadas],['Pendentes', indicadoresPreventivas.pendentes],['Atrasadas', indicadoresPreventivas.atrasadas],['Com NC', indicadoresPreventivas.com_nao_conformidade],['Sem NC', indicadoresPreventivas.sem_nao_conformidade],['OS corretivas', indicadoresPreventivas.os_corretivas],['Cumprimento', `${indicadoresPreventivas.cumprimento_percentual || 0}%`]].forEach(([label,value]) => { %>
      <div style="border:1px solid #d1fae5;border-radius:8px;padding:10px;background:#f0fdf4;"><div class="muted"><%= label %></div><strong style="font-size:20px;color:#0b6b3a;"><%= value || 0 %></strong></div>
    <% }) %>
  </div>
  <% if ((indicadoresPreventivas.equipamentos_com_mais_nc || []).length) { %><div style="margin-top:10px;"><strong>Equipamentos com maior número de não conformidades preventivas:</strong> <%= indicadoresPreventivas.equipamentos_com_mais_nc.map(item => `${item.equipamento} (${item.total})`).join(' • ') %></div><% } %>
</div>

<div class="card" style="margin-bottom:14px;">
  <h3>Filtros do relatório de preventivas</h3>
  <form method="GET" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:8px;align-items:end;">
    <label>Data inicial<input type="date" name="data_inicio" value="<%= filtrosPreventivas.data_inicio %>" /></label>
    <label>Data final<input type="date" name="data_fim" value="<%= filtrosPreventivas.data_fim %>" /></label>
    <label>Equipamento<select name="equipamento_id"><option value="">Todos</option><% equipamentos.forEach(eq => { %><option value="<%= eq.id %>" <%= String(filtrosPreventivas.equipamento_id) === String(eq.id) ? 'selected' : '' %>><%= eq.nome %></option><% }) %></select></label>
    <label>Setor<input name="setor" value="<%= filtrosPreventivas.setor %>" placeholder="Setor" /></label>
    <label>Responsável<input name="responsavel" value="<%= filtrosPreventivas.responsavel %>" placeholder="Responsável" /></label>
    <label>Status<select name="status"><option value="">Todos</option><% ['EXECUTADA','FINALIZADA','CONCLUIDA'].forEach(status => { %><option value="<%= status %>" <%= filtrosPreventivas.status === status ? 'selected' : '' %>><%= status %></option><% }) %></select></label>
    <label>Tipo de atividade<select name="tipo_atividade"><option value="">Todas</option><option value="OS" <%= filtrosPreventivas.tipo_atividade === 'OS' ? 'selected' : '' %>>OS</option><option value="INSPECAO" <%= filtrosPreventivas.tipo_atividade === 'INSPECAO' ? 'selected' : '' %>>Inspeção</option><option value="PREVENTIVA" <%= filtrosPreventivas.tipo_atividade === 'PREVENTIVA' ? 'selected' : '' %>>Preventiva</option></select></label>
    <label>Não conformidade<select name="nao_conformidade"><option value="">Todas</option><option value="com" <%= filtrosPreventivas.nao_conformidade === 'com' ? 'selected' : '' %>>Com NC</option><option value="sem" <%= filtrosPreventivas.nao_conformidade === 'sem' ? 'selected' : '' %>>Sem NC</option></select></label>
    <label>Vínculo com OS<select name="gerou_os"><option value="">Todas</option><option value="1" <%= filtrosPreventivas.gerou_os === '1' ? 'selected' : '' %>>Gerou OS corretiva</option></select></label>
    <button class="btn btn-primary" type="submit">Aplicar filtros</button>
  </form>
</div>

<div class="card inspecao-nc-card">
  <h3>Preventivas Executadas no Período</h3>
  <p class="muted">Registros rastreáveis de inspeção preventiva, incluindo atividades sem não conformidade.</p>
  <div class="table-wrap"><table class="table"><thead><tr><th>Código</th><th>Equipamento / setor</th><th>Datas</th><th>Responsável</th><th>Descrição e itens</th><th>Não conformidade</th><th>Ações</th><th>Situação final</th><th>OS</th></tr></thead><tbody>
    <% if (!(preventivasExecutadas || []).length) { %><tr><td colspan="9">Nenhuma preventiva executada no período filtrado.</td></tr><% } %>
    <% (preventivasExecutadas || []).forEach(p => { %><tr>
      <td><a href="/preventivas/<%= p.plano_id %>">PREV-<%= p.id %></a></td><td><strong><%= p.equipamento_nome || '-' %></strong><br><span class="muted"><%= p.setor || '-' %></span></td><td>Programada: <%= p.data_prevista || '-' %><br>Executada: <%= p.data_executada || '-' %></td><td><%= p.responsavel_exibicao || '-' %></td><td><%= p.descricao_preventiva || p.titulo || '-' %><br><span class="muted"><%= p.itens_verificados || '-' %></span></td><td><strong style="color:<%= Number(p.tem_nao_conformidade) ? '#b91c1c' : '#166534' %>"><%= p.nao_conformidade || '-' %></strong></td><td>Corretiva: <%= p.acao_corretiva || '-' %><br>Preventiva: <%= p.acao_preventiva || '-' %></td><td><%= String(p.situacao_final || '-').replaceAll('_',' ') %></td><td><% if (p.os_corretiva_id) { %><a href="/os/<%= p.os_corretiva_id %>">OS #<%= p.os_corretiva_id %></a><% } else { %>-<% } %></td>
    </tr><% }) %>
  </tbody></table></div>
</div>

<div class="card table-wrap inspecao-grid-wrap">
  <table class="table inspecao-grid">
    <thead>
      <tr>
        <th class="equip-col">EQUIPAMENTO</th>
        <% for (let d = 1; d <= 31; d++) { %>
          <th><%= d %></th>
        <% } %>
      </tr>
    </thead>
    <tbody>
      <% for (const eq of equipamentos) {
        const line = matrix.get(eq.id) || [];
      %>
        <tr>
          <td class="equip-col"><strong><%= eq.nome %></strong><small>Item: <%= eq.item %></small></td>
          <% for (let i = 0; i < 31; i++) {
            const day = i + 1;
            const cell = line[i] || { status: '-' };
            const detailsKey = `${eq.id}-${day}`;
          %>
            <td class="status-cell <%= cell.status === '-' ? 'disabled' : '' %>">
              <button type="button" class="status-badge status-badge-btn <%= cell.status %>" data-eq="<%= eq.nome %>" data-item="<%= eq.item %>" data-day="<%= day %>" data-key="<%= detailsKey %>"><%= cell.status %></button>
            </td>
          <% } %>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<div class="card inspecao-nc-card">
  <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;">
    <div>
      <h3 style="margin-bottom:4px;">OS em andamento — rastreabilidade</h3>
      <div class="muted">Equipamentos com OS aberta, motivo atual e ação necessária.</div>
    </div>
    <a class="btn btn-outline btn-sm" href="/inspecao/<%= ano %>/<%= mes %>/os-em-andamento">Abrir relatório detalhado</a>
  </div>
  <div class="table-wrap">
    <table class="table nc-table">
      <thead><tr><th>OS</th><th>Equipamento</th><th>Dias em aberto</th><th>Status</th><th>Motivo atual</th><th>Última atualização</th><th>Ação necessária</th></tr></thead>
      <tbody>
        <% if (!(osEmAndamento || []).length) { %><tr><td colspan="7">Nenhuma OS aberta ou em andamento no período.</td></tr><% } %>
        <% (osEmAndamento || []).forEach((ordem) => { %>
          <tr>
            <td><a class="btn btn-outline btn-sm" href="/os/<%= ordem.id %>#justificativa-andamento">#<%= ordem.id %></a></td>
            <td><%= ordem.equipamento || '-' %></td><td><%= ordem.dias_aberta %></td><td><%= ordem.status || '-' %></td>
            <td><%= ordem.motivo_atual || 'Justificativa pendente' %></td><td><%= ordem.ultima_atualizacao ? fmtBR(ordem.ultima_atualizacao) : '-' %></td><td><%= ordem.acao_necessaria %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="card inspecao-nc-card">
  <h3>Não Conformidades (automáticas via OS)</h3>
  <div class="table-wrap">
    <table class="table nc-table">
      <thead><tr><th>Item</th><th>Data ocorrência</th><th>Não Conformidade</th><th>Ação preventiva</th><th>Ação corretiva</th><th>Data correção</th><th>OS ID</th></tr></thead>
      <tbody>
        <% if (!ncList.length) { %><tr><td colspan="7">Nenhuma não conformidade detectada no mês.</td></tr><% } %>
        <% for (const nc of ncList) { %>
          <tr>
            <td><%= nc.item %></td><td><%= nc.data_ocorrencia %></td><td><%= nc.nao_conformidade %></td>
            <td><%= nc.acao_preventiva || '-' %></td>
            <td><%= nc.acao_corretiva || '-' %></td>
            <td><%= nc.data_correcao || '-' %></td>
            <td><% if (nc.os_id) { %><a class="btn btn-outline btn-sm" href="/os/<%= nc.os_id %>">OS #<%= nc.os_id %></a><% } else { %>-<% } %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<div id="dayModal" class="inspecao-modal" style="display:none;">
  <div class="inspecao-modal-content">
    <div class="inspecao-modal-head">
      <h3 id="dayModalTitle">Detalhes do dia</h3>
      <button class="btn btn-ghost btn-sm" type="button" id="closeDayModal">Fechar</button>
    </div>
    <ul id="dayModalList" class="modal-os-list"></ul>
  </div>
</div>

<script>
  const detailsByCell = <%- JSON.stringify(osDetailsByCell || {}) %>;
  const modal = document.getElementById('dayModal');
  const modalTitle = document.getElementById('dayModalTitle');
  const modalList = document.getElementById('dayModalList');

  document.querySelectorAll('.status-badge-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.key;
      const rows = detailsByCell[key] || [];
      modalTitle.textContent = `Detalhes - ${btn.dataset.eq} (item ${btn.dataset.item}) dia ${btn.dataset.day}`;
      modalList.innerHTML = rows.length
        ? rows.map((row) => `<li><strong>OS #${row.id}</strong> [${row.status || '-'}]<br>Não conformidade: ${row.nao_conformidade || row.problema || '-'}<br>Ação preventiva: ${row.causa_diagnostico || '-'}<br>Ação corretiva: ${row.resumo_tecnico || '-'}<br>Ocorrência: ${row.data_inicio || '-'} | Correção: ${row.data_fim || '-'}</li>`).join('')
        : '<li>Sem OS vinculada neste dia.</li>';
      modal.style.display = 'flex';
    });
  });

  document.getElementById('closeDayModal').addEventListener('click', () => { modal.style.display = 'none'; });
  modal.addEventListener('click', (e) => { if (e.target === modal) modal.style.display = 'none'; });
</script>
