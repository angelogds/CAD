<%
  const role = (typeof normalizeRole === 'function')
    ? normalizeRole(user?.role || '')
    : String(user?.role || '').toUpperCase();

  const can = (moduleKey) => {
    if (typeof canAccessModule !== 'function') return true;
    return canAccessModule(role, moduleKey);
  };

  const canPainel = can('painel_operacional');
  const canPCM = can('pcm');
  const canEquipamentos = can('equipamentos');
  const canOS = can('os_view');
  const canPreventivas = can('preventivas_view');
  const canDemandas = can('demandas_view');
  const canSolicitacoes = can('solicitacoes');
  const canCompras = can('compras');
  const canFornecedores = can('fornecedores');
  const canAlmoxarifado = can('almoxarifado');
  const canEstoque = can('estoque_view');
  const canMotores = can('motores');
  const canAvisos = can('avisos_view');
  const canUsuarios = can('usuarios');
  const canEscala = can('escala');
  const canInspecao = can('inspecao_view');
  const canTracagem = can('tracagem_view');
  const canDesenhoTecnico = can('desenho_tecnico_view');

  const currentPcmSection = (typeof activePcmSection !== 'undefined' ? activePcmSection : '');

  const navItem = (href, label, isActive, extraClass = '') =>
    `<a class="nav-item ${extraClass} ${isActive ? 'active' : ''}" href="${href}"><span class="nav-label">${label}</span></a>`;
%>

<aside class="sidebar">
  <div class="sidebar-title">Gestão Industrial</div>

  <nav class="nav">
    <% if (canPainel) { %><%- navItem('/dashboard', 'Painel Principal', activeMenu === 'dashboard') %><% } %>
    <% if (canEquipamentos) { %><%- navItem('/equipamentos', 'Equipamentos', activeMenu === 'equipamentos') %><% } %>
    <% if (canOS) { %><%- navItem('/os', 'Ordens de Serviço', activeMenu === 'os') %><% } %>
    <% if (canPreventivas) { %><%- navItem('/preventivas', 'Preventivas', activeMenu === 'preventivas') %><% } %>
    <% if (canDemandas) { %><%- navItem('/demandas', 'Demandas', activeMenu === 'demandas') %><% } %>
    <% if (canSolicitacoes) { %><%- navItem('/solicitacoes/minhas', 'Solicitações', activeMenu === 'solicitacoes') %><% } %>
    <% if (canCompras) { %><%- navItem('/compras/solicitacoes', 'Compras', activeMenu === 'compras') %><% } %>
    <% if (canFornecedores) { %><a class="nav-item <%= activeMenu === 'fornecedores' ? 'active' : '' %>" href="/fornecedores"><span class="nav-label">Fornecedores</span></a><% } %>
    <% if (canAlmoxarifado) { %><%- navItem('/almoxarifado/recebimentos', 'Almoxarifado', activeMenu === 'almoxarifado') %><% } %>
    <% if (canEstoque) { %><%- navItem('/estoque', 'Estoque', activeMenu === 'estoque') %><% } %>
    <% if (canMotores) { %><%- navItem('/motores', 'Motores', activeMenu === 'motores') %><% } %>

    <% if (canAvisos) { %><%- navItem('/avisos', 'Avisos', activeMenu === 'avisos') %><% } %>
    <% if (canEscala) { %><%- navItem('/escala', 'Escala', activeMenu === 'escala') %><% } %>
    <% if (canInspecao) { %><%- navItem('/inspecao', 'Inspeção', activeMenu === 'inspecao') %><% } %>
    <% if (canTracagem) { %><a class="nav-item <%= activeMenu === 'tracagem' ? 'active' : '' %>" href="/tracagem"><span class="nav-label">Traçagem</span></a><% } %>
    <% if (canDesenhoTecnico) { %><%- navItem('/desenho-tecnico', 'Desenho Técnico', activeMenu === 'desenho-tecnico') %><% } %>

    <% if (canPCM) { %>
      <%- navItem('/pcm', 'PCM – Planejamento', activeMenu === 'pcm') %>
      <% if (activeMenu === 'pcm') { %>
        <div class="nav-submenu">
          <a class="nav-item nav-subitem <%= currentPcmSection === 'visao-geral' ? 'active' : '' %>" href="/pcm"><span class="nav-label">Visão Geral</span></a>
          <a class="nav-item nav-subitem <%= currentPcmSection === 'planejamento' ? 'active' : '' %>" href="/pcm/planejamento"><span class="nav-label">Planejamento</span></a>
          <a class="nav-item nav-subitem <%= currentPcmSection === 'falhas' ? 'active' : '' %>" href="/pcm/falhas"><span class="nav-label">Falhas</span></a>
          <a class="nav-item nav-subitem <%= currentPcmSection === 'engenharia' ? 'active' : '' %>" href="/pcm/engenharia"><span class="nav-label">Engenharia</span></a>
          <a class="nav-item nav-subitem <%= currentPcmSection === 'criticidade' ? 'active' : '' %>" href="/pcm/criticidade"><span class="nav-label">Criticidade</span></a>
          <a class="nav-item nav-subitem <%= currentPcmSection === 'lubrificacao' ? 'active' : '' %>" href="/pcm/lubrificacao"><span class="nav-label">Lubrificação</span></a>
          <a class="nav-item nav-subitem <%= currentPcmSection === 'pecas-criticas' ? 'active' : '' %>" href="/pcm/pecas-criticas"><span class="nav-label">Peças Críticas</span></a>
          <a class="nav-item nav-subitem <%= currentPcmSection === 'programacao-semanal' ? 'active' : '' %>" href="/pcm/programacao-semanal"><span class="nav-label">Programação Semanal</span></a>
          <a class="nav-item nav-subitem <%= currentPcmSection === 'backlog' ? 'active' : '' %>" href="/pcm/backlog"><span class="nav-label">Backlog</span></a>
          <a class="nav-item nav-subitem <%= currentPcmSection === 'rotas-inspecao' ? 'active' : '' %>" href="/pcm/rotas-inspecao"><span class="nav-label">Rotas de Inspeção</span></a>
          <a class="nav-item nav-subitem <%= currentPcmSection === 'relatorios-avancados' ? 'active' : '' %>" href="/pcm/relatorios-avancados"><span class="nav-label">Relatórios Avançados</span></a>
        </div>
      <% } %>
    <% } %>

    <div class="nav-divider"></div>

    <% if (canUsuarios) { %>
      <div class="nav-section">ADMIN</div>
      <%- navItem('/usuarios', 'Gerenciar Usuários', activeMenu === 'usuarios') %>
    <% } %>
  </nav>

  <div class="sidebar-footer">
    <small>© <%= new Date().getFullYear() %> Campo do Gado</small>
  </div>
</aside>
