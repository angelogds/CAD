<% layout('layout') %>
<link rel="stylesheet" href="/css/academia.css" />
<div class="page-head"><div><h1>Professor IA da Manutenção</h1><p class="muted">Assistente técnico para dúvidas, revisão e recomendações de estudo.</p></div></div>
<%- include(incluir('academia/_menu')) %>

<div class="academia-grid academia-layout-2">
  <div class="academia-card">
    <h3>Pergunte ao Professor IA</h3>
    <textarea id="iaPergunta" rows="5" placeholder="Ex.: Como inspecionar redutor e identificar falha de rolamento?"></textarea>
    <button class="btn" type="button" id="iaPerguntar" style="margin-top:8px;">Enviar pergunta</button>
    <p class="muted-xs" style="margin-top:8px;">* Em implantação: integração real será habilitada em fase futura.</p>
  </div>
  <div class="academia-card">
    <h3>Resposta</h3>
    <div id="iaResposta" class="muted">Aguardando pergunta. O Professor IA responderá em linguagem simples, técnica e objetiva.</div>
  </div>
</div>
<script src="/js/academia.js"></script>
