<% layout('layout') %>
<link rel="stylesheet" href="/css/academia.css" />
<div class="page-head"><div><h1>Professor IA da Manutenção</h1><p class="muted">Chat técnico com respostas didáticas por tópicos, como um professor para dúvidas do curso.</p></div></div>
<%- include(incluir('_menu')) %>

<div class="academia-chat-wrap academia-card">
  <% if (!iaConfigured) { %>
    <p class="muted-xs" style="color:#b45309;margin-bottom:10px;">IA ainda não ativada. Configure OPENAI_API_KEY (compatível com OPENAI_APIKEY/OPENAI_KEY) para habilitar o Professor IA.</p>
  <% } %>

  <div id="iaChatLog" class="ia-chat-log" aria-live="polite">
    <div class="ia-msg ia-msg-assistant">
      <div class="ia-msg-role">Professora IA</div>
      <div class="ia-msg-body">Olá! Pode perguntar sobre conteúdos do curso, aplicação em <strong>EF (teste final)</strong> ou cenário de <strong>preventiva</strong>. Vou responder em tópicos organizados.</div>
    </div>
  </div>

  <div class="ia-chat-compose">
    <div class="academia-grid" style="grid-template-columns:1fr 220px;gap:8px;">
      <div>
        <label class="muted-xs">Curso de contexto (opcional)</label>
        <select id="iaCursoId">
          <option value="">Sem curso específico</option>
          <% (cursos || []).forEach(function(c){ %>
            <option value="<%= c.id %>"><%= c.titulo %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="muted-xs">Modo da resposta</label>
        <select id="iaModo">
          <option value="curso">Professor do curso</option>
          <option value="ef">Preparar para EF</option>
          <option value="preventiva">Aplicar na preventiva</option>
        </select>
      </div>
    </div>

    <textarea id="iaPergunta" rows="4" placeholder="Ex.: Como aplicar metrologia industrial na inspeção preventiva de redutor?"></textarea>

    <div class="academia-actions" style="margin-top:8px;justify-content:space-between;">
      <p id="iaWarning" class="muted-xs" style="color:#b45309;margin:0;"></p>
      <button class="btn" type="button" data-ia-action="perguntar">Enviar pergunta</button>
    </div>
  </div>
</div>

<script src="/js/academia.js"></script>
