<% layout('layout') %>
<link rel="stylesheet" href="/css/academia.css" />

<div class="page-head"><div><h1>Cursos técnicos</h1><p class="muted">Cursos internos e externos organizados por trilha.</p></div></div>
<%- include('academia/_menu') %>

<form class="card" method="GET" action="/academia/cursos" style="margin-bottom:12px;">
  <div class="grid cols-4">
    <input type="text" name="busca" placeholder="Buscar curso" value="<%= filtros.busca %>" />
    <select name="trilha_id"><option value="">Todas as trilhas</option><% trilhas.forEach(function(t){ %><option value="<%= t.id %>" <%= String(filtros.trilha_id)===String(t.id)?'selected':'' %>><%= t.nome %></option><% }) %></select>
    <select name="nivel"><option value="">Todos os níveis</option><option <%= filtros.nivel==='BÁSICO'?'selected':'' %>>BÁSICO</option><option <%= filtros.nivel==='INTERMEDIÁRIO'?'selected':'' %>>INTERMEDIÁRIO</option><option <%= filtros.nivel==='AVANÇADO'?'selected':'' %>>AVANÇADO</option></select>
    <button class="btn" type="submit">Filtrar</button>
  </div>
</form>

<div class="academia-grid">
  <% cursos.forEach(function(c){ %>
    <div class="academia-card">
      <img src="<%= c.imagem || '/IMG/login_campo_do_gado.png.png.png' %>" alt="<%= c.titulo %>" />
      <h3><a href="/academia/curso/<%= c.id %>"><%= c.titulo %></a></h3>
      <p class="muted"><%= c.descricao || 'Sem descrição' %></p>
      <div class="muted-xs"><%= c.trilha_nome || 'Sem trilha' %> • <%= c.carga_horaria || 0 %>h • <%= c.pontos || 0 %> pts • <%= c.plataforma %></div>
      <div style="margin-top:6px;"><span class="badge-status <%= c.meu_status %>"><%= c.meu_status %></span></div>
      <div class="academia-actions">
        <form method="POST" action="/academia/iniciar/<%= c.id %>"><button class="btn" type="submit">INICIAR CURSO</button></form>
        <% if (c.plataforma !== 'INTERNO' && c.link_externo) { %>
          <button class="btn btn-outline" type="button" data-open-external="<%= c.link_externo %>">Abrir plataforma</button>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>

<% if (canAccessModule(normalizeRole(user?.role), 'academia_manage')) { %>
  <div class="card" style="margin-top:16px;">
    <div class="label">Administração • Novo curso</div>
    <form method="POST" action="/academia/cursos/criar" class="grid cols-3" style="margin-top:8px;">
      <input name="titulo" placeholder="Título" required />
      <input name="descricao" placeholder="Descrição" />
      <select name="trilha_id"><option value="">Sem trilha</option><% trilhas.forEach(function(t){ %><option value="<%= t.id %>"><%= t.nome %></option><% }) %></select>
      <select name="tipo"><option>INTERNO</option><option>EXTERNO</option></select>
      <select name="plataforma"><option>INTERNO</option><option>CURSA</option><option>YOUTUBE</option><option>PDF</option><option>OUTRO</option></select>
      <input name="link_externo" placeholder="Link externo" />
      <input name="imagem" placeholder="URL da imagem" />
      <input type="number" name="carga_horaria" placeholder="Carga horária" min="0" />
      <input type="number" name="pontos" placeholder="Pontos" min="0" value="10" />
      <input name="nivel" placeholder="Nível" value="BÁSICO" />
      <button class="btn" type="submit">Criar</button>
    </form>
  </div>
<% } %>

<script src="/js/academia.js"></script>
