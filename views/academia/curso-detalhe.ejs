<% layout('layout') %>
<link rel="stylesheet" href="/css/academia.css" />

<div class="page-head"><div><h1><%= curso.titulo %></h1><p class="muted"><%= curso.descricao || 'Curso institucional da Academia da Manutenção.' %></p></div></div>
<%- include(incluir('_menu')) %>

<div class="academia-grid academia-layout-2" style="align-items:start;">
  <div class="academia-card">
    <div class="muted-xs">Trilha: <strong><%= curso.trilha_nome || 'Sem trilha' %></strong> • Plataforma: <strong><%= curso.plataforma %></strong></div>
    <p style="margin-top:10px;">Carga horária: <strong><%= curso.carga_horaria || 0 %>h</strong> • Nota mínima final: <strong>70%</strong></p>
    <p>Status do curso: <span class="badge-status <%= curso.meu_status %>"><%= curso.meu_status %></span> • Progresso geral: <strong><%= curso.progresso_percentual %>%</strong></p>
    <% if (curso.avaliacaoFinal) { %>
      <p>Avaliação final: <strong><%= curso.avaliacaoFinal.percentual %>%</strong> (<%= curso.avaliacaoFinal.status %>)</p>
    <% } %>
    <div class="academia-actions">
      <% if (curso.meu_status === 'EM_ANDAMENTO') { %>
        <form method="POST" action="/academia/continuar/<%= curso.id %>"><button class="btn" type="submit">Continuar curso</button></form>
      <% } else { %>
        <form method="POST" action="/academia/iniciar/<%= curso.id %>"><button class="btn" type="submit">Iniciar curso</button></form>
      <% } %>
      <a class="btn btn-outline" href="#ebooks">Ver e-book</a>
      <a class="btn btn-outline" href="#avaliacao-final">Avaliação final</a>
      <a class="btn btn-outline" href="#etapa-externa">Etapa externa</a>
      <a class="btn btn-outline" href="/academia/documentos-internos">Documento interno</a>
    </div>
  </div>

  <div class="academia-card">
    <div class="label">Progresso dos blocos</div>
    <ul style="margin-top:10px;">
      <% (curso.blocos || []).forEach(function(b){ %>
        <li>
          Bloco <strong><%= b.ordem %></strong> - <%= b.titulo %>
          <span class="badge-status <%= b.status %>"><%= b.status %></span>
          <% if (b.percentual != null) { %><span class="muted-xs"> • <%= b.percentual %>%</span><% } %>
        </li>
      <% }) %>
    </ul>
  </div>
</div>

<div class="card" style="margin-top:12px;">
  <div class="label">Bloco atual</div>
  <% if (curso.blocoAtual) { %>
    <div class="academia-card" id="bloco-<%= curso.blocoAtual.id %>" style="margin-top:10px;">
      <h3><%= curso.blocoAtual.ordem %>. <%= curso.blocoAtual.titulo %></h3>
      <p class="muted"><%= curso.blocoAtual.descricao || 'Sem descrição' %></p>
      <p><strong>Resumo:</strong> <%= curso.blocoAtual.resumo || 'Sem resumo.' %></p>
      <p><%= curso.blocoAtual.conteudo_texto || 'Conteúdo em atualização.' %></p>
      <% if (curso.blocoAtual.checklist?.length) { %>
        <div class="muted-xs">Checklist</div>
        <ul>
          <% curso.blocoAtual.checklist.forEach(function(item){ %><li><%= item %></li><% }) %>
        </ul>
      <% } %>
      <div class="academia-actions">
        <form method="POST" action="/academia/curso/<%= curso.id %>/bloco/<%= curso.blocoAtual.id %>/concluir">
          <button class="btn btn-outline" type="submit">Concluir leitura</button>
        </form>
      </div>
      <% if (curso.perguntasBlocoAtual?.length) { %>
        <form method="POST" action="/academia/curso/<%= curso.id %>/bloco/<%= curso.blocoAtual.id %>/avaliar" class="academia-form-stack" style="margin-top:10px;">
          <div class="muted-xs">Avaliação do bloco (mínimo 50%)</div>
          <% curso.perguntasBlocoAtual.forEach(function(p, idx){ %>
            <label><strong><%= idx + 1 %>.</strong> <%= p.pergunta %></label>
            <select name="resposta_<%= p.id %>" required>
              <option value="">Selecione</option>
              <% ['A','B','C','D'].forEach(function(alt){ %>
                <% const txt = p['alternativa_' + alt.toLowerCase()]; %>
                <% if (txt) { %><option value="<%= alt %>"><%= alt %>) <%= txt %></option><% } %>
              <% }) %>
            </select>
          <% }) %>
          <button class="btn" type="submit">Responder avaliação do bloco</button>
        </form>
      <% } %>
    </div>
  <% } else { %>
    <p class="muted" style="margin-top:10px;">Todos os blocos foram concluídos. Faça a avaliação final de 10 questões.</p>
  <% } %>
</div>

<div class="card" id="avaliacao-final" style="margin-top:12px;">
  <div class="label">Avaliação final</div>
  <p class="muted">Liberada após conclusão dos 4 blocos. Aprovação mínima: 70%.</p>
  <form method="POST" action="/academia/avaliacoes/<%= curso.id %>/final" class="academia-form-stack">
    <input type="number" step="0.1" min="0" max="100" name="nota" placeholder="Nota final" required />
    <input type="number" step="0.1" min="0" max="100" name="percentual" placeholder="Percentual final" required />
    <button class="btn" type="submit" <%= curso.blocoAtual ? 'disabled' : '' %>>Registrar avaliação final</button>
  </form>
</div>

<div class="card" id="ebooks" style="margin-top:12px;">
  <div class="label">E-book do curso</div>
  <div class="academia-grid" style="margin-top:8px;">
    <% (curso.ebooks || []).forEach(function(e){ %>
      <div class="academia-card">
        <h3><%= e.titulo %></h3>
        <p class="muted"><%= e.resumo || 'Sem resumo.' %></p>
        <% if (e.arquivo_url) { %><a class="btn btn-outline" href="<%= e.arquivo_url %>" target="_blank" rel="noopener">Abrir PDF</a><% } %>
      </div>
    <% }) %>
  </div>
</div>

<div class="card" id="etapa-externa" style="margin-top:12px;">
  <div class="label">Etapa externa complementar</div>
  <% if (curso.podeLiberarEtapaExterna) { %>
    <p>Etapa externa liberada.</p>
  <% } else { %>
    <p class="muted">A etapa externa só libera após aprovação da avaliação final.</p>
  <% } %>
</div>

<script src="/js/academia.js"></script>
