<% layout('layout') %>
<link rel="stylesheet" href="/css/academia.css" />
<div class="page-head"><div><h1>Biblioteca técnica</h1><p class="muted">Manuais, procedimentos e conteúdos por categoria/equipamento.</p></div></div>
<%- include(incluir('_menu')) %>

<form class="card" method="GET" action="/academia/biblioteca" style="margin-bottom:12px;">
  <div class="grid cols-3">
    <input type="text" name="busca" placeholder="Buscar material" value="<%= filtros.busca %>" />
    <select name="categoria"><option value="">Todas as categorias</option><% categorias.forEach(function(cat){ %><option value="<%= cat %>" <%= filtros.categoria===cat?'selected':'' %>><%= cat %></option><% }) %></select>
    <button class="btn" type="submit">Filtrar</button>
  </div>
</form>

<div class="academia-grid">
  <% if (!itens.length) { %><p class="muted">Nenhum item disponível.</p><% } %>
  <% itens.forEach(function(item){ %>
    <div class="academia-card">
      <div class="muted-xs"><strong><%= item.tipo %></strong> • <%= item.categoria || 'Sem categoria' %></div>
      <h3><%= item.titulo %></h3>
      <p class="muted"><%= item.descricao || 'Sem descrição' %></p>
      <a class="btn btn-outline" href="<%= item.arquivo_url %>" target="_blank" rel="noopener">Abrir material</a>
    </div>
  <% }) %>
</div>
