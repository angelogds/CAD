<% layout('layout') %>
<link rel="stylesheet" href="/css/academia.css" />
<div class="page-head"><div><h1>Minhas aulas</h1><p class="muted">Acompanhe andamento, notas e progresso por trilha.</p></div></div>
<%- include(incluir('academia/_menu')) %>

<div class="academia-grid academia-layout-3">
  <div class="academia-card"><h3>Em andamento</h3><div class="valor"><%= minhasAulas.emAndamento.length %></div></div>
  <div class="academia-card"><h3>Concluídos</h3><div class="valor"><%= minhasAulas.concluidos.length %></div></div>
  <div class="academia-card"><h3>Pendentes</h3><div class="valor"><%= minhasAulas.pendentes.length %></div></div>
</div>

<div class="academia-grid academia-layout-2" style="margin-top:12px;">
  <div class="academia-card"><h3>Cursos recentes</h3>
    <% if (!minhasAulas.recentes.length) { %><p class="muted">Você ainda não iniciou cursos.</p><% } %>
    <% minhasAulas.recentes.forEach(function(a){ %>
      <a class="academia-row" href="/academia/curso/<%= a.curso_id %>"><span><%= a.titulo %></span><span class="muted-xs"><%= a.progresso_percentual %>%</span></a>
    <% }) %>
  </div>
  <div class="academia-card"><h3>Progresso por trilha</h3>
    <% minhasAulas.progressoTrilhas.forEach(function(t){ %>
      <div style="margin-bottom:8px;"><div class="muted-xs"><%= t.nome %> • <%= t.percentual %>%</div><div class="progress"><span style="width:<%= t.percentual %>%"></span></div></div>
    <% }) %>
  </div>
</div>
