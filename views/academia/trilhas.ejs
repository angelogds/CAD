<% layout('layout') %>
<link rel="stylesheet" href="/css/academia.css" />

<div class="page-head"><div><h1>Trilhas de conhecimento</h1><p class="muted">Escolha uma trilha para evoluir tecnicamente.</p></div></div>

<div class="academia-grid">
  <% trilhas.forEach(function(t){ %>
    <div class="academia-card">
      <h3><%= t.icone || '📘' %> <%= t.nome %></h3>
      <p class="muted"><%= t.descricao || 'Sem descrição.' %></p>
      <p class="muted-xs"><%= t.total_cursos %> cursos ativos</p>
      <a class="btn" href="/academia/cursos?trilha_id=<%= t.id %>">Ver cursos</a>
    </div>
  <% }) %>
</div>
