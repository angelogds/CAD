<%- layout('layout') -%>
<div class="page-head"><div><h1>Pré-visualizar escala</h1><p class="muted">Confira conflitos antes de aplicar.</p></div><a class="btn" href="/escala/rodizio">Voltar</a></div>
<form method="POST" action="/escala/rodizio/aplicar" class="card" style="margin-top:12px;display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
  <% Object.entries(dados || {}).forEach(([k,v])=>{ if(Array.isArray(v)){ v.forEach(x=>{ %><input type="hidden" name="<%= k %>" value="<%= x %>"><% }) } else { %><input type="hidden" name="<%= k %>" value="<%= v %>"><% } }) %>
  <label><input type="checkbox" name="sobrescrever" value="1"> Sobrescrever ajustes manuais</label>
  <button class="btn btn-green">Aplicar escala</button>
</form>
<div class="escala-card-grid" style="margin-top:12px;">
  <% preview.forEach((s,idx)=>{ %>
    <article class="card-padrao-escala">
      <div class="card-padrao-header"><div><h3 class="card-padrao-title">Semana #<%= idx+1 %></h3><div class="card-padrao-subtitle"><%= s.data_inicio %> até <%= s.data_fim %></div></div><span class="card-padrao-badge <%= s.conflitos.length?'is-warning':'is-success' %>"><%= s.conflitos.length?'Conflito':'OK' %></span></div>
      <div class="card-padrao-row"><span class="label-text">Noturno</span><span class="value-text"><%= s.noturno?.nome || '-' %></span></div>
      <div class="card-padrao-row"><span class="label-text">Diurno</span><span class="value-text"><%= (s.diurnos||[]).map(d=>d.nome).join(', ') || '-' %></span></div>
      <div class="card-padrao-row"><span class="label-text">Conflitos</span><span class="value-text"><%= s.conflitos.join('; ') || 'nenhum' %></span></div>
    </article>
  <% }) %>
</div>
