<%- layout('layout') -%><div class="page-head"><h1>Horas Extras Pendentes</h1><a class="btn" href="/escala">Voltar</a></div><div class="card"><table class="table"><thead><tr><th>Funcionário</th><th>Data</th><th>Início/Fim</th><th>Total</th><th>OS</th><th>Equipamento</th><th>Serviço</th><th>Ações</th></tr></thead><tbody><% if(!pendentes.length){ %><tr><td colspan="8">Nenhuma hora extra pendente.</td></tr><% } pendentes.forEach(h=>{ %><tr><td><%= h.colaborador_nome %></td><td><%= h.data_servico %></td><td><%= h.inicio_extra %><br><%= h.fim_extra %></td><td><%= h.total_minutos %> min</td><td><%= h.os_id || '-' %></td><td><%= h.equipamento_nome || h.os_equipamento || '-' %></td><td><%= h.descricao_servico %></td><td><form method="POST" action="/escala/hora-extra/<%= h.id %>/aprovar"><input class="input" name="observacao" placeholder="Observação"><button class="btn btn-green btn-sm">Aprovar</button></form><form method="POST" action="/escala/hora-extra/<%= h.id %>/reprovar" style="margin-top:6px"><input class="input" name="motivo" placeholder="Motivo" required><button class="btn btn-sm">Reprovar</button></form><form method="POST" action="/escala/hora-extra/<%= h.id %>/cancelar" style="margin-top:6px"><input class="input" name="motivo" placeholder="Motivo" required><button class="btn btn-sm">Cancelar</button></form></td></tr><% }) %></tbody></table></div>
