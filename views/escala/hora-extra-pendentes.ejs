<%- layout('layout') -%>
<div class="page-head"><h1>Horas Extras Pendentes</h1><a class="btn" href="/escala">Voltar</a></div>
<div class="escala-card-grid">
  <% if(!pendentes.length){ %><div class="escala-empty" style="grid-column:1/-1;">Nenhuma hora extra pendente.</div><% } %>
  <% pendentes.forEach(h=>{ %>
    <article class="card-padrao-escala">
      <div class="card-padrao-header"><div class="card-padrao-person"><span class="card-padrao-avatar"><%= String(h.colaborador_nome || 'M').charAt(0).toUpperCase() %></span><div><h3 class="card-padrao-title"><%= h.colaborador_nome %></h3><div class="card-padrao-subtitle"><%= h.data_servico %></div></div></div><span class="card-padrao-badge is-warning">Pendente</span></div>
      <div class="card-padrao-body"><div class="card-padrao-row"><span class="label-text">Data</span><span class="value-text"><%= h.data_servico %></span></div><div class="card-padrao-row"><span class="label-text">Início / Fim</span><span class="value-text"><%= h.inicio_extra %> → <%= h.fim_extra || '-' %></span></div><div class="card-padrao-row"><span class="label-text">Total</span><span class="value-text"><%= h.total_minutos %> min</span></div><div class="card-padrao-row"><span class="label-text">OS</span><span class="value-text"><%= h.os_id ? ('OS ' + h.os_id) : '-' %></span></div><div class="card-padrao-row"><span class="label-text">Equipamento</span><span class="value-text"><%= h.equipamento_nome || h.os_equipamento || '-' %></span></div><div class="card-padrao-row"><span class="label-text">Serviço</span><span class="value-text"><%= h.descricao_servico %></span></div><div class="card-padrao-row"><span class="label-text">Localização</span><span class="value-text"><%= h.status_localizacao || h.localizacao_status || 'Não capturada' %></span></div></div>
      <div class="card-padrao-footer"><form method="POST" action="/escala/hora-extra/<%= h.id %>/aprovar"><input class="input" name="observacao" placeholder="Observação"><button class="btn btn-green btn-sm">Aprovar</button></form><form method="POST" action="/escala/hora-extra/<%= h.id %>/reprovar"><input class="input" name="motivo" placeholder="Motivo" required><button class="btn btn-sm">Reprovar</button></form><form method="POST" action="/escala/hora-extra/<%= h.id %>/cancelar"><input class="input" name="motivo" placeholder="Motivo" required><button class="btn btn-sm">Ajustar/Cancelar</button></form></div>
    </article>
  <% }) %>
</div>
