<%- layout('layout') -%>
<style>
.escala-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:16px}.escala-card{display:flex;flex-direction:column;gap:10px;border:1px solid #e2e8f0;border-radius:18px;padding:18px;background:#fff;box-shadow:0 10px 26px rgba(15,23,42,.06);min-height:155px}.escala-card h3{margin:0;color:#14532d}.escala-card p{margin:0;color:#64748b;font-weight:700;line-height:1.35}.escala-card .btn{margin-top:auto;justify-content:center}.info-banco{border-left:5px solid #16a34a;background:#f0fdf4;border-radius:16px;padding:16px;color:#14532d;font-weight:800;line-height:1.45}
</style>
<div class="page-head"><h1 style="margin:0;">Escala</h1><p style="margin:6px 0 0;color:#64748b;font-weight:800;">Central da escala e do Banco de Horas da Manutenção.</p></div>
<div class="info-banco" style="margin-top:14px;">Este controle é interno da manutenção e tem como objetivo organizar as horas extras realizadas pela equipe, vinculando cada período trabalhado a uma OS, descrição do serviço e aprovação do encarregado. As informações poderão ser utilizadas para programação de folgas compensatórias e apresentação ao RH ou à diretoria quando solicitado.</div>
<div class="escala-grid" style="margin-top:16px;">
<% [{t:'Escala da Semana',d:'Veja a equipe escalada para a semana atual.',u:'/escala/semana'},{t:'Escala Completa',d:'Consulte a escala por período.',u:'/escala/completa'},{t:'Folgas / Atestados / Férias',d:'Controle ausências e indisponibilidades.',u:'/escala/ausencias'},{t:'Registrar Hora Extra',d:'Lance serviço realizado fora da jornada normal.',u:'/escala/hora-extra/nova'},{t:'Horas Extras Pendentes',d:'Aprove ou reprove lançamentos da equipe.',u:'/escala/hora-extra/pendentes'},{t:'Banco de Horas',d:'Consulte saldo de horas por funcionário.',u:'/escala/banco-horas'},{t:'Programar Folga',d:'Agende folgas compensatórias.',u:'/escala/folgas'},{t:'Relatórios PDF',d:'Emita relatórios para manutenção, RH ou direção.',u:'/escala/relatorios'}].forEach(c=>{ %>
  <div class="escala-card"><h3><%= c.t %></h3><p><%= c.d %></p><a class="btn btn-green" href="<%= c.u %>">Acessar</a></div>
<% }) %>
</div>
