<%- layout('layout') -%>
<style>
.escala-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:16px}.escala-card{display:flex;flex-direction:column;gap:10px;border:1px solid #e2e8f0;border-radius:18px;padding:18px;background:#fff;box-shadow:0 10px 26px rgba(15,23,42,.06);min-height:155px}.escala-card h3{margin:0;color:#14532d}.escala-card p{margin:0;color:#64748b;font-weight:700;line-height:1.35}.escala-card .btn{margin-top:auto;justify-content:center}.info-banco{border-left:5px solid #16a34a;background:#f0fdf4;border-radius:16px;padding:16px;color:#14532d;font-weight:800;line-height:1.45}.colaborador-avatar,.colaborador-avatar-placeholder{width:58px;height:58px;border-radius:50%;object-fit:cover;flex-shrink:0}.colaborador-avatar-placeholder{display:flex;align-items:center;justify-content:center;background:#dcfce7;color:#166534;font-weight:800}.oper-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:14px}.oper-meta{display:grid;gap:6px;color:#334155;font-weight:700}.fab-extra{display:none}@media(max-width:760px){.escala-grid,.oper-grid{grid-template-columns:1fr}.escala-card .btn{min-height:46px}.fab-extra{display:block;position:fixed;right:16px;bottom:16px;z-index:20;border-radius:999px;padding:14px 18px;box-shadow:0 16px 34px rgba(22,163,74,.35)}}
</style>
<div class="page-head"><h1 style="margin:0;">Escala</h1><p style="margin:6px 0 0;color:#64748b;font-weight:800;">Central da escala e do Banco de Horas da Manutenção.</p></div>
<div class="info-banco" style="margin-top:14px;">Controle interno da manutenção para organizar escala, banco de horas, folga compensatória e hora extra vinculada à OS. Não é ponto eletrônico, ponto RH ou registro oficial de jornada.</div>
<div class="escala-grid" style="margin-top:16px;">
<% [{t:'Escala da Semana',d:'Veja a equipe escalada para a semana atual.',u:'/escala/semana'},{t:'Escala Completa',d:'Consulte, edite e recalcule a escala por período.',u:'/escala/completa'},{t:'Folgas / Atestados / Férias',d:'Controle ausências e indisponibilidades.',u:'/escala/ausencias'},{t:'Registrar Hora Extra',d:'Hora extra vinculada à OS com lançamento rápido pelo celular.',u:'/escala/hora-extra/nova'},{t:'Horas Extras Pendentes',d:'Aguardando aprovação do encarregado.',u:'/escala/hora-extra/pendentes'},{t:'Banco de Horas',d:'Banco de Horas da Manutenção por colaborador.',u:'/escala/banco-horas'},{t:'Programar Folga',d:'Folga compensatória, folga manual, atestado, férias e faltas.',u:'/escala/folgas'},{t:'Relatórios PDF',d:'Emita todos os PDFs da escala e banco de horas.',u:'/escala/relatorios'}].forEach(c=>{ %>
  <div class="escala-card"><h3><%= c.t %></h3><p><%= c.d %></p><a class="btn btn-green" href="<%= c.u %>">Acessar</a></div>
<% }) %>
</div>

<div class="card" style="margin-top:18px;">
  <h2 style="margin:0;color:#14532d;">Painel Operacional da Equipe</h2>
  <p class="muted" style="margin-top:6px;"><%= canViewAllEscala ? 'Painel geral da manutenção.' : 'Você está visualizando apenas suas próprias informações.' %></p>
  <div class="escala-card-grid" style="margin-top:12px;">
    <% (painel.colaboradores || []).forEach(c => { %>
      <article class="card-padrao-escala">
        <div style="display:flex;gap:12px;align-items:center;">
          <% if (c.foto_path) { %><img class="colaborador-avatar" src="<%= c.foto_path %>" alt="Foto de <%= c.nome %>"><% } else { %><div class="colaborador-avatar-placeholder"><%= c.iniciais || String(c.nome||'M').charAt(0).toUpperCase() %></div><% } %>
          <div><h3 class="card-padrao-title"><%= c.nome %></h3><div class="card-padrao-subtitle"><%= c.funcaoLabel || 'Mecânico Industrial' %></div></div><span class="card-padrao-badge is-success"><%= c.statusAtual %></span>
        </div>
        <div class="card-padrao-body"><div class="card-padrao-row"><span class="label-text">Turno atual</span><span class="value-text"><%= c.turnoAtual %></span></div><div class="card-padrao-row"><span class="label-text">Função</span><span class="value-text"><%= c.funcaoLabel || 'Mecânico Industrial' %></span></div><div class="card-padrao-row"><span class="label-text">Saldo</span><span class="value-text"><%= c.saldo.horas %></span></div><div class="card-padrao-row"><span class="label-text">Equiv.</span><span class="value-text"><%= c.saldo.diasFolgaDecimal %> dia(s)</span></div><div class="card-padrao-row"><span class="label-text">Extras aprovadas no mês</span><span class="value-text"><%= c.horasExtrasMes %></span></div><div class="card-padrao-row"><span class="label-text">Ausências</span><span class="value-text"><%= c.ausenciasJustificadas || 0 %></span></div><div class="card-padrao-row"><span class="label-text">Última hora extra</span><span class="value-text"><%= c.ultimaHoraExtra || '-' %></span></div></div>
        <% if (canReadEscalaDetails) { %><div class="card-padrao-footer"><a class="btn btn-sm btn-green" href="/escala/banco-horas/<%= c.id %>">Ver detalhes</a></div><% } %>
      </article>
    <% }) %>
  </div>
</div>
<a class="btn btn-green fab-extra" href="/escala/hora-extra/nova">+ Hora Extra</a>
