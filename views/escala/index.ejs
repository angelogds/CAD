<%- layout('layout') -%>

<% const pdfStartSafe = typeof pdfStart === 'string' ? pdfStart : ''; %>
<% const pdfEndSafe = typeof pdfEnd === 'string' ? pdfEnd : ''; %>

<style>
  .escala-table-wrap { width:100%; overflow:auto; -webkit-overflow-scrolling:touch; }
  .escala-actions {
    display: inline-flex;
    flex-direction: column;
    gap: 6px;
    align-items: stretch;
  }
  .escala-action-btn {
    justify-content: center;
    min-width: 58px;
    padding: 5px 6px;
    line-height: 1.1;
    transition: background .18s ease, border-color .18s ease, color .18s ease, box-shadow .18s ease;
  }
  .escala-action-edit:hover {
    border-color: rgba(22, 163, 74, .5);
    background: linear-gradient(180deg, #f0fdf4 0%, #dcfce7 100%);
  }
  .escala-action-delete:hover {
    border-color: rgba(185, 28, 28, .5);
    color: #7f1d1d;
    background: linear-gradient(180deg, #fee2e2 0%, #fecaca 100%);
  }
  @media (max-width: 760px) {
    .escala-table-wrap .table { min-width: 720px; }
    .escala-table-wrap .table th,
    .escala-table-wrap .table td { font-size:12px; padding:8px; }
  }
</style>

<div class="page-head" style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start;">
  <div>
    <h1 style="margin:0;">Escala</h1>
    <p style="margin:6px 0 0;color:#64748b;font-weight:700;">
      Gestão de escala, compensações e concessões de folgas/atestados/férias.
    </p>
    <div style="margin-top:10px;">
      <a class="btn btn-sm" href="/escala/ausencias?date=<%= alvo %>">Colaboradores em Folga/Atestado</a>
    </div>
  </div>

  <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;justify-content:flex-end;">
    <% if (semana) { %>
      <a class="btn btn-primary" href="/escala/pdf/semana">Gerar PDF da Escala</a>
    <% } %>
    <form method="GET" action="/escala/pdf/periodo" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
      <input class="input" type="date" name="start" value="<%= pdfStartSafe %>" required style="height:38px;">
      <input class="input" type="date" name="end" value="<%= pdfEndSafe %>" required style="height:38px;">
      <button class="btn btn-green" type="submit">Gerar PDF de Folgas</button>
    </form>
    <a class="btn" href="/dashboard">Voltar</a>
  </div>
</div>

<div class="card" style="margin-top:14px;">
  <div style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap;">
    <div>
      <h3 style="margin:0;">Semana do Sistema</h3>
      <% if (semana) { %>
        <div style="margin-top:6px;color:#334155;font-weight:800;">
          Período: <%= semana.data_inicio %> até <%= semana.data_fim %>
        </div>
      <% } else { %>
        <div style="margin-top:6px;color:#b91c1c;font-weight:900;">
          Sem semana cadastrada para esta data.
        </div>
      <% } %>
    </div>

    <div style="display:flex;gap:10px;align-items:center;">
      <form method="GET" action="/escala" style="display:flex;gap:8px;align-items:center;">
        <input type="date" name="date" value="<%= alvo %>" class="input" style="height:38px;">
        <button class="btn btn-sm" type="submit">Ir</button>
        <a class="btn btn-sm" href="/escala?date=<%= (new Date()).toISOString().slice(0,10) %>">Hoje</a>
      </form>
    </div>
  </div>

  <div class="escala-table-wrap" style="margin-top:12px;">
    <table class="table">
      <thead>
        <tr>
          <th style="width:160px;">Data</th>
          <th>Colaborador</th>
          <th style="width:140px;">Turno</th>
          <th style="width:160px;">Função</th>
          <th style="width:240px;">Status</th>
          <th style="width:120px;">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (!semana || !semana.linhas || semana.linhas.length === 0) { %>
          <tr>
            <td colspan="6" style="text-align:center;color:#64748b;">Nenhum item cadastrado nesta semana.</td>
          </tr>
        <% } else { %>
          <% semana.linhas.forEach(l => { %>
            <tr>
              <td><%= semana.data_inicio %> a <%= semana.data_fim %></td>
              <td style="font-weight:900;"><%= l.nome %></td>
              <td><%= l.turnoLabel %></td>
              <td><%= l.funcaoLabel %></td>
              <td><%= l.statusLabel %></td>
              <td>
                <div class="escala-actions">
                  <a class="btn btn-sm escala-action-btn escala-action-edit" href="/escala/editar/<%= semana.id %>" title="Editar" aria-label="Editar">Editar</a>
                  <% if (isAdmin) { %>
                    <form method="POST" action="/escala/alocacao/<%= l.alocacao_id %>/delete" onsubmit="return confirm('Deseja excluir este registro?');" style="margin:0;">
                      <input type="hidden" name="date" value="<%= alvo %>">
                      <button class="btn btn-sm escala-action-btn escala-action-delete" type="submit" title="Excluir" aria-label="Excluir">Excluir</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <hr style="margin:16px 0;border:0;border-top:1px solid #e5e7eb;">

  <h4 style="margin:0 0 10px;">Adicionar rápido</h4>
  <form method="POST" action="/escala/adicionar" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
    <input type="hidden" name="date" value="<%= alvo %>">
    <div style="min-width:200px;">
      <div class="label">DATA INÍCIO</div>
      <input class="input" type="date" name="inicio" value="<%= alvo %>" required>
    </div>
    <div style="min-width:200px;">
      <div class="label">DATA FIM</div>
      <input class="input" type="date" name="fim" value="<%= alvo %>" required>
    </div>
    <div style="flex:1;min-width:220px;">
      <div class="label">COLABORADOR</div>
      <input class="input" name="nome" placeholder="Ex.: Emanuel" required>
    </div>
    <div style="min-width:180px;">
      <div class="label">TURNO</div>
      <select class="input" name="turno" required>
        <option value="">Selecione</option>
        <option value="Dia">Dia</option>
        <option value="Noite">Noite</option>
      </select>
    </div>
    <div style="min-width:200px;">
      <div class="label">FUNÇÃO</div>
      <select class="input" name="funcao" required>
        <option value="">Selecione</option>
        <option value="Mecânico">Mecânico Industrial</option>
      </select>
    </div>

    <button class="btn btn-primary" type="submit">Salvar</button>
  </form>

  <hr style="margin:16px 0;border:0;border-top:1px solid #e5e7eb;">

  <h4 style="margin:0 0 10px;">Folga / Atestado / Férias por período</h4>
  <form id="form-ausencia" method="POST" action="/escala/ausencia" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
    <input type="hidden" name="date" value="<%= alvo %>">
    <div style="flex:1;min-width:220px;">
      <div class="label">COLABORADOR</div>
      <input class="input" name="nome" placeholder="Ex.: Diogo" required>
    </div>
    <div style="min-width:180px;">
      <div class="label">FUNÇÃO</div>
      <select class="input" name="funcao" required>
        <option value="Mecânico">Mecânico Industrial</option>
      </select>
    </div>
    <div style="min-width:180px;">
      <div class="label">TIPO</div>
      <select class="input" name="tipo" id="ausencia-tipo" required>
        <option value="FOLGA">Folga</option>
        <option value="FOLGA_MEIO_PERIODO">Folga meio período</option>
        <option value="ATESTADO">Atestado</option>
        <option value="FERIAS">Férias</option>
      </select>
    </div>
    <div style="min-width:200px;">
      <div class="label">INÍCIO</div>
      <input class="input" type="date" name="inicio" required>
    </div>
    <div style="min-width:200px;">
      <div class="label">FIM</div>
      <input class="input" type="date" name="fim" required>
    </div>
    <div style="flex:1;min-width:260px;">
      <div class="label">MOTIVO</div>
      <input class="input" id="motivo-input" name="motivo" placeholder="Opcional para Folga/Férias">
    </div>

    <div id="compensacao-fields" style="display:flex;gap:10px;flex-wrap:wrap;width:100%;">
      <div style="min-width:200px;">
        <div class="label">DATA DO SERVIÇO PRESTADO</div>
        <input class="input" type="date" name="dataServico">
      </div>
      <div style="min-width:160px;">
        <div class="label">HORA INÍCIO</div>
        <input class="input" type="time" name="horaInicio">
      </div>
      <div style="min-width:160px;">
        <div class="label">HORA FIM</div>
        <input class="input" type="time" name="horaFim">
      </div>
      <div style="flex:1;min-width:220px;">
        <div class="label">EQUIPAMENTO/SETOR</div>
        <input class="input" name="equipamento" placeholder="Ex.: Transportador Correia 02">
      </div>
      <div style="flex:2;min-width:260px;">
        <div class="label">DESCRIÇÃO DOS SERVIÇOS EXECUTADOS</div>
        <input class="input" name="descricaoServico" placeholder="Ex.: troca de rolamento, alinhamento e teste final">
      </div>
      <div style="width:100%;border:1px solid #bfdbfe;background:#eff6ff;border-radius:12px;padding:12px;">
        <strong>Geolocalização de apoio da manutenção</strong>
        <p style="margin:6px 0 10px;color:#1e40af;">Esta localização será usada apenas como apoio ao controle interno da manutenção, para vincular a hora extra ao serviço executado.</p>
        <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
          <button class="btn btn-secondary" type="button" id="btn-geo-inicio">Iniciar Hora Extra / Capturar localização</button>
          <button class="btn btn-secondary" type="button" id="btn-geo-fim">Finalizar Hora Extra / Capturar localização</button>
          <span id="geo-status" style="font-weight:600;color:#1f2937;">Status da localização: não capturada.</span>
        </div>
        <div id="geo-precisao" style="margin-top:8px;color:#374151;">Precisão: -</div>
        <div id="geo-msg" style="margin-top:6px;color:#92400e;"></div>
        <div style="margin-top:10px;min-width:260px;">
          <div class="label">JUSTIFICATIVA SE A LOCALIZAÇÃO NÃO FOR CAPTURADA OU ESTIVER FORA DA ÁREA</div>
          <input class="input" id="geo-justificativa" name="justificativaSemLocalizacao" placeholder="Ex.: sinal de GPS indisponível no setor da caldeira">
        </div>
        <input type="hidden" name="latitudeInicio" id="geo-lat-inicio">
        <input type="hidden" name="longitudeInicio" id="geo-lon-inicio">
        <input type="hidden" name="precisaoInicio" id="geo-prec-inicio">
        <input type="hidden" name="statusLocalizacaoInicio" id="geo-status-inicio" value="NAO_CAPTURADA">
        <input type="hidden" name="latitudeFim" id="geo-lat-fim">
        <input type="hidden" name="longitudeFim" id="geo-lon-fim">
        <input type="hidden" name="precisaoFim" id="geo-prec-fim">
        <input type="hidden" name="statusLocalizacaoFim" id="geo-status-fim" value="NAO_CAPTURADA">
      </div>
    </div>

    <button class="btn btn-primary" type="submit">Lançar</button>
  </form>
</div>

<script>
  (function () {
    const tipoEl = document.getElementById('ausencia-tipo');
    const compEl = document.getElementById('compensacao-fields');
    const motivoEl = document.getElementById('motivo-input');

    function syncFields() {
      const tipo = (tipoEl.value || '').toUpperCase();
      const folga = tipo === 'FOLGA';
      compEl.style.display = folga ? 'flex' : 'none';
      if (tipo === 'FOLGA_MEIO_PERIODO') {
        compEl.style.display = 'none';
      }
      motivoEl.placeholder = tipo === 'ATESTADO'
        ? 'Obrigatório para Atestado'
        : 'Opcional para Folga/Férias';
      motivoEl.required = tipo === 'ATESTADO';
    }

    function setGeoStatus(kind, status, position) {
      const suffix = kind === 'inicio' ? 'inicio' : 'fim';
      document.getElementById(`geo-status-${suffix}`).value = status;
      if (position && position.coords) {
        document.getElementById(`geo-lat-${suffix}`).value = position.coords.latitude;
        document.getElementById(`geo-lon-${suffix}`).value = position.coords.longitude;
        document.getElementById(`geo-prec-${suffix}`).value = Math.round(position.coords.accuracy || 0);
        document.getElementById('geo-precisao').textContent = `Precisão ${kind}: ${Math.round(position.coords.accuracy || 0)} m`;
      }
      document.getElementById('geo-status').textContent = `Status da localização (${kind}): ${status}`;
      const justificativa = document.getElementById('geo-justificativa');
      justificativa.required = ['NAO_AUTORIZADA', 'GPS_INDISPONIVEL', 'NAO_CAPTURADA', 'FORA_DA_AREA'].includes(status);
    }

    function capturarLocalizacao(kind) {
      const msg = document.getElementById('geo-msg');
      msg.textContent = '';
      if (!navigator.geolocation) {
        msg.textContent = 'GPS indisponível neste navegador. Informe uma justificativa para análise do encarregado.';
        setGeoStatus(kind, 'GPS_INDISPONIVEL');
        return;
      }
      navigator.geolocation.getCurrentPosition(
        (position) => setGeoStatus(kind, 'NAO_CAPTURADA', position),
        (error) => {
          const status = error && error.code === error.PERMISSION_DENIED ? 'NAO_AUTORIZADA' : 'GPS_INDISPONIVEL';
          msg.textContent = status === 'NAO_AUTORIZADA'
            ? 'Permissão de localização negada. O lançamento continuará pendente de justificativa/análise.'
            : 'GPS indisponível ou sem sinal. O lançamento continuará pendente de justificativa/análise.';
          setGeoStatus(kind, status);
        },
        { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
      );
    }

    document.getElementById('btn-geo-inicio')?.addEventListener('click', () => capturarLocalizacao('inicio'));
    document.getElementById('btn-geo-fim')?.addEventListener('click', () => capturarLocalizacao('fim'));
    tipoEl.addEventListener('change', syncFields);
    syncFields();
  })();
</script>
