<%- layout('layout') -%><div class="page-head"><h1>Relatórios PDF</h1><a class="btn" href="/escala">Voltar</a></div><div class="card"><form method="GET" action="/escala/relatorios/pdf" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;align-items:end"><div><div class="label">Funcionário</div><select class="input" name="colaborador_id"><option value="">Todos</option><% colaboradores.forEach(c=>{ %><option value="<%= c.id %>"><%= c.nome %></option><% }) %></select></div><div><div class="label">Início</div><input class="input" type="date" name="inicio"></div><div><div class="label">Fim</div><input class="input" type="date" name="fim"></div><div><div class="label">OS</div><select class="input" name="os_id"><option value="">Todas</option><% osDisponiveis.forEach(o=>{ %><option value="<%= o.id %>">OS <%= o.id %> — <%= o.equipamento_nome || o.equipamento %></option><% }) %></select></div><div><div class="label">Status</div><select class="input" name="status"><option value="">Todos</option><option>APROVADO</option><option>PENDENTE_APROVACAO</option><option>REPROVADO</option><option>CANCELADO</option></select></div><button class="btn btn-green">Gerar PDF Geral</button></form></div>
