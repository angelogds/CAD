<%- layout('layout') -%><div class="page-head"><h1>Relatórios PDF</h1><a class="btn" href="/escala">Voltar</a></div><div class="card"><form method="GET" action="/escala/relatorios/pdf" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;align-items:end"><div><div class="label">Tipo de relatório</div><select class="input" name="tipo"><option value="semana">Escala da Semana</option><option value="completa">Escala Completa</option><option value="ausencias">Folgas / Atestados / Férias</option><option value="banco" selected>Banco de Horas da Manutenção</option><option value="funcionario">Horas Extras por Funcionário</option><option value="os">Horas Extras por OS</option><option value="folgas">Folgas Programadas</option><option value="mensal">Relatório Mensal da Manutenção</option></select></div><div><div class="label">Funcionário</div><select class="input" name="colaborador_id"><option value="">Todos</option><% colaboradores.forEach(c=>{ %><option value="<%= c.id %>"><%= c.nome %></option><% }) %></select></div><div><div class="label">Data inicial</div><input class="input" type="date" name="inicio"></div><div><div class="label">Data final</div><input class="input" type="date" name="fim"></div><div><div class="label">OS</div><select class="input" name="os_id"><option value="">Todas</option><% osDisponiveis.forEach(o=>{ %><option value="<%= o.id %>">OS <%= o.id %> — <%= o.equipamento_nome || o.equipamento %></option><% }) %></select></div><div><div class="label">Tipo de ausência</div><select class="input" name="tipo_ausencia"><option value="">Todos</option><option>Folga compensatória</option><option>Folga manual</option><option>Atestado</option><option>Férias</option><option>Falta justificada</option><option>Falta não justificada</option></select></div><div><div class="label">Status da hora extra</div><select class="input" name="status"><option value="">Todos</option><option>APROVADO</option><option>PENDENTE_APROVACAO</option><option>REPROVADO</option><option>CANCELADO</option></select></div><div><div class="label">Setor/equipamento</div><input class="input" name="equipamento"></div><button class="btn btn-green">Gerar PDF</button></form></div>
