<%- layout('layout') -%>
<div class="page-head"><div><h1>Escala Completa</h1><p style="color:#64748b;font-weight:700;">Visualizar, editar e recalcular a escala antes da impressão.</p></div><div style="display:flex;gap:8px"><a class="btn btn-primary" href="/escala/folgas-sabado">Folgas e Plantão de Sábado</a><a class="btn" href="/escala">Voltar</a></div></div>
<% if (canManageEscala) { %><div class="card" style="margin-top:12px;"><h3>Editar Escala Completa</h3><div style="display:flex;gap:10px;flex-wrap:wrap;"><a class="btn btn-primary" href="/escala/rodizio">Editar Rodízio da Escala</a><form method="POST" action="/escala/rodizio/recalcular" onsubmit="return confirm('Existem semanas com ajustes manuais. Deseja manter esses ajustes? Clique OK para manter; marque sobrescrever para apagar ajustes.');" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center"><input type="hidden" name="config_id" value="<%= rodizioAtivo?.id || '' %>"><label><input type="checkbox" name="sobrescreverTudo" value="1"> Sobrescrever tudo</label><button class="btn btn-green">Recalcular pelo Rodízio</button></form></div><p class="muted">Por padrão o recálculo mantém semanas com ajuste_manual = 1.</p></div><% } %>
<div class="escala-card-grid" style="margin-top:12px;">
  <% if (!semanas || semanas.length === 0) { %><div class="escala-empty" style="grid-column:1/-1;">Nenhuma semana encontrada.</div><% } %>
  <% (semanas || []).forEach(s => { %>
    <article class="card-padrao-escala">
      <div class="card-padrao-header"><div><h3 class="card-padrao-title">Semana #<%= s.semana_numero %></h3><div class="card-padrao-subtitle"><%= s.data_inicio %> → <%= s.data_fim %></div></div><span class="card-padrao-badge <%= s.ajuste_manual?'is-warning':'is-info' %>"><%= s.ajuste_manual?'Ajuste manual':'Escala Completa' %></span></div>
      <div class="card-padrao-body">
        <div class="card-padrao-row"><span class="label-text">Período</span><span class="value-text"><%= s.data_inicio %> → <%= s.data_fim %></span></div>
        <div class="card-padrao-row"><span class="label-text">Plantonista<%= (s.times.noturno || []).length > 1 ? 's' : '' %> da noite</span><span class="value-text"><%= (s.times.noturno || []).join(' e ') || '-' %></span></div>
        <div class="card-padrao-row"><span class="label-text">Turno diurno</span><span class="value-text"><%= (s.times.diurno || []).join(', ') || '-' %></span></div>
        <div class="card-padrao-row"><span class="label-text">Observação</span><span class="value-text"><%= s.ajuste_manual ? 'Semana ajustada manualmente pelo encarregado.' : (s.observacao || 'Todos como Mecânico Industrial') %></span></div>
      </div>
      <% if (canManageEscala) { %><div class="card-padrao-footer"><a class="btn btn-sm btn-green" href="/escala/editar/<%= s.id %>">Editar Semana</a><a class="btn btn-sm" href="/escala/editar/<%= s.id %>">Ajustar Colaboradores</a></div><% } %>
    </article>
  <% }) %>
</div>
