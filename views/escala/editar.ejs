<%- layout('layout') -%>
<h1>Editar Semana <%= semana.semana_numero %></h1>
<p style="color:#64748b;font-weight:800;">Período: <%= semana.data_inicio %> até <%= semana.data_fim %> <% if(semana.ajuste_manual){ %>• Ajuste manual<% } %></p>
<div class="card" style="margin-top:12px;">
  <form method="POST" action="/escala/editar/<%= semana.id %>" style="display:grid;gap:12px;">
    <input type="hidden" name="modo" value="semana">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;"><div><div class="label">Início</div><input class="input" type="date" name="data_inicio" value="<%= semana.data_inicio %>"></div><div><div class="label">Fim</div><input class="input" type="date" name="data_fim" value="<%= semana.data_fim %>"></div><div><div class="label">Status</div><input class="input" name="status" value="<%= semana.status || 'ATIVA' %>"></div></div>
    <div><div class="label">Plantonista noturno</div><select class="input" name="noturno_id"><option value="">Sem noturno</option><% colaboradores.forEach(c=>{ const sel=(semana.alocacoes||[]).some(a=>a.tipo_turno==='noturno'&&Number(a.colaborador_id)===Number(c.id)); %><option value="<%= c.id %>" <%= sel?'selected':'' %>><%= c.nome %></option><% }) %></select></div>
    <div><div class="label">Mecânicos diurnos</div><div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:8px;"><% colaboradores.forEach(c=>{ const checked=(semana.alocacoes||[]).some(a=>(a.tipo_turno==='diurno'||a.tipo_turno==='apoio')&&Number(a.colaborador_id)===Number(c.id)); %><label class="card" style="padding:10px;"><input type="checkbox" name="diurnos" value="<%= c.id %>" <%= checked?'checked':'' %>> <%= c.nome %></label><% }) %></div></div>
    <div><div class="label">Observação / função</div><textarea class="input" name="observacao" rows="3"><%= semana.observacao || '' %></textarea></div>
    <button class="btn btn-green">Salvar como ajuste manual</button>
  </form>
</div>
<div class="card" style="margin-top:12px;"><h3>Alocações atuais</h3><% (semana.alocacoes||[]).forEach(a=>{ %><p><strong><%= a.nome %></strong> — <%= a.tipo_turno %></p><% }) %></div>
<div style="margin-top:12px;display:flex;gap:10px;"><a class="btn" href="/escala/completa">Voltar</a><a class="btn btn-primary" href="/escala/pdf/semana/<%= semana.id %>">PDF da Semana</a></div>
