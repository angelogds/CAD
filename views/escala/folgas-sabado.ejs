<%- layout('layout') -%>
<div class="page-head"><div><h1>Folgas e Plantão de Sábado</h1><p class="muted">Folga compensatória da sexta e cobertura mínima de dois mecânicos no sábado.</p></div><a class="btn" href="/escala/completa">Voltar</a></div>
<div class="card" style="margin-top:12px;overflow:auto"><table class="table"><thead><tr><th>Semana</th><th>Sexta-feira</th><th>Colaborador de folga</th><th>Motivo</th><th>Sábado</th><th>Colaborador fixo</th><th>Parceiro de Diogo</th><th>Situação</th><th>Observação / responsável</th><% if(canManageEscala){ %><th>Ajustar</th><% } %></tr></thead><tbody>
<% if(!registros.length){ %><tr><td colspan="10">Nenhuma cobertura gerada. Recalcule o rodízio a partir de 20/07/2026.</td></tr><% } %>
<% registros.forEach(r=>{ const equipeFixa=r.substituto_diogo||r.colaborador_fixo; %><tr><td>#<%= r.semana_numero %><br><small><%= r.data_inicio %> a <%= r.data_fim %></small></td><td><%= r.data_sexta %></td><td><%= r.colaborador_folga %></td><td><%= r.motivo_folga %></td><td><%= r.data_sabado %></td><td><%= equipeFixa %></td><td><%= r.parceiro_diogo %></td><td><%= r.situacao %></td><td><%= r.observacao||'-' %><br><small><%= r.responsavel %></small></td>
<% if(canManageEscala){ %><td><details><summary class="btn btn-sm">Editar</summary><form method="POST" action="/escala/folgas-sabado/<%= r.semana_id %>" style="display:grid;gap:6px;min-width:260px;margin-top:8px"><label>Folga na sexta<select class="input" name="colaborador_folga_id" required><% colaboradores.forEach(c=>{ %><option value="<%= c.id %>" <%= Number(c.id)===Number(r.colaborador_folga_id)?'selected':'' %>><%= c.nome %></option><% }) %></select></label><label>Motivo<select class="input" name="motivo_folga"><option value="PLANTAO_NOTURNO">Compensação do plantão noturno</option><option value="TRABALHO_FIM_SEMANA">Trabalho no final de semana</option><option value="BANCO_HORAS">Banco de horas</option><option value="HORAS_EXTRAS">Horas extras</option><option value="AUTORIZADA_ENCARREGADO">Autorizada pelo encarregado</option><option value="OUTRO">Outro</option></select></label><label>Parceiro de Diogo<select class="input" name="parceiro_diogo_id" required><% colaboradores.forEach(c=>{ %><option value="<%= c.id %>" <%= Number(c.id)===Number(r.parceiro_diogo_id)?'selected':'' %>><%= c.nome %></option><% }) %></select></label><label><input type="checkbox" name="diogo_folga" value="1"> Diogo terá folga</label><label>Substituto<select class="input" name="substituto_diogo_id"><option value="">Selecione</option><% colaboradores.forEach(c=>{ %><option value="<%= c.id %>"><%= c.nome %></option><% }) %></select></label><label>Justificativa<textarea class="input" name="justificativa"></textarea></label><label>Observação<input class="input" name="observacao" value="<%= r.observacao||'' %>"></label><label><input type="checkbox" name="alterar_sequencia" value="1"> Recalcular sequência futura</label><button class="btn btn-primary">Salvar ajuste</button></form></details></td><% } %></tr><% }) %>
</tbody></table></div>
