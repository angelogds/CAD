<%- layout('layout') -%><div class="page-head"><h1>Banco de Horas da Manutenção</h1><a class="btn" href="/escala">Voltar</a></div><div class="card"><table class="table"><thead><tr><th>Funcionário</th><th>Créditos</th><th>Débitos</th><th>Saldo</th><th>Dias</th><th>Ações</th></tr></thead><tbody><% banco.forEach(b=>{ %><tr><td><%= b.nome %></td><td><%= b.saldo.creditos %> min</td><td><%= b.saldo.debitos %> min</td><td><b><%= b.saldo.horas %></b></td><td><%= b.saldo.diasFolgaDecimal %></td><td><a class="btn btn-sm" href="/escala/banco-horas/<%= b.id %>">Detalhar</a> <a class="btn btn-sm" href="/escala/relatorios/funcionario/<%= b.id %>/pdf">PDF</a></td></tr><% }) %></tbody></table></div><% if(selecionado){ %><div class="card" style="margin-top:14px"><h3>Extrato - <%= selecionado.nome %></h3><h4>Movimentos</h4><table class="table"><tbody><% movimentos.forEach(m=>{ %><tr><td><%= m.data_movimento %></td><td><%= m.tipo %></td><td><%= m.minutos %> min</td><td><%= m.descricao || '-' %></td></tr><% }) %></tbody></table><h4>Horas extras</h4><table class="table"><tbody><% horasExtras.forEach(h=>{ %><tr><td><%= h.data_servico %></td><td><%= h.status %></td><td>OS <%= h.os_id || '-' %></td><td><%= h.total_minutos %> min</td><td><%= h.descricao_servico %></td></tr><% }) %></tbody></table><h4>Folgas</h4><table class="table"><tbody><% folgas.forEach(f=>{ %><tr><td><%= f.data_folga %></td><td><%= f.status %></td><td><%= f.minutos_descontados %> min</td><td><%= f.motivo || '-' %></td></tr><% }) %></tbody></table></div><% } %>
