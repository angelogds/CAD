<%- layout('layout') -%><style>.bh-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px}.bh-card{border:1px solid #e2e8f0;border-radius:18px;padding:16px;background:#fff;box-shadow:0 8px 22px rgba(15,23,42,.06)}.avatar{width:52px;height:52px;border-radius:999px;background:#dcfce7;display:inline-grid;place-items:center;font-weight:900;color:#14532d}</style><div class="page-head"><h1>Banco de Horas da Manutenção</h1><a class="btn" href="/escala">Voltar</a></div><div class="bh-grid"><% banco.forEach(b=>{ %><div class="bh-card"><div style="display:flex;gap:12px;align-items:center"><% if(b.foto_path){ %><img class="avatar" src="<%= b.foto_path %>" alt="Foto"><% } else { %><span class="avatar"><%= String(b.nome||'M').charAt(0).toUpperCase() %></span><% } %><div><h3 style="margin:0"><%= b.nome %></h3><div class="muted"><%= b.funcaoLabel || 'Mecânico Industrial' %></div></div></div><p><b>Saldo:</b> <%= b.saldo.horas %></p><p><b>Equivalente:</b> <%= b.saldo.diasFolgaDecimal %> dia(s)</p><p><b>Extras aprovadas no mês:</b> <%= b.horasExtrasMesMinutos %> min</p><p><b>Folgas compensadas:</b> <%= b.folgasCompensadasMinutos %> min</p><p><b>Faltas/ausências:</b> <%= b.ausenciasJustificadas || 0 %></p><a class="btn btn-sm" href="/escala/banco-horas/<%= b.id %>">Ver detalhes</a> <a class="btn btn-sm" href="/escala/relatorios/funcionario/<%= b.id %>/pdf">PDF</a></div><% }) %></div><% if(selecionado){ %><div class="card" style="margin-top:14px"><h3>Extrato - <%= selecionado.nome %></h3><h4>Movimentos</h4><table class="table"><tbody><% movimentos.forEach(m=>{ %><tr><td><%= m.data_movimento %></td><td><%= m.tipo %></td><td><%= m.minutos %> min</td><td><%= m.descricao || '-' %></td></tr><% }) %></tbody></table><h4>Horas extras</h4><table class="table"><tbody><% horasExtras.forEach(h=>{ %><tr><td><%= h.data_servico %></td><td><%= h.status %></td><td>OS <%= h.os_id || '-' %></td><td><%= h.total_minutos %> min</td><td><%= h.descricao_servico %></td></tr><% }) %></tbody></table><h4>Folgas</h4><table class="table"><tbody><% folgas.forEach(f=>{ %><tr><td><%= f.data_folga %></td><td><%= f.status %></td><td><%= f.minutos_descontados %> min</td><td><%= f.motivo || '-' %></td></tr><% }) %></tbody></table></div><% } %>
