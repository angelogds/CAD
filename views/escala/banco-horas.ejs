<%- layout('layout') -%>
<div class="page-head"><h1>Banco de Horas da Manutenção</h1><a class="btn" href="/escala">Voltar</a></div>
<div class="escala-card-grid"><% banco.forEach(b=>{ %><article class="card-padrao-escala"><div class="card-padrao-header"><div class="card-padrao-person"><% if(b.foto_path){ %><img class="card-padrao-avatar" src="<%= b.foto_path %>" alt="Foto"><% } else { %><span class="card-padrao-avatar"><%= String(b.nome||'M').charAt(0).toUpperCase() %></span><% } %><div><h3 class="card-padrao-title"><%= b.nome %></h3><div class="card-padrao-subtitle"><%= b.funcaoLabel || 'Mecânico Industrial' %></div></div></div><span class="card-padrao-badge is-success"><%= b.statusAtual || 'Trabalhando' %></span></div><div class="card-padrao-body"><div class="card-padrao-row"><span class="label-text">Função</span><span class="value-text"><%= b.funcaoLabel || 'Mecânico Industrial' %></span></div><div class="card-padrao-row"><span class="label-text">Saldo</span><span class="value-text"><%= b.saldo.horas %></span></div><div class="card-padrao-row"><span class="label-text">Equiv.</span><span class="value-text"><%= b.saldo.diasFolgaDecimal %> dia(s)</span></div><div class="card-padrao-row"><span class="label-text">Extras aprovadas no mês</span><span class="value-text"><%= b.horasExtrasMesMinutos %> min</span></div><div class="card-padrao-row"><span class="label-text">Folgas compensadas</span><span class="value-text"><%= b.folgasCompensadasMinutos %> min</span></div><div class="card-padrao-row"><span class="label-text">Ausências</span><span class="value-text"><%= b.ausenciasJustificadas || 0 %></span></div><div class="card-padrao-row"><span class="label-text">Última hora extra</span><span class="value-text"><%= b.ultimaHoraExtra || '-' %></span></div></div><div class="card-padrao-footer"><a class="btn btn-sm btn-green" href="/escala/banco-horas/<%= b.id %>">Ver detalhes</a><a class="btn btn-sm" href="/escala/relatorios/funcionario/<%= b.id %>/pdf">PDF</a></div></article><% }) %></div>
<% if(selecionado){ %><div class="card" style="margin-top:14px"><h3>Extrato - <%= selecionado.nome %></h3><h4>Movimentos</h4><div class="escala-card-grid"><% movimentos.forEach(m=>{ %><article class="card-padrao-escala"><div class="card-padrao-header"><h3 class="card-padrao-title"><%= m.data_movimento %></h3><span class="card-padrao-badge is-info"><%= m.tipo %></span></div><div class="card-padrao-row"><span class="label-text">Minutos</span><span class="value-text"><%= m.minutos %> min</span></div><div class="card-padrao-row"><span class="label-text">Descrição</span><span class="value-text"><%= m.descricao || '-' %></span></div></article><% }) %></div></div><% } %>
