<%- layout('layout') -%>

<div class="page-head" style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap;">
  <div>
    <h1 style="margin:0;">Folga / Atestado</h1>
    <p style="margin:6px 0 0;color:#64748b;font-weight:700;">Visualize, edite e apague datas de colaboradores afastados antes de gerar o PDF.</p>
  </div>

  <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;justify-content:flex-end;">
    <form method="GET" action="/escala/ausencias" style="display:flex;gap:8px;align-items:center;">
      <input type="date" name="date" value="<%= alvo %>" class="input" style="height:38px;">
      <button class="btn btn-sm" type="submit">Filtrar</button>
    </form>
    <a class="btn" href="/escala?date=<%= alvo %>">Voltar para Escala</a>
  </div>
</div>

<style>
  .ausencias-actions .btn-danger {
    background:#dc2626;
    border-color:#dc2626;
    color:#fff;
  }
  .ausencias-actions .btn-danger:hover {
    background:#b91c1c;
    border-color:#b91c1c;
  }
</style>

<div class="card ausencias-actions" style="margin-top:14px;">
  <h3 style="margin:0 0 10px;">Registros de folga, atestado e férias</h3>

  <div class="escala-card-grid">
    <% if (!ausencias || ausencias.length === 0) { %><div class="escala-empty" style="grid-column:1/-1;">Nenhum registro encontrado.</div><% } %>
    <% (ausencias || []).forEach(item => { const tipoUp = String(item.tipo || '').replace(/_/g,' '); const tipoClass = tipoUp.includes('ATEST') ? 'is-warning' : (tipoUp.includes('FÉRI') || tipoUp.includes('FERI') ? 'is-info' : 'is-success'); %>
      <article class="card-padrao-escala">
        <div class="card-padrao-header"><div class="card-padrao-person"><span class="card-padrao-avatar"><%= String(item.nome || 'M').charAt(0).toUpperCase() %></span><div><h3 class="card-padrao-title"><%= item.nome %></h3><div class="card-padrao-subtitle"><%= item.funcaoLabel %></div></div></div><span class="card-padrao-badge <%= tipoClass %>"><%= tipoUp %></span></div>
        <div class="card-padrao-body"><div class="card-padrao-row"><span class="label-text">Função</span><span class="value-text"><%= item.funcaoLabel %></span></div><div class="card-padrao-row"><span class="label-text">Início</span><span class="value-text"><%= item.inicio %></span></div><div class="card-padrao-row"><span class="label-text">Fim</span><span class="value-text"><%= item.fim %></span></div><div class="card-padrao-row"><span class="label-text">Motivo</span><span class="value-text"><%= item.motivo || '-' %></span></div><div class="card-padrao-row"><span class="label-text">Situação</span><span class="value-text"><span class="card-padrao-badge <%= item.ativoNoDia ? 'is-success' : 'is-muted' %>"><%= item.ativoNoDia ? 'Ativo' : 'Inativo' %></span></span></div></div>
        <div class="card-padrao-footer"><button class="btn btn-sm btn-primary" type="button" data-edit-ausencia="<%= item.id %>" aria-expanded="false" aria-controls="ausencia-edit-<%= item.id %>">Editar</button><form method="POST" action="/escala/ausencia/<%= item.id %>/delete" onsubmit="return confirm('Apagar este registro de folga/atestado/férias? Esta ação também remove o item do PDF.');" style="margin:0;flex:1 1 auto;"><input type="hidden" name="date" value="<%= alvo %>"><button class="btn btn-sm btn-danger" type="submit">Apagar</button></form></div>
        <form id="ausencia-edit-<%= item.id %>" method="POST" action="/escala/ausencia/<%= item.id %>/update" data-edit-form="<%= item.id %>" style="display:none;gap:8px;align-items:center;flex-wrap:wrap;"><input type="hidden" name="date" value="<%= alvo %>"><select class="input" name="tipo" style="width:145px;" required><option value="FOLGA" <%= item.tipo === 'FOLGA' ? 'selected' : '' %>>Folga</option><option value="FOLGA_MEIO_PERIODO" <%= item.tipo === 'FOLGA_MEIO_PERIODO' ? 'selected' : '' %>>Folga meio período</option><option value="ATESTADO" <%= item.tipo === 'ATESTADO' ? 'selected' : '' %>>Atestado</option><option value="FERIAS" <%= item.tipo === 'FERIAS' ? 'selected' : '' %>>Férias</option></select><input class="input" type="date" name="inicio" value="<%= item.inicio %>" required><input class="input" type="date" name="fim" value="<%= item.fim %>" required><input class="input" name="motivo" value="<%= item.motivo || '' %>" placeholder="Motivo" style="min-width:140px;"><button class="btn btn-sm btn-primary" type="submit">Salvar</button><button class="btn btn-sm" type="button" data-cancel-edit="<%= item.id %>">Cancelar</button></form>
      </article>
    <% }) %>
  </div>
</div>

<script>
  document.addEventListener('click', function (event) {
    const editButton = event.target.closest('[data-edit-ausencia]');
    const cancelButton = event.target.closest('[data-cancel-edit]');
    const id = editButton?.dataset.editAusencia || cancelButton?.dataset.cancelEdit;

    if (!id) return;

    const form = document.querySelector(`[data-edit-form="${id}"]`);
    const trigger = document.querySelector(`[data-edit-ausencia="${id}"]`);
    if (!form || !trigger) return;

    const shouldOpen = Boolean(editButton) && form.style.display === 'none';
    form.style.display = shouldOpen ? 'flex' : 'none';
    trigger.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
    trigger.textContent = shouldOpen ? 'Fechar edição' : 'Editar';
  });
</script>
