<%- layout('layout') -%>
<div class="page-head"><h1>Programar Folga / Afastamento</h1><a class="btn" href="/escala">Voltar</a></div>
<div class="card"><form method="post" action="/escala/folgas/programar" enctype="multipart/form-data" id="folga-form" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px;align-items:end">
<label><span class="label">Funcionário</span><select class="input" name="colaborador_id" id="colaborador" required><option value="">Selecione</option><% colaboradores.forEach(c=>{ %><option value="<%= c.id %>" data-saldo="<%= c.saldo.minutos %>"><%= c.nome %> — saldo <%= c.saldo.horas %></option><% }) %></select></label>
<label><span class="label">Tipo</span><select class="input" name="tipo_lancamento" id="tipo" required><option value="FOLGA_COMPENSATORIA">Folga compensatória (desconta)</option><option value="FOLGA_MANUAL">Folga manual — não desconta</option><option value="ATESTADO">Atestado — não desconta</option><option value="FERIAS">Férias — não desconta</option><option value="FALTA_JUSTIFICADA">Falta justificada — não desconta</option><option value="FALTA_NAO_JUSTIFICADA">Falta não justificada — não desconta</option><option value="OUTRO">Outro afastamento — não desconta</option></select></label>
<label><span class="label">Data inicial</span><input class="input" type="date" name="data_folga" required></label><label><span class="label">Data final</span><input class="input" type="date" name="data_fim" required></label>
<label id="horas-wrap"><span class="label">Horas a descontar</span><input class="input" type="number" min="0.01" step="0.01" name="horas" id="horas"></label>
<label><span class="label">Motivo (obrigatório)</span><input class="input" name="motivo" required></label><label><span class="label">Data do serviço</span><input class="input" type="date" name="data_servico"></label><label><span class="label">Início do serviço</span><input class="input" type="time" name="hora_inicio"></label><label><span class="label">Fim do serviço</span><input class="input" type="time" name="hora_fim"></label><label><span class="label">Equipamento / setor</span><input class="input" name="equipamento"></label><label><span class="label">Descrição do serviço</span><input class="input" name="descricao_servico"></label><label><span class="label">Anexo (imagem ou PDF)</span><input class="input" type="file" name="anexo" accept="image/*,.pdf,application/pdf"></label><label><span class="label">Justificativa ADMIN para saldo negativo</span><input class="input" name="justificativa_saldo_negativo"></label>
<div><strong id="saldo-info">Selecione o funcionário.</strong><div id="debito-info">Este tipo desconta o banco.</div></div><button class="btn btn-green">Programar</button></form></div>
<div class="card" style="margin-top:14px"><h2>Registros</h2><div style="overflow:auto"><table class="table"><thead><tr><th>Funcionário</th><th>Tipo</th><th>Período</th><th>Saldo antes</th><th>Desconto</th><th>Saldo depois</th><th>Status</th><th>Ações</th></tr></thead><tbody><% folgas.forEach(f=>{ %><tr><td><%= f.colaborador_nome %></td><td><%= f.tipo_lancamento %></td><td><%= f.data_folga %> a <%= f.data_fim || f.data_folga %></td><td><%= f.saldo_antes_minutos == null ? '-' : f.saldo_antes_minutos+' min' %></td><td><%= f.debita_banco ? f.minutos_descontados+' min' : 'Não desconta' %></td><td><%= f.saldo_depois_minutos == null ? '-' : f.saldo_depois_minutos+' min' %></td><td><%= f.status %></td><td><% if(f.status==='PROGRAMADA'){ %><form method="post" action="/escala/folgas/<%= f.id %>/realizar" style="display:inline"><button class="btn btn-sm">Realizada</button></form> <form method="post" action="/escala/folgas/<%= f.id %>/cancelar" style="display:inline"><input type="hidden" name="motivo" value="Cancelado pelo responsável"><button class="btn btn-sm">Cancelar</button></form><% } %></td></tr><% }) %></tbody></table></div></div>
<script>const tipo=document.getElementById('tipo'),col=document.getElementById('colaborador'),horas=document.getElementById('horas');function update(){const debita=tipo.value==='FOLGA_COMPENSATORIA';document.getElementById('horas-wrap').style.display=debita?'block':'none';horas.required=debita;document.getElementById('debito-info').textContent=debita?'Desconta exatamente as horas informadas.':'Não desconta do banco de horas.';const o=col.selectedOptions[0],saldo=Number(o?.dataset.saldo||0),min=debita?Math.round(Number(horas.value||0)*60):0;document.getElementById('saldo-info').textContent=o?.value?`Saldo atual: ${saldo} min; depois: ${saldo-min} min`:'Selecione o funcionário.'}tipo.addEventListener('change',update);col.addEventListener('change',update);horas.addEventListener('input',update);update();</script>
