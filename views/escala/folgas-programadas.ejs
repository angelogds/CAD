<%- layout('layout') -%><div class="page-head"><h1>Programar Folga</h1><a class="btn" href="/escala">Voltar</a></div><div class="card"><p class="muted">Concentra folga compensatória, folga manual, atestado, férias, faltas e ausências da manutenção.</p><form method="POST" action="/escala/folgas/programar" enctype="multipart/form-data" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;align-items:end"><div><div class="label">Funcionário</div><select class="input" name="colaborador_id" required><% colaboradores.forEach(c=>{ %><option value="<%= c.id %>"><%= c.nome %> — saldo <%= c.saldo.horas %></option><% }) %></select></div><div><div class="label">Tipo de lançamento</div><select class="input" name="tipo_lancamento"><option>Folga compensatória</option><option>Folga manual</option><option>Atestado</option><option>Férias</option><option>Falta justificada</option><option>Falta não justificada</option><option>Outro</option></select></div><div><div class="label">Início</div><input class="input" type="date" name="data_folga" required></div><div><div class="label">Fim</div><input class="input" type="date" name="data_fim"></div><div><div class="label">Horas a descontar</div><input class="input" type="number" step="0.5" name="horas" value="8" required></div><div><div class="label">Data do serviço prestado</div><input class="input" type="date" name="data_servico"></div><div><div class="label">Hora início</div><input class="input" type="time" name="hora_inicio"></div><div><div class="label">Hora fim</div><input class="input" type="time" name="hora_fim"></div><div><div class="label">Equipamento/setor</div><input class="input" name="equipamento"></div><div style="grid-column:1/-1"><div class="label">Descrição dos serviços executados / motivo / observação</div><textarea class="input" name="motivo" rows="3"></textarea></div><div><div class="label">Anexo (opcional)</div><input class="input" type="file" name="anexo"></div><button class="btn btn-green">Programar</button></form></div><div class="card" style="margin-top:14px"><h3>Folgas programadas</h3><div class="escala-card-grid"><% if(!folgas.length){ %><div class="escala-empty" style="grid-column:1/-1;">Nenhuma folga programada.</div><% } folgas.forEach(f=>{ const st = String(f.status || 'PROGRAMADA'); const stClass = st.includes('CANCEL') ? 'is-muted' : (st.includes('REAL') ? 'is-success' : 'is-warning'); %><article class="card-padrao-escala"><div class="card-padrao-header"><div class="card-padrao-person"><span class="card-padrao-avatar"><%= String(f.colaborador_nome || 'M').charAt(0).toUpperCase() %></span><div><h3 class="card-padrao-title"><%= f.colaborador_nome %></h3><div class="card-padrao-subtitle"><%= f.tipo_lancamento || 'Folga compensatória' %></div></div></div><span class="card-padrao-badge <%= stClass %>"><%= st %></span></div><div class="card-padrao-body"><div class="card-padrao-row"><span class="label-text">Data</span><span class="value-text"><%= f.data_folga %></span></div><div class="card-padrao-row"><span class="label-text">Horas descontadas</span><span class="value-text"><%= f.minutos_descontados/60 %>h</span></div><div class="card-padrao-row"><span class="label-text">Saldo antes</span><span class="value-text"><%= f.saldo_antes || '-' %></span></div><div class="card-padrao-row"><span class="label-text">Saldo depois</span><span class="value-text"><%= f.saldo_depois || '-' %></span></div><div class="card-padrao-row"><span class="label-text">Motivo</span><span class="value-text"><%= f.motivo || '-' %></span></div><div class="card-padrao-row"><span class="label-text">Aprovador</span><span class="value-text"><%= f.aprovador_nome || '-' %></span></div></div><div class="card-padrao-footer"><form method="POST" action="/escala/folgas/<%= f.id %>/realizar"><button class="btn btn-sm btn-green">Realizar</button></form><form method="POST" action="/escala/folgas/<%= f.id %>/cancelar"><input class="input" name="motivo" placeholder="Motivo" required><button class="btn btn-sm">Cancelar</button></form></div></article><% }) %></div></div>