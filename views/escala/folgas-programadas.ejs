<%- layout('layout') -%><div class="page-head"><h1>Programar Folga</h1><a class="btn" href="/escala">Voltar</a></div><div class="card"><p class="muted">Concentra folga compensatória, folga manual, atestado, férias, faltas e ausências da manutenção.</p><form method="POST" action="/escala/folgas/programar" enctype="multipart/form-data" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;align-items:end"><div><div class="label">Funcionário</div><select class="input" name="colaborador_id" required><% colaboradores.forEach(c=>{ %><option value="<%= c.id %>"><%= c.nome %> — saldo <%= c.saldo.horas %></option><% }) %></select></div><div><div class="label">Tipo de lançamento</div><select class="input" name="tipo_lancamento"><option>Folga compensatória</option><option>Folga manual</option><option>Atestado</option><option>Férias</option><option>Falta justificada</option><option>Falta não justificada</option><option>Outro</option></select></div><div><div class="label">Início</div><input class="input" type="date" name="data_folga" required></div><div><div class="label">Fim</div><input class="input" type="date" name="data_fim"></div><div><div class="label">Horas a descontar</div><input class="input" type="number" step="0.5" name="horas" value="8" required></div><div><div class="label">Data do serviço prestado</div><input class="input" type="date" name="data_servico"></div><div><div class="label">Hora início</div><input class="input" type="time" name="hora_inicio"></div><div><div class="label">Hora fim</div><input class="input" type="time" name="hora_fim"></div><div><div class="label">Equipamento/setor</div><input class="input" name="equipamento"></div><div style="grid-column:1/-1"><div class="label">Descrição dos serviços executados / motivo / observação</div><textarea class="input" name="motivo" rows="3"></textarea></div><div><div class="label">Anexo (opcional)</div><input class="input" type="file" name="anexo"></div><button class="btn btn-green">Programar</button></form></div><div class="card" style="margin-top:14px"><h3>Folgas programadas</h3><table class="table"><thead><tr><th>Funcionário</th><th>Data</th><th>Horas</th><th>Status</th><th>Motivo</th><th>Ações</th></tr></thead><tbody><% folgas.forEach(f=>{ %><tr><td><%= f.colaborador_nome %></td><td><%= f.data_folga %></td><td><%= f.minutos_descontados/60 %>h</td><td><%= f.status %></td><td><%= f.motivo || '-' %></td><td><form method="POST" action="/escala/folgas/<%= f.id %>/realizar" style="display:inline"><button class="btn btn-sm">Realizar</button></form><form method="POST" action="/escala/folgas/<%= f.id %>/cancelar" style="display:inline"><input name="motivo" placeholder="Motivo" required><button class="btn btn-sm">Cancelar</button></form></td></tr><% }) %></tbody></table></div>
