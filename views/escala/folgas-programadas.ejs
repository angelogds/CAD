<%- layout('layout') -%><div class="page-head"><h1>Programar Folga Compensatória</h1><a class="btn" href="/escala">Voltar</a></div><div class="card"><form method="POST" action="/escala/folgas/programar" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;align-items:end"><div><div class="label">Funcionário</div><select class="input" name="colaborador_id" required><% colaboradores.forEach(c=>{ %><option value="<%= c.id %>"><%= c.nome %> — saldo <%= c.saldo.horas %></option><% }) %></select></div><div><div class="label">Data da folga</div><input class="input" type="date" name="data_folga" required></div><div><div class="label">Horas a descontar</div><input class="input" type="number" step="0.5" name="horas" value="8" required></div><div><div class="label">Motivo/justificativa</div><input class="input" name="motivo"></div><button class="btn btn-green">Programar</button></form></div><div class="card" style="margin-top:14px"><h3>Folgas programadas</h3><table class="table"><thead><tr><th>Funcionário</th><th>Data</th><th>Horas</th><th>Status</th><th>Motivo</th><th>Ações</th></tr></thead><tbody><% folgas.forEach(f=>{ %><tr><td><%= f.colaborador_nome %></td><td><%= f.data_folga %></td><td><%= f.minutos_descontados/60 %>h</td><td><%= f.status %></td><td><%= f.motivo || '-' %></td><td><form method="POST" action="/escala/folgas/<%= f.id %>/realizar" style="display:inline"><button class="btn btn-sm">Realizar</button></form><form method="POST" action="/escala/folgas/<%= f.id %>/cancelar" style="display:inline"><input name="motivo" placeholder="Motivo" required><button class="btn btn-sm">Cancelar</button></form></td></tr><% }) %></tbody></table></div>
