<% layout('layout') %>

<style>
  .prev-page-head{
    display:flex;
    align-items:flex-end;
    justify-content:space-between;
    gap:12px;
    margin-bottom:14px;
    flex-wrap:wrap;
  }

  .muted{ font-size:13px; color:#6b7280; margin-top:6px; }

  .card{
    background:#fff;
    border:1px solid #e5e7eb;
    border-radius:16px;
    padding:18px;
  }

  .actions{
    display:flex;
    gap:10px;
    align-items:center;
    flex-wrap:wrap;
  }

  .btn-primary{
    background:#16a34a;
    color:#fff;
    border:none;
    padding:10px 16px;
    border-radius:10px;
    font-weight:700;
    cursor:pointer;
    text-decoration:none;
    display:inline-flex;
    align-items:center;
    gap:8px;
    white-space:nowrap;
  }
  .btn-primary:hover{ background:#15803d; }

  .table-wrap{ overflow:auto; -webkit-overflow-scrolling:touch; }
  table{
    width:100%;
    border-collapse:separate;
    border-spacing:0;
    min-width:980px;
  }

  thead th{
    text-align:left;
    font-size:12px;
    color:#64748b;
    font-weight:700;
    letter-spacing:.02em;
    padding:12px 12px;
    border-bottom:1px solid #e5e7eb;
    background:#fff;
    position:sticky;
    top:0;
    z-index:1;
  }

  tbody td{
    padding:12px 12px;
    border-bottom:1px solid #f1f5f9;
    vertical-align:top;
    font-size:14px;
    color:#0f172a;
  }
  tbody tr:hover td{ background:#f8fafc; }

  .link{
    font-weight:800;
    text-decoration:none;
    color:#0f172a;
  }
  .link:hover{ text-decoration:underline; }

  .pill{
    display:inline-flex;
    align-items:center;
    gap:6px;
    padding:4px 10px;
    border-radius:999px;
    font-weight:800;
    font-size:12px;
    border:1px solid #e5e7eb;
    background:#f8fafc;
    color:#0f172a;
    white-space:nowrap;
  }
  .pill-green{ background:#ecfdf5; border-color:#bbf7d0; color:#14532d; }
  .pill-gray{  background:#f1f5f9; border-color:#e2e8f0; color:#334155; }
  .pill-blue{  background:#eff6ff; border-color:#bfdbfe; color:#1d4ed8; }

  .freq{
    display:inline-flex;
    align-items:center;
    gap:8px;
    white-space:nowrap;
  }
  .freq .muted-inline{ color:#6b7280; font-size:13px; }

  .btn-sm{
    display:inline-flex;
    align-items:center;
    gap:6px;
    padding:8px 12px;
    border-radius:10px;
    border:1px solid #d1d5db;
    background:#fff;
    cursor:pointer;
    text-decoration:none;
    font-weight:800;
    color:#0f172a;
    white-space:nowrap;
  }
  .btn-sm:hover{
    border-color: rgba(22,163,74,.45);
    background:#ecfdf5;
  }

  .prev-cards{
    display:none;
    gap:10px;
    flex-direction:column;
  }

  .prev-card{
    background:#fff;
    border:1px solid #e5e7eb;
    border-radius:14px;
    padding:14px;
    display:grid;
    gap:8px;
    text-decoration:none;
    color:inherit;
    transition:box-shadow .15s ease;
  }

  .prev-card:hover{ box-shadow:0 4px 12px rgba(0,0,0,.08); }

  .prev-card-head{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    gap:8px;
  }

  .prev-card-id{
    font-weight:900;
    font-size:13px;
    color:#64748b;
  }

  .prev-card-title{
    font-weight:800;
    font-size:15px;
    color:#0f172a;
    line-height:1.35;
  }

  .prev-card-equip{
    font-size:13px;
    color:#475569;
    line-height:1.4;
  }

  .prev-card-footer{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:8px;
    flex-wrap:wrap;
    padding-top:8px;
    border-top:1px solid #f1f5f9;
  }

  .prev-card-pills{
    display:flex;
    gap:6px;
    flex-wrap:wrap;
  }

  .prev-card-open{
    font-size:12px;
    color:#334155;
    font-weight:700;
  }

  .empty-state{
    text-align:center;
    padding:40px 20px;
    color:#94a3b8;
    font-size:14px;
  }

  @media (max-width:760px){
    .card{
      padding:0;
      border:none;
      background:transparent;
    }

    .table-wrap{ display:none; }
    .prev-cards{ display:flex; }
  }

  @media (max-width:400px){
    .btn-primary,
    .btn-sm{
      width:100%;
      justify-content:center;
    }

    .actions{ width:100%; }
  }
</style>

<div class="prev-page-head">
  <div>
    <h1>Preventivas</h1>
    <div class="muted">Planos de manutenção preventiva.</div>
  </div>

  <div class="actions">
    <% if (canAdminPreventivas && !tvMode) { %>
    <a class="btn-primary" href="/preventivas/nova">+ Nova Preventiva</a>
    <a class="btn-sm" href="/preventivas/programadas">Preventivas programadas</a>
    <form method="POST" action="/preventivas/programadas/lancar-os-lote-dia" style="margin:0;">
      <button
        class="btn-sm"
        type="submit"
        onclick="return confirm('Lançar o próximo lote de 5 preventivas para OS agora? Equipe padrão: Júnior (executor) e Luís (apoio).');"
      >
        Lançar 5 preventivas/dia
      </button>
    </form>
    <% } %>
  </div>
</div>


<% if (diagnosticoLeitura) { %>
<div class="card" style="margin-bottom:12px;">
  <div class="muted" style="font-weight:800;">Auditoria de leitura de equipamentos</div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;">
    <span class="pill pill-blue">Elegíveis: <%= diagnosticoLeitura.equipamentosElegiveis || 0 %></span>
    <span class="pill">Sem plano: <%= diagnosticoLeitura.equipamentosSemPlano || 0 %></span>
    <span class="pill">Planos ativos: <%= diagnosticoLeitura.planosAtivos || 0 %></span>
    <span class="pill">Pendentes/andamento: <%= diagnosticoLeitura.execucoesPendentes || 0 %></span>
  </div>
</div>
<% } %>
<div class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="width:80px;">ID</th>
          <th>Título</th>
          <th>Equipamento</th>
          <th style="width:200px;">Frequência</th>
          <th style="width:140px;">Status</th>
          <th style="width:140px; text-align:right;">Ações</th>
        </tr>
      </thead>

      <tbody>
        <% if (!lista || !lista.length) { %>
          <tr>
            <td colspan="6" style="padding:18px; color:#6b7280; text-align:center;">
              Nenhuma preventiva cadastrada.
            </td>
          </tr>
        <% } %>

        <% (lista || []).forEach(p => { %>
          <tr>
            <td>
              <a class="link" href="/preventivas/<%= p.id %>">#<%= p.id %></a>
            </td>

            <td>
              <%= p.titulo || "-" %>
            </td>

            <td class="muted">
              <%= p.equipamento_nome
                    ? (p.equipamento_codigo
                        ? (p.equipamento_codigo + " • " + p.equipamento_nome)
                        : p.equipamento_nome)
                    : "-" %>
            </td>

            <td>
              <div class="freq">
                <span class="pill pill-blue"><%= (p.frequencia_tipo || "-").toUpperCase() %></span>
                <span class="muted-inline">x<%= p.frequencia_valor || 1 %></span>
              </div>
            </td>

            <td>
              <% if (Number(p.ativo) === 1 || p.ativo === true) { %>
                <span class="pill pill-green">ATIVA</span>
              <% } else { %>
                <span class="pill pill-gray">INATIVA</span>
              <% } %>
            </td>

            <td style="text-align:right;">
              <a class="btn-sm" href="/preventivas/<%= p.id %>">Abrir</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="prev-cards">
    <% if (!lista || !lista.length) { %>
      <div class="empty-state">Nenhuma preventiva cadastrada.</div>
    <% } %>

    <% (lista || []).forEach(p => {
      const equipamento = p.equipamento_nome
        ? (p.equipamento_codigo
            ? (p.equipamento_codigo + ' • ' + p.equipamento_nome)
            : p.equipamento_nome)
        : '-';
      const ativa = Number(p.ativo) === 1 || p.ativo === true;
    %>
      <a class="prev-card" href="/preventivas/<%= p.id %>">
        <div class="prev-card-head">
          <div>
            <div class="prev-card-id">PREV #<%= p.id %></div>
            <div class="prev-card-title"><%= p.titulo || '-' %></div>
          </div>
          <% if (ativa) { %>
            <span class="pill pill-green">ATIVA</span>
          <% } else { %>
            <span class="pill pill-gray">INATIVA</span>
          <% } %>
        </div>

        <div class="prev-card-equip"><strong>Equipamento:</strong> <%= equipamento %></div>

        <div class="prev-card-footer">
          <div class="prev-card-open">Toque para abrir detalhes</div>
          <div class="prev-card-pills">
            <span class="pill pill-blue"><%= (p.frequencia_tipo || '-').toUpperCase() %></span>
            <span class="pill">x<%= p.frequencia_valor || 1 %></span>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
</div>
