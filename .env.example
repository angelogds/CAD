# App
PORT=8080
SESSION_SECRET=change-me
DATA_DIR=/data
UPLOAD_DIR=/data/uploads
PDF_DIR=/data/pdfs
IMAGE_DIR=/data/imagens
TEMP_DIR=/data/temp
SQLITE_DIR=/data/sqlite
DB_PATH=/data/sqlite/app.db

# AI (backend only)
AI_ENABLED=true
# Use uma chave real no formato sk-... (não use placeholders como SUA_CHAVE_NOVA)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_TIMEOUT_MS=20000
OPENAI_MAX_OUTPUT_TOKENS=300

# Modelos
OPENAI_MODEL_TEXT=gpt-4o-mini
OPENAI_MODEL_ACADEMIA=gpt-4o-mini
OPENAI_MODEL_AVALIACAO=gpt-4o-mini
OPENAI_MODEL_OS_AUTOMATICA=gpt-4o-mini
OPENAI_MODEL_FECHAMENTO_OS=gpt-4o-mini

# Push Notifications (Web Push)
VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here
VAPID_SUBJECT=mailto:admin@campodogado.local

# Integração WhatsApp para notificações de OS
# Opções: disabled (não envia), manual (gera link wa.me), cloud_api (envio automático pela API oficial Meta)
WHATSAPP_PROVIDER=disabled
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_DEFAULT_COUNTRY_CODE=55
# URL pública do sistema para anexos enviados como link (ex.: https://manutencao.exemplo.com)
PUBLIC_BASE_URL=
