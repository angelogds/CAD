<%
  const labels = planificacao?.labels || {};
  const divisoes = planificacao?.divisoes || [];
  const AA = Number(labels.AA || entrada?.A || 0);
  const AB = Number(labels.AB || entrada?.B || 0);
  const C = Number(labels.C || resultado?.geratrizAproximada || 0);
%>
<svg viewBox="0 0 800 600" role="img" aria-label="Quadrado para redondo com planificação" style="width:100%;max-width:960px;border:1px solid #e2e8f0;border-radius:14px;background:#fff;">
  <text x="30" y="35" fill="#222" font-size="20">Peça montada - Quadrado para redondo</text>
  <rect x="120" y="110" width="190" height="130" stroke="#222" fill="none"/>
  <ellipse cx="520" cy="170" rx="95" ry="45" stroke="#222" fill="none"/>
  <line x1="310" y1="110" x2="425" y2="130" stroke="#222"/>
  <line x1="310" y1="240" x2="425" y2="210" stroke="#222"/>
  <text x="120" y="270" fill="#222">AA = <%= AA.toFixed(2) %></text>
  <text x="430" y="270" fill="#222">AB = <%= AB.toFixed(2) %></text>

  <text x="30" y="330" fill="#222" font-size="20">Planificação em abas/setores</text>
  <% divisoes.forEach((d, idx) => { const x = 100 + (idx * 130); %>
    <polygon points="<%= x %>,500 <%= x + 110 %>,500 <%= x + 95 %>,400 <%= x + 15 %>,400" stroke="#222" fill="none"/>
    <text x="<%= x + 48 %>" y="520" fill="#222" font-size="12"><%= d.indice %></text>
    <text x="<%= x + 35 %>" y="535" fill="#222" font-size="11">A<%= idx + 1 %></text>
  <% }); %>
  <text x="640" y="420" fill="#222">C = <%= C.toFixed(2) %></text>
</svg>
