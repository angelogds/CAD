<%
  const R1 = Number(resultado?.R1 || 0);
  const R2 = Number(resultado?.R2 || 0);
  const C = Number(resultado?.C || 0);
  const T = Number(resultado?.T || 0);
  const P = Number(entrada?.P || 0);
%>
<svg viewBox="0 0 800 600" role="img" aria-label="Rosca helicoidal e planificação" style="width:100%;max-width:960px;border:1px solid #e2e8f0;border-radius:14px;background:#fff;">
  <defs><marker id="arrRos" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M 0 0 L 10 5 L 0 10 z" fill="#222"/></marker></defs>
  <text x="30" y="35" fill="#222" font-size="20">Peça montada - Eixo + hélice</text>
  <line x1="70" y1="170" x2="700" y2="170" stroke="#222"/>
  <path d="M80 170 C130 120,180 220,230 170 C280 120,330 220,380 170 C430 120,480 220,530 170 C580 120,630 220,680 170" stroke="#222" fill="none"/>
  <text x="80" y="215" fill="#222">R1=<%= R1.toFixed(2) %></text>
  <text x="200" y="215" fill="#222">R2=<%= R2.toFixed(2) %></text>
  <text x="320" y="215" fill="#222">C=<%= C.toFixed(2) %></text>
  <text x="430" y="215" fill="#222">T=<%= T.toFixed(2) %></text>
  <text x="540" y="215" fill="#222">P=<%= P.toFixed(2) %></text>

  <text x="30" y="330" fill="#222" font-size="20">Planificação da aleta</text>
  <polygon points="110,510 680,510 620,400 170,400" stroke="#222" fill="none"/>
  <line x1="110" y1="530" x2="680" y2="530" stroke="#222" marker-start="url(#arrRos)" marker-end="url(#arrRos)"/>
  <text x="360" y="555" fill="#222">T = <%= T.toFixed(2) %></text>
</svg>
