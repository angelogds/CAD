<% layout("layout") %>
<section class="card" style="display:flex;justify-content:space-between;align-items:center;">
  <h1><%= mode==='edit' ? 'Editar Desenho Técnico' : 'Novo Desenho Técnico' %></h1>
  <a class="btn" href="/desenho-tecnico">Voltar</a>
</section>

<form class="dt-editor" method="POST" action="<%= mode==='edit' ? '/desenho-tecnico/' + desenho.id : '/desenho-tecnico' %>">
  <section class="card dt-col">
    <h3>Formulário técnico</h3>
    <input class="input" name="codigo" placeholder="Código" value="<%= desenho.codigo || '' %>" required>
    <input class="input" name="titulo" placeholder="Título" value="<%= desenho.titulo || '' %>" required>
    <select class="input" name="categoria" id="categoriaSelect" required>
      <option value="">Categoria</option>
      <% ['EIXOS','FLANGES','CHAPARIA','ESTRUTURAS','TRANSICOES'].forEach((cat)=>{ %>
        <option value="<%= cat %>" <%= desenho.categoria===cat?'selected':'' %>><%= cat %></option>
      <% }) %>
    </select>
    <select class="input" name="subtipo" id="subtipoSelect" required></select>
    <input class="input" name="material" placeholder="Material" value="<%= desenho.material || '' %>">
    <input class="input" type="number" min="0" name="revisao" placeholder="Revisão" value="<%= desenho.revisao || 0 %>">
    <select class="input" name="equipamento_id"><option value="">Equipamento vinculado</option><% (equipamentos||[]).forEach((e)=>{ %><option value="<%=e.id%>" <%= Number(desenho.equipamento_id)===Number(e.id)?'selected':'' %>><%=e.codigo || ('#'+e.id)%> - <%=e.nome%></option><% }) %></select>
    <textarea class="input" name="observacoes" placeholder="Observações"><%= desenho.observacoes || '' %></textarea>
    <div id="paramFields"></div>
    <button class="btn btn-green" type="submit">Salvar</button>
  </section>

  <section class="card dt-col">
    <h3>Prévia técnica (SVG)</h3>
    <div id="svgPreview" class="dt-svg-pane"></div>
  </section>

  <section class="card dt-col">
    <h3>Resumo técnico</h3>
    <div id="technicalSummary">Preencha os parâmetros para visualizar resumo.</div>
    <div style="display:grid;gap:8px;margin-top:10px;">
      <button formaction="<%= mode==='edit' ? '/desenho-tecnico/' + desenho.id + '/pdf' : '#' %>" class="btn" type="submit" <%= mode==='edit' && canManage ? '' : 'disabled' %>>Gerar PDF</button>
    </div>
  </section>
</form>

<script>
  window.DT_INITIAL = {
    categoria: '<%= desenho.categoria || '' %>',
    subtipo: '<%= desenho.subtipo || '' %>',
    params: <%- JSON.stringify((() => { try { return JSON.parse(desenho.props_json || '{}'); } catch(_e){ return {}; } })()) %>
  };
</script>
<script src="/js/desenho-tecnico.js"></script>
