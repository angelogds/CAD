<% layout("layout") %>
<section class="card" style="display:flex;justify-content:space-between;align-items:center;">
  <h1>Blocos Técnicos</h1>
  <a class="btn" href="/desenho-tecnico">Voltar</a>
</section>

<form class="card" method="GET" action="/desenho-tecnico/biblioteca" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:8px;">
  <input class="input" name="q" placeholder="Buscar modelo" value="<%= filtros.q %>">
  <input class="input" name="categoria" placeholder="Categoria" value="<%= filtros.categoria %>">
  <input class="input" name="subtipo" placeholder="Subtipo" value="<%= filtros.subtipo %>">
  <button class="btn" type="submit">Filtrar</button>
</form>

<section class="dt-grid">
  <% if(!itens.length){ %>
    <article class="card">Sem modelos ativos na biblioteca.</article>
  <% } %>
  <% itens.forEach((i)=>{ %>
    <article class="card">
      <h3><%= i.nome %></h3>
      <p><%= i.categoria %> / <%= i.subtipo %></p>
      <p><%= i.descricao || '-' %></p>
      <details><summary>Preview JSON</summary><pre><%= i.definicao_json %></pre></details>
      <form method="POST" action="/desenho-tecnico/biblioteca/<%= i.id %>/duplicar"><button class="btn" type="submit">Duplicar bloco</button></form>
    </article>
  <% }) %>
</section>
