<% layout("layout") %>
<section class="card" style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
  <h1><%= desenho.codigo %> - <%= desenho.titulo %> <span class="badge <%= desenho.tipo_origem==='cad'?'badge-cad':'badge-param' %>"><%= desenho.tipo_origem==='cad'?'CAD':'Paramétrico' %></span></h1>
  <div style="display:flex;gap:8px;flex-wrap:wrap;">
    <% if (canManage) { %>
      <a class="btn" href="/desenho-tecnico/<%= desenho.id %>/editar">Editar</a>
      <form method="POST" action="/desenho-tecnico/<%= desenho.id %>/pdf"><button class="btn btn-green" type="submit">Gerar PDF</button></form>
      <form method="POST" action="/desenho-tecnico/<%= desenho.id %>/duplicar"><button class="btn" type="submit">Duplicar</button></form>
    <% } %>
  </div>
</section>

<section class="dt-editor">
  <article class="card dt-col">
    <h3>Dados gerais</h3>
    <p><b>Categoria:</b> <%= desenho.categoria %></p>
    <p><b>Subtipo:</b> <%= desenho.subtipo %></p>
    <p><b>Revisão:</b> R<%= desenho.revisao %></p>
    <p><b>Material:</b> <%= desenho.material || '-' %></p>
    <p><b>Equipamento:</b> <%= desenho.equipamento_nome || '-' %></p>
    <p><b>Status:</b> <%= desenho.status %></p>
    <% if (desenho.origem_modulo) { %>
      <hr>
      <p><b>Origem:</b> <%= desenho.origem_modulo %></p>
      <p><b>Ref. origem:</b> <%= desenho.origem_referencia || '-' %></p>
      <p><b>Integrado em:</b> <%= fmtBR(desenho.origem_integracao_em) %></p>
    <% } %>
  </article>
  <article class="card dt-col"><h3>Desenho</h3><div class="dt-svg-pane"><%- svgPreview %></div></article>
  <article class="card dt-col">
    <h3>Ações rápidas</h3>
    <% if (canManage) { %>
      <form method="POST" action="/desenho-tecnico/<%= desenho.id %>/vincular" style="display:grid;gap:8px;">
        <input class="input" name="equipamento_id" placeholder="ID do equipamento" required>
        <input class="input" name="posicao_aplicacao" placeholder="Posição da aplicação">
        <textarea class="input" name="observacao" placeholder="Observação"></textarea>
        <button class="btn" type="submit">Vincular ao equipamento</button>
      </form>
    <% } else { %>
      <p>Perfil com acesso somente leitura.</p>
    <% } %>
    <a class="btn" style="margin-top:8px;" href="/desenho-tecnico/<%= desenho.id %>/revisoes">Ver revisões</a>
  </article>
</section>

<section class="dt-editor">
  <article class="card dt-col">
    <h3>Camadas</h3>
    <form method="POST" action="/desenho-tecnico/<%= desenho.id %>/camadas" style="display:flex;gap:8px;margin-bottom:8px;">
      <input class="input" name="nome" placeholder="Nova camada customizada" required>
      <button class="btn" type="submit">Criar</button>
    </form>
    <% camadas.forEach((c)=>{ %>
      <div style="display:grid;grid-template-columns:1fr auto auto;gap:6px;align-items:center;border-bottom:1px solid #e2e8f0;padding:6px 0;">
        <div><b><%= c.nome %></b><br><small><%= c.slug %> • Entidades: <%= c.total_entidades %></small></div>
        <form method="POST" action="/desenho-tecnico/<%= desenho.id %>/camadas/<%= c.id %>"><input type="hidden" name="action" value="toggle-visible"><button class="btn" type="submit"><%= Number(c.visivel)===1?'Ocultar':'Mostrar' %></button></form>
        <form method="POST" action="/desenho-tecnico/<%= desenho.id %>/camadas/<%= c.id %>"><input type="hidden" name="action" value="toggle-lock"><button class="btn" type="submit"><%= Number(c.bloqueado)===1?'Desbloquear':'Bloquear' %></button></form>
      </div>
    <% }) %>
  </article>

  <article class="card dt-col">
    <h3>Blocos</h3>
    <form method="POST" action="/desenho-tecnico/<%= desenho.id %>/blocos/inserir" style="display:grid;gap:8px;">
      <select class="input" name="bloco_id" required>
        <option value="">Selecionar bloco técnico</option>
        <% bibliotecaBlocos.forEach((b)=>{ %><option value="<%= b.id %>"><%= b.nome %> (<%= b.subtipo %>)</option><% }) %>
      </select>
      <input class="input" type="number" step="any" name="x" placeholder="Posição X" required>
      <input class="input" type="number" step="any" name="y" placeholder="Posição Y" required>
      <input class="input" type="number" step="any" name="escala" placeholder="Escala" value="1">
      <input class="input" type="number" step="any" name="rotacao" placeholder="Rotação" value="0">
      <select class="input" name="camada"><% camadas.forEach((c)=>{ %><option value="<%= c.slug %>"><%= c.nome %></option><% }) %></select>
      <button class="btn" type="submit">Inserir bloco</button>
    </form>
    <ul>
      <% blocosInstancias.forEach((i)=>{ %><li><%= i.nome_instancia || i.bloco_nome %> • <%= i.camada %> • x=<%= i.x %>, y=<%= i.y %></li><% }) %>
    </ul>
  </article>

  <article class="card dt-col">
    <h3>Cotas avançadas</h3>
    <form method="POST" action="/desenho-tecnico/<%= desenho.id %>/cotas" style="display:grid;gap:8px;">
      <select class="input" name="tipo_cota" required>
        <option value="linear">Linear</option><option value="cadeia">Cadeia</option><option value="baseline">Baseline</option>
        <option value="angular">Angular</option><option value="raio">Raio</option><option value="diametro">Diâmetro</option>
        <option value="entre_centros">Entre centros</option><option value="profundidade">Profundidade</option>
        <option value="padrao_furacao">Padrão de furação</option><option value="espessura">Espessura</option>
      </select>
      <input class="input" type="number" step="any" name="x1" placeholder="x1" required>
      <input class="input" type="number" step="any" name="y1" placeholder="y1" required>
      <input class="input" type="number" step="any" name="x2" placeholder="x2" required>
      <input class="input" type="number" step="any" name="y2" placeholder="y2" required>
      <input class="input" type="number" step="any" name="x3" placeholder="x3 opcional">
      <input class="input" type="number" step="any" name="y3" placeholder="y3 opcional">
      <input class="input" type="number" step="any" name="valor" placeholder="valor">
      <input class="input" name="texto" placeholder="texto cota">
      <input class="input" name="unidade" placeholder="unidade" value="mm">
      <button class="btn" type="submit">Adicionar cota</button>
    </form>
    <ul>
      <% cotas.forEach((c)=>{ %><li><%= c.tipo_cota %> • <%= c.texto || c.valor %> <%= c.unidade || 'mm' %></li><% }) %>
    </ul>
  </article>
</section>

<section class="card">
  <h3>Arquivos de revisão</h3>
  <ul>
    <% revisoes.forEach((r)=>{ %>
      <li><b><%= r.tipo_arquivo %></b> • Revisão <%= r.revisao %> • <%= fmtBR(r.criado_em) %> <% if(r.arquivo_pdf){ %>- <a href="<%= r.arquivo_pdf %>" target="_blank">PDF</a><% } %></li>
    <% }) %>
  </ul>
</section>
