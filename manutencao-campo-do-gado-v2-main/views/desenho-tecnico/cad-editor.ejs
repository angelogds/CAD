<% layout("layout") %>
<section class="card cad-shell cad-shell-real">
  <header class="cad-toolbar-fixed">
    <div class="cad-toolbar-group">
      <a class="btn" href="/desenho-tecnico/cad/<%= (desenho && desenho.id) || '' %>">⬅ Voltar</a>
      <button class="btn" type="button" id="cadSaveBtn">💾 Salvar</button>
      <button class="btn" type="button" id="cadUndoBtn">↶ Desfazer</button>
      <button class="btn" type="button" id="cadRedoBtn">↷ Refazer</button>
    </div>
    <div class="cad-toolbar-group">
      <% const topTools = [['select','Selecionar'],['line','Linha'],['rect','Retângulo'],['circle','Círculo'],['arc','Arco'],['polyline','Polilinha'],['text','Texto'],['dim_linear','Cota'],['erase','Apagar']]; %>
      <% topTools.forEach(([tool,label])=>{ %>
        <button class="btn cad-tool" data-tool="<%= tool %>" type="button"><%= label %></button>
      <% }) %>
      <button class="btn" id="cadGridToggle" type="button">Grade ON</button>
      <button class="btn" id="cadSnapToggle" type="button">Snap ON</button>
      <button class="btn" id="cadOrthoToggle" type="button">Ortho OFF</button>
      <a class="btn" href="/desenho-tecnico/cad/<%= (desenho && desenho.id) || '' %>/pdf">PDF</a>
    </div>
  </header>

  <section class="cad-workspace cad-workspace-real">
    <aside class="card cad-side-left cad-panel-dark cad-left-tools">
      <% [['select','🖱 Selecionar'],['line','／ Linha'],['rect','▭ Retângulo'],['circle','◯ Círculo'],['arc','◜ Arco'],['polyline','⎺ Polilinha'],['text','T Texto'],['centerline','╍ Linha centro'],['dim_linear','↔ Cota linear'],['dim_diameter','⌀ Cota diâmetro'],['erase','⌫ Apagar']].forEach(([tool,label])=>{ %>
        <button class="btn cad-tool cad-left-tool" data-tool="<%= tool %>" type="button"><%= label %></button>
      <% }) %>
    </aside>

    <article class="card cad-center cad-center-dark cad-editor-core">
      <svg id="cadCanvas" viewBox="0 0 2200 1400" aria-label="Área de desenho CAD"></svg>
    </article>

    <aside class="card cad-right cad-panel-dark">
      <h3>Propriedades</h3>
      <div id="cadProperties">Selecione um objeto para editar propriedades.</div>

      <h3>Camadas</h3>
      <label>Camada ativa
        <select id="cadLayerSelect" class="input"></select>
      </label>
      <div id="cadLayers"></div>

      <h3>Metadados</h3>
      <div id="cadMetaPanel" class="cad-meta-grid">
        <label>Código <input class="input" id="cadMetaCodigo" value="<%= (desenho && desenho.codigo) || '' %>"></label>
        <label>Título <input class="input" id="cadMetaTitulo" value="<%= (desenho && desenho.titulo) || '' %>"></label>
        <label>Material <input class="input" id="cadMetaMaterial" value="<%= (desenho && desenho.material) || '' %>"></label>
        <label>Equipamento
          <select class="input" id="cadMetaEquipamento">
            <option value="">Sem vínculo</option>
            <% (equipamentos || []).forEach((e)=>{ %>
              <option value="<%= e.id %>" <%= Number((desenho && desenho.equipamento_id) || 0)===Number(e.id)?'selected':'' %>><%= e.codigo || ('#'+e.id) %> - <%= e.nome %></option>
            <% }) %>
          </select>
        </label>
        <label style="grid-column:1/-1;">Observações
          <textarea class="input" id="cadMetaObservacoes"><%= (desenho && desenho.observacoes) || '' %></textarea>
        </label>
        <button class="btn" id="cadMetaSaveBtn" type="button">Salvar metadados</button>
      </div>
    </aside>
  </section>

  <footer id="cadStatusBar" class="card cad-statusbar-fixed">
    Cursor: X 0 / Y 0 • Ferramenta: select • Comprimento: 0 • Ângulo: 0° • Grid: ON • Snap: ON • Ortho: OFF
  </footer>
</section>

<script>
window.CAD_INITIAL = {
  desenhoId: <%= (desenho && desenho.id) || 0 %>,
  canManage: <%= !!canManage %>,
  data: <%- JSON.stringify(cadData || { objects: [], layers: {}, activeTool: 'select' }) %>
};
</script>
<script src="/js/desenho-tecnico-cad.js"></script>
