<% layout('layout') %>
<div class="page-head">
  <div>
    <h1>Registrar saída</h1>
    <p class="muted">Baixa de material para requisição interna.</p>
  </div>
</div>
<%- include('_tabs', { tab: 'saida' }) %>

<div class="card">
  <form method="POST" action="/estoque/saidas" class="grid-3">
    <div>
      <div class="label">Item</div>
      <select class="input" name="item_id" required>
        <option value="">Selecione</option>
        <% itens.forEach((item) => { %>
          <option value="<%= item.id %>"><%= item.nome %> (saldo: <%= item.saldo_atual %> <%= item.unidade %>)</option>
        <% }) %>
      </select>
    </div>
    <div>
      <div class="label">Quantidade</div>
      <input class="input" type="number" step="0.01" min="0.01" name="quantidade" required />
    </div>
    <div>
      <div class="label">Referência (ID Solicitação)</div>
      <input class="input" name="referencia_id" placeholder="Opcional" />
    </div>
    <div style="grid-column:1/-1;">
      <div class="label">Observação</div>
      <textarea class="input" name="observacao" placeholder="Descreva o destino/finalidade da retirada"></textarea>
    </div>
    <div style="grid-column:1/-1;display:flex;gap:8px;">
      <button class="btn btn-green" type="submit">Registrar saída</button>
      <a class="btn btn-ghost" href="/estoque/movimentos">Ver movimentos</a>
    </div>
  </form>
</div>
