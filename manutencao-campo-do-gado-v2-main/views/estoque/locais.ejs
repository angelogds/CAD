<% layout('layout') %>
<div class="page-head">
  <div>
    <h1>Locais de Estoque</h1>
    <p class="muted">Defina corredores, prateleiras e posições de armazenagem.</p>
  </div>
</div>
<%- include('_tabs', { tab: 'locais' }) %>

<div class="grid-2">
  <div class="card">
    <div class="label">Novo local</div>
    <form method="POST" action="/estoque/locais">
      <input class="input" name="nome" placeholder="Nome do local" required />
      <textarea class="input" name="descricao" placeholder="Descrição (opcional)"></textarea>
      <button class="btn btn-green" style="margin-top:10px;">Criar local</button>
    </form>
  </div>
  <div class="card">
    <div class="label">Locais ativos</div>
    <div class="table-wrap">
      <table class="table">
        <thead><tr><th>ID</th><th>Nome</th><th>Descrição</th></tr></thead>
        <tbody>
          <% if (!locais.length) { %><tr><td colspan="3" class="muted">Sem locais cadastrados.</td></tr><% } %>
          <% locais.forEach((local) => { %><tr><td><%= local.id %></td><td><%= local.nome %></td><td><%= local.descricao || '-' %></td></tr><% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
