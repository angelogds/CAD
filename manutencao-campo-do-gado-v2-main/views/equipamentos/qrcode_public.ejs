<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title><%= title %></title><link rel="stylesheet" href="/css/app.css"><style>.wrap{max-width:820px;margin:24px auto;padding:14px}.foto{width:100%;max-height:360px;object-fit:cover;border-radius:14px;border:1px solid #e5e7eb;background:#f3f4f6}.btn-big{display:block;text-align:center;padding:14px;border-radius:12px;font-weight:700;text-decoration:none;margin-top:10px}.btn-green{background:#166534;color:#fff}.btn-blue{background:#1d4ed8;color:#fff}</style></head><body><div class="wrap"><div class="card"><% if (equip.foto_url) { %><img class="foto" src="<%= equip.foto_url %>"/><% } else { %><div class="foto" style="display:flex;align-items:center;justify-content:center;">Sem foto</div><% } %><h1><%= equip.nome %></h1><p><b>Código:</b> <%= equip.codigo || '-' %> | <b>Setor:</b> <%= equip.setor || '-' %></p><p><b>Tipo:</b> <%= equip.tipo || '-' %> | <b>Status:</b> <%= equip.status_operacional || 'ATIVO' %> | <b>Criticidade:</b> <%= equip.criticidade || '-' %></p><a class="btn-big btn-blue" href="<%= detalhesUrl %>">Ver informações completas do equipamento</a><a class="btn-big btn-green" href="<%= abrirOsUrl %>">Abrir nova OS para este equipamento</a><div style="margin-top:14px"><img src="<%= qrImage %>" style="width:130px"/></div></div></div></body></html>
